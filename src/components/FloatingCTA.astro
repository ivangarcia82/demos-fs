---
// Botón flotante de contacto: WhatsApp del negocio; si no tiene, llamada; si no, mapa.
const { whatsapp = null, telefono = null, mapsUrl = null } = Astro.props;
const telHref = telefono ? `tel:+52${telefono.replace(/\D/g, '').replace(/^52/, '')}` : null;
const mode = whatsapp ? 'wa' : telHref ? 'tel' : mapsUrl ? 'map' : null;
const href = whatsapp || telHref || mapsUrl;
const label = mode === 'wa' ? 'Escribir por WhatsApp' : mode === 'tel' ? 'Llamar por teléfono' : 'Cómo llegar';
---
{mode && (
  <a
    class={`floating-cta floating-cta--${mode}`}
    href={href}
    target={mode === 'tel' ? undefined : '_blank'}
    rel={mode === 'tel' ? undefined : 'noopener'}
    aria-label={label}
  >
    {mode === 'wa' && (
      <svg viewBox="0 0 32 32" width="30" height="30" aria-hidden="true" fill="currentColor">
        <path d="M16 3C9.4 3 4 8.3 4 14.9c0 2.6.8 5 2.3 7L4 29l7.3-2.3c1.9 1 3.9 1.5 4.7 1.5 6.6 0 12-5.3 12-11.9S22.6 3 16 3zm0 21.8c-1.4 0-3.2-.5-4.7-1.4l-.3-.2-4.3 1.4 1.4-4.2-.2-.3c-1.2-1.7-1.9-3.7-1.9-5.7C6 9.4 10.5 5 16 5s10 4.4 10 9.9-4.5 9.9-10 9.9zm5.5-7.4c-.3-.2-1.8-.9-2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.2-.2.2-.3.3-.5.1-.2 0-.4 0-.6-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4-.3.3-1.1 1.1-1.1 2.7s1.2 3.1 1.3 3.3c.2.2 2.3 3.5 5.6 4.9.8.3 1.4.5 1.9.7.8.2 1.5.2 2.1.1.6-.1 1.8-.7 2.1-1.5.3-.7.3-1.3.2-1.5-.1-.1-.3-.2-.6-.4z"/>
      </svg>
    )}
    {mode === 'tel' && (
      <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" fill="currentColor">
        <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z"/>
      </svg>
    )}
    {mode === 'map' && (
      <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" fill="currentColor">
        <path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/>
      </svg>
    )}
  </a>
)}

<style is:global>
  .floating-cta {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 2147482000;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    color: #fff;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
    transition: transform 0.15s ease;
  }
  .floating-cta:hover { transform: scale(1.06); }
  .floating-cta:focus-visible { outline: 3px solid #fff; outline-offset: 2px; }
  .floating-cta--wa { background: #25D366; }
  .floating-cta--tel { background: #1a73e8; }
  .floating-cta--map { background: #e8501a; }
  @media (prefers-reduced-motion: reduce) {
    .floating-cta { transition: none; }
    .floating-cta:hover { transform: none; }
  }
</style>
