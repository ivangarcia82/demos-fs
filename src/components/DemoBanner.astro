---
// Banner fijo de demo — UN solo lugar para cambiarlo en las 190 demos.
const WA_IVAN = 'https://wa.me/529991284580';
---
<div class="demo-banner" role="complementary" aria-label="Aviso de demostración">
  <span>✨ Demo creada por <strong>ivang.mx</strong> — ¿Te gusta?</span>
  <a href={WA_IVAN} target="_blank" rel="noopener">Escríbenos</a>
</div>

<style is:global>
  .demo-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2147483000;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    flex-wrap: wrap;
    min-height: var(--demo-banner-h, 38px);
    padding: 6px 12px;
    box-sizing: border-box;
    background: rgba(12, 12, 14, 0.92);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    color: #f4f4f4;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 13px;
    line-height: 1.3;
    text-align: center;
  }
  .demo-banner strong { font-weight: 700; }
  .demo-banner a {
    color: #7CF2B4;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
    white-space: nowrap;
  }
  .demo-banner a:focus-visible {
    outline: 2px solid #7CF2B4;
    outline-offset: 2px;
    border-radius: 3px;
  }
  /* Las páginas compensan el banner con este padding en body */
  body { padding-top: var(--demo-banner-h, 38px); }
  @media (max-width: 340px) {
    .demo-banner { font-size: 12px; }
  }
</style>
