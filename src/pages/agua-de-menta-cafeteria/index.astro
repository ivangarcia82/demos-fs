---
import BaseLayout from '../../layouts/BaseLayout.astro';

const slug = 'agua-de-menta-cafeteria';
const nombre = 'Agua de Menta';
const rating = 4.7;
const totalResenas = 599;
const whatsapp = 'https://wa.me/529995140333';
const telefono = '999 514 0333';
const mapsUrl = 'https://maps.google.com/?cid=6290210294753119467&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA';
const direccion = 'Plaza Victory Platz, Av. Andrés García Lavín Loc. 19A, Montebello, 97113 Mérida, Yuc., México';
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent('Agua de Menta Cafetería, ' + direccion)}&output=embed`;
const instagram = 'https://www.instagram.com/aguadementamx/';

const atributos = [
  { emoji: '🍳', txt: 'Desayunos' },
  { emoji: '☕', txt: 'Café de especialidad' },
  { emoji: '🌱', txt: 'Opciones vegetarianas' },
  { emoji: '🌳', txt: 'Área al aire libre' },
  { emoji: '🛵', txt: 'Servicio a domicilio' },
  { emoji: '💳', txt: 'Acepta tarjetas' },
  { emoji: '🅿️', txt: 'Estacionamiento' },
  { emoji: '♿', txt: 'Acceso para silla de ruedas' },
];

const platillos = [
  { n: 'Chilaquiles de la casa', d: 'con aguacate, cotija, cebolla morada y huevo, servidos en sartén.' },
  { n: 'Waffle de pollo crujiente', d: 'dorado, con papas a la francesa y un toque dulce.' },
  { n: 'Sándwich club', d: 'grande y llenador, como lo describen quienes vuelven por él.' },
  { n: 'Pastas cremosas', d: 'con milanesa crocante y pan de ajo tostado a un lado.' },
  { n: 'Pan chocolatín galleta', d: 'el favorito para acompañar el café de la mañana.' },
  { n: 'Lattes con arte', d: 'café de especialidad con figuras dibujadas en la espuma.' },
];

const horarios = [
  { d: 'Lunes', h: 'Cerrado', off: true },
  { d: 'Martes', h: '8:00 – 16:00' },
  { d: 'Miércoles', h: '8:00 – 16:00' },
  { d: 'Jueves', h: '8:00 – 16:00' },
  { d: 'Viernes', h: '8:00 – 16:00' },
  { d: 'Sábado', h: '8:00 – 16:00' },
  { d: 'Domingo', h: '8:00 – 16:00' },
];

const galeria = [
  { src: `/${slug}/img/foto_2.jpg`, alt: 'Chilaquiles con aguacate, cotija y huevo en Agua de Menta' },
  { src: `/${slug}/img/foto_3.jpg`, alt: 'Pasta cremosa, latte con arte y skillet de huevos en salsa' },
  { src: `/${slug}/img/foto_4.jpg`, alt: 'Waffle de pollo, lattes con arte de colores y sartén de pollo' },
  { src: `/${slug}/img/foto_5.jpg`, alt: 'Sartén de chilaquiles con aguacate y plato de melón' },
];
---
<BaseLayout
  title="Agua de Menta · Cafetería en Mérida"
  description="Desayunos, café de especialidad y un rincón verde en Montebello, Mérida. ⭐ 4.7 · 599 reseñas en Google."
  slug={slug}
  ogImage={`/${slug}/img/foto_2.jpg`}
  fonts="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;600;700&family=Nunito+Sans:ital,opsz,wght@0,6..12,400;0,6..12,600;0,6..12,700;1,6..12,400&display=swap"
  favicon="🌿"
  themeColor="#1E6E45"
  whatsapp={whatsapp}
  telefono={telefono}
  mapsUrl={mapsUrl}
>
  <!-- sprite del elemento firma: sprig de menta -->
  <svg class="sprite" aria-hidden="true" focusable="false" width="0" height="0">
    <symbol id="sprig" viewBox="0 0 24 24">
      <path d="M12 22.5 C12 16 12 9 12 2.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
      <path d="M12 8.4 C8 8.4 5.4 6.3 4.9 3.1 C9 3.4 11.5 5.2 12 8.4Z" fill="currentColor"/>
      <path d="M12 8.4 C16 8.4 18.6 6.3 19.1 3.1 C15 3.4 12.5 5.2 12 8.4Z" fill="currentColor"/>
      <path d="M12 14.4 C8.4 14.4 6.1 12.6 5.5 9.9 C9.2 10.2 11.5 11.7 12 14.4Z" fill="currentColor"/>
      <path d="M12 14.4 C15.6 14.4 17.9 12.6 18.5 9.9 C14.8 10.2 12.5 11.7 12 14.4Z" fill="currentColor"/>
    </symbol>
  </svg>

  <!-- ===================== HERO ===================== -->
  <header class="hero">
    <img class="hero__bg" src={`/${slug}/img/foto_1.jpg`} alt="Fachada de Agua de Menta con su logo verde y jardín de palmas en Montebello, Mérida" fetchpriority="high" decoding="async" width="810" height="1200" />
    <div class="hero__scrim"></div>
    <div class="hero__inner wrap">
      <svg class="seal" viewBox="0 0 120 120" role="img" aria-label="Fresh coffee & enjoy — Agua de Menta">
        <defs>
          <path id="ring" d="M60,60 m-45,0 a45,45 0 1,1 90,0 a45,45 0 1,1 -90,0" />
        </defs>
        <circle cx="60" cy="60" r="58.5" fill="none" stroke="currentColor" stroke-width="1" opacity="0.55" />
        <text class="seal__t"><textPath href="#ring" startOffset="0%">· FRESH COFFEE &amp; ENJOY · AGUA DE MENTA </textPath></text>
        <use href="#sprig" x="46" y="44" width="28" height="28" />
      </svg>

      <p class="hero__eyebrow">Cafetería · Montebello, Mérida</p>
      <h1 class="hero__title">Agua de<br><span>Menta</span></h1>
      <p class="hero__lead">Desayunos frescos, café con arte y un rincón verde para quedarte. Siéntate en la barra y platica con quien te atiende: aquí eso es parte del sabor.</p>

      <div class="rating-chip">
        <span class="rating-chip__stars" aria-hidden="true">★★★★★</span>
        <span><strong>4.7</strong> · 599 reseñas en Google</span>
      </div>

      <div class="hero__cta">
        <a class="btn btn--wa" href={whatsapp} target="_blank" rel="noopener">
          <span aria-hidden="true">💬</span> Escríbenos por WhatsApp
        </a>
        <a class="btn btn--ghost" href={mapsUrl} target="_blank" rel="noopener">Cómo llegar</a>
      </div>
      <p class="hero__hours">Abierto de martes a domingo · 8:00 a 16:00</p>
    </div>
  </header>

  <!-- ===================== FRANJA DE ATRIBUTOS ===================== -->
  <section class="strip" aria-label="Lo que ofrecemos">
    <div class="wrap strip__row">
      {atributos.map((a) => (
        <span class="chip"><span class="chip__i" aria-hidden="true">{a.emoji}</span>{a.txt}</span>
      ))}
    </div>
  </section>

  <!-- ===================== QUIÉNES SOMOS ===================== -->
  <section class="about" id="nosotros">
    <div class="wrap about__grid">
      <div class="about__copy reveal">
        <p class="eyebrow"><svg class="mk" aria-hidden="true"><use href="#sprig"/></svg> Quiénes somos</p>
        <h2>Un jardín para desayunar en Mérida</h2>
        <p>Somos <strong>Agua de Menta</strong>, una cafetería de barrio en Montebello donde el verde no es solo el color de nuestro nombre: es el de las palmas que rodean la terraza, el del aguacate fresco en cada sartén y el de la calma que buscamos regalarte apenas cruzas la puerta.</p>
        <p>Hacemos desayunos generosos, comida casera con un toque de cariño y café de especialidad que servimos con figuras dibujadas en la espuma. Pero si le preguntas a quien nos visita, casi siempre habla de lo mismo: de lo <strong>atento y amable</strong> que es el equipo. Por eso nuestra recomendación es sencilla — siéntate en la barra, pide lo que se te antoje y déjate consentir.</p>
      </div>
      <figure class="about__photo reveal">
        <img src={`/${slug}/img/foto_2.jpg`} alt="Chilaquiles con aguacate, cotija, cebolla morada y huevo" loading="lazy" decoding="async" width="800" height="1200" />
        <figcaption>Chilaquiles de la casa, recién salidos de la barra.</figcaption>
      </figure>
    </div>
  </section>

  <!-- ===================== LO MÁS PEDIDO ===================== -->
  <section class="menu">
    <div class="wrap">
      <p class="eyebrow center"><svg class="mk" aria-hidden="true"><use href="#sprig"/></svg> Lo más pedido</p>
      <h2 class="center">Lo que la gente vuelve a pedir</h2>
      <p class="menu__note">Platillos y bebidas que aparecen una y otra vez en las reseñas y en la mesa.</p>
      <ul class="menu__list">
        {platillos.map((p) => (
          <li class="dish reveal">
            <svg class="dish__mk" aria-hidden="true"><use href="#sprig"/></svg>
            <div>
              <h3>{p.n}</h3>
              <p>{p.d}</p>
            </div>
          </li>
        ))}
      </ul>
      <p class="menu__ask">¿Quieres el menú completo del día? <a href={whatsapp} target="_blank" rel="noopener">Pídelo por WhatsApp</a>.</p>
    </div>
  </section>

  <!-- ===================== GALERÍA ===================== -->
  <section class="gallery" aria-label="Galería">
    <div class="wrap">
      <p class="eyebrow center"><svg class="mk" aria-hidden="true"><use href="#sprig"/></svg> De nuestra mesa</p>
      <h2 class="center">Así se ve un día en Agua de Menta</h2>
    </div>
    <div class="gallery__grid wrap">
      {galeria.map((g, i) => (
        <figure class={`ga ga--${i + 1} reveal`}>
          <img src={g.src} alt={g.alt} loading="lazy" decoding="async" width="900" height="1200" />
        </figure>
      ))}
    </div>
  </section>

  <!-- ===================== PRUEBA SOCIAL ===================== -->
  <section class="social" id="resenas">
    <div class="wrap">
      <div class="social__head">
        <div class="bigrate">
          <span class="bigrate__num">4.7</span>
          <span class="bigrate__stars" aria-hidden="true">★★★★★</span>
          <span class="bigrate__label">599 reseñas en Google</span>
        </div>
        <p class="social__intro">Cientos de personas en Mérida ya nos dejaron su opinión. Esto es lo que dicen, en sus propias palabras.</p>
      </div>

      <div class="quotes">
        <blockquote class="quote reveal">
          <svg class="quote__mk" aria-hidden="true"><use href="#sprig"/></svg>
          <p>Me lleve la mejor experiencia de mi vida! Ya quisiera un novio que me atienda como en este lugar, son super amables y lindos. Todo estuvo delicioso y el ambiente es de lo mejor 💖…</p>
          <footer><strong>Natalia Méndez</strong><span>Hace 2 meses</span></footer>
        </blockquote>

        <blockquote class="quote reveal">
          <svg class="quote__mk" aria-hidden="true"><use href="#sprig"/></svg>
          <p>…La comida excelente, me encantó tu pan chocolatín galleta, el waffle y sándwich club eran grandes y llenadores. Su personal es atento y amable. Sin duda regresaré 💖</p>
          <footer><strong>Rosita Drew</strong><span>Hace 4 meses</span></footer>
        </blockquote>

        <blockquote class="quote reveal">
          <svg class="quote__mk" aria-hidden="true"><use href="#sprig"/></svg>
          <p>Lo ame! El lugar es muy lindo y agradable, sus desayunos me encantaron, volvería a ir mil veces…</p>
          <footer><strong>Karla Marina Urbina</strong><span>Hace 6 meses</span></footer>
        </blockquote>
      </div>

      <div class="center">
        <a class="btn btn--outline" href={mapsUrl} target="_blank" rel="noopener">Leer más reseñas en Google</a>
      </div>
    </div>
  </section>

  <!-- ===================== CTA INTERMEDIO ===================== -->
  <section class="midcta">
    <div class="wrap midcta__inner">
      <svg class="midcta__mk" aria-hidden="true"><use href="#sprig"/></svg>
      <h2>¿Se te antojó el desayuno?</h2>
      <p>Aparta tu mesa, pregunta por el menú del día o pide a domicilio. Te respondemos por WhatsApp.</p>
      <a class="btn btn--wa" href={whatsapp} target="_blank" rel="noopener"><span aria-hidden="true">💬</span> Escríbenos ahora</a>
    </div>
  </section>

  <!-- ===================== UBICACIÓN Y HORARIOS ===================== -->
  <section class="location" id="ubicacion">
    <div class="wrap location__grid">
      <div class="location__info">
        <p class="eyebrow"><svg class="mk" aria-hidden="true"><use href="#sprig"/></svg> Dónde estamos</p>
        <h2>Ven a visitarnos</h2>
        <p class="location__addr">Plaza Victory Platz, Av. Andrés García Lavín, Local 19A<br>Montebello, 97113 Mérida, Yucatán</p>
        <a class="btn btn--outline" href={mapsUrl} target="_blank" rel="noopener">Abrir en Google Maps</a>

        <h3 class="hours__title">Horario</h3>
        <table class="hours">
          <tbody>
            {horarios.map((r) => (
              <tr class={r.off ? 'is-off' : ''}>
                <th scope="row">{r.d}</th>
                <td>{r.h}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="location__map">
        <iframe
          title="Mapa de Agua de Menta en Google Maps"
          src={mapSrc}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ===================== CTA FINAL + FOOTER ===================== -->
  <footer class="foot">
    <div class="wrap foot__inner">
      <svg class="foot__seal" viewBox="0 0 120 120" role="img" aria-label="Agua de Menta">
        <use href="#sprig" x="42" y="40" width="36" height="36" />
      </svg>
      <h2 class="foot__title">Te esperamos en la barra</h2>
      <p class="foot__lead">Un café, un buen desayuno y gente que te atiende con gusto. Así de simple.</p>
      <a class="btn btn--wa btn--big" href={whatsapp} target="_blank" rel="noopener"><span aria-hidden="true">💬</span> Escríbenos por WhatsApp</a>

      <div class="foot__links">
        <a href={`tel:${telefono.replace(/\s/g, '')}`}>📞 {telefono}</a>
        <a href={mapsUrl} target="_blank" rel="noopener">📍 Cómo llegar</a>
        <a href={instagram} target="_blank" rel="noopener">📷 @aguadementamx</a>
      </div>
      <p class="foot__name">Agua de Menta · Cafetería · Mérida, Yucatán</p>
    </div>
  </footer>

  <style is:global>
    :root {
      --cream: #FAF6EC;
      --cream-card: #FFFDF6;
      --verde: #1E6E45;
      --verde-deep: #17583A;
      --menta: #A8DCC0;
      --menta-soft: #E6F2E8;
      --salvia: #86A063;
      --cacao: #2C2018;
      --cacao-soft: #5D4E42;
      --uva: #7A4EA6;
      --shadow: 0 18px 45px -22px rgba(26, 60, 40, 0.45);
      --radius: 20px;
    }

    body {
      background: var(--cream);
      color: var(--cacao);
      font-family: 'Nunito Sans', system-ui, sans-serif;
      font-size: 17px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    .wrap { width: 100%; max-width: 1080px; margin-inline: auto; padding-inline: 22px; }
    .sprite { position: absolute; width: 0; height: 0; overflow: hidden; }

    h1, h2, h3 { font-family: 'Quicksand', system-ui, sans-serif; font-weight: 700; line-height: 1.08; margin: 0; letter-spacing: -0.01em; }
    h2 { font-size: clamp(1.7rem, 5.2vw, 2.6rem); color: var(--verde-deep); }
    p { margin: 0 0 1em; }
    a { color: var(--verde); }
    strong { font-weight: 700; color: var(--cacao); }
    .center { text-align: center; }

    /* markers / eyebrows */
    .eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: 'Quicksand', sans-serif; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.16em; font-size: 0.74rem;
      color: var(--verde); margin: 0 0 12px;
    }
    .eyebrow.center { display: flex; justify-content: center; }
    .mk { width: 18px; height: 18px; color: var(--salvia); flex: none; }

    /* buttons */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 9px;
      font-family: 'Quicksand', sans-serif; font-weight: 700; font-size: 1rem;
      text-decoration: none; padding: 14px 24px; border-radius: 999px;
      border: 2px solid transparent; cursor: pointer; line-height: 1;
      transition: transform .18s ease, box-shadow .18s ease, background-color .18s ease, color .18s ease;
    }
    .btn--wa { background: var(--verde); color: #fff; box-shadow: 0 12px 26px -12px rgba(30,110,69,.8); }
    .btn--wa:hover { background: var(--verde-deep); transform: translateY(-2px); }
    .btn--big { padding: 17px 34px; font-size: 1.08rem; }
    .btn--ghost { background: rgba(255,255,255,.14); color: #fff; border-color: rgba(255,255,255,.65); backdrop-filter: blur(3px); }
    .btn--ghost:hover { background: rgba(255,255,255,.9); color: var(--verde-deep); transform: translateY(-2px); }
    .btn--outline { background: transparent; color: var(--verde); border-color: var(--menta); }
    .btn--outline:hover { background: var(--menta-soft); border-color: var(--verde); transform: translateY(-2px); }
    a.btn:focus-visible, a:focus-visible { outline: 3px solid var(--uva); outline-offset: 3px; border-radius: 6px; }

    /* ---------- HERO ---------- */
    .hero {
      position: relative; isolation: isolate;
      min-height: calc(100svh - var(--demo-banner-h, 38px));
      display: flex; align-items: flex-end;
      background: linear-gradient(180deg, #cfe7f2, var(--menta));
      overflow: hidden;
    }
    .hero__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: 50% 42%; z-index: -2; }
    .hero__scrim {
      position: absolute; inset: 0; z-index: -1;
      background:
        linear-gradient(180deg, rgba(20,58,40,0) 32%, rgba(19,55,38,.55) 66%, rgba(15,45,31,.92) 100%),
        linear-gradient(90deg, rgba(15,45,31,.35), rgba(15,45,31,0) 60%);
    }
    .hero__inner { padding-block: 40px 46px; color: #fff; }
    .seal { width: 92px; height: 92px; color: var(--menta); margin-bottom: 20px; opacity: .95; animation: spin 40s linear infinite; }
    .seal__t { font-family: 'Quicksand', sans-serif; font-weight: 600; font-size: 8.7px; letter-spacing: 1.7px; fill: currentColor; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .seal { transform-box: fill-box; transform-origin: center; }

    .hero__eyebrow {
      font-family: 'Quicksand', sans-serif; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.2em; font-size: 0.78rem; margin: 0 0 10px; color: var(--menta);
    }
    .hero__title {
      font-size: clamp(3.2rem, 15vw, 6.2rem); font-weight: 700; margin: 0 0 18px;
      letter-spacing: -0.02em; text-shadow: 0 4px 24px rgba(0,0,0,.35);
    }
    .hero__title span { color: var(--menta); }
    .hero__lead { max-width: 30ch; font-size: 1.12rem; margin: 0 0 22px; color: rgba(255,255,255,.94); text-shadow: 0 2px 12px rgba(0,0,0,.35); }

    .rating-chip {
      display: inline-flex; align-items: center; gap: 10px; margin-bottom: 24px;
      background: rgba(255,255,255,.16); backdrop-filter: blur(6px);
      border: 1px solid rgba(255,255,255,.4); padding: 9px 16px; border-radius: 999px;
      font-size: 0.98rem;
    }
    .rating-chip strong { color: #fff; }
    .rating-chip__stars { color: #FFD25A; letter-spacing: 2px; font-size: 0.95rem; }

    .hero__cta { display: flex; flex-wrap: wrap; gap: 12px; }
    .hero__hours { margin: 18px 0 0; font-size: 0.9rem; color: rgba(255,255,255,.85); font-weight: 600; }

    /* ---------- STRIP ---------- */
    .strip { background: var(--verde-deep); color: #fff; }
    .strip__row { display: flex; flex-wrap: wrap; gap: 10px 8px; justify-content: center; padding-block: 18px; }
    .chip {
      display: inline-flex; align-items: center; gap: 7px;
      font-size: 0.86rem; font-weight: 600; color: #eaf5ee;
      background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.14);
      padding: 7px 13px; border-radius: 999px;
    }
    .chip__i { font-size: 1rem; }

    /* ---------- ABOUT ---------- */
    .about { padding-block: clamp(56px, 9vw, 96px); }
    .about__grid { display: grid; gap: 34px; align-items: center; }
    .about__copy p { color: var(--cacao-soft); }
    .about__copy p:last-child { margin-bottom: 0; }
    .about__photo { margin: 0; }
    .about__photo img { border-radius: var(--radius); box-shadow: var(--shadow); width: 100%; aspect-ratio: 4/5; object-fit: cover; }
    .about__photo figcaption { font-size: 0.85rem; color: var(--salvia); margin-top: 10px; font-style: italic; }

    /* ---------- MENU ---------- */
    .menu { background: var(--menta-soft); padding-block: clamp(56px, 9vw, 96px); }
    .menu__note { text-align: center; color: var(--cacao-soft); max-width: 46ch; margin: 4px auto 34px; }
    .menu__list { list-style: none; margin: 0; padding: 0; display: grid; gap: 14px; }
    .dish {
      display: flex; gap: 14px; align-items: flex-start;
      background: var(--cream-card); border: 1px solid rgba(30,110,69,.1);
      border-radius: 16px; padding: 18px 20px;
    }
    .dish__mk { width: 24px; height: 24px; color: var(--verde); flex: none; margin-top: 2px; }
    .dish h3 { font-size: 1.14rem; color: var(--verde-deep); margin-bottom: 3px; }
    .dish p { margin: 0; color: var(--cacao-soft); font-size: 0.96rem; }
    .menu__ask { text-align: center; margin: 30px 0 0; color: var(--cacao-soft); }
    .menu__ask a { font-weight: 700; }

    /* ---------- GALLERY ---------- */
    .gallery { padding-block: clamp(56px, 9vw, 96px); }
    .gallery h2 { margin-bottom: 30px; }
    .gallery__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .ga { margin: 0; border-radius: 16px; overflow: hidden; box-shadow: var(--shadow); }
    .ga img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 3/4; transition: transform .5s ease; }
    .ga:hover img { transform: scale(1.05); }

    /* ---------- SOCIAL ---------- */
    .social { background: var(--verde-deep); color: #fff; padding-block: clamp(56px, 9vw, 96px); }
    .social__head { text-align: center; max-width: 40ch; margin: 0 auto 36px; }
    .bigrate { display: flex; flex-direction: column; align-items: center; gap: 4px; margin-bottom: 14px; }
    .bigrate__num { font-family: 'Quicksand', sans-serif; font-weight: 700; font-size: 4.2rem; line-height: 1; color: #fff; }
    .bigrate__stars { color: #FFD25A; letter-spacing: 4px; font-size: 1.3rem; }
    .bigrate__label { color: var(--menta); font-weight: 600; letter-spacing: .03em; }
    .social__intro { color: rgba(255,255,255,.86); }
    .quotes { display: grid; gap: 16px; margin-bottom: 34px; }
    .quote {
      position: relative; margin: 0; background: rgba(255,255,255,.06);
      border: 1px solid rgba(168,220,192,.28); border-radius: 18px; padding: 26px 24px 20px;
    }
    .quote__mk { position: absolute; top: 18px; right: 18px; width: 26px; height: 26px; color: var(--menta); opacity: .5; }
    .quote p { font-size: 1.06rem; line-height: 1.6; color: #fdfdf8; margin: 0 0 16px; }
    .quote footer { display: flex; flex-direction: column; }
    .quote footer strong { color: var(--menta); font-family: 'Quicksand', sans-serif; }
    .quote footer span { font-size: 0.82rem; color: rgba(255,255,255,.6); }

    /* ---------- MID CTA ---------- */
    .midcta { background: var(--menta); padding-block: clamp(50px, 8vw, 80px); }
    .midcta__inner { text-align: center; max-width: 44ch; margin-inline: auto; }
    .midcta__mk { width: 40px; height: 40px; color: var(--verde-deep); margin-bottom: 8px; }
    .midcta h2 { color: var(--verde-deep); margin-bottom: 8px; }
    .midcta p { color: #2f4a3a; margin-bottom: 22px; }

    /* ---------- LOCATION ---------- */
    .location { padding-block: clamp(56px, 9vw, 96px); }
    .location__grid { display: grid; gap: 32px; align-items: start; }
    .location__addr { color: var(--cacao-soft); margin-bottom: 20px; }
    .hours__title { font-size: 1.2rem; color: var(--verde-deep); margin: 30px 0 12px; }
    .hours { width: 100%; border-collapse: collapse; max-width: 360px; }
    .hours th, .hours td { text-align: left; padding: 9px 4px; border-bottom: 1px solid rgba(30,110,69,.14); font-size: 0.98rem; }
    .hours th { font-weight: 600; color: var(--cacao); }
    .hours td { text-align: right; color: var(--verde); font-weight: 600; font-variant-numeric: tabular-nums; }
    .hours tr.is-off th { color: var(--cacao-soft); }
    .hours tr.is-off td { color: #b0453a; font-weight: 700; }
    .location__map iframe { width: 100%; height: 340px; border: 0; border-radius: var(--radius); box-shadow: var(--shadow); }

    /* ---------- FOOTER ---------- */
    .foot { background: var(--verde-deep); color: #fff; padding: clamp(56px, 9vw, 92px) 0 96px; text-align: center; }
    .foot__inner { max-width: 44ch; margin-inline: auto; }
    .foot__seal { width: 60px; height: 60px; color: var(--menta); margin-bottom: 10px; }
    .foot__title { color: #fff; margin-bottom: 10px; font-size: clamp(1.8rem, 6vw, 2.6rem); }
    .foot__lead { color: rgba(255,255,255,.86); margin-bottom: 26px; }
    .foot__links { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px 22px; margin: 30px 0 18px; }
    .foot__links a { color: var(--menta); text-decoration: none; font-weight: 600; font-size: 0.96rem; }
    .foot__links a:hover { color: #fff; text-decoration: underline; }
    .foot__name { font-size: 0.82rem; color: rgba(255,255,255,.5); margin: 0; letter-spacing: .04em; }

    /* ---------- REVEAL (progressive enhancement) ---------- */
    .js .reveal { opacity: 0; transform: translateY(20px); transition: opacity .7s ease, transform .7s ease; }
    .js .reveal.in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) {
      .js .reveal { opacity: 1 !important; transform: none !important; }
      .seal { animation: none; }
    }

    /* ---------- RESPONSIVE ---------- */
    @media (min-width: 720px) {
      .about__grid { grid-template-columns: 1.15fr 0.85fr; gap: 48px; }
      .menu__list { grid-template-columns: 1fr 1fr; }
      .gallery__grid { grid-template-columns: repeat(4, 1fr); }
      .quotes { grid-template-columns: repeat(3, 1fr); align-items: start; }
      .location__grid { grid-template-columns: 0.9fr 1.1fr; gap: 40px; }
      .location__map iframe { height: 420px; }
      .seal { width: 104px; height: 104px; }
    }
    @media (min-width: 720px) and (max-width: 980px) {
      .quotes { grid-template-columns: 1fr; max-width: 620px; margin-inline: auto; }
    }
  </style>

  <script is:inline>
    (function () {
      if (!('IntersectionObserver' in window)) return;
      var root = document.documentElement;
      root.classList.add('js');
      var els = document.querySelectorAll('.reveal');
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
      els.forEach(function (el) { io.observe(el); });
    })();
  </script>
</BaseLayout>
