---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Inkorpus Tattoo & Barber Shop — Barbería y estudio de tatuajes en Mérida"
  description="Barbería, estudio de tatuajes y piercing en la colonia Fidel Velázquez, Mérida. ⭐ 4.9 con 212 reseñas en Google. Corte abajo, tinta arriba y buena música en toda la casa. Agenda por WhatsApp."
  slug="inkorpus-tattoo-and-barber-shop"
  ogImage="/inkorpus-tattoo-and-barber-shop/img/foto_2.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Alfa+Slab+One&family=Epilogue:wght@400;500;600;700&display=swap"
  favicon="💈"
  themeColor="#171114"
  whatsapp="https://wa.me/529992853769"
  telefono="999 285 3769"
  mapsUrl="https://maps.google.com/?cid=15196353358334702496&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA"
>

<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "BarberShop",
  "name": "Inkorpus Tattoo and Barber Shop",
  "telephone": "+52 999 285 3769",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle 38 #2105, Av Fidel Velázquez, Fidel Velázquez",
    "postalCode": "97166",
    "addressLocality": "Mérida",
    "addressRegion": "Yucatán",
    "addressCountry": "MX"
  },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "212" }
}
</script>

<!-- HERO -->
<header class="hero">
  <div class="hero-bg" role="img" aria-label="Barbero de Inkorpus trabajando un corte en la silla roja del local"></div>
  <div class="hero-inner">
    <p class="kicker">Barbería · Tatuajes · Piercing · Mérida</p>
    <h1>Inkorpus</h1>
    <p class="sub">Tattoo &amp; Barber Shop</p>
    <p class="lema">Corte abajo, tinta arriba y buena música en toda la casa.</p>
    <a class="rating-chip" href="https://maps.google.com/?cid=15196353358334702496&amp;g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">
      <span aria-hidden="true">⭐</span> 4.9 · 212 reseñas en Google
    </a>
    <div class="cta-row">
      <a class="btn btn-rojo" href="https://wa.me/529992853769" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.9-1.4A10 10 0 1 0 12 2Zm5.2 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5s.8 1.9.8 2c.1.1.1.3 0 .5l-.3.5-.4.4c-.1.1-.3.3-.1.6.2.3.8 1.3 1.7 2.1 1.2 1 2.1 1.4 2.4 1.5.3.1.5.1.6-.1.2-.2.7-.8.9-1.1.2-.3.4-.2.6-.1l1.9.9c.3.1.5.2.5.3.1.1.1.7-.1 1.2Z"/></svg>
        Agenda por WhatsApp
      </a>
      <a class="btn btn-linea" href="https://maps.google.com/?cid=15196353358334702496&amp;g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Cómo llegar</a>
    </div>
  </div>
</header>

<!-- Cinta musical: géneros citados palabra por palabra en una reseña real -->
<div class="cinta" aria-label="Ambiente musical: reggae, ska, blues, trova, 70s, 80s y rock">
  <div class="cinta-track">
    <span>Reggae</span><span class="star" aria-hidden="true">★</span><span>Ska</span><span class="star" aria-hidden="true">★</span><span>Blues</span><span class="star" aria-hidden="true">★</span><span>Trova</span><span class="star" aria-hidden="true">★</span><span>70’s</span><span class="star" aria-hidden="true">★</span><span>80’s</span><span class="star" aria-hidden="true">★</span><span>Rock</span><span class="star" aria-hidden="true">★</span>
    <span aria-hidden="true">Reggae</span><span class="star" aria-hidden="true">★</span><span aria-hidden="true">Ska</span><span class="star" aria-hidden="true">★</span><span aria-hidden="true">Blues</span><span class="star" aria-hidden="true">★</span><span aria-hidden="true">Trova</span><span class="star" aria-hidden="true">★</span><span aria-hidden="true">70’s</span><span class="star" aria-hidden="true">★</span><span aria-hidden="true">80’s</span><span class="star" aria-hidden="true">★</span><span aria-hidden="true">Rock</span><span class="star" aria-hidden="true">★</span>
  </div>
</div>

<!-- SOBRE NOSOTROS -->
<section id="sobre">
  <div class="wrap sobre-grid">
    <div class="reveal">
      <span class="sec-kicker">Sobre nosotros</span>
      <h2>Una casa, dos oficios</h2>
      <p>Inkorpus es una casa con dos oficios: abajo suena la máquina de la <strong>barbería</strong> y arriba trabaja la tinta del <strong>estudio de tatuajes y piercing</strong>. Estamos en la colonia Fidel Velázquez, en Mérida, con la puerta abierta para todos: vengas por un corte clásico, por traer a los niños o por ese tatuaje que llevas tiempo planeando.</p>
      <p>Nuestros clientes lo cuentan mejor que nosotros: la plática en la silla es de cualquier tema —pregunta por <strong>Ramiro</strong>—, la música va del reggae y el ska al blues, la trova y el rock, y el corte sale siempre como lo pediste. En el estudio trabajamos varios estilos de tatuaje, con calidad e higiene en cada pieza.</p>
      <p>Y si vienes con tiempo, al fondo te espera la <strong>tienda</strong> de ropa y accesorios, y un buen frappe de la barra mientras esperas tu turno.</p>
    </div>
    <div class="reveal">
      <figure>
        <div class="sobre-foto">
          <img src="/inkorpus-tattoo-and-barber-shop/img/foto_5.jpg" alt="Estación de la barbería de Inkorpus: silla reclinable, espejo y productos para el cabello" loading="lazy" width="535" height="1100">
        </div>
        <figcaption class="pie-foto">La silla te espera: estación de barbería en Inkorpus.</figcaption>
      </figure>
    </div>
  </div>
</section>

<!-- LA CASA / SERVICIOS -->
<section id="servicios" class="sec-oscura">
  <div class="wrap">
    <span class="sec-kicker">Servicios</span>
    <h2>Recorre la casa</h2>
    <div class="casa">
      <div class="piso reveal">
        <p class="piso-nivel">Planta baja</p>
        <h3>La barbería</h3>
        <p>Cortes clásicos y modernos, buena plática y buen ambiente musical. Vengas como vengas, aquí hay silla para ti — también para los más pequeños de la casa.</p>
        <ul class="chips">
          <li>Corte de cabello</li>
          <li>Cortes para niños</li>
          <li>Buen ambiente musical</li>
        </ul>
      </div>
      <div class="piso reveal">
        <p class="piso-nivel">Planta alta</p>
        <h3>El estudio de tatuajes</h3>
        <p>Tatuajes en varios estilos y perforaciones, trabajados con calidad e higiene. Escríbenos por WhatsApp y agenda tu cita en la planta alta.</p>
        <ul class="chips">
          <li>Tatuajes en varios estilos</li>
          <li>Piercing</li>
          <li>Calidad e higiene</li>
        </ul>
      </div>
      <div class="piso reveal">
        <p class="piso-nivel">Al fondo</p>
        <h3>La tienda</h3>
        <p>Playeras, mochilas, tenis, calcetas y de todo un poco. Date una vuelta mientras esperas tu turno o llévate algo para estrenar con el corte nuevo.</p>
        <ul class="chips">
          <li>Playeras</li>
          <li>Mochilas</li>
          <li>Accesorios</li>
        </ul>
        <div class="piso-foto">
          <img src="/inkorpus-tattoo-and-barber-shop/img/foto_1.jpg" alt="Tienda de Inkorpus con playeras, tenis, calcetas y accesorios bajo luz neón azul" loading="lazy" width="1100" height="823">
        </div>
        <div class="piso-foto">
          <img src="/inkorpus-tattoo-and-barber-shop/img/foto_4.jpg" alt="Pasamontañas de microfibra y más accesorios de marca en la vitrina de la tienda" loading="lazy" width="618" height="1100">
        </div>
      </div>
      <div class="piso reveal">
        <p class="piso-nivel">La barra</p>
        <h3>El café</h3>
        <p>Un buen frappe o un café para acompañar la visita. Porque un corte o un tatuaje saben mejor con algo frío en la mano.</p>
        <ul class="chips">
          <li>Frappes</li>
          <li>Café</li>
        </ul>
        <div class="piso-foto">
          <img src="/inkorpus-tattoo-and-barber-shop/img/foto_3.jpg" class="enfoque-bajo" alt="Frappe con crema batida servido en la barra del café, frente al mural de la cafetería" loading="lazy" width="825" height="1100">
        </div>
      </div>
    </div>
  </div>
</section>

<!-- RESEÑAS -->
<section id="resenas">
  <div class="wrap">
    <span class="sec-kicker">Lo que dicen de nosotros</span>
    <h2>La banda opina</h2>
    <div class="nota-grande reveal">
      <span class="nota-num">4.9</span>
      <span class="nota-det"><span class="estrellas" aria-hidden="true">★★★★★</span>212 reseñas en Google</span>
    </div>
    <div class="resenas-grid">
      <article class="resena reveal">
        <blockquote>Excelente atención del barbero Ramiro, una barbería que se presta a cualquier tipo de personas, con temas de platica de cualquier tipo, además con buen ambiente musical, desde reggae, ska, blues, trova, 70’s, 80’s, rock y por supuesto la tienda de ropa que tiene en la parte posterior de la barbería, también cuenta en la parte superior él área de tatuajes y piercing</blockquote>
        <footer><b>walter segovia saraz</b> · ★★★★★ · Hace 4 años</footer>
      </article>
      <article class="resena reveal">
        <blockquote>Tanto la barbería como el tattoo studio son excelentes. El servicio en la barbería es increíble, banda muy agradable que te hace sentir cómodo y el corte siempre perfecto. Los artistas son de los mejores de la ciudad, realizan varios estilos y todo con calidad e higiene. Altamente recomendado.</blockquote>
        <footer><b>Hugo Cabrera</b> · ★★★★★ · Hace 6 años</footer>
      </article>
      <article class="resena reveal">
        <blockquote>Excelente lugar para cortarse el pelo, tatuarse, tomarse un buen frappe y adquirir artículos tipo playeras, mochilas y de todo un poco. Super recomendable!!</blockquote>
        <footer><b>Ernesto sanchez</b> · ★★★★★ · Hace 5 años</footer>
      </article>
    </div>
    <a class="btn btn-linea" href="https://maps.google.com/?cid=15196353358334702496&amp;g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Leer más reseñas en Google</a>
  </div>
</section>

<!-- UBICACIÓN Y HORARIOS -->
<section id="ubicacion" class="sec-oscura">
  <div class="wrap ubi-grid">
    <div class="reveal">
      <span class="sec-kicker">Visítanos</span>
      <h2>Aquí está la casa</h2>
      <p class="dir-texto">Calle 38 #2105, Av. Fidel Velázquez, col. Fidel Velázquez, 97166 Mérida, Yucatán.</p>
      <div class="mapa">
        <iframe
          title="Mapa de ubicación de Inkorpus Tattoo and Barber Shop en Mérida"
          src="https://www.google.com/maps?q=Inkorpus%20Tattoo%20and%20Barber%20Shop%2C%20Calle%2038%20%232105%2C%20Fidel%20Vel%C3%A1zquez%2C%2097166%20M%C3%A9rida%2C%20Yucat%C3%A1n&output=embed"
          loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
      </div>
    </div>
    <div class="reveal">
      <table class="horarios" id="tabla-horarios">
        <caption>Horarios</caption>
        <tbody>
          <tr data-dia="1"><td>Lunes</td><td>11:00 – 21:00</td></tr>
          <tr data-dia="2"><td>Martes</td><td>11:00 – 21:00</td></tr>
          <tr data-dia="3"><td>Miércoles</td><td>11:00 – 21:00</td></tr>
          <tr data-dia="4"><td>Jueves</td><td>11:00 – 21:00</td></tr>
          <tr data-dia="5"><td>Viernes</td><td>11:00 – 21:00</td></tr>
          <tr data-dia="6"><td>Sábado</td><td>11:00 – 21:00</td></tr>
          <tr data-dia="0" class="cerrado"><td>Domingo</td><td>Cerrado</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <p class="nombre">Inkorpus Tattoo &amp; Barber Shop</p>
  <p>Calle 38 #2105, col. Fidel Velázquez, Mérida, Yuc.</p>
  <a class="tel" href="tel:+529992853769">999 285 3769</a>
  <p>Lunes a sábado · 11:00 – 21:00</p>
</footer>

<style is:global>
:root{
  --negro:#171114;       /* humo de estudio */
  --carbon:#221a1e;      /* superficie */
  --carbon-2:#2b2126;
  --hueso:#ece3d4;       /* texto */
  --taupe:#a79a8e;       /* texto secundario */
  --rojo:#c2382f;        /* rojo silla de barbero */
  --rojo-claro:#e05a50;  /* rojo para texto pequeño (AA sobre fondos oscuros) */
  --rojo-osc:#8e2723;
  --turquesa:#5cb3a6;    /* mural Django's */
  --linea:#3a2e33;
  --display:'Alfa Slab One',serif;
  --body:'Epilogue',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  font-family:var(--body);
  background:var(--negro);
  color:var(--hueso);
  line-height:1.65;
  -webkit-font-smoothing:antialiased;
}
img{max-width:100%;display:block}
a{color:var(--hueso)}
:focus-visible{outline:3px solid var(--turquesa);outline-offset:3px;border-radius:4px}

/* ---------- Hero ---------- */
.hero{
  position:relative;
  min-height:calc(100svh - 38px);
  display:flex;flex-direction:column;justify-content:flex-end;
  isolation:isolate;overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;z-index:-2;
  background:url("/inkorpus-tattoo-and-barber-shop/img/foto_2.jpg") center 28%/cover no-repeat var(--carbon);
}
.hero::after{
  content:"";position:absolute;inset:0;z-index:-1;
  background:
    linear-gradient(180deg,rgba(23,17,20,.55) 0%,rgba(23,17,20,.25) 34%,rgba(23,17,20,.82) 68%,var(--negro) 96%);
}
.hero-inner{
  width:100%;max-width:1060px;margin:0 auto;
  padding:6.5rem 1.35rem 2.8rem;
}
.kicker{
  font-size:.72rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;
  color:var(--turquesa);
}
.hero h1{
  font-family:var(--display);font-weight:400;
  font-size:clamp(2.9rem,13vw,6.2rem);
  line-height:.95;letter-spacing:.01em;
  margin:.5rem 0 .1rem;
  text-shadow:0 4px 30px rgba(0,0,0,.6);
}
.hero .sub{
  font-family:var(--display);font-weight:400;
  font-size:clamp(1.05rem,4.4vw,1.7rem);
  color:var(--rojo);
  text-shadow:0 2px 14px rgba(0,0,0,.7);
  margin-bottom:1rem;
}
.hero p.lema{
  max-width:34ch;font-size:1.05rem;color:#d8cec0;
  margin-bottom:1.4rem;
}
.rating-chip{
  display:inline-flex;align-items:center;gap:.45rem;
  background:rgba(14,10,12,.72);border:1px solid var(--linea);
  border-radius:999px;padding:.42rem .95rem;
  font-size:.86rem;font-weight:600;text-decoration:none;
  margin-bottom:1.5rem;backdrop-filter:blur(4px);
}
.rating-chip:hover{border-color:var(--rojo)}
.cta-row{display:flex;flex-wrap:wrap;gap:.75rem}
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:.55rem;
  font-family:var(--body);font-weight:700;font-size:1rem;
  padding:.95rem 1.5rem;border-radius:10px;text-decoration:none;
  transition:transform .18s ease,box-shadow .18s ease,background .18s ease;
}
.btn:active{transform:scale(.97)}
.btn-rojo{
  background:var(--rojo);color:#fdf6ea;
  box-shadow:0 8px 26px rgba(194,56,47,.35);
}
.btn-rojo:hover{background:#d34238;transform:translateY(-2px)}
.btn-linea{
  border:2px solid rgba(236,227,212,.5);color:var(--hueso);
  background:rgba(14,10,12,.35);
}
.btn-linea:hover{border-color:var(--hueso);transform:translateY(-2px)}
.btn svg{flex:none}

/* ---------- Cinta musical (de la reseña de Walter) ---------- */
.cinta{
  background:var(--rojo-osc);
  border-top:1px solid rgba(0,0,0,.25);border-bottom:1px solid rgba(0,0,0,.25);
  overflow:hidden;white-space:nowrap;
  padding:.55rem 0;
}
.cinta-track{display:inline-flex;animation:rodar 26s linear infinite}
.cinta span{
  font-family:var(--display);font-size:.85rem;letter-spacing:.14em;
  color:#f3d9c4;padding:0 .9rem;text-transform:uppercase;
}
.cinta .star{color:#e8a83d}
@keyframes rodar{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ---------- Secciones ---------- */
section{padding:4.2rem 1.35rem}
.wrap{max-width:1060px;margin:0 auto}
.sec-kicker{
  font-size:.72rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;
  color:var(--rojo-claro);display:block;margin-bottom:.6rem;
}
h2{
  font-family:var(--display);font-weight:400;
  font-size:clamp(1.7rem,6.4vw,2.6rem);line-height:1.1;
  margin-bottom:1.3rem;
}
.sec-oscura{background:var(--carbon)}

/* Sobre nosotros */
.sobre-grid{display:grid;gap:2rem}
.sobre-grid p{color:#cfc5b7;margin-bottom:1rem;max-width:60ch}
.sobre-grid strong{color:var(--hueso)}
.sobre-foto{
  border-radius:14px;overflow:hidden;border:1px solid var(--linea);
  aspect-ratio:4/5;
}
.sobre-foto img{width:100%;height:100%;object-fit:cover;object-position:center 40%}
.pie-foto{font-size:.78rem;color:var(--taupe);margin-top:.55rem}

/* ---------- La casa (elemento firma) ---------- */
.casa{position:relative}
.piso{
  position:relative;
  padding:0 0 2.6rem 2rem;
  border-left:3px solid var(--linea);
  margin-left:.55rem;
}
.piso:last-child{padding-bottom:.4rem;border-left-color:transparent}
.piso::before{
  content:"";position:absolute;left:-11px;top:.35rem;
  width:19px;height:19px;border-radius:50%;
  background:var(--negro);border:4px solid var(--rojo);
}
.piso-nivel{
  font-family:var(--display);font-size:.8rem;letter-spacing:.18em;
  text-transform:uppercase;color:var(--turquesa);
}
.piso h3{
  font-family:var(--display);font-weight:400;font-size:1.45rem;
  margin:.25rem 0 .5rem;
}
.piso p{color:#cfc5b7;max-width:56ch;margin-bottom:.9rem}
.chips{display:flex;flex-wrap:wrap;gap:.5rem}
.chips li{
  list-style:none;font-size:.8rem;font-weight:600;
  border:1px solid var(--linea);border-radius:999px;
  padding:.32rem .85rem;color:#d8cec0;background:var(--carbon);
}
.piso-foto{
  margin-top:1.1rem;border-radius:12px;overflow:hidden;
  border:1px solid var(--linea);aspect-ratio:16/10;
}
.piso-foto img{width:100%;height:100%;object-fit:cover}
.piso-foto img.enfoque-bajo{object-position:center 68%}

/* ---------- Reseñas ---------- */
.nota-grande{display:flex;align-items:baseline;gap:1rem;flex-wrap:wrap;margin-bottom:2rem}
.nota-num{
  font-family:var(--display);font-size:4.2rem;line-height:1;color:var(--hueso);
}
.nota-det{font-size:.95rem;color:var(--taupe)}
.estrellas{color:#e8a83d;letter-spacing:.12em;font-size:1.05rem;display:block}
.resenas-grid{display:grid;gap:1.1rem;margin-bottom:2rem}
.resena{
  background:var(--carbon-2);border:1px solid var(--linea);
  border-radius:14px;padding:1.5rem 1.4rem;
  position:relative;
}
.resena::before{
  content:"“";font-family:var(--display);font-size:3rem;line-height:1;
  color:var(--rojo);display:block;margin-bottom:.4rem;
}
.resena blockquote{font-size:.96rem;color:#ddd3c5;margin-bottom:1.1rem}
.resena footer{font-size:.83rem;color:var(--taupe)}
.resena footer b{color:var(--hueso);font-weight:600}

/* ---------- Ubicación ---------- */
.ubi-grid{display:grid;gap:2rem}
.mapa{
  border-radius:14px;overflow:hidden;border:1px solid var(--linea);
  filter:saturate(.85) contrast(.96);
}
.mapa iframe{display:block;width:100%;height:330px;border:0}
.dir-texto{color:#cfc5b7;margin:1rem 0 1.4rem;max-width:46ch}
.horarios{width:100%;border-collapse:collapse;font-size:.95rem}
.horarios caption{
  text-align:left;font-family:var(--display);font-size:1.05rem;
  margin-bottom:.7rem;
}
.horarios td{
  padding:.55rem .3rem;border-bottom:1px solid var(--linea);
}
.horarios td:last-child{text-align:right;color:#d8cec0}
.horarios .cerrado td:last-child{color:var(--rojo-claro)}
.horarios .hoy td{
  color:var(--hueso);font-weight:700;
}
.horarios .hoy td:first-child::after{
  content:"HOY";font-size:.62rem;font-weight:700;letter-spacing:.1em;
  background:var(--rojo);color:#fdf6ea;border-radius:4px;
  padding:.12rem .4rem;margin-left:.55rem;vertical-align:middle;
}

/* ---------- Footer ---------- */
.footer{
  background:#0e0a0c;border-top:1px solid var(--linea);
  padding:3rem 1.35rem 5.5rem;text-align:center;
}
.footer .nombre{font-family:var(--display);font-size:1.25rem;margin-bottom:.6rem}
.footer p{color:var(--taupe);font-size:.9rem;margin-bottom:.4rem}
.footer a.tel{
  display:inline-block;font-size:1.35rem;font-weight:700;color:var(--hueso);
  text-decoration:none;margin:.5rem 0 .8rem;
}
.footer a.tel:hover{color:var(--rojo)}

/* ---------- Reveal ---------- */
.reveal{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
.reveal.in{opacity:1;transform:none}

@media (prefers-reduced-motion:reduce){
  html{scroll-behavior:auto}
  *,*::before,*::after{animation:none!important;transition:none!important}
  .reveal{opacity:1;transform:none}
}

/* La foto del hero (825px de ancho) se escala en desktop: blur sutil + overlay para disimular */
@media (min-width:900px){
  .hero-bg{filter:blur(2px) brightness(.94);transform:scale(1.04)}
}

/* ---------- Desktop ---------- */
@media (min-width:760px){
  .hero-inner{padding-bottom:4rem}
  .sobre-grid{grid-template-columns:1.15fr .85fr;align-items:start;gap:3rem}
  .resenas-grid{grid-template-columns:repeat(3,1fr)}
  .ubi-grid{grid-template-columns:1.1fr .9fr;align-items:start;gap:3rem}
  .piso{padding-left:2.6rem}
  .piso-foto{max-width:560px}
  section{padding:5.5rem 1.35rem}
}
</style>

<script is:inline>
// Resaltar el día actual en la tabla de horarios
(function(){
  var hoy = new Date().getDay(); // 0 = domingo
  var fila = document.querySelector('#tabla-horarios tr[data-dia="' + hoy + '"]');
  if (fila) fila.classList.add('hoy');
})();

// Scroll reveal sutil
(function(){
  var els = document.querySelectorAll('.reveal');
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
    els.forEach(function(el){ el.classList.add('in'); });
    return;
  }
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  els.forEach(function(el){ io.observe(el); });
})();
</script>

</BaseLayout>
