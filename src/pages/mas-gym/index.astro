---
import BaseLayout from '../../layouts/BaseLayout.astro';

const whatsapp = 'https://wa.me/529991743610';
const telefono = '999 174 3610';
const telHref = `tel:+52${telefono.replace(/\D/g, '')}`;
const mapsUrl = 'https://maps.google.com/?cid=2523866993629562407&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA';
const facebook = 'https://www.facebook.com/MAS-GYM-365222267321849/?ref=br_rs';
---
<BaseLayout
  title="MAS GYM · Gimnasio en Vicente Guerrero, Progreso"
  description="⭐ 4.8 con 25 reseñas en Google. Ambiente tranquilo, instructores amables y buen equipo en Vicente Guerrero, Progreso. Escríbenos por WhatsApp."
  slug="mas-gym"
  ogImage="/mas-gym/img/foto_1.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Titan+One&family=Nunito:wght@400;600;700&display=swap"
  favicon="💪"
  themeColor="#fb923c"
  whatsapp={whatsapp}
  telefono={telefono}
  mapsUrl={mapsUrl}
>
  <main class="mg">

    <!-- ============ HERO ============ -->
    <header class="hero">
      <div class="wrap hero-grid">
        <div class="hero-copy">
          <p class="kicker reveal">Gimnasio de barrio · Vicente Guerrero, Progreso</p>
          <h1 class="poster reveal">
            <span class="l1">MAS</span>
            <span class="plus" aria-hidden="true">+</span>
            <span class="l2">GYM</span>
          </h1>
          <p class="tagline reveal">Buen equipo, instructores amables y el ambiente tranquilo que necesitas para no faltar a tu rutina.</p>

          <a class="chip reveal" href={mapsUrl} target="_blank" rel="noopener">
            <span class="star" aria-hidden="true">★</span> 4.8 · 25 reseñas en Google
          </a>

          <div class="cta-row reveal">
            <a class="btn btn-solid" href={whatsapp} target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2zm0 18.2c-1.5 0-3-.4-4.3-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.6.8-.8 1-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.4-3c-.3-.4 0-.5.2-.7l.4-.5c.1-.2.2-.3.3-.5v-.5c0-.1-.5-1.3-.7-1.8-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.3.3-.9.9-.9 2.2s.9 2.5 1 2.7c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2l-.4-.3z"/></svg>
              Escríbenos por WhatsApp
            </a>
            <a class="btn btn-ghost" href={mapsUrl} target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12 2a7 7 0 0 0-7 7c0 5.2 7 13 7 13s7-7.8 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
              Cómo llegar
            </a>
          </div>

          <dl class="datos reveal">
            <div><dt>4.8 <span aria-hidden="true">★</span></dt><dd>calificación real en Google</dd></div>
            <div><dt>25</dt><dd>reseñas de clientes</dd></div>
            <div><dt>Lun–Vie</dt><dd>6:00 a 23:00 · sábado hasta las 15:00</dd></div>
          </dl>
        </div>

        <div class="hero-photo reveal">
          <img
            src="/mas-gym/img/foto_1.jpg"
            alt="Área de pesas y máquinas de MAS GYM junto a su característica pared amarilla"
            width="1100"
            height="618"
          />
        </div>
      </div>
    </header>

    <!-- Firma: banda de "+" -->
    <div class="plus-band reveal" aria-hidden="true">
      <div class="plus-row">
        <span class="pb c-naranja">+</span>
        <span class="pb c-turquesa">+</span>
        <span class="pb c-crema">+</span>
        <span class="pb c-naranja">+</span>
        <span class="pb c-turquesa">+</span>
        <span class="pb c-crema">+</span>
        <span class="pb c-naranja">+</span>
      </div>
    </div>

    <!-- ============ QUIÉNES SOMOS ============ -->
    <section class="sec" id="nosotros">
      <div class="wrap">
        <p class="kicker-sec reveal"><span class="plus-ico">+</span> Quiénes somos</p>
        <h2 class="sec-title reveal">Un gym donde te conocen por tu nombre</h2>
        <div class="about reveal">
          <p>Somos <strong>MAS GYM</strong>, un gimnasio de barrio en Vicente Guerrero, Progreso. Aquí no te vas a perder entre máquinas ni entre desconocidos: el ambiente es tranquilo, ideal si prefieres entrenar sin multitudes y con espacio real para concentrarte en tu rutina.</p>
          <p>No necesitas llegar con un plan armado de casa. Nuestros instructores acompañan tu progreso, te ayudan con la técnica y le dan seguimiento a tus avances, tengas o no un entrenador personal. Quienes ya entrenan con nosotros lo describen así: gente amable, de trato cercano, que se nota que quiere verte mejorar.</p>
          <p>Contamos con área de pesas libres, máquinas de fuerza, zona de spinning y espacio para cardio, en una ubicación cómoda dentro de Vicente Guerrero. Ven a conocer el gimnasio: la primera impresión se nota apenas cruzas la puerta amarilla.</p>
        </div>
      </div>
    </section>

    <!-- ============ QUÉ OFRECEMOS ============ -->
    <section class="sec sec-dark" id="instalaciones">
      <div class="wrap">
        <p class="kicker-sec reveal"><span class="plus-ico">+</span> Qué ofrecemos</p>
        <h2 class="sec-title reveal">Todo lo que necesitas para entrenar en serio</h2>
        <div class="ofrece-grid reveal">
          <ul class="ofrece-list">
            <li><span class="li-plus" aria-hidden="true">+</span> Área de pesas libres, barras y mancuernas</li>
            <li><span class="li-plus" aria-hidden="true">+</span> Máquinas de fuerza para tren superior e inferior</li>
            <li><span class="li-plus" aria-hidden="true">+</span> Zona de spinning con bicicletas fijas</li>
            <li><span class="li-plus" aria-hidden="true">+</span> Costal de boxeo para liberar tensión</li>
            <li><span class="li-plus" aria-hidden="true">+</span> Instructores que acompañan tu rutina, sin costo extra</li>
            <li><span class="li-plus" aria-hidden="true">+</span> Ambiente tranquilo, sin multitudes</li>
          </ul>
          <div class="ofrece-gallery">
            <img src="/mas-gym/img/foto_2.jpg" alt="Zona de spinning de MAS GYM con bicicletas fijas" loading="lazy" width="770" height="960" />
            <img src="/mas-gym/img/foto_3.jpg" alt="Área de máquinas y pesas de MAS GYM" loading="lazy" width="960" height="720" />
            <img src="/mas-gym/img/foto_4.jpg" alt="Pasillo del gimnasio con máquinas, costal de boxeo y equipo libre" loading="lazy" width="960" height="720" />
          </div>
        </div>
      </div>
    </section>

    <!-- ============ RESEÑAS ============ -->
    <section class="sec" id="resenas">
      <div class="wrap">
        <p class="kicker-sec reveal"><span class="plus-ico">+</span> Lo que dicen en Google</p>
        <h2 class="sec-title reveal"><span class="hl">4.8 de 5</span> en 25 reseñas</h2>
        <div class="reviews reveal">
          <figure class="rev">
            <span class="rev-plus" aria-hidden="true">+</span>
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«Excelente lugar para ir a entrenar, excelente ambiente, los instructores muy amables y no tienes que tener plan personal para que te entrenen ellos te ayudan con tus progresos.»</blockquote>
            <figcaption><strong>Luis Acosta</strong><span>Hace 4 años · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <span class="rev-plus" aria-hidden="true">+</span>
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«Tiene bastante equipo y el trato es amable. Buen lugar para hacer ejercicio»</blockquote>
            <figcaption><strong>Edwin Perera</strong><span>Hace 5 años · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <span class="rev-plus" aria-hidden="true">+</span>
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«Excelente lugar para entrenar si no te gusta mucho la gente.»</blockquote>
            <figcaption><strong>Rafa Tilo</strong><span>Hace 3 años · Google</span></figcaption>
          </figure>
        </div>
        <div class="center reveal">
          <a class="btn btn-ghost" href={mapsUrl} target="_blank" rel="noopener">Leer más reseñas en Google</a>
        </div>
      </div>
    </section>

    <!-- ============ UBICACIÓN Y HORARIOS ============ -->
    <section class="sec sec-dark" id="ubicacion">
      <div class="wrap">
        <p class="kicker-sec reveal"><span class="plus-ico">+</span> Cómo llegar</p>
        <h2 class="sec-title reveal">Vicente Guerrero, Progreso</h2>
        <div class="ubica reveal">
          <div class="ubica-info">
            <p class="dir">C. 31 478, Vicente Guerrero<br />97320 Progreso, Yucatán</p>
            <a class="btn btn-solid btn-sm" href={mapsUrl} target="_blank" rel="noopener">Abrir en Google Maps</a>
            <h3 class="horario-titulo">Horario del gimnasio</h3>
            <table class="horarios">
              <tbody>
                <tr data-dia="1"><th scope="row">Lunes</th><td>6:00–23:00</td></tr>
                <tr data-dia="2"><th scope="row">Martes</th><td>6:00–23:00</td></tr>
                <tr data-dia="3"><th scope="row">Miércoles</th><td>6:00–23:00</td></tr>
                <tr data-dia="4"><th scope="row">Jueves</th><td>6:00–23:00</td></tr>
                <tr data-dia="5"><th scope="row">Viernes</th><td>6:00–23:00</td></tr>
                <tr data-dia="6"><th scope="row">Sábado</th><td>6:00–15:00</td></tr>
                <tr data-dia="0"><th scope="row">Domingo</th><td>Cerrado</td></tr>
              </tbody>
            </table>
          </div>
          <div class="mapa">
            <iframe
              src="https://www.google.com/maps?q=MAS%20GYM%2C%20C.%2031%20478%2C%20Vicente%20Guerrero%2C%2097320%20Progreso%2C%20Yuc.%2C%20M%C3%A9xico&output=embed"
              title="Mapa: MAS GYM en Vicente Guerrero, Progreso"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA FINAL ============ -->
    <section class="banda">
      <div class="wrap">
        <h2 class="banda-title">¿Listo para MAS resultados?</h2>
        <p class="banda-sub">Escríbenos y agenda tu primera visita. Sin vueltas, sin presión — solo entrenar.</p>
        <div class="cta-row">
          <a class="btn btn-dark" href={whatsapp} target="_blank" rel="noopener">WhatsApp directo</a>
          <a class="btn btn-dark-ghost" href={telHref}>Llamar · {telefono}</a>
        </div>
      </div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="pie">
      <div class="wrap">
        <p class="pie-logo">MAS<span class="pie-plus" aria-hidden="true">+</span>GYM</p>
        <p class="pie-dato">Gimnasio · C. 31 478, Vicente Guerrero, 97320 Progreso, Yucatán</p>
        <p class="pie-dato"><a href={telHref}>{telefono}</a> · <a href={whatsapp} target="_blank" rel="noopener">WhatsApp</a> · <a href={facebook} target="_blank" rel="noopener">Facebook</a></p>
        <p class="pie-mini">Lunes a viernes 6:00–23:00 · Sábado 6:00–15:00 · Domingo cerrado</p>
      </div>
    </footer>
  </main>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "HealthClub",
    "name": "MAS GYM",
    "telephone": "+529991743610",
    "url": "https://demos.ivang.mx/mas-gym",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "C. 31 478, Vicente Guerrero",
      "addressLocality": "Progreso",
      "addressRegion": "Yucatán",
      "postalCode": "97320",
      "addressCountry": "MX"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "reviewCount": "25"
    },
    "openingHours": ["Mo-Fr 06:00-23:00", "Sa 06:00-15:00"]
  }
  </script>

  <style is:global>
    :root {
      --crema: #fff7ed;
      --crema-panel: #ffedd8;
      --navy: #1e293b;
      --navy-2: #263449;
      --navy-soft: #94a3b8;
      --naranja: #fb923c;
      --naranja-deep: #c2410c;
      --turquesa: #2dd4bf;
      --turquesa-deep: #0d9488;
      --line-lt: rgba(30, 41, 59, 0.12);
      --line-dk: rgba(255, 247, 237, 0.14);
      --display: "Titan One", "Arial Rounded MT Bold", sans-serif;
      --body: "Nunito", system-ui, sans-serif;
    }

    body {
      background: var(--crema);
      color: var(--navy);
      font-family: var(--body);
      font-size: 17px;
      line-height: 1.6;
      overflow-x: clip;
    }

    .mg ::selection { background: var(--naranja); color: var(--navy); }
    .mg a:focus-visible,
    .mg .btn:focus-visible,
    .mg .chip:focus-visible {
      outline: 3px solid var(--turquesa-deep);
      outline-offset: 3px;
    }

    .wrap { max-width: 1080px; margin: 0 auto; padding: 0 20px; }

    /* ---------- HERO ---------- */
    .hero {
      padding: 52px 0 0;
      background:
        radial-gradient(720px 420px at 92% -6%, rgba(45, 212, 191, 0.16), transparent 60%),
        var(--crema);
    }
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
      align-items: center;
      padding-bottom: 44px;
    }
    .kicker {
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--naranja-deep);
      margin: 0 0 14px;
    }
    .poster {
      margin: 0 0 18px;
      font-family: var(--display);
      font-weight: 400;
      text-transform: uppercase;
      line-height: 0.92;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 6px 14px;
    }
    .poster .l1 {
      font-size: clamp(46px, 13vw, 84px);
      color: var(--navy);
    }
    .poster .l2 {
      font-size: clamp(46px, 13vw, 84px);
      color: var(--naranja);
    }
    .poster .plus {
      font-size: clamp(40px, 11vw, 70px);
      color: var(--turquesa-deep);
      display: inline-block;
      transform: rotate(-8deg);
      animation: girar 7s ease-in-out infinite;
    }
    @keyframes girar {
      0%, 100% { transform: rotate(-8deg) scale(1); }
      50% { transform: rotate(8deg) scale(1.08); }
    }
    .tagline {
      font-size: clamp(17px, 4vw, 21px);
      font-weight: 600;
      color: var(--navy);
      max-width: 40ch;
      margin: 0 0 20px;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 2px solid var(--navy);
      border-radius: 999px;
      padding: 8px 16px;
      font-weight: 700;
      font-size: 15px;
      color: var(--navy);
      text-decoration: none;
      background: #fff;
    }
    .chip .star { color: var(--naranja-deep); }
    .chip:hover { border-color: var(--turquesa-deep); color: var(--turquesa-deep); }

    .cta-row { display: flex; flex-wrap: wrap; gap: 12px; margin: 22px 0 0; }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-family: var(--body);
      font-weight: 800;
      font-size: 16px;
      text-decoration: none;
      padding: 15px 24px;
      border-radius: 999px;
      transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }
    .btn:active { transform: scale(0.97); }
    .btn-solid { background: var(--naranja); color: var(--navy); }
    .btn-solid:hover { background: #fda962; }
    .btn-ghost { border: 2px solid var(--navy); color: var(--navy); background: transparent; }
    .btn-ghost:hover { border-color: var(--turquesa-deep); color: var(--turquesa-deep); }
    .btn-sm { font-size: 15px; padding: 12px 18px; }

    .sec-dark .btn-ghost { border-color: var(--crema); color: var(--crema); }
    .sec-dark .btn-ghost:hover { border-color: var(--turquesa); color: var(--turquesa); }

    .datos {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin: 34px 0 0;
      border-top: 2px solid var(--line-lt);
      padding-top: 18px;
    }
    .datos dt {
      font-family: var(--display);
      font-weight: 400;
      font-size: clamp(20px, 5.5vw, 32px);
      color: var(--navy);
    }
    .datos dt span { color: var(--naranja-deep); }
    .datos dd { margin: 4px 0 0; font-size: 12.5px; color: #57626f; line-height: 1.4; }

    .hero-photo img {
      width: 100%;
      border-radius: 20px;
      border: 4px solid var(--navy);
      box-shadow: 8px 8px 0 var(--naranja);
    }

    /* ---------- BANDA DE "+" (firma) ---------- */
    .plus-band {
      background: var(--navy);
      padding: 18px 0;
      overflow: hidden;
    }
    .plus-row {
      display: flex;
      justify-content: space-between;
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 20px;
    }
    .pb {
      font-family: var(--display);
      font-weight: 400;
      font-size: clamp(22px, 6vw, 40px);
      line-height: 1;
    }
    .pb.c-naranja { color: var(--naranja); }
    .pb.c-turquesa { color: var(--turquesa); }
    .pb.c-crema { color: var(--crema); opacity: 0.55; }

    /* ---------- SECCIONES ---------- */
    .sec { padding: 68px 0; }
    .sec-dark {
      background: var(--navy);
      color: var(--crema);
    }
    .kicker-sec {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--naranja-deep);
      margin: 0 0 10px;
    }
    .sec-dark .kicker-sec { color: var(--turquesa); }
    .plus-ico {
      font-family: var(--display);
      font-weight: 400;
      font-size: 18px;
    }
    .sec-title {
      font-family: var(--display);
      font-weight: 400;
      font-size: clamp(30px, 7vw, 52px);
      line-height: 1.05;
      margin: 0 0 26px;
      color: var(--navy);
    }
    .sec-dark .sec-title { color: var(--crema); }
    .sec-title .hl {
      background: var(--naranja);
      color: var(--navy);
      padding: 2px 12px;
      border-radius: 8px;
      display: inline-block;
    }

    .about p { max-width: 62ch; margin: 0 0 18px; color: #384454; font-size: 16.5px; }
    .about strong { color: var(--navy); }

    /* ---------- QUÉ OFRECEMOS ---------- */
    .ofrece-grid { display: grid; grid-template-columns: 1fr; gap: 32px; }
    .ofrece-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 0; }
    .ofrece-list li {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 14px 0;
      border-top: 1px solid var(--line-dk);
      font-weight: 600;
      font-size: 16px;
    }
    .ofrece-list li:last-child { border-bottom: 1px solid var(--line-dk); }
    .li-plus {
      font-family: var(--display);
      font-weight: 400;
      font-size: 20px;
      color: var(--naranja);
      line-height: 1.2;
    }
    .ofrece-gallery {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .ofrece-gallery img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 14px;
      border: 3px solid var(--turquesa);
    }
    .ofrece-gallery img:first-child { grid-row: 1 / 3; }

    /* ---------- RESEÑAS ---------- */
    .reviews {
      display: grid;
      grid-template-columns: 1fr;
      gap: 18px;
      margin: 0 0 30px;
    }
    .rev {
      position: relative;
      margin: 0;
      background: #fff;
      color: var(--navy);
      border-radius: 16px;
      padding: 22px 20px 18px;
      border: 2px solid var(--navy);
      box-shadow: 6px 6px 0 var(--turquesa);
    }
    .rev-plus {
      position: absolute;
      top: -16px;
      left: 18px;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--naranja);
      color: var(--navy);
      border-radius: 50%;
      border: 2px solid var(--navy);
      font-family: var(--display);
      font-size: 18px;
    }
    .rev-stars { color: var(--naranja-deep); font-size: 15px; letter-spacing: 0.15em; margin: 8px 0 10px; }
    .rev blockquote {
      margin: 0 0 14px;
      font-size: 15.5px;
      line-height: 1.55;
      font-weight: 700;
    }
    .rev figcaption { display: flex; flex-direction: column; gap: 2px; }
    .rev figcaption strong { font-size: 15px; font-weight: 800; }
    .rev figcaption span { font-size: 12.5px; color: #64748b; }
    .center { text-align: center; }

    /* ---------- UBICACIÓN ---------- */
    .ubica { display: grid; grid-template-columns: 1fr; gap: 26px; }
    .dir { font-size: 17px; font-weight: 700; margin: 0 0 14px; }
    .horario-titulo {
      font-family: var(--display);
      font-weight: 400;
      font-size: 20px;
      margin: 28px 0 10px;
      color: var(--crema);
    }
    .horarios { width: 100%; max-width: 400px; border-collapse: collapse; font-size: 15px; }
    .horarios th, .horarios td { padding: 8px 10px; border-bottom: 1px solid var(--line-dk); text-align: left; }
    .horarios th { font-weight: 600; color: var(--crema); }
    .horarios td { color: var(--navy-soft); text-align: right; font-variant-numeric: tabular-nums; }
    .horarios tr.hoy th, .horarios tr.hoy td { color: var(--navy); background: var(--turquesa); font-weight: 800; }
    .horarios tr.hoy th::after {
      content: "hoy";
      font-family: var(--display);
      font-weight: 400;
      font-size: 11px;
      text-transform: uppercase;
      background: var(--navy);
      color: var(--crema);
      border-radius: 4px;
      padding: 2px 7px;
      margin-left: 8px;
      vertical-align: 1px;
    }
    .mapa iframe {
      width: 100%;
      height: 300px;
      border: 0;
      border-radius: 14px;
      display: block;
      border: 3px solid var(--turquesa);
    }

    /* ---------- CTA FINAL ---------- */
    .banda {
      background: var(--naranja);
      color: var(--navy);
      padding: 60px 0;
      text-align: center;
    }
    .banda-title {
      font-family: var(--display);
      font-weight: 400;
      font-size: clamp(30px, 8vw, 56px);
      line-height: 1.05;
      margin: 0 0 12px;
    }
    .banda-sub { margin: 0 auto 24px; max-width: 40ch; font-weight: 700; }
    .banda .cta-row { justify-content: center; }
    .btn-dark { background: var(--navy); color: var(--crema); }
    .btn-dark:hover { background: var(--navy-2); }
    .btn-dark-ghost { border: 2px solid var(--navy); color: var(--navy); }
    .btn-dark-ghost:hover { background: rgba(30, 41, 59, 0.08); }

    /* ---------- FOOTER ---------- */
    .pie {
      background: var(--navy);
      color: var(--crema);
      padding: 40px 0 90px;
      text-align: center;
    }
    .pie-logo {
      font-family: var(--display);
      font-weight: 400;
      font-size: 26px;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 4px;
      margin: 0 0 10px;
    }
    .pie-plus { color: var(--turquesa); }
    .pie-dato { margin: 4px 0; color: var(--navy-soft); font-size: 14px; }
    .pie-dato a { color: var(--crema); text-decoration: none; border-bottom: 1px solid var(--naranja); }
    .pie-dato a:hover { color: var(--turquesa); border-color: var(--turquesa); }
    .pie-mini { margin: 14px 0 0; color: #64748b; font-size: 12px; }

    /* ---------- REVEAL (solo con JS) ---------- */
    html.js .reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    html.js .reveal.in { opacity: 1; transform: none; }

    /* ---------- DESKTOP ---------- */
    @media (min-width: 760px) {
      .hero-grid { grid-template-columns: 1.1fr 0.9fr; gap: 40px; padding-bottom: 60px; }
      .sec { padding: 100px 0; }
      .ofrece-grid { grid-template-columns: 1fr 1fr; align-items: center; gap: 48px; }
      .reviews { grid-template-columns: repeat(3, 1fr); align-items: start; }
      .ubica { grid-template-columns: 1fr 1.2fr; align-items: start; }
      .mapa iframe { height: 400px; }
    }
  </style>

  <script is:inline>
    (function () {
      var d = document;
      d.documentElement.classList.add('js');

      // Resaltar el día de hoy en la tabla de horarios
      var hoy = new Date().getDay(); // 0 = domingo
      var fila = d.querySelector('.horarios tr[data-dia="' + hoy + '"]');
      if (fila) fila.classList.add('hoy');

      // Scroll-reveal (mejora progresiva)
      var els = d.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach(function (el) { io.observe(el); });
      } else {
        els.forEach(function (el) { el.classList.add('in'); });
      }
    })();
  </script>
</BaseLayout>
