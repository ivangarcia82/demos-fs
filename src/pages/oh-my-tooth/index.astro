---
import BaseLayout from '../../layouts/BaseLayout.astro';

const negocio = 'Oh My Tooth!';
const whatsapp = 'https://wa.me/529902021037';
const telefono = '990 202 1037';
const telHref = 'tel:+529902021037';
const mapsUrl = 'https://maps.google.com/?cid=17181700342219041351&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA';
const direccion = 'Plaza Carrillón, Local 17, Campestre, 97120 Mérida, Yuc., México';
const mapEmbed = 'https://www.google.com/maps?q=' + encodeURIComponent(direccion) + '&output=embed';

const horarios = [
  ['Lunes', '9:00–13:00 · 15:30–19:30'],
  ['Martes', '9:00–13:00 · 15:30–19:30'],
  ['Miércoles', '9:00–13:00 · 15:30–19:30'],
  ['Jueves', '9:00–13:00 · 15:30–19:30'],
  ['Viernes', '9:00–13:00 · 15:30–19:30'],
  ['Sábado', '9:00–13:00 · 15:30–19:30'],
  ['Domingo', '9:00–13:00 · 15:30–19:30'],
];

const resenas = [
  {
    autor: 'Marta Suseth Ceballos Maza',
    cuando: 'Hace 3 semanas',
    texto: 'La doctora Fabiola pedrero me atendió súper bien, puntualidad en la cita, pendiente en todo momento de mi, súper amable, muy recordable la clínica',
  },
  {
    autor: 'Karla Cárdenas',
    cuando: 'Hace 3 semanas',
    texto: '…Me sentí muy cómoda en todo momento, con la doctora Karen Torres, muy amable y muy profesional, nos explico paso a paso lo que haría.',
  },
  {
    autor: 'Oscar Salazar',
    cuando: 'Hace 1 mes',
    texto: 'Exelente atención y muy profecíonal. Me explico todo con claridad y el trato fue muy amable desde el primer momento. Quedé muy satisfecho con el resultado.…',
  },
  {
    autor: 'Yessica Cardeña',
    cuando: 'Hace 4 semanas',
    texto: 'El lugar es bien acogedor y limpio. La doctora Fabiola Pedrero es súper linda, cuidadosa y delicada en los procedimientos',
  },
  {
    autor: 'A. V.',
    cuando: 'Hace un año',
    texto: '…Todo el equipo fue muy amable y me hicieron sentir cómoda desde que llegué. El lugar está limpio y bien cuidado, y se nota que les importa hacer bien su trabajo.',
  },
];
---
<BaseLayout
  title="Oh My Tooth! · Dentista en Mérida"
  description="Clínica dental en Campestre, Mérida. ⭐ 5.0 · 157 reseñas. Trato amable y te explicamos paso a paso. Agenda tu cita por WhatsApp."
  slug="oh-my-tooth"
  ogImage="/oh-my-tooth/img/foto_1.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito+Sans:wght@400;600;700;800&display=swap"
  favicon="🦷"
  themeColor="#3FA9C9"
  whatsapp={whatsapp}
  telefono={telefono}
  mapsUrl={mapsUrl}
>
  <main class="omt">

    <!-- ============ HERO ============ -->
    <header class="hero">
      <div class="hero__glow" aria-hidden="true"></div>
      <svg class="spark spark--a" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0c.6 6 5.4 10.8 12 12-6.6 1.2-11.4 6-12 12-.6-6-5.4-10.8-12-12C6.6 10.8 11.4 6 12 0Z"/></svg>
      <svg class="spark spark--b" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0c.6 6 5.4 10.8 12 12-6.6 1.2-11.4 6-12 12-.6-6-5.4-10.8-12-12C6.6 10.8 11.4 6 12 0Z"/></svg>
      <svg class="spark spark--c" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0c.6 6 5.4 10.8 12 12-6.6 1.2-11.4 6-12 12-.6-6-5.4-10.8-12-12C6.6 10.8 11.4 6 12 0Z"/></svg>

      <div class="hero__inner">
        <div class="hero__copy">
          <p class="eyebrow">Especialistas dentales · Campestre, Mérida</p>
          <h1 class="hero__title">Oh my tooth!<span class="hero__spark" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M12 0c.6 6 5.4 10.8 12 12-6.6 1.2-11.4 6-12 12-.6-6-5.4-10.8-12-12C6.6 10.8 11.4 6 12 0Z"/></svg>
          </span></h1>
          <p class="hero__lead">Ir al dentista puede dar gusto. Te recibimos con calma, te explicamos paso a paso y no empezamos hasta que estés cómodo.</p>

          <div class="rating-pill">
            <span class="rating-pill__stars" aria-hidden="true">★★★★★</span>
            <span><strong>5.0</strong> · 157 reseñas en Google</span>
          </div>

          <div class="hero__cta">
            <a class="btn btn--wa" href={whatsapp} target="_blank" rel="noopener">
              <svg class="ico" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21 5.46 0 9.91-4.45 9.91-9.91C21.95 6.45 17.5 2 12.04 2Zm5.8 14.02c-.24.68-1.4 1.3-1.94 1.38-.5.07-1.13.1-1.82-.11-.42-.13-.96-.31-1.65-.61-2.9-1.25-4.8-4.17-4.94-4.36-.15-.19-1.19-1.58-1.19-3.01 0-1.43.75-2.13 1.02-2.42.27-.29.58-.36.78-.36.19 0 .39 0 .56.01.18.01.42-.07.66.5.24.59.82 2.03.89 2.18.07.15.12.32.02.51-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.76 1.25 1.63 2.02 1.12 1 2.06 1.31 2.35 1.46.29.15.46.12.63-.07.17-.19.73-.85.92-1.14.19-.29.39-.24.66-.15.27.1 1.71.81 2 .96.29.15.49.22.56.34.07.12.07.68-.17 1.36Z"/></svg>
              Escríbenos por WhatsApp
            </a>
            <a class="btn btn--ghost" href={mapsUrl} target="_blank" rel="noopener">
              <svg class="ico" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7Zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5Z"/></svg>
              Cómo llegar
            </a>
          </div>
        </div>

        <figure class="hero__photo reveal">
          <img src="/oh-my-tooth/img/foto_1.jpg" width="1200" height="800"
               alt="Recepción de Oh My Tooth! con el logotipo iluminado en la pared" />
          <span class="hero__sticker" aria-hidden="true">
            <span class="hero__sticker-tooth">
              <svg viewBox="0 0 64 64"><path d="M32 7C19 7 10 15 10 27c0 10 4 18 7 25 2 5 7 4 8-1 1-6 3-9 7-9s6 3 7 9c1 5 6 6 8 1 3-7 7-15 7-25C54 15 45 7 32 7Z" fill="#fff" stroke="#3FA9C9" stroke-width="2.5" stroke-linejoin="round"/><path d="M25 27c1 3 4 4.5 7 4.5S38 30 39 27" fill="none" stroke="#3FA9C9" stroke-width="2.5" stroke-linecap="round"/><circle cx="24.5" cy="22.5" r="1.8" fill="#213343"/><circle cx="39.5" cy="22.5" r="1.8" fill="#213343"/></svg>
            </span>
            <span class="hero__sticker-txt">¡Sonríe!</span>
          </span>
        </figure>
      </div>
    </header>

    <!-- ============ FRANJA DE CONFIANZA ============ -->
    <section class="trust" aria-label="Datos de confianza">
      <ul class="trust__row">
        <li><span class="trust__k">⭐ 5.0</span><span class="trust__v">en Google</span></li>
        <li><span class="trust__k">157</span><span class="trust__v">reseñas reales</span></li>
        <li><span class="trust__k">Todos los días</span><span class="trust__v">9:00 – 19:30</span></li>
        <li><span class="trust__k">Acepta tarjetas</span><span class="trust__v">pago fácil</span></li>
        <li><span class="trust__k">Silla de ruedas</span><span class="trust__v">acceso completo</span></li>
      </ul>
    </section>

    <!-- ============ QUIÉNES SOMOS ============ -->
    <section class="about reveal" aria-labelledby="about-h">
      <div class="about__mascot" aria-hidden="true">
        <svg viewBox="0 0 64 64"><path d="M32 7C19 7 10 15 10 27c0 10 4 18 7 25 2 5 7 4 8-1 1-6 3-9 7-9s6 3 7 9c1 5 6 6 8 1 3-7 7-15 7-25C54 15 45 7 32 7Z" fill="#fff" stroke="#3FA9C9" stroke-width="2.5" stroke-linejoin="round"/><path d="M24 28c1.5 3.5 4.5 5.2 8 5.2S38.5 31.5 40 28" fill="none" stroke="#3FA9C9" stroke-width="2.5" stroke-linecap="round"/><circle cx="24" cy="22.5" r="2" fill="#213343"/><circle cx="40" cy="22.5" r="2" fill="#213343"/><circle cx="19" cy="27" r="2.4" fill="#FFC7B8"/><circle cx="45" cy="27" r="2.4" fill="#FFC7B8"/></svg>
      </div>
      <p class="eyebrow eyebrow--center">Hola, somos Oh My Tooth!</p>
      <h2 id="about-h" class="h2">Una clínica donde de verdad da gusto sonreír</h2>
      <div class="about__text">
        <p>Estamos en el corazón de Campestre, en Plaza Carrillón, y trabajamos para que cada visita se sienta distinta a lo que esperabas de un dentista. Aquí nadie es un número: te recibimos con calma, escuchamos qué te trae y te explicamos <strong>paso a paso</strong> lo que vamos a hacer antes de empezar.</p>
        <p>Nuestros pacientes lo dicen mejor que nosotros: un espacio <strong>limpio y acogedor</strong>, doctoras que se toman su tiempo, y la tranquilidad de estar en buenas manos. Sin prisas, sin tecnicismos y sin sorpresas.</p>
      </div>
    </section>

    <!-- ============ POR QUÉ NOS ELIGEN ============ -->
    <section class="why reveal" aria-labelledby="why-h">
      <div class="section-head">
        <p class="eyebrow eyebrow--center">Por qué la gente vuelve</p>
        <h2 id="why-h" class="h2">Lo que más nos agradecen</h2>
      </div>
      <div class="why__grid">
        <article class="card card--sky">
          <span class="card__icon" aria-hidden="true">🗣️</span>
          <h3 class="card__title">Te explicamos paso a paso</h3>
          <p>Sabrás exactamente qué haremos y por qué, en palabras claras. Nada empieza sin que estés de acuerdo.</p>
        </article>
        <article class="card card--mint">
          <span class="card__icon" aria-hidden="true">🧼</span>
          <h3 class="card__title">Limpio y acogedor</h3>
          <p>Una clínica cuidada de arriba abajo. El ambiente se siente cálido desde que cruzas la puerta.</p>
        </article>
        <article class="card card--lav">
          <span class="card__icon" aria-hidden="true">💜</span>
          <h3 class="card__title">Trato amable de verdad</h3>
          <p>Amabilidad desde el primer momento y atención pendiente de ti durante toda la cita.</p>
        </article>
        <article class="card card--coral">
          <span class="card__icon" aria-hidden="true">⏱️</span>
          <h3 class="card__title">Puntuales con tu cita</h3>
          <p>Respetamos tu hora. Reservas, llegas y te atendemos: tu tiempo también importa.</p>
        </article>
      </div>
    </section>

    <!-- ============ CÓMO ES TU VISITA ============ -->
    <section class="visit reveal" aria-labelledby="visit-h">
      <div class="section-head">
        <p class="eyebrow eyebrow--center">Cómo es tu visita</p>
        <h2 id="visit-h" class="h2">Tres pasos, cero nervios</h2>
      </div>
      <ol class="steps">
        <li class="step">
          <span class="step__n">1</span>
          <h3 class="step__title">Nos cuentas qué necesitas</h3>
          <p>Escuchamos con calma y revisamos tu caso sin apuros. Aquí empiezan las buenas decisiones.</p>
        </li>
        <li class="step">
          <span class="step__n">2</span>
          <h3 class="step__title">Te explicamos el plan</h3>
          <p>Con claridad y sin tecnicismos: qué haremos, cómo y qué esperar en cada paso.</p>
        </li>
        <li class="step">
          <span class="step__n">3</span>
          <h3 class="step__title">Trabajamos con delicadeza</h3>
          <p>Cuidadosas en cada procedimiento y pendientes de ti en todo momento hasta que salgas contento.</p>
        </li>
      </ol>
    </section>

    <!-- ============ GALERÍA ============ -->
    <section class="gallery reveal" aria-labelledby="gal-h">
      <div class="section-head">
        <p class="eyebrow eyebrow--center">Conoce el lugar</p>
        <h2 id="gal-h" class="h2">Así se ve por dentro</h2>
      </div>
      <div class="gallery__grid">
        <figure class="ga ga--tall">
          <img src="/oh-my-tooth/img/foto_4.jpg" loading="lazy" width="1200" height="800"
               alt="Consultorio con sillón dental y cuadros de acuarela de un diente" />
        </figure>
        <figure class="ga">
          <img src="/oh-my-tooth/img/foto_2.jpg" loading="lazy" width="1200" height="800"
               alt="Consultorio dental limpio y luminoso con pared de madera" />
        </figure>
        <figure class="ga">
          <img src="/oh-my-tooth/img/foto_5.jpg" loading="lazy" width="900" height="1200"
               alt="Doctora mostrando a una paciente ligas de ortodoncia de colores" />
        </figure>
        <figure class="ga ga--wide">
          <img src="/oh-my-tooth/img/foto_3.jpg" loading="lazy" width="1200" height="800"
               alt="Sala de la clínica con pared de madera y mobiliario cuidado" />
        </figure>
      </div>
    </section>

    <!-- ============ CTA INTERMEDIO ============ -->
    <section class="cta-band reveal" aria-label="Agenda por WhatsApp">
      <div class="cta-band__inner">
        <div>
          <h2 class="cta-band__title">¿Lista tu sonrisa para su cita?</h2>
          <p class="cta-band__sub">Cuéntanos qué necesitas por WhatsApp y te decimos el siguiente paso.</p>
        </div>
        <a class="btn btn--wa btn--onwhite" href={whatsapp} target="_blank" rel="noopener">
          <svg class="ico" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21 5.46 0 9.91-4.45 9.91-9.91C21.95 6.45 17.5 2 12.04 2Zm5.8 14.02c-.24.68-1.4 1.3-1.94 1.38-.5.07-1.13.1-1.82-.11-.42-.13-.96-.31-1.65-.61-2.9-1.25-4.8-4.17-4.94-4.36-.15-.19-1.19-1.58-1.19-3.01 0-1.43.75-2.13 1.02-2.42.27-.29.58-.36.78-.36.19 0 .39 0 .56.01.18.01.42-.07.66.5.24.59.82 2.03.89 2.18.07.15.12.32.02.51-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.76 1.25 1.63 2.02 1.12 1 2.06 1.31 2.35 1.46.29.15.46.12.63-.07.17-.19.73-.85.92-1.14.19-.29.39-.24.66-.15.27.1 1.71.81 2 .96.29.15.49.22.56.34.07.12.07.68-.17 1.36Z"/></svg>
          Escríbenos ahora
        </a>
      </div>
    </section>

    <!-- ============ RESEÑAS ============ -->
    <section class="reviews reveal" aria-labelledby="rev-h">
      <div class="section-head">
        <p class="eyebrow eyebrow--center">Lo que dicen sus pacientes</p>
        <h2 id="rev-h" class="h2">157 reseñas y todas de 5 estrellas</h2>
        <p class="reviews__score"><span aria-hidden="true">★★★★★</span> <strong>5.0</strong> de calificación promedio en Google</p>
      </div>
      <div class="reviews__wall">
        {resenas.map((r) => (
          <figure class="review">
            <div class="review__stars" aria-hidden="true">★★★★★</div>
            <blockquote>{r.texto}</blockquote>
            <figcaption>
              <span class="review__author">{r.autor}</span>
              <span class="review__when">{r.cuando}</span>
            </figcaption>
          </figure>
        ))}
      </div>
      <div class="reviews__more">
        <a class="btn btn--ghost" href={mapsUrl} target="_blank" rel="noopener">Leer más reseñas en Google</a>
      </div>
    </section>

    <!-- ============ EQUIPO ============ -->
    <section class="team reveal" aria-labelledby="team-h">
      <div class="team__inner">
        <p class="eyebrow eyebrow--center">Detrás de cada sonrisa</p>
        <h2 id="team-h" class="h2">Manos que tienen nombre</h2>
        <p class="team__lead">Cuando una paciente recuerda el nombre de su doctora, es porque hubo tiempo, atención y trato humano. En sus reseñas, muchas nombran a la <strong>Dra. Karen Torres</strong> y a la <strong>Dra. Fabiola Pedrero</strong>: puntuales, amables y delicadas en cada procedimiento.</p>
        <div class="team__chips">
          <span class="chip">Dra. Karen Torres</span>
          <span class="chip">Dra. Fabiola Pedrero</span>
        </div>
      </div>
    </section>

    <!-- ============ UBICACIÓN Y HORARIOS ============ -->
    <section class="place reveal" aria-labelledby="place-h">
      <div class="section-head">
        <p class="eyebrow eyebrow--center">Dónde estamos</p>
        <h2 id="place-h" class="h2">Fácil de encontrar en Campestre</h2>
      </div>
      <div class="place__grid">
        <div class="place__info">
          <div class="place__block">
            <h3 class="place__k">Dirección</h3>
            <p>Plaza Carrillón, Local 17<br>Campestre, 97120 Mérida, Yucatán</p>
            <a class="link" href={mapsUrl} target="_blank" rel="noopener">Abrir en Google Maps →</a>
          </div>
          <div class="place__block">
            <h3 class="place__k">Teléfono</h3>
            <p><a class="link" href={telHref}>990 202 1037</a></p>
          </div>
          <div class="place__block">
            <h3 class="place__k">Horarios</h3>
            <p class="place__note">Abierto los 7 días · mismo horario</p>
            <table class="hours">
              <tbody>
                {horarios.map(([dia, hrs]) => (
                  <tr>
                    <th scope="row">{dia}</th>
                    <td>{hrs}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
        <div class="place__map">
          <iframe
            src={mapEmbed}
            title="Mapa de Oh My Tooth! en Plaza Carrillón, Mérida"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
    </section>

    <!-- ============ CTA FINAL ============ -->
    <section class="final reveal" aria-labelledby="final-h">
      <svg class="spark spark--d" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0c.6 6 5.4 10.8 12 12-6.6 1.2-11.4 6-12 12-.6-6-5.4-10.8-12-12C6.6 10.8 11.4 6 12 0Z"/></svg>
      <span class="final__tooth" aria-hidden="true">
        <svg viewBox="0 0 64 64"><path d="M32 7C19 7 10 15 10 27c0 10 4 18 7 25 2 5 7 4 8-1 1-6 3-9 7-9s6 3 7 9c1 5 6 6 8 1 3-7 7-15 7-25C54 15 45 7 32 7Z" fill="#fff" stroke="#fff" stroke-width="2" stroke-linejoin="round"/><path d="M24 28c1.5 3.5 4.5 5.2 8 5.2S38.5 31.5 40 28" fill="none" stroke="#3FA9C9" stroke-width="2.6" stroke-linecap="round"/><circle cx="24" cy="22.5" r="2" fill="#213343"/><circle cx="40" cy="22.5" r="2" fill="#213343"/><circle cx="19" cy="27" r="2.4" fill="#FFC7B8"/><circle cx="45" cy="27" r="2.4" fill="#FFC7B8"/></svg>
      </span>
      <h2 id="final-h" class="final__title">Tu próxima sonrisa empieza con un mensaje</h2>
      <p class="final__sub">Agenda tu cita en Oh My Tooth! Te respondemos por WhatsApp y resolvemos tus dudas.</p>
      <div class="final__cta">
        <a class="btn btn--wa btn--onwhite" href={whatsapp} target="_blank" rel="noopener">
          <svg class="ico" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21 5.46 0 9.91-4.45 9.91-9.91C21.95 6.45 17.5 2 12.04 2Zm5.8 14.02c-.24.68-1.4 1.3-1.94 1.38-.5.07-1.13.1-1.82-.11-.42-.13-.96-.31-1.65-.61-2.9-1.25-4.8-4.17-4.94-4.36-.15-.19-1.19-1.58-1.19-3.01 0-1.43.75-2.13 1.02-2.42.27-.29.58-.36.78-.36.19 0 .39 0 .56.01.18.01.42-.07.66.5.24.59.82 2.03.89 2.18.07.15.12.32.02.51-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.76 1.25 1.63 2.02 1.12 1 2.06 1.31 2.35 1.46.29.15.46.12.63-.07.17-.19.73-.85.92-1.14.19-.29.39-.24.66-.15.27.1 1.71.81 2 .96.29.15.49.22.56.34.07.12.07.68-.17 1.36Z"/></svg>
          Escríbenos por WhatsApp
        </a>
        <a class="btn btn--outline-white" href={telHref}>Llamar: 990 202 1037</a>
      </div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="foot">
      <p class="foot__name">Oh My Tooth! · Especialistas dentales</p>
      <p class="foot__addr">Plaza Carrillón, Local 17 · Campestre, Mérida, Yucatán</p>
      <p class="foot__contact">
        <a href={telHref}>990 202 1037</a>
        <span aria-hidden="true">·</span>
        <a href={whatsapp} target="_blank" rel="noopener">WhatsApp</a>
        <span aria-hidden="true">·</span>
        <a href={mapsUrl} target="_blank" rel="noopener">Google Maps</a>
      </p>
    </footer>

  </main>

  <style is:global>
    .omt {
      --sky:#3FA9C9;
      --sky-deep:#1F6C88;
      --sky-soft:#DCF1F7;
      --mint:#57C4B8;
      --mint-deep:#2E8C82;
      --mint-soft:#DBF3EF;
      --lav:#8E82CE;
      --lav-deep:#6152A8;
      --lav-soft:#ECE9FB;
      --coral:#FF6F52;
      --coral-deep:#E8492A;
      --coral-soft:#FFE3DB;
      --paper:#F4FBFD;
      --white:#FFFFFF;
      --ink:#213343;
      --ink-soft:#566673;
      --radius:26px;
      --radius-sm:16px;
      --shadow:0 18px 46px -22px rgba(31,108,136,.35);
      --shadow-sm:0 10px 26px -16px rgba(31,108,136,.4);
      --maxw:1120px;
      --pad:clamp(1.15rem, 5vw, 2.4rem);
      font-family:'Nunito Sans', system-ui, -apple-system, sans-serif;
      color:var(--ink);
      background:
        radial-gradient(120% 60% at 12% -8%, var(--sky-soft), transparent 55%),
        radial-gradient(120% 55% at 100% 4%, var(--lav-soft), transparent 50%),
        var(--paper);
      line-height:1.6;
      overflow-x:clip;
    }
    .omt *,.omt *::before,.omt *::after{box-sizing:border-box;}

    .omt h1,.omt h2,.omt h3{font-family:'Fredoka', system-ui, sans-serif;font-weight:600;line-height:1.08;margin:0;letter-spacing:-.01em;}
    .omt p{margin:0;}
    .omt a{color:inherit;}

    .omt .eyebrow{
      font-family:'Fredoka', sans-serif;font-weight:600;
      font-size:.82rem;letter-spacing:.08em;text-transform:uppercase;
      color:var(--sky-deep);margin:0 0 .7rem;
    }
    .omt .eyebrow--center{text-align:center;}
    .omt .h2{font-size:clamp(1.7rem, 5.2vw, 2.6rem);color:var(--ink);}

    .omt .section-head{max-width:640px;margin:0 auto clamp(1.8rem,4vw,2.8rem);text-align:center;}
    .omt .section-head .h2{margin-top:.1rem;}

    /* ---------- buttons ---------- */
    .omt .btn{
      display:inline-flex;align-items:center;justify-content:center;gap:.55rem;
      font-family:'Fredoka', sans-serif;font-weight:600;font-size:1.02rem;
      padding:.85rem 1.4rem;border-radius:999px;text-decoration:none;
      border:2px solid transparent;cursor:pointer;line-height:1.1;
      transition:transform .15s ease, box-shadow .2s ease, background .2s ease;
    }
    .omt .btn .ico{width:1.25em;height:1.25em;fill:currentColor;flex:none;}
    .omt .btn--wa{
      background:linear-gradient(135deg,#FF8A63,var(--coral));
      color:#3a1207;box-shadow:0 12px 26px -12px rgba(232,73,42,.7);
    }
    .omt .btn--wa:hover{transform:translateY(-2px);box-shadow:0 16px 30px -12px rgba(232,73,42,.75);}
    .omt .btn--ghost{
      background:var(--white);color:var(--sky-deep);border-color:#BEE4EE;
      box-shadow:var(--shadow-sm);
    }
    .omt .btn--ghost:hover{transform:translateY(-2px);border-color:var(--sky);}
    .omt .btn--onwhite{color:#3a1207;}
    .omt .btn--outline-white{background:transparent;color:#fff;border-color:rgba(255,255,255,.7);}
    .omt .btn--outline-white:hover{background:rgba(255,255,255,.14);transform:translateY(-2px);}
    .omt a:focus-visible,.omt .btn:focus-visible{outline:3px solid var(--lav);outline-offset:3px;border-radius:6px;}

    /* ---------- sparkles / mascot ---------- */
    .omt .spark{position:absolute;fill:var(--coral);filter:drop-shadow(0 3px 8px rgba(255,111,82,.35));animation:twinkle 3.4s ease-in-out infinite;z-index:1;}
    .omt .spark--a{width:34px;top:12%;left:7%;color:var(--mint);fill:var(--mint);animation-delay:.2s;}
    .omt .spark--b{width:22px;top:22%;right:10%;fill:var(--lav);animation-delay:1.1s;}
    .omt .spark--c{width:28px;bottom:16%;left:14%;fill:var(--coral);animation-delay:1.9s;}
    .omt .spark--d{width:30px;top:14%;right:14%;fill:#fff;animation-delay:.6s;}
    @keyframes twinkle{0%,100%{opacity:.35;transform:scale(.8) rotate(-6deg);}50%{opacity:1;transform:scale(1.08) rotate(6deg);}}

    /* ---------- hero ---------- */
    .omt .hero{position:relative;overflow:hidden;padding:clamp(1.6rem,5vw,3rem) var(--pad) clamp(2.4rem,6vw,4rem);}
    .omt .hero__glow{position:absolute;inset:auto -20% 30% -20%;height:60%;background:radial-gradient(60% 60% at 50% 50%, rgba(87,196,184,.25), transparent 70%);pointer-events:none;}
    .omt .hero__inner{max-width:var(--maxw);margin:0 auto;display:grid;gap:clamp(1.8rem,4vw,3rem);align-items:center;position:relative;z-index:2;}
    .omt .hero__title{
      font-size:clamp(3rem, 13vw, 6rem);font-weight:700;letter-spacing:-.02em;
      margin:.1rem 0 .9rem;position:relative;display:inline-block;
      background:linear-gradient(100deg,var(--sky) 0%, var(--mint) 42%, var(--lav) 100%);
      -webkit-background-clip:text;background-clip:text;color:transparent;
    }
    .omt .hero__spark{display:inline-block;width:.42em;vertical-align:.35em;margin-left:.04em;}
    .omt .hero__spark svg{width:100%;fill:var(--coral);animation:twinkle 2.6s ease-in-out infinite;filter:drop-shadow(0 3px 6px rgba(255,111,82,.4));}
    .omt .hero__lead{font-size:clamp(1.05rem,3.2vw,1.28rem);color:var(--ink);max-width:34ch;margin-bottom:1.3rem;}

    .omt .rating-pill{
      display:inline-flex;align-items:center;gap:.5rem;background:var(--white);
      border:1px solid #CDEAF1;border-radius:999px;padding:.5rem .95rem;
      font-size:.95rem;box-shadow:var(--shadow-sm);margin-bottom:1.5rem;
    }
    .omt .rating-pill__stars{color:#FFB300;letter-spacing:.06em;}
    .omt .rating-pill strong{font-family:'Fredoka',sans-serif;}
    .omt .hero__cta{display:flex;flex-wrap:wrap;gap:.7rem;}

    .omt .hero__photo{position:relative;margin:0;border-radius:var(--radius);overflow:visible;}
    .omt .hero__photo img{border-radius:var(--radius);box-shadow:var(--shadow);width:100%;object-fit:cover;aspect-ratio:3/2;}
    .omt .hero__sticker{
      position:absolute;right:-6px;bottom:-18px;background:var(--white);
      border-radius:18px;padding:.5rem .8rem .5rem .55rem;display:flex;align-items:center;gap:.5rem;
      box-shadow:var(--shadow);border:2px solid var(--sky-soft);
    }
    .omt .hero__sticker-tooth{width:40px;height:40px;display:block;}
    .omt .hero__sticker-tooth svg{width:100%;height:100%;}
    .omt .hero__sticker-txt{font-family:'Fredoka',sans-serif;font-weight:600;color:var(--sky-deep);font-size:1rem;padding-right:.25rem;}

    /* ---------- trust strip ---------- */
    .omt .trust{padding:0 var(--pad);margin:clamp(.5rem,2vw,1rem) 0 clamp(2.5rem,6vw,4rem);}
    .omt .trust__row{
      max-width:var(--maxw);margin:0 auto;list-style:none;padding:1.1rem 1rem;
      background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow-sm);
      border:1px solid #E4F2F6;
      display:grid;grid-template-columns:repeat(2,1fr);gap:1rem .5rem;
    }
    .omt .trust__row li{display:flex;flex-direction:column;align-items:center;text-align:center;gap:.1rem;position:relative;}
    .omt .trust__k{font-family:'Fredoka',sans-serif;font-weight:600;font-size:1.05rem;color:var(--ink);}
    .omt .trust__v{font-size:.82rem;color:var(--ink-soft);}

    /* ---------- about ---------- */
    .omt .about{max-width:760px;margin:0 auto;padding:0 var(--pad) clamp(2.6rem,7vw,4.5rem);text-align:center;position:relative;}
    .omt .about__mascot{width:72px;height:72px;margin:0 auto 1.1rem;background:var(--white);border-radius:22px;box-shadow:var(--shadow-sm);padding:8px;border:2px solid var(--sky-soft);}
    .omt .about__mascot svg{width:100%;height:100%;}
    .omt .about__text{margin-top:1.2rem;display:grid;gap:1rem;font-size:clamp(1.02rem,2.7vw,1.15rem);color:var(--ink-soft);}
    .omt .about__text strong{color:var(--ink);}

    /* ---------- why ---------- */
    .omt .why{max-width:var(--maxw);margin:0 auto;padding:0 var(--pad) clamp(2.6rem,7vw,4.5rem);}
    .omt .why__grid{display:grid;grid-template-columns:1fr;gap:1rem;}
    .omt .card{
      background:var(--white);border-radius:var(--radius);padding:1.5rem 1.4rem;
      box-shadow:var(--shadow-sm);border:1px solid #EAF4F7;position:relative;overflow:hidden;
    }
    .omt .card::before{content:"";position:absolute;left:0;top:0;bottom:0;width:6px;background:var(--sky);}
    .omt .card--sky::before{background:var(--sky);}
    .omt .card--mint::before{background:var(--mint);}
    .omt .card--lav::before{background:var(--lav);}
    .omt .card--coral::before{background:var(--coral);}
    .omt .card__icon{font-size:1.7rem;display:block;margin-bottom:.6rem;}
    .omt .card__title{font-size:1.2rem;margin-bottom:.4rem;color:var(--ink);}
    .omt .card p{color:var(--ink-soft);font-size:.98rem;}

    /* ---------- visit / steps ---------- */
    .omt .visit{max-width:var(--maxw);margin:0 auto;padding:0 var(--pad) clamp(2.6rem,7vw,4.5rem);}
    .omt .steps{list-style:none;padding:0;margin:0;display:grid;grid-template-columns:1fr;gap:1rem;counter-reset:none;}
    .omt .step{
      background:linear-gradient(180deg,var(--white),#FBFEFF);border:1px solid #E7F3F6;
      border-radius:var(--radius);padding:1.5rem 1.4rem;box-shadow:var(--shadow-sm);position:relative;
    }
    .omt .step__n{
      display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;
      border-radius:14px;font-family:'Fredoka',sans-serif;font-weight:700;font-size:1.3rem;color:#fff;
      background:linear-gradient(140deg,var(--sky),var(--mint));margin-bottom:.8rem;
      box-shadow:0 8px 18px -8px rgba(63,169,201,.7);
    }
    .omt .step:nth-child(2) .step__n{background:linear-gradient(140deg,var(--mint),var(--lav));}
    .omt .step:nth-child(3) .step__n{background:linear-gradient(140deg,var(--lav),var(--coral));}
    .omt .step__title{font-size:1.2rem;margin-bottom:.35rem;}
    .omt .step p{color:var(--ink-soft);font-size:.98rem;}

    /* ---------- gallery ---------- */
    .omt .gallery{max-width:var(--maxw);margin:0 auto;padding:0 var(--pad) clamp(2.6rem,7vw,4.5rem);}
    .omt .gallery__grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.8rem;}
    .omt .ga{margin:0;border-radius:var(--radius-sm);overflow:hidden;box-shadow:var(--shadow-sm);background:var(--sky-soft);}
    .omt .ga img{width:100%;height:100%;object-fit:cover;aspect-ratio:4/3;transition:transform .5s ease;}
    .omt .ga--tall img{aspect-ratio:3/4;}
    .omt .ga:hover img{transform:scale(1.04);}

    /* ---------- cta band ---------- */
    .omt .cta-band{padding:0 var(--pad);margin:0 0 clamp(2.6rem,7vw,4.5rem);}
    .omt .cta-band__inner{
      max-width:var(--maxw);margin:0 auto;border-radius:var(--radius);
      background:linear-gradient(120deg,var(--sky),var(--mint));
      color:#fff;padding:clamp(1.6rem,4vw,2.4rem);
      display:flex;flex-direction:column;gap:1.1rem;align-items:flex-start;
      box-shadow:0 20px 44px -22px rgba(46,140,130,.6);
    }
    .omt .cta-band__title{font-size:clamp(1.4rem,4vw,2rem);color:#fff;}
    .omt .cta-band__sub{color:rgba(255,255,255,.92);font-size:1.02rem;}

    /* ---------- reviews ---------- */
    .omt .reviews{max-width:var(--maxw);margin:0 auto;padding:0 var(--pad) clamp(2.6rem,7vw,4.5rem);}
    .omt .reviews__score{margin-top:.7rem;color:var(--ink-soft);}
    .omt .reviews__score span{color:#FFB300;letter-spacing:.05em;}
    .omt .reviews__score strong{font-family:'Fredoka',sans-serif;color:var(--ink);}
    .omt .reviews__wall{columns:1;column-gap:1rem;}
    .omt .review{
      break-inside:avoid;margin:0 0 1rem;background:var(--white);border-radius:var(--radius);
      padding:1.4rem;box-shadow:var(--shadow-sm);border:1px solid #EAF4F7;
    }
    .omt .review__stars{color:#FFB300;letter-spacing:.08em;font-size:.95rem;margin-bottom:.6rem;}
    .omt .review blockquote{margin:0 0 1rem;font-size:1.04rem;color:var(--ink);quotes:none;}
    .omt .review figcaption{display:flex;flex-direction:column;border-top:1px solid #EEF5F7;padding-top:.7rem;}
    .omt .review__author{font-family:'Fredoka',sans-serif;font-weight:600;color:var(--sky-deep);}
    .omt .review__when{font-size:.82rem;color:var(--ink-soft);}
    .omt .reviews__more{text-align:center;margin-top:.6rem;}

    /* ---------- team ---------- */
    .omt .team{padding:0 var(--pad);margin:0 0 clamp(2.6rem,7vw,4.5rem);}
    .omt .team__inner{
      max-width:760px;margin:0 auto;text-align:center;background:var(--lav-soft);
      border-radius:var(--radius);padding:clamp(1.8rem,5vw,2.8rem);border:1px solid #E0DAF6;
    }
    .omt .team__lead{margin-top:.9rem;color:var(--ink-soft);font-size:clamp(1.02rem,2.7vw,1.14rem);}
    .omt .team__lead strong{color:var(--lav-deep);}
    .omt .team__chips{display:flex;flex-wrap:wrap;gap:.6rem;justify-content:center;margin-top:1.3rem;}
    .omt .chip{
      background:var(--white);border-radius:999px;padding:.55rem 1.1rem;
      font-family:'Fredoka',sans-serif;font-weight:600;color:var(--lav-deep);
      box-shadow:var(--shadow-sm);border:1px solid #E0DAF6;
    }

    /* ---------- place ---------- */
    .omt .place{max-width:var(--maxw);margin:0 auto;padding:0 var(--pad) clamp(2.6rem,7vw,4.5rem);}
    .omt .place__grid{display:grid;grid-template-columns:1fr;gap:1.2rem;}
    .omt .place__info{background:var(--white);border-radius:var(--radius);padding:1.6rem 1.5rem;box-shadow:var(--shadow-sm);border:1px solid #EAF4F7;display:grid;gap:1.4rem;}
    .omt .place__block h3{margin-bottom:.35rem;}
    .omt .place__k{font-family:'Fredoka',sans-serif;font-weight:600;font-size:.95rem;letter-spacing:.04em;text-transform:uppercase;color:var(--sky-deep);}
    .omt .place__block p{color:var(--ink);}
    .omt .place__note{color:var(--ink-soft);font-size:.9rem;margin-bottom:.5rem;}
    .omt .link{color:var(--sky-deep);font-weight:700;text-decoration:none;border-bottom:2px solid var(--sky-soft);}
    .omt .link:hover{border-color:var(--sky);}
    .omt .hours{width:100%;border-collapse:collapse;font-size:.95rem;}
    .omt .hours th,.omt .hours td{text-align:left;padding:.42rem 0;border-bottom:1px solid #EFF6F8;}
    .omt .hours th{font-weight:700;color:var(--ink);width:38%;}
    .omt .hours td{color:var(--ink-soft);}
    .omt .hours tr:last-child th,.omt .hours tr:last-child td{border-bottom:none;}
    .omt .place__map{border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-sm);border:1px solid #EAF4F7;min-height:300px;}
    .omt .place__map iframe{width:100%;height:100%;min-height:320px;border:0;display:block;}

    /* ---------- final cta ---------- */
    .omt .final{position:relative;overflow:hidden;text-align:center;margin:0 var(--pad);border-radius:32px;
      background:linear-gradient(150deg,var(--lav) 0%, var(--sky) 55%, var(--mint) 100%);
      color:#fff;padding:clamp(2.6rem,8vw,4.5rem) clamp(1.2rem,5vw,2.5rem);}
    .omt .final__tooth{width:72px;height:72px;display:inline-block;margin-bottom:1rem;background:rgba(255,255,255,.16);border-radius:22px;padding:9px;}
    .omt .final__tooth svg{width:100%;height:100%;}
    .omt .final__title{font-size:clamp(1.7rem,5.5vw,2.7rem);color:#fff;max-width:16ch;margin:0 auto .7rem;}
    .omt .final__sub{color:rgba(255,255,255,.94);max-width:44ch;margin:0 auto 1.6rem;font-size:1.05rem;}
    .omt .final__cta{display:flex;flex-wrap:wrap;gap:.7rem;justify-content:center;}

    /* ---------- footer ---------- */
    .omt .foot{text-align:center;padding:2.2rem var(--pad) 92px;color:var(--ink-soft);}
    .omt .foot__name{font-family:'Fredoka',sans-serif;font-weight:600;color:var(--ink);font-size:1.1rem;}
    .omt .foot__addr{font-size:.92rem;margin-top:.3rem;}
    .omt .foot__contact{margin-top:.7rem;display:flex;gap:.6rem;justify-content:center;flex-wrap:wrap;align-items:center;font-size:.95rem;}
    .omt .foot__contact a{color:var(--sky-deep);font-weight:700;text-decoration:none;}
    .omt .foot__contact a:hover{text-decoration:underline;}

    /* ---------- reveal (progressive enhancement) ---------- */
    .omt.js .reveal{opacity:0;transform:translateY(22px);transition:opacity .7s ease, transform .7s ease;}
    .omt.js .reveal.is-in{opacity:1;transform:none;}

    /* ---------- responsive ---------- */
    @media (min-width:720px){
      .omt .trust__row{grid-template-columns:repeat(5,1fr);}
      .omt .trust__row li:not(:last-child)::after{content:"";position:absolute;right:-.25rem;top:15%;height:70%;width:1px;background:#E4F0F3;}
      .omt .why__grid{grid-template-columns:repeat(2,1fr);}
      .omt .steps{grid-template-columns:repeat(3,1fr);}
      .omt .reviews__wall{columns:2;}
      .omt .cta-band__inner{flex-direction:row;align-items:center;justify-content:space-between;}
      .omt .cta-band__inner .btn{flex:none;}
    }
    @media (min-width:960px){
      .omt .hero__inner{grid-template-columns:1.05fr .95fr;}
      .omt .why__grid{grid-template-columns:repeat(4,1fr);}
      .omt .reviews__wall{columns:3;}
      .omt .place__grid{grid-template-columns:1fr 1fr;}
      .omt .gallery__grid{grid-template-columns:repeat(3,1fr);grid-auto-rows:1fr;}
      .omt .ga--tall{grid-row:span 2;}
      .omt .ga--tall img{aspect-ratio:auto;height:100%;}
      .omt .ga--wide{grid-column:span 2;}
      .omt .ga--wide img{aspect-ratio:16/7;}
    }
    @media (prefers-reduced-motion:reduce){
      .omt .spark,.omt .hero__spark svg{animation:none;}
      .omt.js .reveal{opacity:1;transform:none;transition:none;}
    }
  </style>

  <script is:inline>
    (function () {
      var root = document.querySelector('.omt');
      if (!root) return;
      root.classList.add('js');
      var els = root.querySelectorAll('.reveal');
      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach(function (el) { el.classList.add('is-in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
        });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
      els.forEach(function (el) { io.observe(el); });
    })();
  </script>
</BaseLayout>
