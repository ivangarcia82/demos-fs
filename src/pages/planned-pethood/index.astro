---
import BaseLayout from '../../layouts/BaseLayout.astro';

const nombre = 'Planned Pethood';
const slug = 'planned-pethood';
const direccion = 'Por 3 y 3c 344, Carr. Mérida - Progreso, Gonzalo Guerrero, 97119 Mérida, Yuc., México';
const telefono = '999 944 2310';
const whatsapp = 'https://wa.me/529999442310';
const mapsUrl = 'https://maps.google.com/?cid=5038248911605334616&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA';
const rating = '4.6';
const totalResenas = '1,147';

const waMsg = 'Hola, vi su página web y me gustaría agendar una consulta para mi mascota.';
const waLink = `${whatsapp}?text=${encodeURIComponent(waMsg)}`;
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(direccion)}&output=embed`;
const telHref = `tel:+52${telefono.replace(/\s/g, '')}`;

const horarios = [
  { d: 'Lunes', h: '9:00 – 21:00' },
  { d: 'Martes', h: '9:00 – 21:00' },
  { d: 'Miércoles', h: '9:00 – 21:00' },
  { d: 'Jueves', h: '9:00 – 21:00' },
  { d: 'Viernes', h: '9:00 – 21:00' },
  { d: 'Sábado', h: '9:00 – 16:00' },
  { d: 'Domingo', h: 'Cerrado' },
];
---
<BaseLayout
  title="Planned Pethood — Veterinaria en Mérida"
  description="Medicina veterinaria accesible y con trato humano en Mérida. ⭐ 4.6 · 1,147 reseñas. Esterilización, cirugía, consultas, oncología y farmacia."
  slug="planned-pethood"
  ogImage="/planned-pethood/img/foto_1.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700;800&family=Work+Sans:wght@400;500;600&display=swap"
  favicon="🐾"
  themeColor="#123D2C"
  whatsapp={whatsapp}
  telefono={telefono}
  mapsUrl={mapsUrl}
>
  <!-- ============ HERO ============ -->
  <header class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="wrap hero-in">
      <span class="eyebrow">
        <svg class="duo" viewBox="0 0 88 44" aria-hidden="true">
          <ellipse cx="22" cy="24" rx="5" ry="11" transform="rotate(22 22 24)"/>
          <ellipse cx="40" cy="24" rx="5" ry="11" transform="rotate(-22 40 24)"/>
          <circle cx="31" cy="27" r="11"/>
          <path d="M62 8 L66 26 L74 20 Z"/>
          <path d="M84 8 L80 26 L72 20 Z"/>
          <circle cx="73" cy="30" r="11"/>
        </svg>
        Clínica veterinaria · Mérida, Yucatán
      </span>

      <h1>Cuidamos a tu perro y a tu gato como de la familia.</h1>
      <p class="hero-sub">
        Medicina veterinaria cercana y accesible, con trato humano y
        explicaciones claras. <strong>Piensa globalmente, actúa localmente.</strong>
      </p>

      <div class="rating-chip">
        <span class="stars" aria-hidden="true">★★★★★</span>
        <span class="rate-num">{rating}</span>
        <span class="rate-txt">{totalResenas} reseñas en Google</span>
      </div>

      <div class="cta-row">
        <a class="btn btn-wa" href={waLink}>
          <svg viewBox="0 0 24 24" aria-hidden="true" class="i-wa"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 1.67c2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.24 8.24a8.2 8.2 0 0 1-4.19-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.24-8.24zm-2.9 4.44c-.14 0-.36.05-.55.26-.19.21-.72.7-.72 1.71s.74 1.99.84 2.12c.1.14 1.43 2.29 3.55 3.12 1.76.69 2.12.55 2.5.52.38-.03 1.23-.5 1.4-.99.17-.48.17-.9.12-.99-.05-.09-.19-.14-.4-.24-.21-.1-1.23-.61-1.42-.68-.19-.07-.33-.1-.47.1-.14.21-.54.68-.66.82-.12.14-.24.16-.45.05-.21-.1-.88-.32-1.68-1.03-.62-.55-1.04-1.24-1.16-1.45-.12-.21-.01-.32.09-.42.09-.09.21-.24.31-.36.1-.12.14-.21.21-.35.07-.14.03-.26-.02-.36-.05-.1-.46-1.12-.63-1.53-.17-.4-.34-.35-.47-.36l-.4-.01z"/></svg>
          Escríbenos por WhatsApp
        </a>
        <a class="btn btn-ghost" href={mapsUrl}>Cómo llegar</a>
      </div>
    </div>

    <figure class="hero-photo">
      <img src="/planned-pethood/img/foto_1.jpg" width="1280" height="960"
           alt="Carnets veterinarios de Planned Pethood México sobre la mesa de la clínica" fetchpriority="high" />
      <figcaption>Cada paciente lleva su propio carnet veterinario.</figcaption>
    </figure>
  </header>

  <!-- ============ FRANJA DE CONFIANZA ============ -->
  <section class="strip" aria-label="Datos de la clínica">
    <div class="wrap strip-grid">
      <div class="stat">
        <span class="stat-num">{rating}<span class="star">★</span></span>
        <span class="stat-lab">Calificación en Google</span>
      </div>
      <div class="stat">
        <span class="stat-num">{totalResenas}</span>
        <span class="stat-lab">Reseñas de clientes</span>
      </div>
      <div class="stat">
        <span class="stat-num">21<span class="unit">h</span></span>
        <span class="stat-lab">Abierto hasta, entre semana</span>
      </div>
      <div class="stat">
        <span class="stat-num">🐶🐱</span>
        <span class="stat-lab">Perros y gatos</span>
      </div>
    </div>
  </section>

  <!-- ============ QUIÉNES SOMOS ============ -->
  <section class="about" id="nosotros">
    <div class="wrap about-grid">
      <div class="about-text reveal">
        <span class="kicker">Quiénes somos</span>
        <h2>Una clínica de barrio, con corazón y criterio.</h2>
        <p>
          En <strong>Planned Pethood</strong> abrimos las puertas todos los días para
          atender a las mascotas de la carretera Mérida–Progreso y de toda la ciudad.
          Somos parte de la red Planned Pethood México, y esa idea de
          <em>“piensa globalmente, actúa localmente”</em> es la que guía nuestro trabajo:
          medicina de calidad, al alcance de las familias de aquí.
        </p>
        <p>
          Nuestros clientes lo repiten en cada reseña: un <strong>trato humano y amable</strong>,
          doctores que explican las veces que haga falta y que son conscientes del lado
          económico de cada paciente. Contamos con consultorio, quirófano, farmacia y
          alimento, todo en instalaciones cómodas para que tú y tu compañero se sientan
          en confianza.
        </p>
        <a class="text-link" href={mapsUrl}>Ver la clínica en Google Maps →</a>
      </div>
      <figure class="about-photo reveal">
        <img src="/planned-pethood/img/foto_5.jpg" width="675" height="1200" loading="lazy"
             alt="Carnet veterinario con el logo de Planned Pethood México" />
      </figure>
    </div>
  </section>

  <!-- ============ EQUIPO / DOCTORES ============ -->
  <section class="team">
    <div class="wrap">
      <span class="kicker center">Con quién te atiendes</span>
      <h2 class="center">Doctores que los clientes nombran por su nombre</h2>
      <p class="lead center">
        No es casualidad que en las reseñas aparezcan una y otra vez los mismos doctores:
        la gente vuelve por el trato que recibe.
      </p>
      <div class="team-grid">
        <article class="doc reveal">
          <div class="doc-avatar" aria-hidden="true">RC</div>
          <h3>Dr. Ricardo Castrejón</h3>
          <p class="doc-role">Consulta y cirugía · oncología</p>
          <p class="doc-quote">
            “En todo momento el trato fue muy humano y amable. Explicando las veces que
            sean necesarias el procedimiento y los costos.”
          </p>
          <span class="doc-cite">— Daniel Franco</span>
        </article>
        <article class="doc reveal">
          <div class="doc-avatar" aria-hidden="true">A</div>
          <h3>Dr. Alberto</h3>
          <p class="doc-role">Consulta general · oftalmología</p>
          <p class="doc-quote">
            “Me explicó todo muy bien y revisó a mi gatita, excelente. No tengo ningún
            problema con ello.”
          </p>
          <span class="doc-cite">— Lia Herrera</span>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ SERVICIOS ============ -->
  <section class="services" id="servicios">
    <div class="wrap">
      <span class="kicker center">Qué hacemos</span>
      <h2 class="center">Todo lo que tu mascota necesita, en un solo lugar</h2>
      <ul class="svc-grid">
        <li class="svc reveal">
          <span class="svc-ico" aria-hidden="true">🩺</span>
          <h3>Consulta general</h3>
          <p>Revisiones y diagnóstico para perros y gatos, con explicación clara de cada paso.</p>
        </li>
        <li class="svc reveal">
          <span class="svc-ico" aria-hidden="true">✂️</span>
          <h3>Esterilización</h3>
          <p>Cirugías cuidadas: tus mascotas se recuperan “como si no les hubieran hecho nada”.</p>
        </li>
        <li class="svc reveal">
          <span class="svc-ico" aria-hidden="true">🏥</span>
          <h3>Cirugía y oncología</h3>
          <p>Procedimientos quirúrgicos con el Dr. Ricardo, especialista en oncología.</p>
        </li>
        <li class="svc reveal">
          <span class="svc-ico" aria-hidden="true">👁️</span>
          <h3>Oftalmología</h3>
          <p>Atención a problemas de ojos y otras revisiones especializadas.</p>
        </li>
        <li class="svc reveal">
          <span class="svc-ico" aria-hidden="true">🔁</span>
          <h3>Seguimiento post-operatorio</h3>
          <p>Damos seguimiento a la recuperación, sin costos escondidos ni prisas.</p>
        </li>
        <li class="svc reveal">
          <span class="svc-ico" aria-hidden="true">💊</span>
          <h3>Farmacia y alimento</h3>
          <p>Medicamentos, accesorios y alimento de marca para completar tu visita.</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- ============ DIFERENCIADORES ============ -->
  <section class="why">
    <div class="wrap">
      <span class="kicker center light">Por qué nos eligen</span>
      <h2 class="center light">Lo que nuestros clientes destacan</h2>
      <div class="why-grid">
        <div class="why-item reveal">
          <span class="why-mark" aria-hidden="true">$</span>
          <h3>Precios accesibles</h3>
          <p>“A un precio increíble.” Somos conscientes del aspecto económico de cada familia.</p>
        </div>
        <div class="why-item reveal">
          <span class="why-mark" aria-hidden="true">♥</span>
          <h3>Trato humano</h3>
          <p>Doctores amables que despejan tus dudas y te devuelven la tranquilidad.</p>
        </div>
        <div class="why-item reveal">
          <span class="why-mark" aria-hidden="true">✓</span>
          <h3>Explicaciones claras</h3>
          <p>Te explican el procedimiento y los costos las veces que haga falta.</p>
        </div>
        <div class="why-item reveal">
          <span class="why-mark" aria-hidden="true">⏱</span>
          <h3>Horario amplio</h3>
          <p>Abierto de lunes a viernes hasta las 9 de la noche, y sábados por la mañana.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA INTERMEDIO ============ -->
  <section class="cta-band">
    <div class="wrap cta-band-in">
      <p class="cta-band-txt">¿Tu mascota necesita una revisión? Estamos a un mensaje de distancia.</p>
      <a class="btn btn-sol" href={waLink}>Agendar por WhatsApp</a>
    </div>
  </section>

  <!-- ============ PRUEBA SOCIAL ============ -->
  <section class="social" id="resenas">
    <div class="wrap">
      <div class="social-head">
        <span class="kicker">Lo que dicen de nosotros</span>
        <div class="social-score">
          <span class="score-num">{rating}</span>
          <div class="score-meta">
            <span class="score-stars" aria-hidden="true">★★★★★</span>
            <span class="score-count">{totalResenas} reseñas reales en Google</span>
          </div>
        </div>
      </div>

      <div class="reviews">
        <blockquote class="review reveal">
          <p>“Hoy llevé a esterilizar a mis gatitos (Maka y Thiago), salieron de la clínica
            como si no les hubieran hecho nada, en excelente estado, y a un precio
            increíble…”</p>
          <footer><span class="rev-name">Eva Valdez Olguín</span><span class="rev-when">Hace 4 meses</span></footer>
        </blockquote>

        <blockquote class="review reveal">
          <p>“Excelente atención para mi perrito Rocco, es un chow chow que el Dr. Ricardo
            Castrejón atendió y no puedo más que súper recomendarlo; su trato, atención, la
            explicación… despejó mis dudas y me devolvió la tranquilidad…”</p>
          <footer><span class="rev-name">Fabiola Chuc</span><span class="rev-when">Hace 3 meses</span></footer>
        </blockquote>

        <blockquote class="review reveal">
          <p>“Muy agradecida con todos los doctores. Que siempre con su profesionalismo y
            trato cálido me han ayudado a resolver muchas situaciones con mi manada y más.”</p>
          <footer><span class="rev-name">Gianina Manzur</span><span class="rev-when">Hace 3 meses</span></footer>
        </blockquote>
      </div>

      <a class="text-link center-link" href={mapsUrl}>Leer más reseñas en Google →</a>
    </div>
  </section>

  <!-- ============ MISIÓN / LABOR ============ -->
  <section class="mission">
    <div class="wrap mission-grid">
      <figure class="mission-photo reveal">
        <img src="/planned-pethood/img/foto_4.jpg" width="720" height="960" loading="lazy"
             alt="Perro rescatado recibiendo cuidados sobre la mesa de la clínica" />
      </figure>
      <div class="mission-text reveal">
        <span class="kicker">Actúa localmente</span>
        <h2>Cada animal que llega recibe atención, sin importar su historia.</h2>
        <p>
          Parte de lo que somos está en las mascotas que más lo necesitan. Aquí llegan
          animales en situaciones difíciles y salen adelante gracias al cuidado del equipo
          y a un costo que las familias sí pueden pagar.
        </p>
        <p>
          Es lo mismo que buscamos para tu compañero: medicina seria, hecha con cariño,
          pensada para tu comunidad.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ GALERÍA ============ -->
  <section class="gallery">
    <div class="wrap">
      <span class="kicker center">Nuestras instalaciones</span>
      <h2 class="center">Un espacio limpio, cómodo y bien equipado</h2>
      <div class="gal-grid">
        <figure class="gal-a reveal">
          <img src="/planned-pethood/img/foto_2.jpg" width="900" height="1200" loading="lazy"
               alt="Consultorio de Planned Pethood con mesa de acero inoxidable" />
        </figure>
        <figure class="gal-b reveal">
          <img src="/planned-pethood/img/foto_3.jpg" width="900" height="1200" loading="lazy"
               alt="Área de farmacia y alimento con el personal atendiendo" />
        </figure>
        <figure class="gal-c reveal">
          <img src="/planned-pethood/img/foto_1.jpg" width="1280" height="960" loading="lazy"
               alt="Carnets veterinarios de Planned Pethood México" />
        </figure>
      </div>
    </div>
  </section>

  <!-- ============ UBICACIÓN Y HORARIOS ============ -->
  <section class="location" id="ubicacion">
    <div class="wrap loc-grid">
      <div class="loc-info reveal">
        <span class="kicker">Dónde estamos</span>
        <h2>Sobre la carretera Mérida–Progreso</h2>
        <p class="addr">{direccion}</p>
        <div class="loc-actions">
          <a class="btn btn-wa" href={waLink}>WhatsApp</a>
          <a class="btn btn-ghost" href={mapsUrl}>Abrir en Maps</a>
        </div>

        <h3 class="hours-title">Horarios</h3>
        <table class="hours">
          <tbody>
            {horarios.map((row) => (
              <tr class={row.h === 'Cerrado' ? 'closed' : ''}>
                <th scope="row">{row.d}</th>
                <td>{row.h}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="loc-map reveal">
        <iframe
          title="Mapa de Planned Pethood en Mérida"
          src={mapSrc}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="faq">
    <div class="wrap">
      <span class="kicker center">Preguntas frecuentes</span>
      <h2 class="center">Antes de tu visita</h2>
      <div class="faq-list">
        <details class="reveal">
          <summary>¿Atienden perros y gatos?</summary>
          <p>Sí. Atendemos tanto a perros como a gatos, de todas las edades y tamaños.</p>
        </details>
        <details class="reveal">
          <summary>¿Hacen esterilizaciones?</summary>
          <p>Sí, es uno de nuestros servicios. Cuidamos cada cirugía para que tu mascota se
            recupere pronto y en buen estado.</p>
        </details>
        <details class="reveal">
          <summary>¿Tienen farmacia y alimento?</summary>
          <p>Sí. Dentro de la clínica encuentras medicamentos, accesorios y alimento de marca
            para llevar todo en una sola visita.</p>
        </details>
        <details class="reveal">
          <summary>¿Cuál es su horario?</summary>
          <p>De lunes a viernes de 9:00 a 21:00, sábados de 9:00 a 16:00. Domingos cerrado.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ============ CTA FINAL ============ -->
  <section class="final">
    <div class="wrap final-in">
      <svg class="final-heart" viewBox="0 0 100 100" aria-hidden="true">
        <path d="M50 82 C 20 58, 14 40, 26 30 C 36 22, 48 30, 50 38 C 52 30, 64 22, 74 30 C 86 40, 80 58, 50 82 Z"/>
      </svg>
      <h2>La salud de tu mascota empieza con un mensaje.</h2>
      <p>Escríbenos por WhatsApp y con gusto agendamos su consulta.</p>
      <a class="btn btn-sol big" href={waLink}>Escribir por WhatsApp</a>
      <a class="tel-link" href={telHref}>o llámanos al {telefono}</a>
    </div>
  </section>

  <footer class="foot">
    <div class="wrap foot-in">
      <div class="foot-brand">
        <svg class="duo small" viewBox="0 0 88 44" aria-hidden="true">
          <ellipse cx="22" cy="24" rx="5" ry="11" transform="rotate(22 22 24)"/>
          <ellipse cx="40" cy="24" rx="5" ry="11" transform="rotate(-22 40 24)"/>
          <circle cx="31" cy="27" r="11"/>
          <path d="M62 8 L66 26 L74 20 Z"/>
          <path d="M84 8 L80 26 L72 20 Z"/>
          <circle cx="73" cy="30" r="11"/>
        </svg>
        <strong>Planned Pethood</strong>
      </div>
      <p class="foot-addr">{direccion}</p>
      <p class="foot-contact">
        <a href={telHref}>{telefono}</a>
        <span aria-hidden="true"> · </span>
        <a href={mapsUrl}>Google Maps</a>
      </p>
      <p class="foot-slogan">Piensa globalmente, actúa localmente.</p>
    </div>
  </footer>

  <style is:global>
    /* ====== Tokens ====== */
    :root {
      --crema: #FBF3E3;
      --marfil: #FFFDF6;
      --bosque: #123D2C;
      --esmeralda: #17714B;
      --esmeralda-2: #0E5E3C;
      --sol: #F4B72A;
      --sol-suave: #FBE3A0;
      --tinta: #26382E;
      --hoja: #E7F0E3;
      --hoja-2: #D5E7CF;
      --linea: rgba(18, 61, 44, 0.12);
    }

    body {
      background: var(--crema);
      color: var(--tinta);
      font-family: 'Work Sans', system-ui, sans-serif;
      font-size: 17px;
      line-height: 1.62;
      -webkit-font-smoothing: antialiased;
    }
    .wrap { width: 100%; max-width: 1080px; margin: 0 auto; padding: 0 22px; }

    h1, h2, h3 {
      font-family: 'Poppins', system-ui, sans-serif;
      color: var(--bosque);
      line-height: 1.12;
      letter-spacing: -0.015em;
      margin: 0;
    }
    h1 { font-weight: 800; font-size: clamp(2rem, 8.4vw, 3.4rem); }
    h2 { font-weight: 700; font-size: clamp(1.55rem, 5.6vw, 2.4rem); }
    h3 { font-weight: 700; font-size: 1.16rem; }
    p { margin: 0 0 1rem; }
    strong { color: var(--bosque); font-weight: 600; }
    em { font-style: italic; color: var(--esmeralda-2); }

    .kicker {
      display: inline-block;
      font-family: 'Poppins', sans-serif;
      font-weight: 700;
      font-size: 0.74rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--esmeralda);
      margin-bottom: 0.7rem;
    }
    .kicker::before { content: '🐾 '; }
    .kicker.center, h2.center, .lead.center { display: block; text-align: center; }
    .kicker.center { margin-left: auto; margin-right: auto; }
    .kicker.light { color: var(--sol); }
    h2.center { margin-left: auto; margin-right: auto; max-width: 20ch; }
    h2.light, .light { color: var(--marfil) !important; }
    .lead { max-width: 46ch; margin: 0.5rem auto 0; color: color-mix(in srgb, var(--tinta) 82%, transparent); }

    /* ====== Buttons ====== */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
      font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 1rem;
      text-decoration: none; border-radius: 999px; padding: 0.85rem 1.5rem;
      border: 2px solid transparent; cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    }
    .btn:active { transform: translateY(1px); }
    .btn-wa { background: var(--esmeralda); color: #fff; box-shadow: 0 8px 20px -8px rgba(23,113,75,0.7); }
    .btn-wa:hover { background: var(--esmeralda-2); box-shadow: 0 12px 26px -8px rgba(23,113,75,0.75); }
    .btn-wa .i-wa { width: 20px; height: 20px; fill: #fff; }
    .btn-ghost { background: transparent; color: var(--bosque); border-color: var(--linea); }
    .btn-ghost:hover { border-color: var(--esmeralda); background: var(--hoja); }
    .btn-sol { background: var(--sol); color: var(--bosque); box-shadow: 0 8px 20px -8px rgba(244,183,42,0.75); }
    .btn-sol:hover { background: #f6c651; box-shadow: 0 12px 26px -8px rgba(244,183,42,0.8); }
    .btn.big { padding: 1rem 2rem; font-size: 1.08rem; }

    a:focus-visible, .btn:focus-visible, summary:focus-visible {
      outline: 3px solid var(--esmeralda); outline-offset: 3px; border-radius: 8px;
    }

    .text-link {
      font-family: 'Poppins', sans-serif; font-weight: 600; color: var(--esmeralda-2);
      text-decoration: none; border-bottom: 2px solid var(--sol); padding-bottom: 2px;
    }
    .text-link:hover { color: var(--bosque); }
    .center-link { display: block; text-align: center; width: fit-content; margin: 2rem auto 0; }

    /* silueta duo (perro + gato) */
    .duo { width: 62px; height: 31px; fill: var(--esmeralda); vertical-align: middle; margin-right: 8px; }
    .duo.small { width: 48px; height: 24px; fill: var(--sol); }

    /* ====== Hero ====== */
    .hero { position: relative; overflow: hidden; padding: 2.4rem 0 0; }
    .hero-glow {
      position: absolute; inset: -30% -20% auto -20%; height: 620px; z-index: 0;
      background:
        radial-gradient(60% 55% at 78% 12%, rgba(244,183,42,0.28), transparent 70%),
        radial-gradient(70% 60% at 12% 0%, rgba(23,113,75,0.16), transparent 72%);
      pointer-events: none;
    }
    .hero-in { position: relative; z-index: 1; text-align: center; padding-top: 0.6rem; }
    .eyebrow {
      display: inline-flex; align-items: center; gap: 2px; flex-wrap: wrap; justify-content: center;
      font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 0.82rem;
      color: var(--esmeralda-2); background: var(--marfil);
      border: 1px solid var(--linea); border-radius: 999px; padding: 0.4rem 1rem 0.4rem 0.6rem;
      box-shadow: 0 6px 16px -12px rgba(18,61,44,0.5);
    }
    .hero h1 { margin: 1.1rem auto 0; max-width: 15ch; }
    .hero-sub { max-width: 40ch; margin: 1rem auto 0; font-size: 1.1rem; }
    .hero-sub strong { color: var(--esmeralda-2); }

    .rating-chip {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--bosque); color: var(--marfil);
      border-radius: 999px; padding: 0.5rem 1.1rem; margin: 1.4rem auto 0;
      font-family: 'Poppins', sans-serif;
    }
    .rating-chip .stars { color: var(--sol); letter-spacing: 1px; font-size: 0.9rem; }
    .rating-chip .rate-num { font-weight: 800; font-size: 1.05rem; }
    .rating-chip .rate-txt { font-weight: 500; font-size: 0.85rem; opacity: 0.9; }

    .cta-row { display: flex; flex-wrap: wrap; gap: 0.7rem; justify-content: center; margin-top: 1.5rem; }

    .hero-photo { margin: 2.4rem 0 0; }
    .hero-photo img {
      width: 100%; height: clamp(230px, 56vw, 460px); object-fit: cover;
      border-radius: 22px 22px 0 0; box-shadow: 0 -1px 0 var(--linea);
    }
    .hero-photo figcaption {
      background: var(--bosque); color: var(--sol-suave); text-align: center;
      font-family: 'Poppins', sans-serif; font-size: 0.82rem; font-weight: 500;
      padding: 0.7rem; border-radius: 0 0 22px 22px;
    }

    /* ====== Strip ====== */
    .strip { background: var(--bosque); }
    .strip-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
      padding: 0; background: rgba(255,255,255,0.08);
    }
    .stat { background: var(--bosque); text-align: center; padding: 1.5rem 0.8rem; }
    .stat-num {
      display: block; font-family: 'Poppins', sans-serif; font-weight: 800;
      font-size: 1.9rem; color: var(--marfil); line-height: 1;
    }
    .stat-num .star { color: var(--sol); font-size: 1.2rem; }
    .stat-num .unit { color: var(--sol); font-size: 1.1rem; }
    .stat-lab {
      display: block; margin-top: 0.5rem; font-size: 0.8rem;
      color: color-mix(in srgb, var(--marfil) 74%, transparent); line-height: 1.35;
    }

    /* ====== Sections base ====== */
    section { padding: 3.6rem 0; }
    .about, .team, .services, .why, .social, .mission, .gallery, .location, .faq, .final { position: relative; }

    /* About */
    .about-grid { display: grid; gap: 2rem; align-items: center; }
    .about-photo img { width: 100%; border-radius: 20px; box-shadow: 0 24px 50px -28px rgba(18,61,44,0.45); }
    .about-photo { margin: 0; max-width: 360px; }

    /* Team */
    .team { background: var(--hoja); border-radius: 32px; margin: 0 12px; }
    .team-grid { display: grid; gap: 1.2rem; margin-top: 2rem; }
    .doc {
      background: var(--marfil); border-radius: 20px; padding: 1.6rem;
      border: 1px solid var(--linea); box-shadow: 0 14px 30px -26px rgba(18,61,44,0.5);
    }
    .doc-avatar {
      width: 52px; height: 52px; border-radius: 14px; display: grid; place-items: center;
      background: var(--esmeralda); color: #fff; font-family: 'Poppins', sans-serif;
      font-weight: 800; font-size: 1.1rem; margin-bottom: 0.9rem;
    }
    .doc h3 { margin-bottom: 0.15rem; }
    .doc-role { font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 0.82rem; color: var(--esmeralda-2); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.9rem; }
    .doc-quote { font-style: italic; margin-bottom: 0.6rem; }
    .doc-cite { font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 0.85rem; color: var(--bosque); }

    /* Services */
    .svc-grid { list-style: none; padding: 0; margin: 2.2rem 0 0; display: grid; grid-template-columns: 1fr; gap: 1rem; }
    .svc {
      background: var(--marfil); border: 1px solid var(--linea); border-radius: 18px;
      padding: 1.4rem 1.5rem; display: grid; grid-template-columns: auto 1fr; gap: 0.4rem 1rem;
      align-items: start; transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .svc:hover { transform: translateY(-3px); box-shadow: 0 18px 34px -26px rgba(18,61,44,0.5); }
    .svc-ico {
      grid-row: span 2; width: 48px; height: 48px; border-radius: 14px; display: grid; place-items: center;
      background: var(--hoja); font-size: 1.5rem; border: 1px solid var(--linea);
    }
    .svc h3 { align-self: center; }
    .svc p { margin: 0; font-size: 0.95rem; }

    /* Why */
    .why { background: var(--esmeralda-2); border-radius: 32px; margin: 0 12px; color: var(--marfil); }
    .why h2, .why h3 { color: var(--marfil); }
    .why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-top: 2.2rem; }
    .why-item { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.16); border-radius: 18px; padding: 1.3rem; }
    .why-mark {
      display: grid; place-items: center; width: 42px; height: 42px; border-radius: 50%;
      background: var(--sol); color: var(--bosque); font-family: 'Poppins', sans-serif;
      font-weight: 800; font-size: 1.2rem; margin-bottom: 0.8rem;
    }
    .why-item p { color: color-mix(in srgb, var(--marfil) 85%, transparent); font-size: 0.94rem; margin: 0.3rem 0 0; }

    /* CTA band */
    .cta-band { background: var(--sol); padding: 2.4rem 0; }
    .cta-band-in { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1.1rem; }
    .cta-band-txt { font-family: 'Poppins', sans-serif; font-weight: 700; font-size: clamp(1.15rem, 4.4vw, 1.6rem); color: var(--bosque); margin: 0; max-width: 22ch; }
    .cta-band .btn-sol { background: var(--bosque); color: var(--marfil); }
    .cta-band .btn-sol:hover { background: #0c2d20; }

    /* Social */
    .social-head { text-align: center; }
    .social-score { display: inline-flex; align-items: center; gap: 1rem; margin-top: 0.6rem; }
    .score-num { font-family: 'Poppins', sans-serif; font-weight: 800; font-size: 3.6rem; color: var(--esmeralda); line-height: 1; }
    .score-meta { text-align: left; }
    .score-stars { display: block; color: var(--sol); font-size: 1.3rem; letter-spacing: 2px; }
    .score-count { font-size: 0.9rem; color: color-mix(in srgb, var(--tinta) 78%, transparent); }
    .reviews { display: grid; gap: 1.1rem; margin-top: 2.4rem; }
    .review {
      margin: 0; background: var(--marfil); border: 1px solid var(--linea);
      border-left: 4px solid var(--sol); border-radius: 14px; padding: 1.5rem 1.6rem;
      box-shadow: 0 14px 30px -28px rgba(18,61,44,0.5);
    }
    .review p { font-size: 1.02rem; color: var(--bosque); margin: 0 0 1rem; }
    .review footer { display: flex; flex-direction: column; }
    .rev-name { font-family: 'Poppins', sans-serif; font-weight: 700; color: var(--bosque); font-size: 0.95rem; }
    .rev-when { font-size: 0.82rem; color: color-mix(in srgb, var(--tinta) 65%, transparent); }

    /* Mission */
    .mission-grid { display: grid; gap: 1.8rem; align-items: center; }
    .mission-photo { margin: 0; }
    .mission-photo img { width: 100%; border-radius: 20px; box-shadow: 0 24px 50px -30px rgba(18,61,44,0.5); }

    /* Gallery */
    .gal-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.8rem; margin-top: 2.2rem; }
    .gal-grid figure { margin: 0; overflow: hidden; border-radius: 16px; }
    .gal-grid img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
    .gal-grid figure:hover img { transform: scale(1.05); }
    .gal-a { aspect-ratio: 3 / 4; }
    .gal-b { aspect-ratio: 3 / 4; }
    .gal-c { grid-column: 1 / -1; aspect-ratio: 16 / 9; }

    /* Location */
    .loc-grid { display: grid; gap: 1.8rem; }
    .addr { font-size: 1.02rem; }
    .loc-actions { display: flex; flex-wrap: wrap; gap: 0.7rem; margin: 0.4rem 0 2rem; }
    .hours-title { margin-bottom: 0.6rem; }
    .hours { width: 100%; border-collapse: collapse; font-size: 0.98rem; }
    .hours th, .hours td { text-align: left; padding: 0.6rem 0; border-bottom: 1px solid var(--linea); }
    .hours th { font-family: 'Poppins', sans-serif; font-weight: 600; color: var(--bosque); }
    .hours td { text-align: right; color: var(--esmeralda-2); font-variant-numeric: tabular-nums; }
    .hours tr.closed td { color: color-mix(in srgb, var(--tinta) 55%, transparent); }
    .loc-map { border-radius: 20px; overflow: hidden; box-shadow: 0 24px 50px -30px rgba(18,61,44,0.5); border: 1px solid var(--linea); }
    .loc-map iframe { width: 100%; height: 320px; border: 0; display: block; }

    /* FAQ */
    .faq { background: var(--hoja); border-radius: 32px; margin: 0 12px; }
    .faq-list { max-width: 640px; margin: 2rem auto 0; display: grid; gap: 0.7rem; }
    details {
      background: var(--marfil); border: 1px solid var(--linea); border-radius: 14px;
      padding: 0.5rem 1.2rem; overflow: hidden;
    }
    summary {
      font-family: 'Poppins', sans-serif; font-weight: 600; color: var(--bosque);
      cursor: pointer; list-style: none; padding: 0.7rem 0; display: flex;
      justify-content: space-between; align-items: center; gap: 1rem;
    }
    summary::-webkit-details-marker { display: none; }
    summary::after {
      content: '+'; font-size: 1.5rem; color: var(--esmeralda); font-weight: 400;
      transition: transform 0.2s ease; line-height: 1;
    }
    details[open] summary::after { transform: rotate(45deg); }
    details p { margin: 0 0 0.9rem; font-size: 0.97rem; }

    /* Final CTA */
    .final { background: var(--bosque); text-align: center; }
    .final-in { max-width: 620px; margin: 0 auto; }
    .final h2 { color: var(--marfil); max-width: 18ch; margin: 0.4rem auto 0.7rem; }
    .final p { color: color-mix(in srgb, var(--marfil) 82%, transparent); }
    .final-heart { width: 52px; height: 52px; fill: var(--sol); margin: 0 auto; }
    .final .btn-sol { margin-top: 1rem; }
    .tel-link {
      display: block; margin-top: 1.1rem; color: var(--sol-suave);
      font-family: 'Poppins', sans-serif; font-weight: 500; font-size: 0.95rem; text-decoration: none;
    }
    .tel-link:hover { color: var(--sol); }

    /* Footer */
    .foot { background: #0c2d20; color: color-mix(in srgb, var(--marfil) 76%, transparent); padding: 2.6rem 0 96px; text-align: center; }
    .foot-in { display: grid; gap: 0.5rem; justify-items: center; }
    .foot-brand { display: flex; align-items: center; gap: 0.5rem; }
    .foot-brand strong { color: var(--marfil); font-family: 'Poppins', sans-serif; font-size: 1.15rem; }
    .foot-addr { font-size: 0.9rem; max-width: 34ch; margin: 0; }
    .foot-contact { margin: 0.2rem 0 0; font-size: 0.95rem; }
    .foot-contact a { color: var(--sol); text-decoration: none; font-weight: 600; }
    .foot-slogan { font-family: 'Poppins', sans-serif; font-style: italic; color: var(--sol-suave); font-size: 0.9rem; margin: 0.6rem 0 0; }

    /* ====== Reveal (progressive enhancement) ====== */
    .js .reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .js .reveal.in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) {
      .js .reveal { opacity: 1; transform: none; transition: none; }
    }

    /* ====== Responsive ====== */
    @media (min-width: 720px) {
      .strip-grid { grid-template-columns: repeat(4, 1fr); }
      .about-grid { grid-template-columns: 1.3fr 0.9fr; gap: 3rem; }
      .about-photo { max-width: none; justify-self: end; }
      .team-grid { grid-template-columns: 1fr 1fr; }
      .svc-grid { grid-template-columns: 1fr 1fr; }
      .why-grid { grid-template-columns: repeat(4, 1fr); }
      .cta-band-in { flex-direction: row; justify-content: space-between; text-align: left; }
      .cta-band-txt { max-width: 30ch; }
      .mission-grid { grid-template-columns: 0.85fr 1.15fr; }
      .gal-grid { grid-template-columns: repeat(3, 1fr); }
      .gal-a, .gal-b { aspect-ratio: 3 / 4; }
      .gal-c { grid-column: auto; aspect-ratio: 3 / 4; }
      .loc-grid { grid-template-columns: 1fr 1.15fr; align-items: start; }
      .loc-map iframe { height: 100%; min-height: 420px; }
    }
    @media (min-width: 960px) {
      .hero-photo img { height: 440px; border-radius: 26px 26px 0 0; }
      section { padding: 4.4rem 0; }
    }
  </style>

  <script is:inline>
    (function () {
      document.documentElement.classList.add('js');
      var els = document.querySelectorAll('.reveal');
      if (!('IntersectionObserver' in window) ||
          window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach(function (el) { el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
      els.forEach(function (el) { io.observe(el); });
    })();
  </script>
</BaseLayout>
