---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Performance Gym · Gimnasio en Nueva Yucalpetén, Progreso"
  description="Limpio, ordenado y completo. ⭐ 4.8 con 33 reseñas en Google. Gimnasio en Nueva Yucalpetén, Progreso, Yucatán."
  slug="performance-gym"
  ogImage="/performance-gym/img/foto_1.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Tektur:wght@500;600;700&family=Inter:wght@400;500;600&display=swap"
  favicon="📈"
  themeColor="#e11d48"
  whatsapp={null}
  telefono={null}
  mapsUrl={"https://maps.google.com/?cid=2122473949698509013&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA"}
>
  <main class="pg">

    <!-- ============ HERO ============ -->
    <header class="hero">
      <img class="hero-bg" src="/performance-gym/img/foto_1.jpg" alt="Área de pesas de Performance Gym con el letrero PERFORMANCE iluminado" />
      <div class="hero-scrim" aria-hidden="true"></div>

      <div class="wrap hero-content">
        <p class="kicker reveal">Gimnasio · Nueva Yucalpetén, Progreso</p>
        <h1 class="wordmark reveal">PERFORMANCE<span>GYM</span></h1>
        <p class="tagline reveal">Limpio, ordenado y completo. Máquinas variadas —algunas hasta por duplicado— para que nunca esperes tu turno.</p>

        <a class="chip reveal" href="https://maps.google.com/?cid=2122473949698509013&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">
          <span class="star" aria-hidden="true">★</span> 4.8 · 33 reseñas en Google
        </a>

        <div class="cta-row reveal">
          <a class="btn btn-solid" href="https://maps.google.com/?cid=2122473949698509013&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
            Cómo llegar
          </a>
          <a class="btn btn-ghost" href="https://www.facebook.com/performancegymprogreso" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M13.5 21v-7.7h2.6l.4-3h-3v-1.9c0-.9.25-1.5 1.55-1.5H16.6V4.2C16.3 4.16 15.32 4 14.2 4c-2.35 0-3.96 1.44-3.96 4.07v2.23H7.6v3h2.64V21h3.26z"/></svg>
            Facebook
          </a>
        </div>
      </div>

      <!-- Elemento firma: medidor circular de calificación -->
      <div class="gauge reveal" aria-hidden="true">
        <svg viewBox="0 0 120 120" width="120" height="120">
          <circle class="gauge-track" cx="60" cy="60" r="52" />
          <circle class="gauge-fill" cx="60" cy="60" r="52" pathLength="100" stroke-dasharray="96 100" />
        </svg>
        <div class="gauge-read">
          <strong>4.8</strong>
          <span>/ 5</span>
        </div>
      </div>
    </header>

    <!-- ============ TABLERO DE DATOS ============ -->
    <section class="dash" aria-label="Datos reales del gimnasio">
      <div class="wrap dash-grid">
        <div class="dash-item">
          <strong>4.8<span class="unit">★</span></strong>
          <span>calificación en Google</span>
        </div>
        <div class="dash-item">
          <strong>33</strong>
          <span>reseñas de socios</span>
        </div>
        <div class="dash-item">
          <strong>16<span class="unit">h</span></strong>
          <span>abiertos lun–vie (6:00–22:00)</span>
        </div>
        <div class="dash-item">
          <strong>A/C</strong>
          <span>climatizado todo el año</span>
        </div>
      </div>
    </section>

    <!-- ============ QUIÉNES SOMOS ============ -->
    <section class="sec" id="nosotros">
      <div class="wrap about-grid">
        <div>
          <p class="sec-kicker reveal">Quiénes somos</p>
          <h2 class="sec-title reveal">Entrenar sin<br />fricciones</h2>
          <div class="about reveal">
            <p>Somos <strong>Performance Gym</strong>, un gimnasio en Nueva Yucalpetén, Progreso. Nuestra idea es simple: que entrenar aquí se sienta ordenado, cómodo y sin esperas — desde que abres la puerta hasta que sales de las regaderas.</p>
            <p>Por eso muchas de nuestras máquinas están duplicadas, para que no tengas que hacer fila para usarlas. El gimnasio está climatizado, los baños son amplios y cuentan con regaderas, y nuestros instructores están al pendiente de que tu rutina avance bien.</p>
            <p>Si buscas un gym limpio, completo y con buen servicio en Progreso, ven a conocernos.</p>
          </div>
        </div>
        <figure class="about-photo reveal">
          <img src="/performance-gym/img/foto_2.jpg" alt="Fachada de Performance Gym en Nueva Yucalpetén, Progreso" loading="lazy" />
        </figure>
      </div>
    </section>

    <!-- ============ INSTALACIONES (firma: fotos como gráfica de barras) ============ -->
    <section class="sec sec-dark" id="instalaciones">
      <div class="wrap">
        <p class="sec-kicker reveal">Qué ofrecemos</p>
        <h2 class="sec-title reveal">Instalaciones completas</h2>

        <ul class="ofrece reveal">
          <li><span class="bar-ico" aria-hidden="true"></span>Área de pesas con variedad de máquinas, algunas por duplicado</li>
          <li><span class="bar-ico" aria-hidden="true"></span>Zona de cardio y equipo funcional</li>
          <li><span class="bar-ico" aria-hidden="true"></span>Instructores atentos a tu rutina</li>
          <li><span class="bar-ico" aria-hidden="true"></span>Gimnasio climatizado todo el año</li>
          <li><span class="bar-ico" aria-hidden="true"></span>Baños amplios con regaderas</li>
          <li><span class="bar-ico" aria-hidden="true"></span>Aceptamos pago con tarjeta</li>
        </ul>

        <div class="barchart reveal" role="group" aria-label="Fotos reales de las instalaciones">
          <figure class="bar bar-1">
            <img src="/performance-gym/img/foto_2.jpg" alt="Entrada de Performance Gym" loading="lazy" />
          </figure>
          <figure class="bar bar-2">
            <img src="/performance-gym/img/foto_3.jpg" alt="Máquina de peso en Performance Gym" loading="lazy" />
          </figure>
          <figure class="bar bar-3">
            <img src="/performance-gym/img/foto_5.jpg" alt="Área de pesas y cardio de Performance Gym" loading="lazy" />
          </figure>
          <figure class="bar bar-4">
            <img src="/performance-gym/img/foto_4.jpg" alt="Letrero de Performance Gym visto desde abajo" loading="lazy" />
          </figure>
        </div>
      </div>
    </section>

    <!-- ============ PRUEBA SOCIAL ============ -->
    <section class="sec" id="resenas">
      <div class="wrap">
        <p class="sec-kicker reveal">Reseñas de Google</p>
        <h2 class="sec-title reveal">Lo que dicen<br />nuestros socios</h2>

        <div class="reviews reveal">
          <figure class="rev">
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«¡Excelente lugar para entrenar!, muy limpio y ordenado, cuenta con variedad de máquinas y algunas son de hasta 2 para evitar hacer cola para usarse. Los baños muy bien y amplios, ambos cuentan con regaderas para bañarse»</blockquote>
            <figcaption><strong>ReviewsYuc</strong><span>Hace 5 meses · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«Muchas máquinas, buenos instructores, buenas instalaciones, muy cómodo, con clima, tranquilo.»</blockquote>
            <figcaption><strong>Jessica Carrillo</strong><span>Hace 2 meses · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«Muy completo y muy limpio»</blockquote>
            <figcaption><strong>Alberto Garcia Barroso</strong><span>Hace 2 meses · Google</span></figcaption>
          </figure>
        </div>

        <div class="center reveal">
          <a class="btn btn-ghost-dark" href="https://maps.google.com/?cid=2122473949698509013&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Leer más reseñas en Google</a>
        </div>
      </div>
    </section>

    <!-- ============ UBICACIÓN Y HORARIOS ============ -->
    <section class="sec sec-dark" id="ubicacion">
      <div class="wrap">
        <p class="sec-kicker reveal">Dónde estamos</p>
        <h2 class="sec-title reveal">Nueva Yucalpetén,<br />Progreso</h2>
        <div class="ubica reveal">
          <div class="ubica-info">
            <p class="dir">97320, Nueva Yucalpetén<br />97320 Progreso, Yuc., México</p>
            <a class="btn btn-solid btn-sm" href="https://maps.google.com/?cid=2122473949698509013&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Abrir en Google Maps</a>

            <h3 class="horario-titulo">Horario</h3>
            <table class="horarios">
              <tbody>
                <tr data-dia="1"><th scope="row">Lunes</th><td>6:00–22:00</td></tr>
                <tr data-dia="2"><th scope="row">Martes</th><td>6:00–22:00</td></tr>
                <tr data-dia="3"><th scope="row">Miércoles</th><td>6:00–22:00</td></tr>
                <tr data-dia="4"><th scope="row">Jueves</th><td>6:00–22:00</td></tr>
                <tr data-dia="5"><th scope="row">Viernes</th><td>6:00–22:00</td></tr>
                <tr data-dia="6"><th scope="row">Sábado</th><td>7:00–16:00</td></tr>
                <tr data-dia="0"><th scope="row">Domingo</th><td>Cerrado</td></tr>
              </tbody>
            </table>
          </div>
          <div class="mapa">
            <iframe
              src="https://www.google.com/maps?q=Performance%20Gym%2C%2097320%2C%20Nueva%20Yucalpet%C3%A9n%2C%2097320%20Progreso%2C%20Yuc.%2C%20M%C3%A9xico&output=embed"
              title="Mapa: Performance Gym en Nueva Yucalpetén, Progreso"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA FINAL ============ -->
    <section class="banda">
      <div class="wrap">
        <h2 class="banda-title">Entrena donde<br />todo está en orden</h2>
        <p class="banda-sub">Limpio, completo y sin filas para las máquinas. Ven a conocer Performance Gym.</p>
        <div class="cta-row">
          <a class="btn btn-dark" href="https://maps.google.com/?cid=2122473949698509013&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Cómo llegar</a>
          <a class="btn btn-dark-ghost" href="https://www.facebook.com/performancegymprogreso" target="_blank" rel="noopener">Síguenos en Facebook</a>
        </div>
      </div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="pie">
      <div class="wrap">
        <p class="pie-logo">Performance Gym</p>
        <p class="pie-dato">Gimnasio · 97320, Nueva Yucalpetén, 97320 Progreso, Yuc., México</p>
        <p class="pie-dato">
          <a href="https://maps.google.com/?cid=2122473949698509013&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Cómo llegar</a>
          ·
          <a href="https://www.facebook.com/performancegymprogreso" target="_blank" rel="noopener">Facebook</a>
        </p>
        <p class="pie-mini">Lunes a viernes 6:00–22:00 · Sábado 7:00–16:00 · Domingo cerrado</p>
      </div>
    </footer>
  </main>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "HealthClub",
    "name": "Performance Gym",
    "url": "https://demos.ivang.mx/performance-gym",
    "image": "https://demos.ivang.mx/performance-gym/img/foto_1.jpg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Nueva Yucalpetén",
      "addressLocality": "Progreso",
      "addressRegion": "Yucatán",
      "postalCode": "97320",
      "addressCountry": "MX"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "reviewCount": "33"
    },
    "sameAs": ["https://www.facebook.com/performancegymprogreso"],
    "openingHours": ["Mo-Fr 06:00-22:00", "Sa 07:00-16:00"]
  }
  </script>

  <style is:global>
    :root {
      --white: #f6f7f8;
      --red: #e11d48;
      --red-dark: #be123c;
      --red-light: #fb7185;
      --graphite: #1e2227;
      --graphite-2: #262b31;
      --gray: #5b6472;
      --muted-dark: #a3aab3;
      --line: rgba(30, 34, 39, 0.12);
      --line-dark: rgba(246, 247, 248, 0.14);
      --display: "Tektur", "Arial Narrow", sans-serif;
      --body: "Inter", system-ui, sans-serif;
    }

    body {
      background: var(--white);
      color: var(--graphite);
      font-family: var(--body);
      font-size: 17px;
      line-height: 1.6;
      overflow-x: clip;
    }

    .pg ::selection { background: var(--red); color: var(--white); }
    .pg a:focus-visible,
    .pg .btn:focus-visible {
      outline: 3px solid var(--red);
      outline-offset: 3px;
    }

    .wrap { max-width: 1060px; margin: 0 auto; padding: 0 20px; }

    /* ---------- HERO ---------- */
    .hero {
      position: relative;
      min-height: calc(100vh - 38px);
      min-height: calc(100svh - 38px);
      display: flex;
      align-items: flex-end;
      padding: 56px 0 64px;
      overflow: hidden;
      background: var(--graphite);
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .hero-scrim {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(30, 34, 39, 0.55) 0%, rgba(30, 34, 39, 0.72) 45%, rgba(30, 34, 39, 0.94) 100%),
        linear-gradient(90deg, rgba(30, 34, 39, 0.5) 0%, rgba(30, 34, 39, 0.1) 55%);
    }
    .hero-content { position: relative; z-index: 1; }

    .kicker {
      font-family: var(--display);
      font-weight: 600;
      font-size: 12.5px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--red-light);
      margin: 0 0 16px;
    }
    .wordmark {
      margin: 0 0 18px;
      font-family: var(--display);
      font-weight: 700;
      text-transform: uppercase;
      line-height: 0.94;
      color: var(--white);
      font-size: clamp(38px, 10.5vw, 84px);
      letter-spacing: 0.01em;
    }
    .wordmark span {
      display: block;
      color: var(--red);
      font-size: clamp(32px, 9vw, 70px);
    }
    .tagline {
      font-size: clamp(17px, 4.2vw, 21px);
      font-weight: 400;
      color: var(--white);
      max-width: 36ch;
      margin: 0 0 22px;
      opacity: 0.92;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--line-dark);
      border-radius: 999px;
      padding: 8px 16px;
      font-weight: 500;
      font-size: 14.5px;
      color: var(--white);
      text-decoration: none;
      background: rgba(246, 247, 248, 0.06);
    }
    .chip .star { color: var(--red-light); }
    .chip:hover { border-color: var(--red); }

    .cta-row { display: flex; flex-wrap: wrap; gap: 12px; margin: 24px 0 0; }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      font-family: var(--display);
      font-weight: 600;
      font-size: 15.5px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 15px 24px;
      border-radius: 7px;
      transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
    }
    .btn:active { transform: scale(0.97); }
    .btn-solid { background: var(--red-dark); color: var(--white); }
    .btn-solid:hover { background: #9f0f30; }
    .btn-ghost { border: 2px solid var(--line-dark); color: var(--white); }
    .btn-ghost:hover { border-color: var(--red-light); color: var(--red-light); }
    .btn-ghost-dark { border: 2px solid var(--line); color: var(--graphite); }
    .btn-ghost-dark:hover { border-color: var(--red-dark); color: var(--red-dark); }
    .btn-sm { font-size: 13.5px; padding: 12px 18px; }

    /* ---------- GAUGE (firma) ---------- */
    .gauge {
      position: absolute;
      z-index: 1;
      right: 20px;
      top: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .gauge svg { transform: rotate(-90deg); }
    .gauge-track { fill: none; stroke: rgba(246, 247, 248, 0.18); stroke-width: 6; }
    .gauge-fill {
      fill: none;
      stroke: var(--red);
      stroke-width: 6;
      stroke-linecap: round;
    }
    .gauge-read {
      position: absolute;
      display: flex;
      flex-direction: column;
      align-items: center;
      line-height: 1;
      color: var(--white);
      font-family: var(--display);
    }
    .gauge-read strong { font-size: 26px; font-weight: 700; }
    .gauge-read span { font-size: 11px; color: var(--muted-dark); margin-top: 2px; }

    /* ---------- TABLERO DE DATOS ---------- */
    .dash { background: var(--red-dark); padding: 34px 0; }
    .dash-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 22px 16px;
    }
    .dash-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .dash-item strong {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(26px, 6.5vw, 34px);
      color: var(--white);
      line-height: 1;
    }
    .dash-item strong .unit { font-size: 0.5em; margin-left: 2px; }
    .dash-item span {
      font-size: 13px;
      color: rgba(246, 247, 248, 0.86);
      font-weight: 500;
    }

    /* ---------- SECCIONES ---------- */
    .sec { padding: 72px 0; }
    .sec-dark { background: var(--graphite); color: var(--white); }
    .sec-kicker {
      font-family: var(--display);
      font-weight: 600;
      font-size: 12.5px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--red-dark);
      margin: 0 0 10px;
    }
    .sec-title {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(30px, 7.5vw, 48px);
      line-height: 1.02;
      margin: 0 0 26px;
      color: var(--graphite);
    }
    .sec-dark .sec-kicker { color: var(--red-light); }
    .sec-dark .sec-title { color: var(--white); }

    .about-grid { display: grid; grid-template-columns: 1fr; gap: 32px; align-items: start; }
    .about p { max-width: 58ch; margin: 0 0 16px; color: #3c4249; }
    .about strong { color: var(--graphite); }
    .about-photo { margin: 0; border-radius: 10px; overflow: hidden; }
    .about-photo img { width: 100%; height: 260px; object-fit: cover; display: block; }

    /* ---------- QUÉ OFRECEMOS ---------- */
    .ofrece {
      list-style: none;
      margin: 0 0 38px;
      padding: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      max-width: 62ch;
    }
    .ofrece li {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 15px 0;
      border-top: 1px solid var(--line-dark);
      font-size: 15.5px;
      color: #d6d9dc;
    }
    .ofrece li:last-child { border-bottom: 1px solid var(--line-dark); }
    .bar-ico {
      flex: none;
      width: 14px;
      height: 18px;
      position: relative;
      display: inline-block;
    }
    .bar-ico::before, .bar-ico::after {
      content: "";
      position: absolute;
      bottom: 0;
      width: 5px;
      background: var(--red);
      border-radius: 1px;
    }
    .bar-ico::before { left: 0; height: 100%; }
    .bar-ico::after { left: 9px; height: 62%; background: rgba(225, 29, 72, 0.5); }

    /* ---------- BARCHART DE FOTOS (firma) ---------- */
    .barchart {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      align-items: end;
      gap: 8px;
      height: 220px;
    }
    .barchart figure {
      margin: 0;
      overflow: hidden;
      border-radius: 6px 6px 0 0;
      border-bottom: 3px solid var(--red);
    }
    .barchart img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .bar-1 { height: 52%; }
    .bar-2 { height: 68%; }
    .bar-3 { height: 84%; }
    .bar-4 { height: 100%; }

    /* ---------- RESEÑAS ---------- */
    .reviews {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
      margin: 0 0 30px;
    }
    .rev {
      margin: 0;
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 22px 20px;
      box-shadow: 0 10px 26px rgba(30, 34, 39, 0.06);
    }
    .rev-stars { color: var(--red-dark); font-size: 15px; letter-spacing: 0.2em; margin: 0 0 10px; }
    .rev blockquote { margin: 0 0 14px; font-size: 16px; line-height: 1.55; font-weight: 500; color: var(--graphite); }
    .rev figcaption { display: flex; flex-direction: column; gap: 2px; }
    .rev figcaption strong {
      font-family: var(--display);
      font-weight: 600;
      font-size: 14.5px;
      letter-spacing: 0.03em;
      color: var(--graphite);
    }
    .rev figcaption span { font-size: 12.5px; color: var(--gray); }
    .center { text-align: center; }

    /* ---------- UBICACIÓN ---------- */
    .ubica { display: grid; grid-template-columns: 1fr; gap: 28px; }
    .dir { font-size: 17px; font-weight: 500; margin: 0 0 16px; color: var(--white); }
    .horario-titulo {
      font-family: var(--display);
      font-weight: 600;
      font-size: 18px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin: 30px 0 10px;
      color: var(--white);
    }
    .horarios { width: 100%; max-width: 420px; border-collapse: collapse; font-size: 15px; }
    .horarios th, .horarios td { padding: 9px 10px; border-bottom: 1px solid var(--line-dark); text-align: left; }
    .horarios th { font-weight: 500; color: var(--white); }
    .horarios td { color: var(--muted-dark); text-align: right; font-variant-numeric: tabular-nums; }
    .horarios tr.hoy th, .horarios tr.hoy td { color: var(--white); background: var(--red-dark); font-weight: 600; }
    .horarios tr.hoy th { border-radius: 4px 0 0 4px; padding-left: 10px; }
    .horarios tr.hoy td { border-radius: 0 4px 4px 0; }
    .horarios tr.hoy th::after {
      content: "hoy";
      font-family: var(--display);
      font-weight: 700;
      font-size: 10.5px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: var(--graphite);
      color: var(--white);
      border-radius: 4px;
      padding: 2px 7px;
      margin-left: 10px;
      vertical-align: 1px;
    }
    .mapa iframe {
      width: 100%;
      height: 300px;
      border: 0;
      border-radius: 10px;
      display: block;
    }

    /* ---------- CTA FINAL ---------- */
    .banda {
      background: var(--red-dark);
      color: var(--white);
      padding: 60px 0;
      text-align: center;
    }
    .banda-title {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(28px, 7vw, 46px);
      line-height: 1.05;
      margin: 0 0 12px;
    }
    .banda-sub { margin: 0 auto 24px; max-width: 42ch; font-weight: 400; opacity: 0.95; }
    .banda .cta-row { justify-content: center; }
    .btn-dark { background: var(--graphite); color: var(--white); }
    .btn-dark:hover { background: #12151a; }
    .btn-dark-ghost { border: 2px solid rgba(246, 247, 248, 0.55); color: var(--white); }
    .btn-dark-ghost:hover { border-color: var(--white); }

    /* ---------- FOOTER ---------- */
    .pie {
      background: var(--graphite);
      color: var(--white);
      padding: 44px 0 96px;
      text-align: center;
    }
    .pie-logo {
      font-family: var(--display);
      font-weight: 700;
      font-size: 24px;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: var(--white);
      margin: 0 0 10px;
    }
    .pie-dato { margin: 4px 0; color: var(--muted-dark); font-size: 14px; }
    .pie-dato a { color: var(--white); text-decoration: none; border-bottom: 1px solid var(--red); }
    .pie-dato a:hover { color: var(--red-light); }
    .pie-mini { margin: 14px 0 0; color: #8b929c; font-size: 12px; }

    /* ---------- REVEAL (solo con JS) ---------- */
    html.js .reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    html.js .reveal.in { opacity: 1; transform: none; }

    /* ---------- DESKTOP ---------- */
    @media (min-width: 760px) {
      .sec { padding: 100px 0; }
      .about-grid { grid-template-columns: 1.1fr 0.9fr; gap: 48px; }
      .about-photo img { height: 100%; min-height: 320px; }
      .reviews { grid-template-columns: repeat(3, 1fr); align-items: start; }
      .ubica { grid-template-columns: 1fr 1.2fr; align-items: start; }
      .mapa iframe { height: 400px; }
      .dash-grid { grid-template-columns: repeat(4, 1fr); }
      .gauge { top: 40px; right: 40px; }
    }
  </style>

  <script is:inline>
    (function () {
      var d = document;
      d.documentElement.classList.add('js');

      // Resaltar el día de hoy en la tabla de horarios
      var hoy = new Date().getDay(); // 0 = domingo
      var fila = d.querySelector('.horarios tr[data-dia="' + hoy + '"]');
      if (fila) fila.classList.add('hoy');

      // Scroll-reveal (mejora progresiva)
      var els = d.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach(function (el) { io.observe(el); });
      } else {
        els.forEach(function (el) { el.classList.add('in'); });
      }
    })();
  </script>
</BaseLayout>
