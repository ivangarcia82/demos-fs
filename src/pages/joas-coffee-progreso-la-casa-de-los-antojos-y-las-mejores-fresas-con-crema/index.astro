<style is:global>
:root{
  --fresa:#C4173C;
  --fresa-viva:#E8365D;
  --crema:#FFF8EE;
  --galleta:#F6E7D3;
  --cafe:#33200F;
  --cafe-oscuro:#211208;
  --rosa:#E0559A;
  --blanco:#FFFFFF;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  font-family:'Figtree',system-ui,sans-serif;
  background:var(--crema);
  color:var(--cafe);
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
}
img{max-width:100%;display:block}
h1,h2,h3{font-family:'Lilita One',cursive;font-weight:400;line-height:1.1;letter-spacing:.3px}
a:focus-visible,button:focus-visible{outline:3px solid var(--rosa);outline-offset:3px;border-radius:6px}

/* ---- Hero ---- */
.hero{
  position:relative;min-height:min(94svh,860px);
  display:flex;align-items:flex-end;
  overflow:hidden;background:var(--cafe-oscuro);
}
.hero-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 38%}
.hero::after{
  content:"";position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(33,18,8,.42) 0%,rgba(33,18,8,.12) 34%,rgba(63,12,26,.55) 68%,rgba(41,9,17,.88) 100%);
}
.hero-content{
  position:relative;z-index:2;width:100%;max-width:1060px;margin:0 auto;
  padding:6.5rem 1.25rem 6.5rem;color:var(--crema);
}
.hero-eyebrow{
  display:inline-block;font-weight:800;font-size:.8rem;text-transform:uppercase;
  letter-spacing:.14em;background:rgba(255,248,238,.16);border:1px solid rgba(255,248,238,.4);
  backdrop-filter:blur(3px);padding:.35rem .8rem;border-radius:999px;margin-bottom:1rem;
}
.hero h1{font-size:clamp(2.7rem,11vw,5rem);text-shadow:0 3px 22px rgba(33,18,8,.55)}
.hero h1 .fresa-txt{color:#FFB3C4}
.hero-sub{
  font-size:clamp(1.05rem,4.2vw,1.4rem);font-weight:600;max-width:32ch;
  margin:.7rem 0 1.1rem;text-shadow:0 2px 12px rgba(33,18,8,.6);
}
.rating-chip{
  display:inline-flex;align-items:center;gap:.45rem;
  background:var(--crema);color:var(--cafe);font-weight:800;font-size:.95rem;
  padding:.45rem .95rem;border-radius:999px;transform:rotate(-2deg);
  box-shadow:0 6px 18px rgba(33,18,8,.35);margin-bottom:1.5rem;
}
.rating-chip .estrella{color:var(--fresa)}
.hero-cta{display:flex;flex-wrap:wrap;gap:.75rem}
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:.55rem;
  font-family:'Figtree',sans-serif;font-weight:800;font-size:1.02rem;
  padding:.95rem 1.6rem;border-radius:999px;text-decoration:none;
  transition:transform .18s ease,box-shadow .18s ease;border:2px solid transparent;
}
.btn:hover{transform:translateY(-2px)}
.btn svg{flex:none}
.btn-fresa{background:var(--fresa);color:var(--crema);box-shadow:0 8px 22px rgba(196,23,60,.45)}
.btn-fresa:hover{background:var(--fresa-viva);box-shadow:0 10px 26px rgba(196,23,60,.55)}
.btn-borde{background:rgba(33,18,8,.25);color:var(--crema);border-color:rgba(255,248,238,.65);backdrop-filter:blur(3px)}
.btn-borde:hover{background:rgba(255,248,238,.16)}
.hero-drip{position:absolute;bottom:-1px;left:0;right:0;z-index:3;pointer-events:none}
.hero-drip svg,.drip svg{display:block;width:100%;height:clamp(48px,7vw,100px)}

/* ---- Secciones ---- */
.seccion{padding:4rem 1.25rem}
.contenedor{max-width:1060px;margin:0 auto}
.kicker{
  font-weight:800;font-size:.8rem;text-transform:uppercase;letter-spacing:.16em;
  color:var(--fresa);margin-bottom:.5rem;
}
.seccion h2{font-size:clamp(1.9rem,6.5vw,2.8rem);margin-bottom:1.1rem}

/* Sobre nosotros */
.sobre-grid{display:grid;gap:2rem}
.sobre-texto p{margin-bottom:1rem;font-size:1.04rem}
.sobre-texto strong{color:var(--fresa)}
.sobre-foto figure{position:relative}
.sobre-foto img{border-radius:20px;box-shadow:0 14px 34px rgba(51,32,15,.22)}
.sobre-foto figcaption{
  font-size:.85rem;font-weight:600;color:var(--cafe);opacity:.75;
  margin-top:.6rem;text-align:center;
}

/* Consentidos */
.fondo-galleta{background:var(--galleta)}
.consentidos{display:grid;gap:.9rem;margin-top:1.5rem}
.consentido{
  background:var(--blanco);border-radius:18px;padding:1.15rem 1.25rem;
  box-shadow:0 4px 14px rgba(51,32,15,.08);
  display:flex;gap:.9rem;align-items:flex-start;
  transition:transform .18s ease,box-shadow .18s ease;
}
.consentido:hover{transform:translateY(-3px);box-shadow:0 10px 22px rgba(51,32,15,.14)}
.consentido .icono{font-size:1.7rem;line-height:1.2}
.consentido h3{font-size:1.15rem;margin-bottom:.15rem;color:var(--fresa)}
.consentido p{font-size:.94rem}
.estrella-casa{border:2px solid var(--fresa)}

/* Galería */
.galeria{
  display:grid;grid-auto-flow:column;grid-auto-columns:76%;
  gap:.9rem;overflow-x:auto;scroll-snap-type:x mandatory;
  padding:1.6rem 0 .8rem;-webkit-overflow-scrolling:touch;
}
.galeria::-webkit-scrollbar{height:6px}
.galeria::-webkit-scrollbar-thumb{background:var(--fresa);border-radius:3px}
.galeria figure{scroll-snap-align:center}
.galeria img{
  border-radius:18px;aspect-ratio:3/4;object-fit:cover;width:100%;
  box-shadow:0 10px 24px rgba(51,32,15,.18);
}
.galeria figcaption{font-size:.83rem;font-weight:600;margin-top:.5rem;opacity:.75}

/* Comodidades */
.comodidades{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin-top:1.4rem}
.comodidad{
  display:flex;align-items:center;gap:.6rem;
  background:var(--blanco);border-radius:14px;padding:.8rem .9rem;
  font-weight:600;font-size:.92rem;box-shadow:0 3px 10px rgba(51,32,15,.07);
}
.comodidad .palomita{
  flex:none;width:22px;height:22px;border-radius:50%;
  background:var(--fresa);color:var(--crema);
  display:inline-flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:800;
}

/* Divisor goteo */
.drip{line-height:0;font-size:0}

/* Reseñas */
.fondo-cafe{background:var(--cafe-oscuro);color:var(--crema)}
.fondo-cafe .kicker{color:#FFB3C4}
.rating-grande{
  font-family:'Lilita One',cursive;font-size:clamp(2.2rem,8vw,3.4rem);
  color:var(--crema);margin-bottom:.3rem;
}
.rating-grande .estrella{color:#FFC94D}
.rating-sub{opacity:.85;margin-bottom:2rem;font-weight:600}
.resenas{display:grid;gap:1rem;margin-bottom:2rem}
.resena{
  background:rgba(255,248,238,.07);border:1px solid rgba(255,248,238,.16);
  border-radius:18px;padding:1.3rem 1.3rem 1.15rem;position:relative;
}
.resena .comillas{
  font-family:'Lilita One',cursive;font-size:2.6rem;color:var(--fresa-viva);
  line-height:0;display:block;height:.9rem;margin-top:.6rem;
}
.resena p{font-size:.97rem;margin-bottom:.9rem}
.resena footer{font-size:.85rem;font-weight:800;color:#FFB3C4}
.resena footer span{display:block;font-weight:600;color:var(--crema);opacity:.65}
.resena .estrellitas{color:#FFC94D;font-size:.85rem;letter-spacing:2px;margin-bottom:.5rem}

/* Ubicación */
.ubicacion-grid{display:grid;gap:2rem;margin-top:1.5rem}
.mapa{
  border-radius:20px;overflow:hidden;box-shadow:0 12px 30px rgba(51,32,15,.18);
  aspect-ratio:4/3;background:var(--galleta);
}
.mapa iframe{width:100%;height:100%;border:0;display:block}
.direccion{font-size:1.02rem;margin-bottom:1.2rem}
.direccion strong{display:block;font-family:'Lilita One',cursive;font-weight:400;font-size:1.2rem;margin-bottom:.2rem}
.horarios{width:100%;border-collapse:collapse;margin:1.2rem 0 1.5rem;font-size:.97rem}
.horarios caption{
  text-align:left;font-family:'Lilita One',cursive;font-size:1.2rem;margin-bottom:.5rem;
}
.horarios td{padding:.5rem .4rem;border-bottom:1px dashed rgba(51,32,15,.2)}
.horarios td:last-child{text-align:right;font-weight:600}
.horarios tr.hoy td{
  background:var(--fresa);color:var(--crema);font-weight:800;
}
.horarios tr.hoy td:first-child{border-radius:10px 0 0 10px}
.horarios tr.hoy td:last-child{border-radius:0 10px 10px 0}
.hoy-badge{
  display:inline-block;background:var(--crema);color:var(--fresa);
  font-size:.68rem;font-weight:800;padding:.05rem .45rem;border-radius:999px;
  margin-left:.5rem;vertical-align:1px;letter-spacing:.06em;
}
.nota-abierto{font-weight:800;color:var(--fresa);margin-bottom:1.2rem}

/* Footer */
.footer{background:var(--cafe-oscuro);color:var(--crema);text-align:center;padding:3rem 1.25rem 5.5rem}
.footer h2{font-size:1.7rem;margin-bottom:.4rem}
.footer .tel{
  display:inline-block;font-family:'Lilita One',cursive;font-size:1.5rem;
  color:#FFB3C4;text-decoration:none;margin:.5rem 0 1rem;
}
.footer .tel:hover{color:var(--crema)}
.footer p{font-size:.9rem;opacity:.8;max-width:46ch;margin:0 auto .4rem}
.footer .credito{margin-top:1.6rem;font-size:.8rem;opacity:.65}
.footer .credito a{color:#FFB3C4}

/* Reveal */
.reveal{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
.reveal.visible{opacity:1;transform:none}

@media (prefers-reduced-motion:reduce){
  html{scroll-behavior:auto}
  *,*::before,*::after{transition:none!important;animation:none!important}
  .reveal{opacity:1;transform:none}
}

/* ---- Desktop ---- */
@media (min-width:760px){
  .seccion{padding:5.5rem 2rem}
  .sobre-grid{grid-template-columns:1.15fr .85fr;align-items:center;gap:3rem}
  .consentidos{grid-template-columns:repeat(3,1fr)}
  .galeria{grid-auto-flow:row;grid-template-columns:repeat(3,1fr);overflow:visible}
  .comodidades{grid-template-columns:repeat(3,1fr)}
  .resenas{grid-template-columns:repeat(3,1fr);align-items:start}
  .ubicacion-grid{grid-template-columns:1fr 1fr;align-items:start}
  .hero-content{padding-bottom:8rem}
}
</style>

<script is:inline>
// Resaltar el día de hoy en la tabla de horarios
(function(){
  var hoy = new Date().getDay();
  var fila = document.querySelector('#tabla-horarios tr[data-dia="' + hoy + '"]');
  if(fila){
    fila.classList.add('hoy');
    var badge = document.createElement('span');
    badge.className = 'hoy-badge';
    badge.textContent = 'HOY';
    fila.cells[0].appendChild(badge);
  }
})();

// Scroll reveal sutil
(function(){
  var els = document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches){
    els.forEach(function(el){ el.classList.add('visible'); });
    return;
  }
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){ e.target.classList.add('visible'); io.unobserve(e.target); }
    });
  }, {threshold:.12, rootMargin:'0px 0px -40px 0px'});
  els.forEach(function(el){ io.observe(el); });
})();
</script>

