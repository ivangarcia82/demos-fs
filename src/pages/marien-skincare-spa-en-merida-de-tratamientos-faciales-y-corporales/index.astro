    /* WHY */
    .ms-why { padding: clamp(3rem, 8vw, 5rem) 0; background: linear-gradient(165deg, var(--sage-deep), var(--sage-dark)); color: var(--bg); }
    .ms-why .ms-eyebrow { color: var(--apricot); }
