    .ms-sec-head__lead { margin-top: 0.9rem; }
    .ms-treat__grid { list-style: none; margin: 0; padding: 0; display: grid; gap: 1rem; grid-template-columns: 1fr; }
    .ms-treat__card { position: relative; background: #fff; border: 1px solid var(--line); border-radius: 18px; padding: 1.5rem 1.4rem 1.4rem; box-shadow: 0 14px 34px -26px rgba(80, 66, 48, 0.55); transition: transform 0.25s ease, box-shadow 0.25s ease; }
