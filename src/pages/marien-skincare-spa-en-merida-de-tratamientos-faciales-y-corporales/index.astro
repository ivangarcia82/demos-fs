    .ms-why__item { padding-top: 1.4rem; border-top: 1px solid rgba(251, 246, 239, 0.22); }
    .ms-why__item h3 { font-family: 'Newsreader', serif; font-weight: 500; font-size: 1.35rem; margin: 0 0 0.4rem; color: #fff; }
