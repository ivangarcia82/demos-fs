    .ms-faq__item summary:focus-visible { outline: 3px solid var(--sage-deep); outline-offset: 3px; border-radius: 6px; }

    /* FINAL CTA */
    .ms-final { position: relative; overflow: hidden; padding: clamp(3.4rem, 9vw, 5.4rem) 0; background: linear-gradient(160deg, var(--sage-deep), var(--sage-dark)); color: var(--bg); text-align: center; }
    .ms-final__glow { position: absolute; top: -30%; left: 50%; transform: translateX(-50%); width: min(90vw, 640px); aspect-ratio: 1; border-radius: 50%; background: radial-gradient(circle, rgba(243, 199, 161, 0.28), transparent 62%); pointer-events: none; }
    .ms-final__inner { position: relative; z-index: 1; max-width: 34rem; margin: 0 auto; }
    .ms-final__h { font-family: 'Newsreader', serif; font-weight: 500; font-size: clamp(2rem, 7vw, 3.1rem); line-height: 1.08; margin: 0 0 0.9rem; color: #fff; letter-spacing: -0.01em; }
    .ms-final__p { color: rgba(251, 246, 239, 0.85); margin: 0 auto 1.8rem; max-width: 26rem; }
    .ms-final__inner .ms-btn { margin: 0 auto; }
    .ms-final__tel { margin: 1.3rem 0 0; font-size: 0.95rem; color: rgba(251, 246, 239, 0.8); }
    .ms-final__tel a { color: var(--apricot); text-decoration: none; font-weight: 600; }
    .ms-final__tel a:hover { text-decoration: underline; }

    /* FOOTER */
    .ms-footer { background: var(--sage-dark); color: rgba(251, 246, 239, 0.75); padding: 2.2rem 0 88px; text-align: center; }
    .ms-footer__name { font-family: 'Newsreader', serif; font-size: 1.3rem; color: #fff; margin: 0 0 0.3rem; }
    .ms-footer__meta { font-size: 0.9rem; margin: 0; color: rgba(251, 246, 239, 0.65); }
    .ms-footer__meta a { color: var(--apricot); text-decoration: none; }

    /* Reveal (progressive enhancement) */
    @media (prefers-reduced-motion: no-preference) {
      .js .ms-reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.8s ease, transform 0.8s ease; }
      .js .ms-reveal.ms-in { opacity: 1; transform: none; }
    }

    @keyframes ms-breathe {
      0%, 100% { transform: scale(1); opacity: 0.85; }
      50% { transform: scale(1.07); opacity: 1; }
    }

    /* Tablet / desktop */
    @media (min-width: 720px) {
      .ms-hero__inner { grid-template-columns: 1.05fr 0.95fr; align-items: center; gap: 2.6rem; }
      .ms-about__grid { grid-template-columns: 0.9fr 1.1fr; }
      .ms-treat__grid { grid-template-columns: repeat(3, 1fr); }
      .ms-why__grid { grid-template-columns: repeat(2, 1fr); column-gap: 2.6rem; }
      .ms-reviews__grid { grid-template-columns: repeat(2, 1fr); }
      .ms-midcta__inner { flex-direction: row; align-items: center; justify-content: space-between; gap: 2rem; }
      .ms-loc__grid { grid-template-columns: 1fr 1.15fr; align-items: stretch; }
      .ms-faq__wrap { grid-template-columns: 0.8fr 1.2fr; align-items: start; }
      .ms-sec-head--left { margin-bottom: 0; }
    }
    @media (min-width: 980px) {
      .ms-reviews__grid { grid-template-columns: repeat(4, 1fr); }
    }
  </style>

  <script is:inline>
    (function () {
      var root = document.documentElement;
      root.classList.add('js');
      var els = document.querySelectorAll('.ms-reveal');
      if (!('IntersectionObserver' in window) || !els.length) {
        els.forEach(function (el) { el.classList.add('ms-in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('ms-in'); io.unobserve(e.target); }
        });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
      els.forEach(function (el) { io.observe(el); });
    })();
  </script>
</BaseLayout>
