    .ms-drop { display: block; width: 20px; height: 20px; margin-bottom: 0.9rem; background: linear-gradient(160deg, var(--apricot), var(--apricot-deep)); border-radius: 50% 50% 50% 0; transform: rotate(45deg); box-shadow: 0 4px 10px -3px rgba(227, 154, 107, 0.7); }
