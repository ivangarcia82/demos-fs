    .about__copy p:first-of-type { color: var(--carbon); }
    .about__media .frame img { aspect-ratio: 3 / 2; }

    /* ===== DIVIDER ===== */
    .divider {
      display: flex;
      align-items: center;
      gap: 1rem;
      max-width: 620px;
      margin: 0.5rem auto;
      padding-inline: clamp(1.1rem, 5vw, 2.2rem);
      color: var(--pistache-fresco);
