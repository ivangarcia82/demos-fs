    /* ===== REVIEWS ===== */
    .reviews {
      padding-top: clamp(2.5rem, 7vw, 4.5rem);
      padding-bottom: clamp(2.5rem, 7vw, 4.5rem);
    }
    .reviews__head { text-align: center; margin-bottom: 2rem; }
    .score { display: inline-flex; flex-direction: column; align-items: center; gap: 0.2rem; }
    .score__num {
      font-family: 'Fraunces', serif;
      font-weight: 600;
      font-size: clamp(3rem, 12vw, 4.6rem);
