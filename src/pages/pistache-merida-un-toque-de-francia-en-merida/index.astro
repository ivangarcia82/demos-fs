    }
    .band__inner {
      max-width: 760px;
      margin-inline: auto;
      padding: clamp(3rem, 9vw, 5rem) clamp(1.2rem, 5vw, 2.2rem);
      text-align: center;
    }
    .band__sub { margin: 0.3rem 0 1.7rem; color: rgba(248, 242, 227, 0.82); }

    /* ===== VISIT ===== */
    .visit {
      display: grid;
      gap: clamp(1.6rem, 5vw, 3rem);
      align-items: start;
      padding-top: clamp(2.8rem, 7vw, 4.5rem);
