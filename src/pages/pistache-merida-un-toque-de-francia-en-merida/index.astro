    .rating--hero { margin-bottom: 1.5rem; }
    .cta-row { display: flex; flex-wrap: wrap; gap: 0.7rem; }
    .cta-row--center { justify-content: center; }
    .hero__media { position: relative; }
    .hero__media .frame img { aspect-ratio: 4 / 5; }
    .hero__ticket {
