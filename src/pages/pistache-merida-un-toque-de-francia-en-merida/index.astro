    .visit__addr { color: var(--carbon-soft); margin: 0 0 1.4rem; font-weight: 600; }
    .hours { width: 100%; border-collapse: collapse; margin-bottom: 1.6rem; }
    .hours caption {
      text-align: left;
      font-family: 'Fraunces', serif;
      font-weight: 600;
      font-size: 1.05rem;
      color: var(--pistache-deep);
      padding-bottom: 0.5rem;
    }
    .hours th, .hours td { padding: 0.7rem 0; border-bottom: 1px solid var(--line); text-align: left; }
    .hours th { font-weight: 600; color: var(--carbon); }
    .hours td { text-align: right; color: var(--carbon-soft); font-variant-numeric: tabular-nums; }
    .hours td.closed { color: var(--carbon); font-weight: 700; }
    .visit__cta { display: flex; flex-wrap: wrap; gap: 0.7rem; }
    .visit__map {
      border: 1.5px solid rgba(60, 122, 87, 0.5);
      border-radius: 12px;
      overflow: hidden;
      background: var(--crema-2);
      min-height: 300px;
    }
    .visit__map iframe { width: 100%; height: 100%; min-height: 340px; border: 0; display: block; }

    /* ===== FAQ ===== */
    .faq { padding-top: clamp(2rem, 6vw, 3.5rem); padding-bottom: clamp(2.5rem, 7vw, 4rem); }
    .faq__head { text-align: center; margin-bottom: 1.8rem; }
    .faq__list { max-width: 720px; margin-inline: auto; }
    .faq details {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--crema-2);
      margin-bottom: 0.7rem;
      overflow: hidden;
    }
    .faq summary {
      cursor: pointer;
      list-style: none;
      padding: 1.05rem 1.3rem;
      font-family: 'Fraunces', serif;
      font-weight: 600;
      font-size: 1.05rem;
      color: var(--carbon);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }
    .faq summary::-webkit-details-marker { display: none; }
    .faq summary::after {
      content: '+';
      font-family: 'Mulish', sans-serif;
      font-weight: 700;
      color: var(--pistache);
      font-size: 1.4rem;
      transition: transform 0.2s ease;
    }
    .faq details[open] summary::after { transform: rotate(45deg); }
    .faq details p { margin: 0; padding: 0 1.3rem 1.15rem; color: var(--carbon-soft); }
    .faq summary:focus-visible { outline: 3px solid var(--pistache); outline-offset: -3px; border-radius: 12px; }

    /* ===== FOOTER ===== */
    .foot {
      text-align: center;
      background: var(--crema-honda);
      border-top: 1px solid var(--line);
      padding: clamp(3rem, 8vw, 4.5rem) clamp(1.1rem, 5vw, 2.2rem) 96px;
    }
    .foot__brand {
      font-family: 'Fraunces', serif;
      font-weight: 600;
      font-size: clamp(2.2rem, 9vw, 3.2rem);
      color: var(--pistache-deep);
      margin: 0;
      line-height: 1;
    }
    .foot__tag {
      font-family: 'Fraunces', serif;
      font-style: italic;
      color: var(--pistache-text);
      margin: 0.3rem 0 1.7rem;
    }
    .foot__contact {
      margin: 1.7rem 0 0;
      color: var(--carbon-soft);
      font-size: 0.92rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
      align-items: center;
    }
    .foot__contact a { color: var(--pistache-deep); font-weight: 700; text-decoration: none; }
    .foot__contact a:hover { text-decoration: underline; }
    .foot__contact a:focus-visible { outline: 3px solid var(--pistache); outline-offset: 2px; border-radius: 4px; }

    /* ===== REVEAL (progressive enhancement) ===== */
    .has-js .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .has-js .reveal.in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) {
      .has-js .reveal { opacity: 1; transform: none; transition: none; }
    }

    /* ===== RESPONSIVE ===== */
    @media (min-width: 760px) {
      .hero { grid-template-columns: 1.05fr 0.95fr; }
      .about { grid-template-columns: 0.95fr 1.05fr; }
      .about__media { order: -1; }
      .menu__grid { grid-template-columns: 1.15fr 0.85fr; align-items: start; }
      .menu__pics { grid-template-columns: 1fr; }
      .menu__pics .frame img { aspect-ratio: 3 / 2; }
      .gallery { columns: 3 200px; }
      .visit { grid-template-columns: 0.85fr 1.15fr; }
    }
    @media (max-width: 420px) {
      .carte__name { max-width: 100%; }
      .carte__note { max-width: 100%; }
      .carte__row { flex-wrap: wrap; }
      .carte__lead { display: none; }
      .carte__note { text-align: left; width: 100%; }
    }
  </style>

  <script is:inline>
    (function () {
      var root = document.documentElement;
      root.classList.add('has-js');
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var items = document.querySelectorAll('.reveal');
      if (reduce || !('IntersectionObserver' in window)) {
        items.forEach(function (el) { el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      items.forEach(function (el) { io.observe(el); });
    })();
  </script>
</BaseLayout>
