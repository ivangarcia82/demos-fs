      color: var(--pistache-deep);
      border: 1.5px solid var(--rose);
      border-radius: 4px;
      padding: 0.35em 1em;
      font-family: 'Fraunces', serif;
      font-style: italic;
      font-size: 0.95rem;
      white-space: nowrap;
      box-shadow: 0 8px 18px -12px rgba(47, 100, 70, 0.6);
      z-index: 2;
