---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="MeriPet · Hospital para mascotas en Manuel Ávila Camacho, Mérida"
  description="Urgencias con atención inmediata, tratamientos con seguimiento cercano y trato justo hasta en los momentos más difíciles. ⭐ 4.6 con 325 reseñas en Google. Escríbenos por WhatsApp."
  slug="meripet"
  ogImage="/meripet/img/foto_3.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Livvic:wght@600;700&family=Inter:wght@400;500;600&display=swap"
  favicon="❤️"
  themeColor="#e05b52"
  whatsapp={"https://wa.me/529991486017"}
  telefono={"999 148 6017"}
  mapsUrl={"https://maps.google.com/?cid=14946807041865155620&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA"}
>
  <main class="mp">

    <!-- ============ HERO ============ -->
    <header class="hero" id="inicio">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="wrap hero-grid">
        <div class="hero-copy">
          <p class="kicker reveal">
            <svg class="mark" viewBox="0 0 48 48" aria-hidden="true">
              <path d="M24 41S5 29 5 16.5A10.5 10.5 0 0 1 24 9a10.5 10.5 0 0 1 19 7.5C43 29 24 41 24 41Z" fill="currentColor"/>
              <path d="M24 13v16M16 21h16" stroke="#fdf6f2" stroke-width="4" stroke-linecap="round"/>
            </svg>
            Urgencias con corazón · Manuel Ávila Camacho, Mérida
          </p>
          <h1 class="brand reveal" aria-label="MeriPet">
            Meri<span class="mark-plus" aria-hidden="true">
              <svg viewBox="0 0 48 48"><path d="M24 41S5 29 5 16.5A10.5 10.5 0 0 1 24 9a10.5 10.5 0 0 1 19 7.5C43 29 24 41 24 41Z" fill="currentColor"/><path d="M24 13v16M16 21h16" stroke="#fdf6f2" stroke-width="4" stroke-linecap="round"/></svg>
            </span>Pet
          </h1>
          <p class="tagline reveal">Cuidamos a tu mascota con la misma urgencia y el mismo cariño que si fuera nuestra.</p>

          <a class="chip reveal" href="https://maps.google.com/?cid=14946807041865155620&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">
            <span class="star" aria-hidden="true">★</span> 4.6 · 325 reseñas en Google
          </a>

          <div class="cta-row reveal">
            <a class="btn btn-solid" href="https://wa.me/529991486017" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2zm0 18.2c-1.5 0-3-.4-4.3-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.6.8-.8 1-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.4-3c-.3-.4 0-.5.2-.7l.4-.5c.1-.2.2-.3.3-.5v-.5c0-.1-.5-1.3-.7-1.8-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.3.3-.9.9-.9 2.2s.9 2.5 1 2.7c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2l-.4-.3z"/></svg>
              Escríbenos por WhatsApp
            </a>
            <a class="btn btn-ghost" href="https://maps.google.com/?cid=14946807041865155620&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12 2a7 7 0 0 0-7 7c0 5.2 7 13 7 13s7-7.8 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
              Cómo llegar
            </a>
          </div>
        </div>

        <div class="hero-photo reveal">
          <img src="/meripet/img/foto_3.jpg" alt="Cachorra atendida con cariño en el área de consulta de MeriPet" width="828" height="1100" fetchpriority="high" />
        </div>
      </div>

      <div class="pulse-wrap" aria-hidden="true">
        <svg class="pulse" viewBox="0 0 600 40" preserveAspectRatio="none">
          <path class="pulse-line" d="M0 20 H210 L228 6 L244 34 L260 20 H340 L358 4 L376 36 L392 20 H600" />
        </svg>
      </div>
    </header>

    <!-- ============ QUIÉNES SOMOS ============ -->
    <section class="sec" id="nosotros">
      <div class="wrap two-col">
        <div class="col-text">
          <p class="sec-kicker reveal">Quiénes somos</p>
          <h2 class="sec-title reveal">Un hospital de barrio que sí se queda a acompañarte</h2>
          <div class="about reveal">
            <p>Somos <strong>MeriPet</strong>, hospital para mascotas en Manuel Ávila Camacho. Aquí no despachamos consultas rápidas y ya: nuestras doctoras —como la <strong>Dra. Jaqueline</strong> o la <strong>Dra. Abril</strong>— dan seguimiento cercano a cada caso, desde tratamientos que toman semanas hasta las urgencias que no pueden esperar ni un minuto.</p>
            <p>Sabemos que una mascota es familia, y así la tratamos: con el mismo cariño en una vacuna de rutina que en el momento más difícil, cuando toca despedirse. Por eso cuidamos también el otro lado de la consulta: precios accesibles en medicamentos y honestidad en lo que cobramos, siempre.</p>
            <p>Nuestras instalaciones cuentan con acceso para silla de ruedas, porque acompañar a tu mascota no debería tener obstáculos.</p>
          </div>
        </div>
        <div class="col-photo reveal">
          <img src="/meripet/img/foto_1.jpg" alt="Fachada de MeriPet, hospital para mascotas en Manuel Ávila Camacho, Mérida" loading="lazy" width="1100" height="825" />
        </div>
      </div>
    </section>

    <!-- ============ SERVICIOS ============ -->
    <section class="sec sec-panel" id="servicios">
      <div class="wrap">
        <p class="sec-kicker reveal">Qué ofrecemos</p>
        <h2 class="sec-title reveal">Servicios pensados para cada etapa</h2>
        <ul class="servicios reveal">
          <li class="serv-card serv-featured">
            <span class="serv-icon" aria-hidden="true">
              <svg viewBox="0 0 48 48"><path d="M24 41S5 29 5 16.5A10.5 10.5 0 0 1 24 9a10.5 10.5 0 0 1 19 7.5C43 29 24 41 24 41Z" fill="currentColor"/><path d="M24 13v16M16 21h16" stroke="#fdf6f2" stroke-width="4" stroke-linecap="round"/></svg>
            </span>
            <h3>Urgencias con atención inmediata</h3>
            <p>Cuando algo pasa, no esperas turno: te recibimos y actuamos al momento.</p>
          </li>
          <li class="serv-card">
            <h3>Consulta general y vacunación</h3>
            <p>Revisiones de rutina, esquemas de vacunación y desparasitación.</p>
          </li>
          <li class="serv-card">
            <h3>Cirugía y recuperación</h3>
            <p>Procedimientos quirúrgicos con monitoreo cercano durante la recuperación.</p>
          </li>
          <li class="serv-card">
            <h3>Tratamientos con seguimiento</h3>
            <p>Casos largos —como el de una gatita en tratamiento por meses— con la misma doctora dando seguimiento puntual.</p>
          </li>
          <li class="serv-card">
            <h3>Farmacia veterinaria</h3>
            <p>Medicamentos a buen precio, en la cantidad exacta que marca la receta.</p>
          </li>
          <li class="serv-card">
            <h3>Despedidas dignas</h3>
            <p>Acompañamiento y trato justo también en los momentos más difíciles.</p>
          </li>
        </ul>
        <p class="nota-acceso reveal">♿ Instalaciones con acceso para silla de ruedas.</p>
      </div>
    </section>

    <!-- ============ PRUEBA SOCIAL ============ -->
    <section class="sec" id="resenas">
      <div class="wrap">
        <p class="sec-kicker reveal">Lo que dicen en Google</p>
        <h2 class="sec-title reveal"><span class="coral-text">4.6 de 5</span> en 325 reseñas</h2>
        <div class="reviews reveal">
          <figure class="rev">
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«Excelente veterinaria👌 La doctora Jaqueline es la que estuvo viendo a mi gatita por mas de 3 meses de tratamiento en su ojito y todo bien. Muy profesional y lo que me gusta es que tratan con mucho amor a tus peluditos🥰»</blockquote>
            <figcaption><strong>Vanessa Paredes</strong><span>Hace 8 meses · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«Tuve la desgracia de que mis dos perritos fueran atacados por un pitbull, la atención en Meripet fue inmediata, lamentablemente una de mis mascotas no sobrevivió, pero el que si lo logró, ha tenido la fortuna de que su doctora lo ha monitoreado y seguido en su recuperación constantemente. Muy agradecido por tanto compromiso de parte de la Dra. Abril, un verdadero Angel de la guarda.»</blockquote>
            <figcaption><strong>jose heredia</strong><span>Hace un año · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«Llevé a eutanasia a mi gato agonizando y me cobraron lo justo, me apoyaron y demás. Los medicamentos a buen precio (te venden la cantidaz que dicta la receta) y el alimento también, las doctoras son muy lindas…»</blockquote>
            <figcaption><strong>Jhoana Martínez</strong><span>Hace 5 meses · Google</span></figcaption>
          </figure>
        </div>
        <div class="rev-photo reveal">
          <img src="/meripet/img/foto_4.jpg" alt="Gatita recién atendida, envuelta en una toalla en MeriPet" loading="lazy" width="619" height="1100" />
        </div>
        <div class="center reveal">
          <a class="btn btn-ghost" href="https://maps.google.com/?cid=14946807041865155620&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Leer más reseñas en Google</a>
        </div>
      </div>
    </section>

    <!-- ============ UBICACIÓN Y HORARIOS ============ -->
    <section class="sec sec-panel" id="ubicacion">
      <div class="wrap">
        <p class="sec-kicker reveal">Dónde estamos</p>
        <h2 class="sec-title reveal">Manuel Ávila Camacho, Mérida</h2>
        <div class="ubica reveal">
          <div class="ubica-info">
            <p class="dir">C. 12 313, Manuel Ávila Camacho<br />97159 Mérida, Yuc., México</p>
            <a class="btn btn-solid btn-sm" href="https://maps.google.com/?cid=14946807041865155620&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Abrir en Google Maps</a>
            <h3 class="horario-titulo">Horario</h3>
            <table class="horarios">
              <tbody>
                <tr data-dia="1"><th scope="row">Lunes</th><td>9:00–20:00</td></tr>
                <tr data-dia="2"><th scope="row">Martes</th><td>9:00–20:00</td></tr>
                <tr data-dia="3"><th scope="row">Miércoles</th><td>9:00–20:00</td></tr>
                <tr data-dia="4"><th scope="row">Jueves</th><td>9:00–20:00</td></tr>
                <tr data-dia="5"><th scope="row">Viernes</th><td>9:00–20:00</td></tr>
                <tr data-dia="6"><th scope="row">Sábado</th><td>9:00–16:00</td></tr>
                <tr data-dia="0"><th scope="row">Domingo</th><td>10:00–16:00</td></tr>
              </tbody>
            </table>
            <img class="rec-photo" src="/meripet/img/foto_5.jpg" alt="Perrito en recuperación tras su cirugía en MeriPet" loading="lazy" width="827" height="1100" />
          </div>
          <div class="mapa">
            <iframe
              src="https://www.google.com/maps?q=MeriPet%2C%20C.%2012%20313%2C%20Manuel%20%C3%81vila%20Camacho%2C%2097159%20M%C3%A9rida%2C%20Yuc.%2C%20M%C3%A9xico&output=embed"
              title="Mapa: MeriPet en Manuel Ávila Camacho, Mérida"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA FINAL ============ -->
    <section class="banda">
      <div class="wrap">
        <svg class="mark mark-banda" viewBox="0 0 48 48" aria-hidden="true">
          <path d="M24 41S5 29 5 16.5A10.5 10.5 0 0 1 24 9a10.5 10.5 0 0 1 19 7.5C43 29 24 41 24 41Z" fill="currentColor"/>
          <path d="M24 13v16M16 21h16" stroke="#e05b52" stroke-width="4" stroke-linecap="round"/>
        </svg>
        <h2 class="banda-title">¿Tu mascota te necesita hoy?</h2>
        <p class="banda-sub">Escríbenos y te atendemos con la urgencia y el cariño que merece.</p>
        <div class="cta-row">
          <a class="btn btn-dark" href="https://wa.me/529991486017" target="_blank" rel="noopener">WhatsApp directo</a>
          <a class="btn btn-dark-ghost" href="tel:+529991486017">Llamar · 999 148 6017</a>
        </div>
      </div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="pie">
      <div class="wrap">
        <p class="pie-logo">MeriPet</p>
        <p class="pie-dato">Hospital para mascotas · C. 12 313, Manuel Ávila Camacho, 97159 Mérida, Yuc.</p>
        <p class="pie-dato"><a href="tel:+529991486017">999 148 6017</a> · <a href="https://wa.me/529991486017" target="_blank" rel="noopener">WhatsApp</a></p>
        <p class="pie-mini">Lun–Vie 9:00–20:00 · Sáb 9:00–16:00 · Dom 10:00–16:00</p>
      </div>
    </footer>
  </main>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "VeterinaryCare",
    "name": "MeriPet",
    "telephone": "+529991486017",
    "url": "https://demos.ivang.mx/meripet",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "C. 12 313, Manuel Ávila Camacho",
      "addressLocality": "Mérida",
      "addressRegion": "Yucatán",
      "postalCode": "97159",
      "addressCountry": "MX"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.6",
      "reviewCount": "325"
    },
    "openingHours": ["Mo-Fr 09:00-20:00", "Sa 09:00-16:00", "Su 10:00-16:00"]
  }
  </script>

  <style is:global>
    :root {
      --paper: #fdf6f2;
      --paper-soft: #ffffff;
      --coral: #e05b52;
      --coral-deep: #c8433b;
      --coral-text: #b8382f;
      --peach: #f4c9a8;
      --peach-soft: #fbe4cf;
      --ink: #2a1f1d;
      --ink-soft: #6b5850;
      --line: rgba(42, 31, 29, 0.12);
      --display: "Livvic", "Arial Narrow", sans-serif;
      --body: "Inter", system-ui, sans-serif;
    }

    body {
      background: var(--paper);
      color: var(--ink);
      font-family: var(--body);
      font-size: 16.5px;
      line-height: 1.6;
      overflow-x: clip;
    }

    .mp ::selection { background: var(--peach); color: var(--ink); }
    .mp a:focus-visible,
    .mp .btn:focus-visible {
      outline: 3px solid var(--coral-deep);
      outline-offset: 3px;
    }

    .wrap { max-width: 1080px; margin: 0 auto; padding: 0 20px; }

    .mark { width: 26px; height: 26px; color: var(--coral); flex-shrink: 0; }
    .mark-plus { display: inline-flex; width: 0.85em; height: 0.85em; vertical-align: -0.1em; color: var(--coral); }
    .mark-plus svg { width: 100%; height: 100%; }

    /* ---------- HERO ---------- */
    .hero {
      position: relative;
      padding: 48px 0 0;
      overflow: hidden;
    }
    .hero-glow {
      position: absolute;
      inset: -20% -10% auto -10%;
      height: 620px;
      background: radial-gradient(560px 420px at 78% 12%, rgba(244, 201, 168, 0.55), transparent 65%),
                  radial-gradient(420px 320px at 8% 30%, rgba(224, 91, 82, 0.14), transparent 70%);
      pointer-events: none;
    }
    .hero-grid {
      position: relative;
      display: grid;
      grid-template-columns: 1fr;
      gap: 34px;
      align-items: center;
      padding-bottom: 30px;
    }
    .kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      font-size: 12.5px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--coral-text);
      margin: 0 0 18px;
    }
    .brand {
      margin: 0;
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(52px, 15vw, 104px);
      line-height: 0.95;
      color: var(--ink);
      display: flex;
      align-items: center;
    }
    .tagline {
      font-size: clamp(18px, 4.4vw, 23px);
      font-weight: 500;
      color: var(--ink-soft);
      max-width: 30ch;
      margin: 20px 0 20px;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 9px 16px;
      font-weight: 600;
      font-size: 14.5px;
      color: var(--ink);
      text-decoration: none;
      background: var(--paper-soft);
      box-shadow: 0 2px 10px rgba(42, 31, 29, 0.06);
    }
    .chip .star { color: var(--coral); }
    .chip:hover { border-color: var(--coral); }

    .cta-row { display: flex; flex-wrap: wrap; gap: 12px; margin: 24px 0 0; }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-family: var(--body);
      font-weight: 600;
      font-size: 16px;
      text-decoration: none;
      padding: 15px 24px;
      border-radius: 12px;
      transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
    }
    .btn:active { transform: scale(0.97); }
    .btn-solid { background: var(--coral-deep); color: #fff; }
    .btn-solid:hover { background: var(--coral); }
    .btn-ghost { border: 2px solid var(--line); color: var(--ink); }
    .btn-ghost:hover { border-color: var(--coral); color: var(--coral-text); }
    .btn-sm { font-size: 15px; padding: 12px 18px; }

    .hero-photo {
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 24px 50px rgba(42, 31, 29, 0.16);
      border: 6px solid var(--paper-soft);
      max-width: 420px;
      margin: 0 auto;
    }
    .hero-photo img { width: 100%; height: auto; object-fit: cover; }

    /* ---------- PULSO (firma) ---------- */
    .pulse-wrap { line-height: 0; }
    .pulse { width: 100%; height: 34px; display: block; }
    .pulse-line {
      fill: none;
      stroke: var(--coral);
      stroke-width: 2.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 1400;
      stroke-dashoffset: 1400;
      animation: pulse-draw 3.4s ease-in-out infinite;
    }
    @keyframes pulse-draw {
      0% { stroke-dashoffset: 1400; }
      55% { stroke-dashoffset: 0; }
      100% { stroke-dashoffset: -1400; }
    }

    /* ---------- SECCIONES ---------- */
    .sec { padding: 64px 0; }
    .sec-panel { background: var(--peach-soft); }
    .sec-kicker {
      font-weight: 600;
      font-size: 12.5px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--coral-text);
      margin: 0 0 10px;
    }
    .sec-title {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(30px, 7.5vw, 48px);
      line-height: 1.05;
      margin: 0 0 26px;
      color: var(--ink);
    }
    .coral-text { color: var(--coral-text); }

    .two-col { display: grid; grid-template-columns: 1fr; gap: 30px; align-items: center; }
    .about p { max-width: 60ch; margin: 0 0 16px; color: var(--ink-soft); }
    .about strong { color: var(--ink); }
    .col-photo img {
      width: 100%;
      border-radius: 20px;
      box-shadow: 0 18px 40px rgba(42, 31, 29, 0.14);
    }

    /* ---------- SERVICIOS ---------- */
    .servicios {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .serv-card {
      background: var(--paper-soft);
      border-radius: 16px;
      padding: 22px;
      box-shadow: 0 6px 18px rgba(42, 31, 29, 0.06);
    }
    .serv-featured {
      background: var(--coral-deep);
      color: #fff;
    }
    .serv-featured h3, .serv-featured p { color: #fff; }
    .serv-icon { display: inline-flex; width: 30px; height: 30px; color: #fff; margin-bottom: 10px; }
    .serv-icon svg { width: 100%; height: 100%; }
    .servicios h3 {
      font-family: var(--display);
      font-weight: 700;
      font-size: 19px;
      margin: 0 0 6px;
      color: var(--ink);
    }
    .servicios p { margin: 0; color: var(--ink-soft); font-size: 15px; }
    .nota-acceso { margin: 22px 0 0; color: var(--ink-soft); font-size: 14px; }

    /* ---------- RESEÑAS ---------- */
    .reviews {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
      margin: 0 0 26px;
    }
    .rev {
      margin: 0;
      background: var(--paper-soft);
      color: var(--ink);
      border-radius: 16px;
      padding: 20px;
      border: 1px solid var(--line);
      box-shadow: 0 10px 24px rgba(42, 31, 29, 0.06);
    }
    .rev-stars { color: var(--coral); font-size: 15px; letter-spacing: 0.15em; margin: 0 0 10px; }
    .rev blockquote { margin: 0 0 14px; font-size: 15.5px; line-height: 1.58; font-weight: 500; }
    .rev figcaption { display: flex; flex-direction: column; gap: 2px; }
    .rev figcaption strong { font-weight: 700; font-size: 15px; }
    .rev figcaption span { font-size: 13px; color: var(--ink-soft); }
    .rev-photo { max-width: 220px; margin: 0 auto 26px; border-radius: 18px; overflow: hidden; box-shadow: 0 16px 34px rgba(42, 31, 29, 0.14); }
    .rev-photo img { width: 100%; }
    .center { text-align: center; }

    /* ---------- UBICACIÓN ---------- */
    .ubica { display: grid; grid-template-columns: 1fr; gap: 28px; }
    .dir { font-size: 17px; font-weight: 500; margin: 0 0 16px; }
    .horario-titulo {
      font-family: var(--display);
      font-weight: 700;
      font-size: 20px;
      margin: 26px 0 10px;
      color: var(--ink);
    }
    .horarios { width: 100%; max-width: 400px; border-collapse: collapse; font-size: 15px; }
    .horarios th, .horarios td { padding: 9px 10px; border-bottom: 1px solid var(--line); text-align: left; }
    .horarios th { font-weight: 500; color: var(--ink); }
    .horarios td { color: var(--ink-soft); text-align: right; font-variant-numeric: tabular-nums; }
    .horarios tr.hoy th, .horarios tr.hoy td { color: #fff; background: var(--coral-deep); font-weight: 600; }
    .horarios tr.hoy th::after {
      content: "hoy";
      font-family: var(--display);
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: rgba(255,255,255,0.25);
      color: #fff;
      border-radius: 4px;
      padding: 2px 7px;
      margin-left: 10px;
      vertical-align: 1px;
    }
    .rec-photo { margin-top: 26px; border-radius: 16px; max-width: 220px; box-shadow: 0 14px 30px rgba(42, 31, 29, 0.14); }
    .mapa iframe {
      width: 100%;
      height: 300px;
      border: 0;
      border-radius: 16px;
      display: block;
    }

    /* ---------- CTA FINAL ---------- */
    .banda {
      background: var(--coral-deep);
      color: #fff;
      padding: 56px 0;
      text-align: center;
    }
    .mark-banda { width: 40px; height: 40px; color: #fff; margin-bottom: 14px; }
    .banda-title {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(28px, 7vw, 46px);
      line-height: 1.05;
      margin: 0 0 12px;
    }
    .banda-sub { margin: 0 auto 24px; max-width: 40ch; font-weight: 500; opacity: 0.95; }
    .banda .cta-row { justify-content: center; }
    .btn-dark { background: #fff; color: var(--coral-deep); }
    .btn-dark:hover { background: var(--peach-soft); }
    .btn-dark-ghost { border: 2px solid rgba(255,255,255,0.6); color: #fff; }
    .btn-dark-ghost:hover { border-color: #fff; }

    /* ---------- FOOTER ---------- */
    .pie {
      padding: 40px 0 96px;
      text-align: center;
    }
    .pie-logo {
      font-family: var(--display);
      font-weight: 700;
      font-size: 26px;
      color: var(--ink);
      margin: 0 0 10px;
    }
    .pie-dato { margin: 4px 0; color: var(--ink-soft); font-size: 14px; }
    .pie-dato a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--coral); }
    .pie-dato a:hover { color: var(--coral-text); }
    .pie-mini { margin: 14px 0 0; color: var(--ink-soft); font-size: 12.5px; opacity: 0.8; }

    /* ---------- REVEAL (solo con JS) ---------- */
    html.js .reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    html.js .reveal.in { opacity: 1; transform: none; }

    /* ---------- DESKTOP ---------- */
    @media (min-width: 760px) {
      .hero-grid { grid-template-columns: 1.15fr 0.85fr; gap: 50px; }
      .hero-photo { max-width: 100%; }
      .sec { padding: 96px 0; }
      .two-col { grid-template-columns: 1.1fr 0.9fr; }
      .servicios { grid-template-columns: repeat(3, 1fr); }
      .reviews { grid-template-columns: repeat(3, 1fr); align-items: start; }
      .ubica { grid-template-columns: 1fr 1.2fr; align-items: start; }
      .mapa iframe { height: 420px; }
    }
  </style>

  <script is:inline>
    (function () {
      var d = document;
      d.documentElement.classList.add('js');

      // Resaltar el día de hoy en la tabla de horarios
      var hoy = new Date().getDay(); // 0 = domingo
      var fila = d.querySelector('.horarios tr[data-dia="' + hoy + '"]');
      if (fila) fila.classList.add('hoy');

      // Scroll-reveal (mejora progresiva)
      var els = d.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach(function (el) { io.observe(el); });
      } else {
        els.forEach(function (el) { el.classList.add('in'); });
      }
    })();
  </script>
</BaseLayout>
