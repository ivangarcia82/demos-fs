---
import BaseLayout from '../../layouts/BaseLayout.astro';

const whatsapp = 'https://wa.me/529999444152';
const telefono = '999 944 4152';
const mapsUrl = 'https://maps.google.com/?cid=6540905639353415213&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA';
const mapEmbed = 'https://www.google.com/maps?q=C.%201H%2097%2C%20M%C3%A9xico%20Nte.%2C%2097128%20M%C3%A9rida%2C%20Yuc.%2C%20M%C3%A9xico&output=embed';
---
<BaseLayout
  title="Bleu Spa & Wellness — Un respiro en Mérida"
  description="Masaje descontracturante, mani y pedi delux y un rato de calma en México Norte, Mérida. ⭐ 4.6 · 261 reseñas en Google. Agenda por WhatsApp."
  slug="bleu-spa-wellness"
  ogImage="/bleu-spa-wellness/img/foto_2.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Marcellus&family=Mulish:wght@300;400;500;600;700&display=swap"
  favicon="💧"
  themeColor="#2c6b7e"
  whatsapp={whatsapp}
  telefono={telefono}
  mapsUrl={mapsUrl}
>
  <!-- ============ HERO ============ -->
  <header class="hero">
    <div class="ripple-campo" aria-hidden="true">
      <svg class="ripple" viewBox="0 0 200 200">
        <circle cx="100" cy="100" r="34"/>
        <circle cx="100" cy="100" r="58"/>
        <circle cx="100" cy="100" r="82"/>
        <circle cx="100" cy="100" r="99"/>
      </svg>
    </div>

    <div class="wrap hero-inner">
      <p class="eyebrow">
        <span class="gota" aria-hidden="true"></span>
        Spa &amp; Wellness · Mérida, Yucatán
      </p>

      <h1 class="marca">
        <span class="marca-nombre">Bleu</span>
        <span class="marca-sub">spa &amp; wellness</span>
      </h1>

      <p class="hero-frase">Respira hondo. En nuestra casa de México Norte, el masaje descontracturante, el mani y pedi delux y un rato para ti te esperan sin prisas.</p>

      <a class="chip-rating" href={mapsUrl} target="_blank" rel="noopener">
        <span class="estrellas" aria-hidden="true">★★★★★</span>
        <strong>4.6</strong><span class="chip-sep">·</span>261 reseñas en Google
      </a>

      <div class="hero-ctas">
        <a class="btn btn-agua" href={whatsapp} target="_blank" rel="noopener">Agenda por WhatsApp</a>
        <a class="btn btn-linea" href={mapsUrl} target="_blank" rel="noopener">Cómo llegar</a>
      </div>

      <figure class="marco marco-hero">
        <img src="/bleu-spa-wellness/img/foto_2.jpg" alt="Sala de descanso de Bleu Spa: dos personas en bata blanca junto al logo enmarcado de bleu spa & wellness" width="1800" height="1200" fetchpriority="high" />
      </figure>
    </div>
  </header>

  <!-- ============ FRANJA DE CONFIANZA ============ -->
  <section class="franja">
    <div class="wrap franja-grid">
      <div class="franja-dato">
        <span class="franja-num">4.6<span class="franja-est">★</span></span>
        <span class="franja-lbl">261 reseñas en Google</span>
      </div>
      <div class="franja-dato">
        <span class="franja-num">Lun a Sáb</span>
        <span class="franja-lbl">Siempre con cita previa</span>
      </div>
      <div class="franja-dato">
        <span class="franja-num">México Nte.</span>
        <span class="franja-lbl">A un lado del centro, Mérida</span>
      </div>
    </div>
  </section>

  <!-- ============ QUIÉNES SOMOS ============ -->
  <section class="seccion s-lino" id="nosotros">
    <div class="wrap grid-2">
      <div class="reveal">
        <p class="kicker"><span class="mini-onda" aria-hidden="true"></span>Quiénes somos</p>
        <h2>Un respiro en Mérida</h2>
        <p>Bleu Spa &amp; Wellness es una casa serena en la colonia México Norte, pensada para que bajes el ritmo desde que cruzas la puerta. Venimos a lo esencial: manos cuidadas, hombros ligeros y un rato de calma que se siente a lujo sin sentirse lejano.</p>
        <p>Nuestras clientas lo cuentan mejor que nosotros: la atención se cuida desde que agendas hasta que sales, las instalaciones son lindas y limpias, y hay dos nombres que se repiten en las reseñas — Angélica y Ángeles, terapeutas que la gente recomienda una y otra vez.</p>
        <p>Ven por el famoso mani y pedi delux, por un masaje descontracturante que deshace los nudos de la semana, o simplemente a darte un break. Agenda por WhatsApp y nosotros nos encargamos del resto.</p>
      </div>
      <figure class="marco marco-retrato reveal">
        <img src="/bleu-spa-wellness/img/foto_5.jpg" alt="Recibidor de Bleu Spa con repisas de velas, productos y un sillón junto a la entrada" width="900" height="1200" loading="lazy" />
        <figcaption>Nuestro recibidor</figcaption>
      </figure>
    </div>
  </section>

  <!-- ============ SERVICIOS ============ -->
  <section class="seccion s-niebla" id="servicios">
    <div class="wrap">
      <p class="kicker reveal"><span class="mini-onda" aria-hidden="true"></span>Lo que puedes vivir aquí</p>
      <h2 class="reveal">Servicios pensados para soltar la prisa</h2>
      <p class="intro reveal">Todo con cita: escríbenos por WhatsApp y te acomodamos el día.</p>

      <div class="serv-grid">
        <article class="serv serv-color reveal">
          <span class="serv-glifo" aria-hidden="true"></span>
          <h3>Masaje descontracturante</h3>
          <p>El favorito de las reseñas. Llega con la tensión de la semana y déjala en la camilla, en manos de terapeutas que la gente recomienda por su nombre.</p>
        </article>

        <article class="serv serv-imagen reveal">
          <img src="/bleu-spa-wellness/img/foto_1.jpg" alt="Dos clientas relajadas en los sillones de pedicure de Bleu Spa mientras las atienden" width="1200" height="850" loading="lazy" />
          <div class="serv-cuerpo">
            <h3>Manicure y pedicure spa</h3>
            <p>Del clásico al delux, en sillones donde nadie te apura. Manos y pies como nuevos, con calma.</p>
          </div>
        </article>

        <article class="serv serv-imagen reveal">
          <img src="/bleu-spa-wellness/img/foto_4.jpg" alt="Cabina de faciales de Bleu Spa con camillas blancas, luz suave y paredes color agua" width="900" height="850" class="img-cabina" loading="lazy" />
          <div class="serv-cuerpo">
            <h3>Cabina facial</h3>
            <p>Cuidado de la piel en cabina, con luz tenue y todo impecable. Un momento solo para tu rostro.</p>
          </div>
        </article>

        <article class="serv serv-suave reveal">
          <span class="serv-glifo serv-glifo-arena" aria-hidden="true"></span>
          <h3>Un ritual de a dos</h3>
          <p>Nuestra sala para venir en pareja o con tu mejor amiga: batas, silencio y un brindis. El break sabe mejor compartido.</p>
        </article>
      </div>

      <ul class="chips reveal">
        <li>💳 Aceptamos tarjeta</li>
        <li>🚗 Estacionamiento disponible</li>
        <li>♿ Acceso para silla de ruedas</li>
        <li>📲 Citas por WhatsApp</li>
      </ul>
    </div>
  </section>

  <!-- ============ GALERÍA ============ -->
  <section class="seccion s-lino" id="galeria">
    <div class="wrap">
      <p class="kicker reveal"><span class="mini-onda" aria-hidden="true"></span>Un vistazo</p>
      <h2 class="reveal">Así se siente Bleu por dentro</h2>
      <div class="galeria reveal">
        <a class="g-item g-ancho" href="/bleu-spa-wellness/img/foto_1.jpg" target="_blank" rel="noopener">
          <img src="/bleu-spa-wellness/img/foto_1.jpg" alt="Sala de manicure y pedicure de Bleu Spa, luminosa y en tonos azul cielo" width="1200" height="800" loading="lazy" />
        </a>
        <a class="g-item" href="/bleu-spa-wellness/img/foto_4.jpg" target="_blank" rel="noopener">
          <img src="/bleu-spa-wellness/img/foto_4.jpg" alt="Cabina de faciales de Bleu Spa" width="800" height="1000" loading="lazy" />
        </a>
        <a class="g-item" href="/bleu-spa-wellness/img/foto_2.jpg" target="_blank" rel="noopener">
          <img src="/bleu-spa-wellness/img/foto_2.jpg" alt="Sala de descanso en pareja de Bleu Spa con el logo enmarcado" width="1200" height="800" loading="lazy" />
        </a>
        <a class="g-item" href="/bleu-spa-wellness/img/foto_5.jpg" target="_blank" rel="noopener">
          <img src="/bleu-spa-wellness/img/foto_5.jpg" alt="Repisa de productos y velas de Bleu Spa en el recibidor" width="800" height="1000" loading="lazy" />
        </a>
        <a class="g-item" href="/bleu-spa-wellness/img/foto_3.jpg" target="_blank" rel="noopener">
          <img src="/bleu-spa-wellness/img/foto_3.jpg" alt="Fachada turquesa de Bleu Spa en México Norte, Mérida" width="800" height="1000" loading="lazy" />
        </a>
      </div>
    </div>
  </section>

  <!-- ============ DIFERENCIADORES ============ -->
  <section class="seccion s-blanco" id="porque">
    <div class="wrap">
      <p class="kicker reveal"><span class="mini-onda" aria-hidden="true"></span>Por qué elegir Bleu</p>
      <h2 class="reveal">Detalles que se notan (y que las clientas repiten)</h2>
      <div class="dif-grid">
        <div class="dif reveal">
          <span class="dif-num">01</span>
          <h3>Atención de principio a fin</h3>
          <p>Desde que agendas por WhatsApp hasta que sales por la puerta: cada paso, cuidado.</p>
        </div>
        <div class="dif reveal">
          <span class="dif-num">02</span>
          <h3>Lindas y limpias</h3>
          <p>Instalaciones pensadas para relajarte de verdad, impecables en cada visita.</p>
        </div>
        <div class="dif reveal">
          <span class="dif-num">03</span>
          <h3>Terapeutas con nombre</h3>
          <p>Angélica y Ángeles se repiten en las reseñas por lo bien que atienden.</p>
        </div>
        <div class="dif reveal">
          <span class="dif-num">04</span>
          <h3>Fácil de visitar</h3>
          <p>Estacionamiento disponible, aceptamos tarjeta y acceso para silla de ruedas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ RESEÑAS (banda profunda) ============ -->
  <section class="seccion s-hondo" id="resenas">
    <svg class="ola" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,30 C240,60 480,0 720,24 C960,48 1200,8 1440,32 L1440,60 L0,60 Z"/>
    </svg>
    <div class="wrap">
      <p class="kicker kicker-claro reveal"><span class="mini-onda mini-onda-claro" aria-hidden="true"></span>Lo que dicen quienes ya vinieron</p>
      <h2 class="h-claro reveal">Palabra de sus clientas</h2>
      <p class="rating-grande reveal"><span class="estrellas-oro" aria-hidden="true">★★★★★</span> <strong>4.6</strong> · 261 reseñas en Google</p>

      <div class="res-grid">
        <blockquote class="res reveal">
          <p>Si deseas un excelente masaje no busques más, aquí es. Angelica y Ángeles son terapeutas increíbles, recomendable al 300%, vale la pena.</p>
          <footer><cite>Ricardo Arellanos</cite><span>Hace 3 semanas</span></footer>
        </blockquote>
        <blockquote class="res reveal">
          <p>…La atención desde que agendas, llegas y en los servicios es muy buena. Instalaciones lindas y limpias. Muy recomendado.</p>
          <footer><cite>Fernanda Ixchel García Ortiz</cite><span>Hace 2 meses</span></footer>
        </blockquote>
        <blockquote class="res reveal">
          <p>…Bleu es un salón que súper recomiendo, el mani y pedi delux es lo más delicioso que existe.</p>
          <footer><cite>Ale Casanova</cite><span>Hace 5 años</span></footer>
        </blockquote>
      </div>

      <p class="centrado reveal">
        <a class="btn btn-marfil" href={mapsUrl} target="_blank" rel="noopener">Leer más reseñas en Google</a>
      </p>
    </div>
  </section>

  <!-- ============ UBICACIÓN Y HORARIOS ============ -->
  <section class="seccion s-niebla" id="ubicacion">
    <div class="wrap">
      <p class="kicker reveal"><span class="mini-onda" aria-hidden="true"></span>Encuéntranos</p>
      <h2 class="reveal">La casa turquesa de México Norte</h2>
      <p class="intro reveal">C. 1H 97, México Nte., 97128 Mérida, Yuc. — busca la casa azul con el rótulo de Bleu en la barda.</p>

      <div class="ubica-grid">
        <figure class="marco marco-retrato reveal">
          <img src="/bleu-spa-wellness/img/foto_3.jpg" alt="Fachada turquesa de Bleu Spa con su rótulo y una motoneta azul estacionada enfrente" width="900" height="1200" class="img-fachada" loading="lazy" />
          <figcaption>Nuestra fachada</figcaption>
        </figure>

        <div class="ubica-col">
          <div class="mapa reveal">
            <iframe
              src={mapEmbed}
              width="600" height="320" style="border:0" loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Mapa de Bleu Spa & Wellness en Mérida"></iframe>
          </div>
          <div class="horarios reveal">
            <h3>Horarios</h3>
            <table>
              <tbody>
                <tr data-day="1"><td>Lunes</td><td>8:00–20:00</td></tr>
                <tr data-day="2"><td>Martes</td><td>8:00–20:00</td></tr>
                <tr data-day="3"><td>Miércoles</td><td>8:00–20:00</td></tr>
                <tr data-day="4"><td>Jueves</td><td>8:00–20:00</td></tr>
                <tr data-day="5"><td>Viernes</td><td>8:00–20:00</td></tr>
                <tr data-day="6"><td>Sábado</td><td>8:00–18:00</td></tr>
                <tr data-day="0"><td>Domingo</td><td class="cerrado">Cerrado</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA FINAL ============ -->
  <section class="cta-final">
    <div class="ripple-campo ripple-campo-cta" aria-hidden="true">
      <svg class="ripple" viewBox="0 0 200 200">
        <circle cx="100" cy="100" r="34"/>
        <circle cx="100" cy="100" r="58"/>
        <circle cx="100" cy="100" r="82"/>
        <circle cx="100" cy="100" r="99"/>
      </svg>
    </div>
    <div class="wrap cta-inner">
      <h2 class="h-claro reveal">Regálate el break que te debes</h2>
      <p class="reveal">Escríbenos por WhatsApp y agenda tu cita. Te esperamos de lunes a sábado.</p>
      <a class="btn btn-marfil btn-grande reveal" href={whatsapp} target="_blank" rel="noopener">Agendar por WhatsApp</a>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->
  <footer class="pie">
    <div class="wrap">
      <p class="pie-marca">Bleu</p>
      <p class="pie-sub">spa &amp; wellness</p>
      <p class="pie-dir">C. 1H 97, México Nte., 97128 Mérida, Yuc.</p>
      <p class="pie-links">
        <a href="tel:+529999444152">999 944 4152</a>
        <span>·</span>
        <a href={whatsapp} target="_blank" rel="noopener">WhatsApp</a>
      </p>
      <p class="pie-nota">Abierto de lunes a sábado · Domingo descansamos</p>
    </div>
  </footer>

  <style is:global>
    :root {
      --agua: #2c6b7e;
      --agua-hondo: #1c4a58;
      --bleu: #5b93a6;
      --niebla: #cfe1e7;
      --niebla-suave: #e9f1f3;
      --arena: #c7a877;
      --arena-suave: #e7dcc6;
      --lino: #f5f0e7;
      --marfil: #ffffff;
      --tinta: #22434c;
      --tinta-suave: #4a656e;
    }

    body {
      font-family: 'Mulish', system-ui, sans-serif;
      color: var(--tinta);
      background: var(--lino);
      line-height: 1.7;
      font-size: 1.0625rem;
      font-weight: 400;
      overflow-x: hidden;
    }
    .wrap { max-width: 1060px; margin-inline: auto; padding-inline: 22px; }

    h2 {
      font-family: 'Marcellus', serif;
      font-weight: 400;
      font-size: clamp(1.85rem, 5.6vw, 2.7rem);
      line-height: 1.16;
      letter-spacing: .01em;
      color: var(--agua);
      margin: 0 0 1rem;
    }
    p { margin: 0 0 1rem; }

    .kicker {
      display: inline-flex; align-items: center; gap: .55rem;
      font-size: .74rem; font-weight: 700;
      letter-spacing: .26em; text-transform: uppercase;
      color: var(--agua); margin: 0 0 .7rem;
    }
    .kicker-claro { color: #bcd7de; }
    .mini-onda {
      width: 22px; height: 8px; flex: none;
      border-radius: 0 0 22px 22px;
      border: 1.5px solid var(--arena);
      border-top: 0;
    }
    .mini-onda-claro { border-color: #cdb98a; }
    .intro { color: var(--tinta-suave); max-width: 42rem; margin-top: -.2rem; }

    /* ---------- Botones ---------- */
    .btn {
      display: inline-block;
      padding: .9rem 1.9rem;
      border-radius: 999px;
      font-family: 'Mulish', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: .01em;
      text-decoration: none;
      cursor: pointer;
      transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
    }
    .btn:hover { transform: translateY(-2px); }
    .btn:focus-visible, a:focus-visible {
      outline: 3px solid var(--arena);
      outline-offset: 3px;
      border-radius: 6px;
    }
    .btn-agua {
      background: var(--agua);
      color: #fff;
      box-shadow: 0 10px 24px rgba(28,74,88,.28);
    }
    .btn-agua:hover { background: #245c6c; box-shadow: 0 14px 30px rgba(28,74,88,.34); }
    .btn-linea {
      background: transparent;
      color: var(--agua);
      box-shadow: inset 0 0 0 1.5px rgba(44,107,126,.55);
    }
    .btn-linea:hover { box-shadow: inset 0 0 0 1.5px var(--agua); }
    .btn-marfil {
      background: #fff;
      color: var(--agua-hondo);
      box-shadow: 0 10px 24px rgba(0,0,0,.18);
    }
    .btn-grande { padding: 1.05rem 2.4rem; font-size: 1.05rem; }

    /* ---------- Firma: ripple que respira ---------- */
    .ripple-campo {
      position: absolute;
      top: 0; left: 50%;
      transform: translateX(-50%);
      width: min(120vw, 900px);
      aspect-ratio: 1;
      z-index: 0;
      pointer-events: none;
    }
    .ripple { width: 100%; height: 100%; display: block; }
    .ripple circle {
      fill: none;
      stroke: var(--bleu);
      stroke-width: 1;
      transform-box: fill-box;
      transform-origin: center;
      opacity: .22;
      animation: respira 7s ease-in-out infinite;
    }
    .ripple circle:nth-child(1) { animation-delay: 0s; }
    .ripple circle:nth-child(2) { animation-delay: .55s; }
    .ripple circle:nth-child(3) { animation-delay: 1.1s; }
    .ripple circle:nth-child(4) { animation-delay: 1.65s; }
    @keyframes respira {
      0%, 100% { transform: scale(.9); opacity: .1; }
      50%      { transform: scale(1.06); opacity: .34; }
    }

    /* ---------- HERO ---------- */
    .hero {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(120% 80% at 50% -10%, rgba(207,225,231,.9), transparent 60%),
        linear-gradient(180deg, #eef4f4 0%, var(--lino) 72%);
      padding: 2.6rem 0 3.4rem;
      text-align: center;
    }
    .hero .ripple-campo { top: -8%; opacity: .8; }
    .hero-inner { position: relative; z-index: 1; }
    .eyebrow {
      display: inline-flex; align-items: center; gap: .6rem;
      font-size: .74rem; font-weight: 700; letter-spacing: .28em;
      text-transform: uppercase; color: var(--agua);
      margin: .6rem 0 1.4rem;
    }
    .gota {
      width: 9px; height: 9px; flex: none;
      background: var(--bleu);
      border-radius: 50% 50% 50% 0;
      transform: rotate(45deg);
    }
    .marca { margin: 0; line-height: 1; }
    .marca-nombre {
      display: block;
      font-family: 'Marcellus', serif;
      font-weight: 400;
      font-size: clamp(4.6rem, 24vw, 9.5rem);
      line-height: .9;
      letter-spacing: .01em;
      color: var(--agua);
    }
    .marca-sub {
      display: block;
      font-family: 'Mulish', sans-serif;
      font-weight: 600;
      font-size: clamp(.72rem, 3.2vw, 1rem);
      letter-spacing: .52em;
      text-indent: .52em;
      text-transform: lowercase;
      color: var(--bleu);
      margin-top: 1.1rem;
    }
    .hero-frase {
      max-width: 34rem;
      margin: 1.7rem auto 1.4rem;
      font-size: clamp(1.02rem, 3.6vw, 1.18rem);
      color: var(--tinta);
    }
    .chip-rating {
      display: inline-flex; align-items: center; gap: .5rem;
      background: #fff;
      box-shadow: 0 6px 18px rgba(28,74,88,.12);
      color: var(--tinta); text-decoration: none;
      padding: .5rem 1.1rem; border-radius: 999px;
      font-size: .95rem;
    }
    .chip-rating strong { font-family: 'Marcellus', serif; font-size: 1.15rem; color: var(--agua); }
    .chip-sep { color: var(--arena); }
    .estrellas { color: var(--arena); letter-spacing: .1em; }
    .hero-ctas {
      display: flex; flex-wrap: wrap; justify-content: center;
      gap: .8rem; margin: 1.7rem 0 0;
    }
    .marco-hero {
      max-width: 760px;
      margin: 3rem auto 0;
    }

    /* ---------- Marcos ---------- */
    .marco {
      background: #fff;
      padding: 12px;
      border-radius: 6px;
      box-shadow: 0 22px 44px rgba(28,74,88,.16);
      margin: 0;
    }
    .marco img { border-radius: 3px; width: 100%; }
    .marco figcaption {
      font-family: 'Marcellus', serif;
      font-size: .95rem;
      color: var(--agua);
      text-align: center;
      padding-top: .6rem;
    }
    .marco-retrato { max-width: 420px; margin-inline: auto; }
    .marco-retrato img { aspect-ratio: 3 / 4; object-fit: cover; object-position: 50% 60%; }
    .marco-retrato .img-fachada { object-position: 50% 32%; }

    /* ---------- Secciones ---------- */
    .seccion { padding: 4.6rem 0; position: relative; }
    .s-lino { background: var(--lino); }
    .s-niebla { background: var(--niebla-suave); }
    .s-blanco { background: #fff; }
    .s-hondo {
      background:
        radial-gradient(120% 70% at 85% 0%, rgba(91,147,166,.28), transparent 55%),
        var(--agua-hondo);
      color: #eaf3f5;
      padding-top: 5.4rem;
    }
    .h-claro { color: #fff; }

    .grid-2 { display: grid; gap: 2.4rem; align-items: center; }

    /* ---------- Franja de confianza ---------- */
    .franja { background: var(--agua); color: #fff; padding: 1.7rem 0; }
    .franja-grid {
      display: grid; grid-template-columns: 1fr; gap: 1.2rem;
      text-align: center;
    }
    .franja-dato { display: flex; flex-direction: column; gap: .15rem; }
    .franja-num {
      font-family: 'Marcellus', serif;
      font-size: 1.55rem; line-height: 1;
    }
    .franja-est { color: #e7dcc6; font-size: 1.1rem; }
    .franja-lbl { font-size: .86rem; color: rgba(255,255,255,.82); letter-spacing: .02em; }

    /* ---------- Servicios ---------- */
    .serv-grid { display: grid; gap: 1.3rem; margin-top: 2.2rem; }
    .serv {
      border-radius: 16px;
      overflow: hidden;
      background: #fff;
      box-shadow: 0 12px 30px rgba(28,74,88,.09);
    }
    .serv h3 {
      font-family: 'Marcellus', serif;
      font-weight: 400;
      font-size: 1.4rem;
      margin: 0 0 .5rem;
      color: var(--agua-hondo);
    }
    .serv p { margin: 0; color: var(--tinta-suave); }
    .serv-color, .serv-suave { padding: 1.8rem 1.7rem; }
    .serv-color {
      background: linear-gradient(160deg, #327889, var(--agua));
      color: #fff;
    }
    .serv-color h3 { color: #fff; }
    .serv-color p { color: rgba(255,255,255,.9); }
    .serv-suave {
      background: linear-gradient(160deg, #f4ecdc, var(--arena-suave));
      color: #4a3f28;
    }
    .serv-suave h3 { color: #6a5227; }
    .serv-suave p { color: #6a5a3d; }
    .serv-glifo {
      display: block; width: 30px; height: 12px;
      border: 2px solid rgba(255,255,255,.7);
      border-top: 0;
      border-radius: 0 0 30px 30px;
      margin-bottom: 1rem;
    }
    .serv-glifo-arena { border-color: rgba(122,96,45,.55); }
    .serv-imagen img { width: 100%; aspect-ratio: 16 / 11; object-fit: cover; }
    .serv-imagen .img-cabina { object-position: 50% 66%; }
    .serv-cuerpo { padding: 1.4rem 1.6rem 1.6rem; }

    .chips {
      list-style: none;
      display: flex; flex-wrap: wrap; gap: .6rem;
      padding: 0; margin: 2.2rem 0 0;
    }
    .chips li {
      background: #fff;
      box-shadow: inset 0 0 0 1px rgba(44,107,126,.28);
      color: var(--agua-hondo);
      border-radius: 999px;
      padding: .5rem 1.05rem;
      font-size: .9rem;
      font-weight: 600;
    }

    /* ---------- Galería ---------- */
    .galeria {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: .7rem;
      margin-top: 2.2rem;
    }
    .g-item {
      display: block; overflow: hidden;
      border-radius: 12px;
      background: var(--niebla);
    }
    .g-item img {
      width: 100%; height: 100%;
      aspect-ratio: 4 / 5; object-fit: cover;
      transition: transform .5s ease;
    }
    .g-ancho { grid-column: span 2; }
    .g-ancho img { aspect-ratio: 16 / 9; }
    .g-item:hover img { transform: scale(1.05); }

    /* ---------- Diferenciadores ---------- */
    .dif-grid {
      display: grid; grid-template-columns: 1fr; gap: 1.6rem;
      margin-top: 2.4rem;
    }
    .dif { border-top: 2px solid var(--niebla); padding-top: 1.1rem; }
    .dif-num {
      font-family: 'Marcellus', serif;
      font-size: 1.1rem;
      color: var(--arena);
      letter-spacing: .05em;
    }
    .dif h3 {
      font-family: 'Marcellus', serif;
      font-weight: 400;
      font-size: 1.28rem;
      color: var(--agua-hondo);
      margin: .35rem 0 .5rem;
    }
    .dif p { margin: 0; color: var(--tinta-suave); }

    /* ---------- Reseñas ---------- */
    .ola {
      position: absolute; top: 0; left: 0;
      width: 100%; height: 46px;
      transform: translateY(-99%);
      display: block;
    }
    .ola path { fill: var(--agua-hondo); }
    .rating-grande { font-size: 1.1rem; margin: .3rem 0 2rem; color: #dceaed; }
    .rating-grande strong { font-family: 'Marcellus', serif; font-size: 1.7rem; color: #fff; }
    .estrellas-oro { color: #e7dcc6; letter-spacing: .1em; }
    .res-grid { display: grid; gap: 1.2rem; }
    .res {
      margin: 0;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 16px;
      padding: 1.7rem 1.5rem 1.4rem;
      position: relative;
    }
    .res::before {
      content: '”';
      position: absolute; top: .3rem; right: 1.1rem;
      font-family: 'Marcellus', serif;
      font-size: 2.6rem; line-height: 1;
      color: rgba(199,168,119,.55);
    }
    .res p { margin: 0 0 1rem; color: #f1f7f8; font-size: 1.02rem; }
    .res footer { display: flex; flex-direction: column; gap: .1rem; }
    .res cite { font-style: normal; font-weight: 700; color: #fff; }
    .res footer span { font-size: .85rem; color: #a9c6cf; }
    .centrado { text-align: center; margin: 2.4rem 0 0; }

    /* ---------- Ubicación ---------- */
    .ubica-grid { display: grid; gap: 1.8rem; margin-top: 2.2rem; align-items: start; }
    .ubica-col { display: grid; gap: 1.4rem; }
    .mapa {
      border-radius: 14px; overflow: hidden;
      background: #fff; padding: 8px;
      box-shadow: 0 14px 32px rgba(28,74,88,.14);
    }
    .mapa iframe { display: block; width: 100%; height: 300px; border-radius: 8px; }
    .horarios {
      background: #fff;
      border-radius: 14px;
      padding: 1.4rem 1.5rem 1.6rem;
      box-shadow: 0 12px 30px rgba(28,74,88,.09);
      overflow-x: auto;
    }
    .horarios h3 {
      font-family: 'Marcellus', serif;
      font-weight: 400;
      color: var(--agua-hondo);
      margin: 0 0 .8rem;
      font-size: 1.3rem;
    }
    .horarios table { width: 100%; border-collapse: collapse; min-width: 250px; }
    .horarios td { padding: .55rem .3rem; border-bottom: 1px solid #eaf1f2; }
    .horarios tr:last-child td { border-bottom: 0; }
    .horarios td:last-child { text-align: right; font-weight: 700; color: var(--agua-hondo); }
    .horarios td.cerrado { color: var(--tinta-suave); font-weight: 600; }
    .horarios tr.hoy td { background: rgba(44,107,126,.1); }
    .horarios tr.hoy td:first-child { border-radius: 8px 0 0 8px; }
    .horarios tr.hoy td:last-child { border-radius: 0 8px 8px 0; }
    .horarios tr.hoy td:first-child::after {
      content: 'hoy';
      font-size: .66rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .08em;
      color: #fff; background: var(--agua);
      border-radius: 999px; padding: .12rem .5rem;
      margin-left: .5rem;
    }

    /* ---------- CTA final ---------- */
    .cta-final {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(120% 90% at 50% 120%, rgba(28,74,88,.5), transparent 60%),
        linear-gradient(160deg, #327889, var(--agua) 60%, #235c6c);
      color: #fff;
      text-align: center;
      padding: 4.6rem 0;
    }
    .ripple-campo-cta { top: auto; bottom: -40%; opacity: .5; }
    .ripple-campo-cta .ripple circle { stroke: #bcd7de; }
    .cta-inner { position: relative; z-index: 1; }
    .cta-inner p { max-width: 34rem; margin: .4rem auto 1.8rem; color: rgba(255,255,255,.92); font-size: 1.1rem; }

    /* ---------- Footer ---------- */
    .pie {
      background: var(--agua-hondo);
      color: #bcd7de;
      text-align: center;
      padding: 3.2rem 0 6.5rem;
      font-size: .96rem;
    }
    .pie-marca {
      font-family: 'Marcellus', serif;
      font-size: 2.6rem;
      color: #fff;
      margin: 0; line-height: 1;
    }
    .pie-sub {
      letter-spacing: .5em; text-indent: .5em;
      font-size: .74rem; font-weight: 600;
      color: var(--arena-suave);
      margin: .5rem 0 1.3rem;
    }
    .pie-dir { margin: .3rem 0; }
    .pie-links { margin: .5rem 0; }
    .pie-links a { color: #fff; font-weight: 700; text-decoration-color: var(--arena-suave); }
    .pie-links span { margin: 0 .4rem; opacity: .5; }
    .pie-nota { font-size: .84rem; opacity: .7; margin-top: 1.1rem; }

    /* ---------- Reveal (mejora progresiva) ---------- */
    html.js .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity .7s ease, transform .7s ease;
    }
    html.js .reveal.in { opacity: 1; transform: none; }

    /* ---------- Desktop ---------- */
    @media (min-width: 720px) {
      .seccion { padding: 5.6rem 0; }
      .franja-grid { grid-template-columns: repeat(3, 1fr); }
      .grid-2 { grid-template-columns: 1.05fr .95fr; gap: 3rem; }
      .serv-grid { grid-template-columns: 1fr 1fr; }
      .serv-color, .serv-suave { display: flex; flex-direction: column; justify-content: center; }
      .galeria { grid-template-columns: repeat(4, 1fr); }
      .g-ancho { grid-column: span 2; grid-row: span 2; }
      .g-ancho img { aspect-ratio: auto; height: 100%; }
      .dif-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem 2.4rem; }
      .res-grid { grid-template-columns: repeat(3, 1fr); align-items: start; }
      .ubica-grid { grid-template-columns: .8fr 1.2fr; gap: 2.4rem; }
      .mapa iframe { height: 340px; }
    }
    @media (min-width: 980px) {
      .marca-nombre { font-size: 9.5rem; }
    }
  </style>

  <script is:inline>
    // Mejora progresiva: reveals y resaltar el día de hoy.
    document.documentElement.classList.add('js');

    var hoy = new Date().getDay();
    var fila = document.querySelector('.horarios tr[data-day="' + hoy + '"]');
    if (fila) fila.classList.add('hoy');

    var nodos = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entradas) {
        entradas.forEach(function (e) {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            obs.unobserve(e.target);
          }
        });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
      nodos.forEach(function (n) { obs.observe(n); });
    } else {
      nodos.forEach(function (n) { n.classList.add('in'); });
    }
  </script>
</BaseLayout>
