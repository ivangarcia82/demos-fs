    }

    /* ---------- Hero ---------- */
    .hero {
      background:
        radial-gradient(120% 90% at 12% -10%, #fff6e6 0%, rgba(255,246,230,0) 55%),
        radial-gradient(110% 80% at 100% 0%, var(--teal-soft) 0%, rgba(227,240,237,0) 50%),
        var(--crema);
      padding: clamp(24px, 6vw, 52px) 0 clamp(40px, 7vw, 64px);
      overflow: hidden;
    }
    .hero-grid { display: grid; gap: clamp(24px, 5vw, 44px); align-items: center; }
    .eyebrow {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: 'Baloo 2', sans-serif; font-weight: 600; font-size: 0.9rem;
      color: var(--teal-deep); background: #fff; border: 1px solid #e6ddc8;
      padding: 0.35rem 0.85rem; border-radius: 999px; margin: 0 0 1rem;
    }
    .eyebrow .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--coral); box-shadow: 0 0 0 4px rgba(239,108,77,.18); }
    .hero-name {
      font-size: clamp(3rem, 15vw, 5.2rem); font-weight: 800; letter-spacing: -0.02em;
      color: var(--teal-deep); margin: 0;
    }
    .hero-sub {
      display: block; font-size: clamp(1rem, 4.2vw, 1.35rem); font-weight: 600;
      letter-spacing: 0.02em; color: var(--coral-btn); margin-top: 0.15rem;
    }
    .pulse { width: min(300px, 78%); height: auto; margin: 0.9rem 0 0.4rem; display: block; }
    .pulse-path { fill: none; stroke: var(--teal); stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
    .pulse-paw { fill: var(--coral); }
    .reveal-on .pulse-path { stroke-dasharray: 640; stroke-dashoffset: 640; animation: draw 1.7s .35s ease forwards; }
    .reveal-on .pulse-paw { opacity: 0; animation: popIn .5s 1.7s ease forwards; }
    @keyframes draw { to { stroke-dashoffset: 0; } }
    @keyframes popIn { to { opacity: 1; } }

    .hero-tag { font-size: clamp(1.05rem, 3.4vw, 1.28rem); color: var(--tinta); max-width: 30ch; margin: 0.2rem 0 1.1rem; }
    .rating-pill {
      display: inline-flex; align-items: center; gap: 0.45rem; flex-wrap: wrap;
      background: #fff; border: 1px solid #eadfca; border-radius: 999px;
      padding: 0.45rem 0.95rem; font-size: 0.98rem; color: var(--tinta); margin: 0 0 1.3rem;
    }
    .rating-pill strong { font-family: 'Baloo 2', sans-serif; font-size: 1.1rem; color: var(--teal-deep); }
    .stars { color: var(--oro); letter-spacing: 0.05em; }

    .hero-cta { display: flex; flex-wrap: wrap; gap: 0.7rem; }
    .hero-cta.center { justify-content: center; }
    .hero-hours { font-size: 0.9rem; color: var(--tinta-soft); margin: 0.9rem 0 0; }

    .hero-media { position: relative; margin: 0; }
    .hero-media img {
      width: 100%; border-radius: 26px; object-fit: cover;
      aspect-ratio: 4 / 5; box-shadow: 0 30px 60px -28px rgba(13,84,77,.55);
      border: 6px solid #fff;
    }
    .hero-badge {
      position: absolute; left: 14px; bottom: 14px;
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--oro); color: #3b2c0a; font-family: 'Baloo 2', sans-serif; font-weight: 700;
      font-size: 0.9rem; padding: 0.45rem 0.85rem 0.45rem 0.5rem; border-radius: 999px;
      box-shadow: 0 10px 24px -10px rgba(0,0,0,.4);
    }
    .paw-mark { display: inline-flex; width: 30px; height: 30px; background: #fff; border-radius: 50%; padding: 5px; }
    .paw-mark svg { fill: var(--coral); width: 100%; height: 100%; }
    .paw-mark.big { width: 62px; height: 62px; padding: 12px; margin: 0 auto 0.4rem; }
    .paw-mark.big svg { fill: var(--oro); }

    /* ---------- Stats ---------- */
    .stats { background: var(--teal-deep); color: #fff; padding: clamp(22px, 4vw, 30px) 0; }
    .stats-row { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px 12px; text-align: center; }
    .stat { display: flex; flex-direction: column; gap: 2px; }
    .stat-num { font-family: 'Baloo 2', sans-serif; font-weight: 700; font-size: clamp(1.3rem, 5vw, 1.7rem); color: #fff; }
    .stat-star { color: var(--oro); font-size: 0.85em; margin-left: 2px; }
    .stat-label { font-size: 0.82rem; color: #bfe0da; letter-spacing: 0.02em; }

    /* ---------- About ---------- */
    .about-grid { display: grid; gap: clamp(26px, 5vw, 48px); align-items: center; }
    .about-copy p { color: var(--tinta); }
    .about-media { margin: 0; }
    .about-media img { width: 100%; border-radius: 22px; aspect-ratio: 4 / 3; object-fit: cover; object-position: 62% 42%; box-shadow: 0 22px 44px -26px rgba(13,84,77,.5); }
    .about-media figcaption { font-size: 0.86rem; color: var(--tinta-soft); margin-top: 0.6rem; text-align: center; font-style: italic; }

    /* ---------- Why ---------- */
    .why { background: var(--crema-hi); }
    .why-grid { list-style: none; margin: 2rem 0 0; padding: 0; display: grid; gap: 16px; }
    .why-card {
      background: var(--card); border: 1px solid #efe6d3; border-radius: 20px;
      padding: 1.5rem 1.4rem; box-shadow: 0 14px 30px -26px rgba(13,84,77,.5);
    }
    .why-ico { display: inline-flex; width: 52px; height: 52px; border-radius: 15px; background: var(--teal-soft); align-items: center; justify-content: center; margin-bottom: 0.9rem; }
    .why-ico svg { width: 30px; height: 30px; fill: var(--teal); }
    .why-ico .ico-pulse { fill: none; width: 34px; }
    .why-ico .ico-pulse path { fill: none; stroke: var(--teal); stroke-width: 18; stroke-linecap: round; stroke-linejoin: round; vector-effect: non-scaling-stroke; }
    .why-card h3 { color: var(--teal-deep); margin-bottom: 0.4rem; }
    .why-card p { margin: 0; color: var(--tinta-soft); font-size: 0.97rem; }

    /* ---------- CTA band ---------- */
    .cta-band { background: linear-gradient(120deg, var(--coral) 0%, var(--coral-btn) 100%); color: #fff; padding: clamp(28px, 5vw, 40px) 0; }
    .cta-band-inner { display: flex; flex-direction: column; gap: 1rem; align-items: center; text-align: center; }
    .cta-band-inner p { font-family: 'Baloo 2', sans-serif; font-weight: 600; font-size: clamp(1.15rem, 4vw, 1.5rem); margin: 0; max-width: 24ch; color: #fff; }
    .cta-band .btn-primary { background: #fff; color: var(--coral-btn); box-shadow: 0 10px 24px -10px rgba(0,0,0,.35); }
    .cta-band .btn-primary:hover { background: #fff5ef; }

    /* ---------- Team ---------- */
    .team { background: var(--teal); color: #fff; }
    .team h2.on-teal { color: #fff; }
    .team-lead { color: #d7ece8; max-width: 46ch; margin: 0.5rem auto 2rem; }
    .team-grid { display: grid; gap: 16px; }
    .team-card {
      background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.16);
      border-radius: 20px; padding: 1.6rem 1.4rem; text-align: center;
    }
    .avatar {
      display: inline-flex; align-items: center; justify-content: center;
      width: 58px; height: 58px; border-radius: 50%;
      background: var(--oro); color: #3b2c0a; font-family: 'Baloo 2', sans-serif; font-weight: 800; font-size: 1.5rem;
      margin-bottom: 0.7rem;
    }
    .team-card h3 { color: #fff; }
    .team-card .role { color: var(--oro); font-family: 'Baloo 2', sans-serif; font-weight: 600; font-size: 0.92rem; margin: 0.15rem 0 0.9rem; }
    .team-quote { color: #eafffb; font-size: 0.98rem; margin: 0 0 0.7rem; }
    .team-by { color: #b7ddd7; font-size: 0.85rem; font-weight: 600; margin: 0; }

    /* ---------- Gallery ---------- */
    .gallery-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-top: 2rem; }
    .gallery-grid figure { margin: 0; border-radius: 18px; overflow: hidden; box-shadow: 0 16px 32px -24px rgba(13,84,77,.5); }
    .gallery-grid img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 3 / 4; display: block; }
    .gallery-grid .g-wide { grid-column: 1 / -1; }
    .gallery-grid .g-wide img { aspect-ratio: 16 / 10; }

    /* ---------- Reviews ---------- */
    .reviews { background: var(--crema-hi); }
    .reviews-score { font-size: 1.05rem; margin: 0.4rem 0 2rem; }
    .reviews-score strong { font-family: 'Baloo 2', sans-serif; color: var(--teal-deep); font-size: 1.2rem; }
    .reviews-grid { display: grid; gap: 16px; }
    .review {
      background: var(--card); border: 1px solid #efe6d3; border-radius: 20px;
      padding: 1.5rem 1.5rem 1.3rem; margin: 0; position: relative;
      box-shadow: 0 14px 30px -26px rgba(13,84,77,.5);
    }
    .review::before {
      content: "\201C"; font-family: 'Baloo 2', sans-serif; font-size: 3.4rem; line-height: 1;
      color: var(--oro); position: absolute; top: 0.2rem; right: 1rem; opacity: .5;
    }
    .review p { font-size: 1.02rem; color: var(--tinta); margin: 0 0 1rem; }
    .review footer { display: flex; flex-direction: column; }
    .r-name { font-family: 'Baloo 2', sans-serif; font-weight: 700; color: var(--teal-deep); }
    .r-when { font-size: 0.82rem; color: var(--tinta-soft); }
    .reviews-cta { margin-top: 2rem; }

    /* ---------- Location ---------- */
    .location-grid { display: grid; gap: clamp(24px, 5vw, 40px); align-items: start; }
    .addr { font-size: 1.05rem; color: var(--tinta); margin-bottom: 0.9rem; }
    .chip {
      display: inline-flex; align-items: center; gap: 0.45rem;
      background: var(--teal-soft); color: var(--teal-deep); font-weight: 600;
      border-radius: 999px; padding: 0.4rem 0.9rem; font-size: 0.9rem; margin: 0 0 1.5rem;
    }
    .hours-title { color: var(--teal-deep); margin-bottom: 0.6rem; }
    .hours { width: 100%; border-collapse: collapse; margin-bottom: 1.6rem; max-width: 360px; }
    .hours th, .hours td { padding: 0.55rem 0.2rem; border-bottom: 1px solid #ece2cd; }
    .hours th { font-family: 'Karla', sans-serif; font-weight: 600; color: var(--tinta); text-align: left; }
    .hours td { text-align: right; color: var(--tinta-soft); font-variant-numeric: tabular-nums; }
    .hours tr.closed th, .hours tr.closed td { color: #a99f92; }
    .loc-cta { display: flex; flex-wrap: wrap; gap: 0.7rem; }
    .map-frame { border-radius: 22px; overflow: hidden; border: 6px solid #fff; box-shadow: 0 22px 44px -26px rgba(13,84,77,.5); background: #dfe7e5; }
    .map-frame iframe { width: 100%; height: 340px; border: 0; display: block; }

    /* ---------- Final CTA ---------- */
    .final-cta { background: var(--teal-deep); color: #fff; padding: clamp(48px, 8vw, 80px) 0; text-align: center; }
    .final-inner h2 { color: #fff; max-width: 20ch; margin: 0 auto 0.8rem; }
    .final-inner p { color: #cfe7e2; max-width: 44ch; margin: 0 auto 1.6rem; }

    /* ---------- Footer ---------- */
    .foot { background: #0a423d; color: #cfe7e2; padding: 34px 0 90px; text-align: center; }
    .foot-name { font-family: 'Baloo 2', sans-serif; font-weight: 700; color: #fff; font-size: 1.05rem; margin: 0 0 0.4rem; }
    .foot-line { font-size: 0.92rem; margin: 0.15rem 0; }
    .foot-line a { color: var(--oro); font-weight: 600; text-decoration: none; }
    .foot-line a:hover { text-decoration: underline; }

    /* ---------- Reveal (progressive enhancement) ---------- */
    .reveal-on .reveal { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }
    .reveal-on .reveal.in { opacity: 1; transform: none; }

    /* ---------- Responsive ---------- */
    @media (min-width: 720px) {
      .stats-row { grid-template-columns: repeat(4, 1fr); }
      .why-grid { grid-template-columns: repeat(2, 1fr); }
      .team-grid { grid-template-columns: repeat(3, 1fr); }
      .reviews-grid { grid-template-columns: repeat(2, 1fr); }
      .gallery-grid { grid-template-columns: repeat(3, 1fr); }
      .gallery-grid .g-wide { grid-column: 1 / 3; }
    }
    @media (min-width: 900px) {
      .hero-grid { grid-template-columns: 1.05fr 0.95fr; }
      .about-grid { grid-template-columns: 1.1fr 0.9fr; }
      .location-grid { grid-template-columns: 0.9fr 1.1fr; }
      .why-grid { grid-template-columns: repeat(4, 1fr); }
    }
  </style>

  <script is:inline>
    (function () {
      var root = document.documentElement;
      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) return;
      root.classList.add('reveal-on');
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
      document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
    })();
  </script>
</BaseLayout>
