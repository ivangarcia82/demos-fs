---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Carlos Luis — Barbería y Peluquería · Arte, pasión y corte"
  description="Barbería y peluquería en García Ginerés, Mérida. ⭐ 4.9 con 175 reseñas en Google. Corte, barba, color, maquillaje y spa de manos y pies. Lun–Sáb 11:00 a 21:00."
  slug="barberia-y-peluqueria-carlos-luis"
  ogImage="/barberia-y-peluqueria-carlos-luis/img/foto_5.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Young+Serif&family=Hanken+Grotesk:ital,wght@0,400;0,600;0,700;1,400&display=swap"
  favicon="💈"
  themeColor="#181410"
  whatsapp={"https://wa.me/529992515072"}
  telefono={"999 251 5072"}
  mapsUrl={"https://maps.google.com/?cid=4491559599674334634&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA"}
>
  <!-- ============ HERO ============ -->
  <header class="hero">
    <img
      class="hero-img"
      src="/barberia-y-peluqueria-carlos-luis/img/foto_5.jpg"
      alt="El barbero de Carlos Luis sonríe junto a dos niños recién cortados, uno con el cabello naranja y otro morado"
      fetchpriority="high"
    />
    <div class="hero-velo" aria-hidden="true"></div>
    <div class="hero-cuerpo wrap">
      <p class="eyebrow">Barbería · Peluquería · García Ginerés, Mérida</p>
      <h1 class="display hero-titulo">Carlos&nbsp;Luis</h1>
      <p class="hero-lema">«Arte, pasión y corte.»</p>
      <p class="hero-sub">
        Cortes limpios y bien definidos para él, para ella
        y para los peques de la casa.
      </p>
      <a class="chip" href="https://maps.google.com/?cid=4491559599674334634&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">
        <span class="chip-estrella">★</span> 4.9 · 175 reseñas en Google
      </a>
      <div class="hero-cta">
        <a class="btn btn-oro" href="https://wa.me/529992515072" target="_blank" rel="noopener">Escríbenos por WhatsApp</a>
        <a class="btn btn-fantasma" href="https://maps.google.com/?cid=4491559599674334634&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Cómo llegar</a>
      </div>
    </div>
  </header>

  <!-- ============ CINTA ============ -->
  <div class="cinta" aria-hidden="true">
    <div class="cinta-pista">
      <span>ARTE ★ PASIÓN ★ CORTE ★ BARBA ★ COLOR ★ SPA ★ </span>
      <span>ARTE ★ PASIÓN ★ CORTE ★ BARBA ★ COLOR ★ SPA ★ </span>
    </div>
  </div>

  <!-- ============ NOSOTROS ============ -->
  <section class="seccion nosotros" id="nosotros">
    <div class="wrap nosotros-grid">
      <div class="nosotros-texto rv">
        <p class="kicker">Sobre nosotros</p>
        <h2 class="display">Tijera de un lado, color del otro.</h2>
        <p>
          «Arte, pasión y corte» — así lo dice el vinil de nuestra entrada, y así
          trabajamos todos los días. Somos una barbería y peluquería de barrio en
          García Ginerés: navaja y tijera de un lado, color y spa del otro, y el
          mismo trato amable para todo el que cruza la puerta.
        </p>
        <p>
          Muchos de nuestros clientes llegaron caminando, de paso por la zona, y se
          quedaron para siempre. Nuestros cortes salen limpios y bien definidos,
          justo como los pides — y si solo quieres las puntas, respetamos las puntas.
        </p>
        <p>
          Del lado del salón, Ana María se encarga del color, el maquillaje, el
          peinado y el spa de manos y pies, con esa atención al detalle que nuestras
          clientas describen como impecable.
        </p>
      </div>
      <div class="nosotros-fotos">
        <figure class="foto-marco rv">
          <img src="/barberia-y-peluqueria-carlos-luis/img/foto_2.jpg" alt="Cliente recibiendo un facial en el sillón de la barbería, con la vitrina y el logo de Carlos Luis al fondo" loading="lazy" />
          <figcaption>Facial en el sillón, con calma.</figcaption>
        </figure>
        <figure class="foto-marco foto-marco-b rv">
          <img src="/barberia-y-peluqueria-carlos-luis/img/foto_4.jpg" alt="La fachada de Barbería y Peluquería Carlos Luis en García Ginerés, con sus viniles de Arte, Pasión y Corte" loading="lazy" />
          <figcaption>Nuestra entrada en la calle 11.</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============ SERVICIOS: EL PIZARRÓN ============ -->
  <section class="seccion servicios" id="servicios">
    <div class="wrap">
      <p class="kicker centrado">Servicios</p>
      <h2 class="display centrado">El pizarrón de la entrada</h2>
      <p class="sub centrado">
        Los mismos servicios que ves al llegar. Escríbenos por WhatsApp y te
        contamos todo con calma.
      </p>

      <div class="board-colgante rv">
        <span class="gancho gancho-a" aria-hidden="true"></span>
        <span class="gancho gancho-b" aria-hidden="true"></span>
        <div class="board" role="list" aria-label="Lista de servicios">
          <p class="board-titulo">B A R B E R Í A</p>
          <p class="board-estrellas" aria-hidden="true">★ ★ ★ ★ ★</p>
          <p class="board-nombre">« CARLOS LUIS »</p>

          <p class="board-grupo">— La barbería —</p>
          <div class="brow" role="listitem"><span class="bnombre">Corte</span><span class="bpuntos"></span><span class="bstar">★</span></div>
          <div class="brow" role="listitem"><span class="bnombre">Barba</span><span class="bpuntos"></span><span class="bstar">★</span></div>
          <div class="brow" role="listitem"><span class="bnombre">Corte y barba VIP</span><span class="bpuntos"></span><span class="bstar">★</span></div>
          <div class="brow" role="listitem"><span class="bnombre">Facial</span><span class="bpuntos"></span><span class="bstar">★</span></div>
          <div class="brow" role="listitem"><span class="bnombre">Keratina</span><span class="bpuntos"></span><span class="bstar">★</span></div>
          <div class="brow" role="listitem"><span class="bnombre">Tinte global y raíz</span><span class="bpuntos"></span><span class="bstar">★</span></div>

          <p class="board-grupo board-grupo-salon">— El salón de Ana María —</p>
          <div class="brow" role="listitem"><span class="bnombre">Peinado y maquillaje</span><span class="bpuntos"></span><span class="bstar">★</span></div>
          <div class="brow" role="listitem"><span class="bnombre">Manicure spa</span><span class="bpuntos"></span><span class="bstar">★</span></div>
          <div class="brow" role="listitem"><span class="bnombre">Pedicure spa</span><span class="bpuntos"></span><span class="bstar">★</span></div>
          <div class="brow" role="listitem"><span class="bnombre">Planchado dama</span><span class="bpuntos"></span><span class="bstar">★</span></div>
          <div class="brow" role="listitem"><span class="bnombre">Corte dama</span><span class="bpuntos"></span><span class="bstar">★</span></div>
          <div class="brow" role="listitem"><span class="bnombre">Cortes para niños</span><span class="bpuntos"></span><span class="bstar">★</span></div>
        </div>
      </div>

      <p class="board-nota rv">💳 Aceptamos tarjetas &nbsp;·&nbsp; ¿Vas pasando por la 11? Entra — así llegaron varios de nuestros clientes de cinco estrellas.</p>
    </div>
  </section>

  <!-- ============ RESEÑAS ============ -->
  <section class="seccion resenas" id="resenas">
    <div class="wrap">
      <div class="resenas-cabeza rv">
        <p class="kicker kicker-oro">Lo que dicen en Google</p>
        <h2 class="display">4.9 estrellas no se cortan solas.</h2>
        <p class="resenas-dato"><span class="num-grande">4.9</span> <span class="de-resenas">de 175 reseñas<br />en Google</span></p>
      </div>

      <div class="resenas-lista">
        <blockquote class="resena rv">
          <p class="resena-estrellas" aria-label="5 estrellas">★★★★★</p>
          <p class="resena-texto">“Pasaba por la zona y decidí entrar. Para mi sorpresa me hicieron un corte excelente justo como lo quería. Trato amable y ameno.”</p>
          <footer><cite>Manuel Segura González</cite> · Hace 4 meses</footer>
        </blockquote>

        <blockquote class="resena rv">
          <p class="resena-estrellas" aria-label="5 estrellas">★★★★★</p>
          <p class="resena-texto">“Los cortes de cabello del barbero estuvieron súper limpios y bien definidos, y él fue muy, muy amable. Ana María también fue muy atenta y amable. Me encantó el pedicure — increíble — y su atención al detalle al aplicar el color en el cabello fue impecable…”</p>
          <footer><cite>claudia Ancona</cite> · Hace 11 meses</footer>
        </blockquote>

        <blockquote class="resena rv">
          <p class="resena-estrellas" aria-label="5 estrellas">★★★★★</p>
          <p class="resena-texto">“Me encantó el corte ! Y además que respetan el solo las puntas 😅y además me dieron shampoo y dejaron divino el cabello…”</p>
          <footer><cite>Daniela Góngora</cite> · Hace 11 meses</footer>
        </blockquote>
      </div>

      <div class="centrado rv">
        <a class="btn btn-oro" href="https://maps.google.com/?cid=4491559599674334634&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Leer más reseñas en Google</a>
      </div>
    </div>
  </section>

  <!-- ============ UBICACIÓN Y HORARIOS ============ -->
  <section class="seccion ubicacion" id="ubicacion">
    <div class="wrap">
      <p class="kicker">Ubicación y horarios</p>
      <h2 class="display">En la 11, entre 12 y 14.</h2>
      <div class="ubi-grid">
        <div class="ubi-info rv">
          <p class="ubi-direccion">
            C. 11 118, entre 12 y 14,<br />
            García Ginerés, 97070<br />
            Mérida, Yuc., México
          </p>
          <a class="btn btn-tinta" href="https://maps.google.com/?cid=4491559599674334634&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Cómo llegar</a>

          <div class="tabla-wrap">
            <table class="horas">
              <caption class="visually-hidden">Horarios de atención</caption>
              <tbody>
                <tr data-d="lunes"><th scope="row">Lunes</th><td>11:00 – 21:00</td></tr>
                <tr data-d="martes"><th scope="row">Martes</th><td>11:00 – 21:00</td></tr>
                <tr data-d="miércoles"><th scope="row">Miércoles</th><td>11:00 – 21:00</td></tr>
                <tr data-d="jueves"><th scope="row">Jueves</th><td>11:00 – 21:00</td></tr>
                <tr data-d="viernes"><th scope="row">Viernes</th><td>11:00 – 21:00</td></tr>
                <tr data-d="sábado"><th scope="row">Sábado</th><td>11:00 – 21:00</td></tr>
                <tr data-d="domingo" class="cerrado"><th scope="row">Domingo</th><td>Cerrado</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="ubi-visual">
          <figure class="foto-marco rv">
            <img src="/barberia-y-peluqueria-carlos-luis/img/foto_3.jpg" alt="Entrada de Barbería y Peluquería Carlos Luis: viniles dorados con el logo y el póster de Ana María maquillaje profesional" loading="lazy" />
            <figcaption>Así se ve nuestra entrada — búscanos por los viniles.</figcaption>
          </figure>
          <div class="mapa rv">
            <iframe
              src="https://www.google.com/maps?q=Barber%C3%ADa%20y%20Peluquer%C3%ADa%20Carlos%20Luis%2C%20Calle%2011%20118%2C%20Garc%C3%ADa%20Giner%C3%A9s%2C%2097070%20M%C3%A9rida%2C%20Yucat%C3%A1n&output=embed"
              title="Mapa de Barbería y Peluquería Carlos Luis en García Ginerés, Mérida"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA FINAL ============ -->
  <section class="seccion cta-final">
    <div class="wrap centrado rv">
      <h2 class="display cta-titulo">¿Vas pasando por la calle 11? Entra.</h2>
      <p class="sub">
        Así llegaron varios de nuestros clientes de cinco estrellas: de paso, sin
        conocernos — y salieron con su nuevo corte favorito.
      </p>
      <div class="hero-cta cta-centrado">
        <a class="btn btn-oro" href="https://wa.me/529992515072" target="_blank" rel="noopener">Escríbenos por WhatsApp</a>
        <a class="btn btn-fantasma" href="tel:+529992515072">Llamar 999 251 5072</a>
      </div>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->
  <footer class="pie">
    <div class="wrap">
      <p class="pie-nombre display">Carlos Luis</p>
      <p class="pie-lema">Barbería y Peluquería · «Arte, pasión y corte»</p>
      <p class="pie-datos">
        C. 11 118, entre 12 y 14, García Ginerés, Mérida, Yuc. ·
        <a href="tel:+529992515072">999 251 5072</a>
      </p>
      <p class="pie-mini">Lunes a sábado, 11:00 a 21:00 · Domingo cerrado · 💳 Aceptamos tarjetas</p>
    </div>
  </footer>

  <style is:global>
    :root {
      --tinta: #181410;
      --tinta-suave: #2a231b;
      --hueso: #f5edda;
      --hueso-2: #ece0c5;
      --blanco: #fbf7ec;
      --oliva: #b5a243;
      --oliva-claro: #d3c46a;
      --oliva-texto: #6d5f1d;
      --rojo: #b03a32;
      --rojo-claro: #e0655e;
      --plata: #cfc9bd;
    }

    body {
      background: var(--hueso);
      color: var(--tinta);
      font-family: 'Hanken Grotesk', system-ui, -apple-system, sans-serif;
      font-size: 1.0625rem;
      line-height: 1.65;
      overflow-x: hidden;
    }

    .display {
      font-family: 'Young Serif', Georgia, serif;
      font-weight: 400;
      line-height: 1.08;
      margin: 0 0 0.6em;
      letter-spacing: -0.01em;
    }
    h2.display { font-size: clamp(1.75rem, 5.5vw, 2.75rem); }

    .wrap { max-width: 1060px; margin: 0 auto; padding: 0 20px; }
    .seccion { padding: clamp(64px, 10vw, 110px) 0; }
    .centrado { text-align: center; }

    .kicker {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--oliva-texto);
      margin: 0 0 0.9em;
    }
    .kicker-oro { color: var(--oliva-claro); }
    .sub {
      max-width: 560px;
      margin: 0 auto 1.5em;
      color: var(--tinta-suave);
    }

    /* ---------- Botones ---------- */
    .btn {
      display: inline-block;
      padding: 0.85em 1.6em;
      border-radius: 999px;
      font-weight: 700;
      font-size: 1rem;
      text-decoration: none;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      border: 2px solid transparent;
    }
    .btn:hover { transform: translateY(-2px); }
    .btn:focus-visible { outline: 3px solid var(--oliva); outline-offset: 3px; }
    .btn-oro {
      background: var(--oliva);
      color: var(--tinta);
      box-shadow: 0 6px 18px rgba(24, 20, 16, 0.35);
    }
    .btn-oro:hover { background: var(--oliva-claro); }
    .btn-fantasma {
      border-color: rgba(251, 247, 236, 0.7);
      color: var(--blanco);
    }
    .btn-fantasma:hover { border-color: var(--blanco); background: rgba(251, 247, 236, 0.1); }
    .btn-tinta {
      background: var(--tinta);
      color: var(--hueso);
    }
    .btn-tinta:hover { background: var(--tinta-suave); }

    /* ---------- Hero ---------- */
    .hero {
      position: relative;
      min-height: calc(100svh - 38px);
      display: flex;
      align-items: flex-end;
      background: var(--tinta);
      color: var(--blanco);
      overflow: hidden;
    }
    .hero-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 50% 22%;
    }
    .hero-velo {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(24, 20, 16, 0.55) 0%,
        rgba(24, 20, 16, 0.15) 38%,
        rgba(24, 20, 16, 0.62) 68%,
        rgba(24, 20, 16, 0.95) 100%
      );
    }
    .hero-cuerpo {
      position: relative;
      width: 100%;
      padding-top: 46vh;
      padding-bottom: clamp(36px, 6vw, 72px);
      animation: hero-entra 0.9s ease both;
    }
    @keyframes hero-entra {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: none; }
    }
    .eyebrow {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--oliva-claro);
      margin: 0 0 0.8em;
    }
    .hero-titulo {
      font-size: clamp(3.2rem, 13vw, 7.5rem);
      margin: 0 0 0.15em;
      text-shadow: 0 4px 30px rgba(0, 0, 0, 0.45);
    }
    .hero-lema {
      font-family: 'Young Serif', Georgia, serif;
      font-size: clamp(1.15rem, 3.6vw, 1.6rem);
      color: var(--oliva-claro);
      margin: 0 0 0.4em;
    }
    .hero-sub {
      max-width: 34ch;
      margin: 0 0 1.2em;
      font-size: clamp(1rem, 2.8vw, 1.15rem);
      color: rgba(251, 247, 236, 0.92);
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 0.45em;
      background: rgba(24, 20, 16, 0.55);
      border: 1px solid rgba(211, 196, 106, 0.5);
      backdrop-filter: blur(4px);
      color: var(--blanco);
      font-weight: 600;
      font-size: 0.92rem;
      padding: 0.45em 1em;
      border-radius: 999px;
      text-decoration: none;
      margin-bottom: 1.3em;
    }
    .chip:focus-visible { outline: 3px solid var(--oliva); outline-offset: 3px; }
    .chip-estrella { color: var(--oliva-claro); }
    .hero-cta { display: flex; flex-wrap: wrap; gap: 12px; }
    .cta-centrado { justify-content: center; }

    /* ---------- Cinta ---------- */
    .cinta {
      background: var(--tinta);
      color: var(--oliva);
      overflow: hidden;
      border-top: 1px solid rgba(211, 196, 106, 0.25);
      border-bottom: 1px solid rgba(211, 196, 106, 0.25);
      padding: 10px 0;
    }
    .cinta-pista {
      display: flex;
      width: max-content;
      white-space: nowrap;
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.28em;
      animation: cinta-rueda 26s linear infinite;
    }
    @keyframes cinta-rueda {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    /* ---------- Nosotros ---------- */
    .nosotros { background: var(--hueso); }
    .nosotros-grid { display: grid; gap: 40px; }
    .nosotros-texto p { margin: 0 0 1.1em; max-width: 58ch; }
    .nosotros-fotos { display: grid; gap: 26px; }
    .foto-marco {
      margin: 0;
      background: var(--blanco);
      padding: 10px 10px 14px;
      box-shadow: 0 12px 30px rgba(24, 20, 16, 0.16);
      transform: rotate(-1.2deg);
    }
    .foto-marco img { width: 100%; }
    .foto-marco figcaption {
      font-size: 0.85rem;
      color: var(--tinta-suave);
      padding-top: 10px;
      font-style: italic;
      text-align: center;
    }
    .foto-marco-b { transform: rotate(1.1deg); }
    @media (min-width: 880px) {
      .nosotros-grid { grid-template-columns: 1.1fr 0.9fr; align-items: start; }
      .nosotros-fotos { padding-top: 30px; }
    }

    /* ---------- Pizarrón ---------- */
    .servicios { background: var(--hueso-2); }
    .board-colgante {
      position: relative;
      max-width: 460px;
      margin: 56px auto 0;
      padding-top: 16px;
    }
    .gancho {
      position: absolute;
      top: 0;
      width: 12px;
      height: 12px;
      border: 3px solid #9a938a;
      border-radius: 50%;
      background: transparent;
    }
    .gancho-a { left: 18%; }
    .gancho-b { right: 18%; }
    .board {
      background:
        repeating-linear-gradient(
          180deg,
          #14100b 0px,
          #14100b 4px,
          #1e1811 4px,
          #1e1811 5px
        );
      border: 6px solid var(--plata);
      border-radius: 4px;
      box-shadow:
        inset 0 0 40px rgba(0, 0, 0, 0.55),
        0 18px 40px rgba(24, 20, 16, 0.3);
      padding: clamp(22px, 6vw, 36px) clamp(18px, 5vw, 32px);
      color: #f2ede1;
    }
    .board p, .board .brow {
      text-shadow: 0 -1px 0 rgba(255, 255, 255, 0.12), 0 2px 3px rgba(0, 0, 0, 0.65);
    }
    .board-titulo {
      text-align: center;
      font-weight: 700;
      font-size: 1.15rem;
      letter-spacing: 0.3em;
      margin: 0 0 4px;
    }
    .board-estrellas {
      text-align: center;
      color: var(--oliva-claro);
      letter-spacing: 0.4em;
      margin: 0 0 4px;
      font-size: 0.9rem;
    }
    .board-nombre {
      text-align: center;
      font-weight: 700;
      letter-spacing: 0.18em;
      font-size: 1rem;
      margin: 0 0 18px;
    }
    .board-grupo {
      text-align: center;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--oliva-claro);
      margin: 20px 0 10px;
    }
    .board-grupo-salon { color: var(--rojo-claro); }
    .brow {
      display: flex;
      align-items: baseline;
      gap: 10px;
      padding: 5px 0;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-size: clamp(0.82rem, 2.6vw, 0.95rem);
    }
    .bpuntos {
      flex: 1;
      border-bottom: 2px dotted rgba(242, 237, 225, 0.35);
      transform: translateY(-4px);
    }
    .bstar { color: var(--oliva-claro); font-size: 0.85em; }
    .board-nota {
      text-align: center;
      max-width: 460px;
      margin: 22px auto 0;
      font-size: 0.92rem;
      color: var(--tinta-suave);
    }

    /* ---------- Reseñas ---------- */
    .resenas { background: var(--tinta); color: var(--blanco); }
    .resenas-cabeza { max-width: 640px; margin-bottom: 40px; }
    .resenas-cabeza .display { color: var(--blanco); }
    .resenas-dato { display: flex; align-items: center; gap: 14px; margin: 18px 0 0; }
    .num-grande {
      font-family: 'Young Serif', Georgia, serif;
      font-size: clamp(3rem, 9vw, 4.5rem);
      color: var(--oliva-claro);
      line-height: 1;
    }
    .de-resenas {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: rgba(251, 247, 236, 0.75);
      line-height: 1.5;
    }
    .resenas-lista { display: grid; gap: 22px; margin-bottom: 44px; }
    @media (min-width: 880px) {
      .resenas-lista { grid-template-columns: repeat(3, 1fr); align-items: start; }
    }
    .resena {
      margin: 0;
      background: rgba(251, 247, 236, 0.05);
      border: 1px solid rgba(211, 196, 106, 0.22);
      border-radius: 10px;
      padding: 26px 24px;
    }
    .resena-estrellas {
      color: var(--oliva-claro);
      letter-spacing: 0.25em;
      margin: 0 0 12px;
      font-size: 0.9rem;
    }
    .resena-texto { margin: 0 0 16px; font-size: 0.98rem; line-height: 1.7; }
    .resena footer {
      font-size: 0.85rem;
      color: rgba(251, 247, 236, 0.65);
    }
    .resena cite { font-style: normal; font-weight: 700; color: var(--blanco); }

    /* ---------- Ubicación ---------- */
    .ubicacion { background: var(--hueso); }
    .ubi-grid { display: grid; gap: 40px; margin-top: 26px; }
    @media (min-width: 880px) {
      .ubi-grid { grid-template-columns: 0.85fr 1.15fr; align-items: start; }
    }
    .ubi-direccion {
      font-family: 'Young Serif', Georgia, serif;
      font-size: 1.25rem;
      line-height: 1.5;
      margin: 0 0 1em;
    }
    .tabla-wrap { overflow-x: auto; margin-top: 28px; }
    .horas {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.98rem;
    }
    .horas th, .horas td {
      text-align: left;
      padding: 9px 12px;
      border-bottom: 1px solid rgba(24, 20, 16, 0.12);
    }
    .horas td { text-align: right; font-variant-numeric: tabular-nums; }
    .horas .cerrado td { color: var(--rojo); font-weight: 600; }
    .horas tr.hoy th, .horas tr.hoy td {
      background: var(--tinta);
      color: var(--hueso);
    }
    .horas tr.hoy th::after {
      content: ' · hoy';
      font-size: 0.75em;
      color: var(--oliva-claro);
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }
    .horas tr.hoy.cerrado td { color: var(--rojo-claro); }
    .ubi-visual { display: grid; gap: 26px; }
    .mapa {
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 12px 30px rgba(24, 20, 16, 0.16);
    }
    .mapa iframe {
      display: block;
      width: 100%;
      height: 320px;
      border: 0;
      filter: grayscale(0.15) sepia(0.12);
    }

    /* ---------- CTA final ---------- */
    .cta-final {
      background: var(--tinta);
      color: var(--blanco);
      border-top: 1px solid rgba(211, 196, 106, 0.25);
    }
    .cta-titulo { color: var(--blanco); max-width: 18ch; margin-left: auto; margin-right: auto; }
    .cta-final .sub { color: rgba(251, 247, 236, 0.8); }

    /* ---------- Footer ---------- */
    .pie {
      background: #0f0c09;
      color: rgba(251, 247, 236, 0.75);
      padding: 54px 0 90px;
      text-align: center;
      font-size: 0.92rem;
    }
    .pie-nombre { color: var(--oliva-claro); font-size: 1.6rem; margin-bottom: 0.2em; }
    .pie-lema { margin: 0 0 1em; letter-spacing: 0.08em; }
    .pie-datos { margin: 0 0 0.5em; }
    .pie-datos a { color: var(--oliva-claro); font-weight: 700; text-decoration: none; }
    .pie-datos a:hover { text-decoration: underline; }
    .pie-datos a:focus-visible { outline: 3px solid var(--oliva); outline-offset: 3px; }
    .pie-mini { margin: 0; font-size: 0.82rem; color: rgba(251, 247, 236, 0.5); }

    /* ---------- Reveal (solo con JS) ---------- */
    .js .rv {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.65s ease, transform 0.65s ease;
    }
    .js .rv.in { opacity: 1; transform: none; }

    .visually-hidden {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
      border: 0;
    }
  </style>

  <script is:inline>
    document.documentElement.classList.add('js');

    // Resaltar el día de hoy en la tabla de horarios
    var dias = ['domingo', 'lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado'];
    var hoy = dias[new Date().getDay()];
    var fila = document.querySelector('.horas tr[data-d="' + hoy + '"]');
    if (fila) fila.classList.add('hoy');

    // Scroll-reveal como mejora progresiva
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(
        function (entradas) {
          entradas.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.rv').forEach(function (el) { io.observe(el); });
    } else {
      document.querySelectorAll('.rv').forEach(function (el) { el.classList.add('in'); });
    }
  </script>
</BaseLayout>
