---
import BaseLayout from '../../layouts/BaseLayout.astro';

const nombre = "Élite Fitness Gym";
const direccion = "Calle 65-A x calle 6 y 4 255, Villas de Oriente, 97370 Kanasín, Yuc., México";
const wa = "https://wa.me/529991360378";
const tel = "999 136 0378";
const telHref = "tel:+529991360378";
const maps = "https://maps.google.com/?cid=5320609684352578346&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA";
const mapEmbed = "https://www.google.com/maps?q=" + encodeURIComponent(nombre + ", " + direccion) + "&output=embed";
---
<BaseLayout
  title="Élite Fitness Gym · Gimnasio en Villas de Oriente, Kanasín"
  description="Máquinas completas, horarios accesibles desde las 6:00 am y buen trato. ⭐ 4.0 con 24 reseñas en Google. Gimnasio en Villas de Oriente, Kanasín, Yucatán. Escríbenos por WhatsApp."
  slug="elite-fitness-gym"
  ogImage="/elite-fitness-gym/img/foto_3.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Saira:wght@500;700;800&family=Inter:wght@400;500;600&display=swap"
  favicon="💪"
  themeColor="#16181d"
  whatsapp={wa}
  telefono={tel}
  mapsUrl={maps}
>
  <main class="efg">

    <!-- símbolo reutilizable de la insignia (bullets, sello "hoy", footer) -->
    <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
      <symbol id="ins-hex" viewBox="0 0 100 100">
        <polygon class="ins-hex-shape" points="50,4 93,27 93,73 50,96 7,73 7,27"></polygon>
        <text x="50" y="61" text-anchor="middle" class="ins-hex-e">E</text>
      </symbol>
    </svg>

    <!-- ============ HERO ============ -->
    <header class="hero">
      <div class="hero-media" aria-hidden="true">
        <img src="/elite-fitness-gym/img/foto_3.jpg" alt="" fetchpriority="high" />
      </div>
      <div class="hero-scrim" aria-hidden="true"></div>

      <div class="wrap hero-inner">
        <div class="badge-hero reveal" aria-hidden="true">
          <svg viewBox="0 0 220 220" class="badge-hero-svg">
            <defs>
              <linearGradient id="badgeGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#2b2f3a"></stop>
                <stop offset="0.55" stop-color="#22252d"></stop>
                <stop offset="1" stop-color="#16181d"></stop>
              </linearGradient>
              <linearGradient id="ringGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#cbd5e1"></stop>
                <stop offset="0.5" stop-color="#7c5cff"></stop>
                <stop offset="1" stop-color="#5b3fe0"></stop>
              </linearGradient>
            </defs>
            <polygon points="110,10 200,58 200,162 110,210 20,162 20,58" fill="url(#badgeGrad)" stroke="url(#ringGrad)" stroke-width="4"></polygon>
            <polygon points="110,28 184,68 184,152 110,192 36,152 36,68" fill="none" stroke="rgba(203,213,225,0.28)" stroke-width="1.5"></polygon>
            <text x="110" y="96" text-anchor="middle" class="badge-word">ÉLITE</text>
            <text x="110" y="118" text-anchor="middle" class="badge-sub">FITNESS GYM</text>
            <g class="badge-ticks" fill="none" stroke="#7c5cff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="66,144 74,154 82,144"></polyline>
              <polyline points="90,144 98,154 106,144"></polyline>
              <polyline points="114,144 122,154 130,144"></polyline>
              <polyline points="138,144 146,154 154,144"></polyline>
            </g>
            <text x="110" y="180" text-anchor="middle" class="badge-rating">4.0</text>
          </svg>
        </div>

        <p class="kicker reveal">Gimnasio · Villas de Oriente, Kanasín</p>
        <h1 class="h1 reveal">
          <span class="h1-l1">Élite</span>
          <span class="h1-l2">Fitness Gym</span>
        </h1>
        <p class="tagline reveal">Máquinas completas, horarios que se acomodan a ti y el trato que hace que vuelvas.</p>

        <a class="chip reveal" href={maps} target="_blank" rel="noopener">
          <span class="star" aria-hidden="true">★</span> 4.0 · 24 reseñas en Google
        </a>

        <div class="cta-row reveal">
          <a class="btn btn-solid" href={wa} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2zm0 18.2c-1.5 0-3-.4-4.3-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.6.8-.8 1-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.4-3c-.3-.4 0-.5.2-.7l.4-.5c.1-.2.2-.3.3-.5v-.5c0-.1-.5-1.3-.7-1.8-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.3.3-.9.9-.9 2.2s.9 2.5 1 2.7c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2l-.4-.3z"/></svg>
            Escríbenos por WhatsApp
          </a>
          <a class="btn btn-ghost" href={maps} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12 2a7 7 0 0 0-7 7c0 5.2 7 13 7 13s7-7.8 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
            Cómo llegar
          </a>
        </div>

        <dl class="stats reveal">
          <div><dt>4.0<span>★</span></dt><dd>calificación en Google</dd></div>
          <div><dt>24</dt><dd>reseñas de socios</dd></div>
          <div><dt>6:00</dt><dd>abrimos, lun–sáb</dd></div>
        </dl>
      </div>
    </header>

    <!-- ============ TIRA DE SERVICIOS ============ -->
    <div class="strip-wrap" aria-hidden="true">
      <div class="strip-track">
        <span>Pesas libres · Máquinas guiadas · Cardio · Coaching en piso · Mensualidad accesible · Abrimos desde las 6:00&nbsp;am ·&nbsp;</span>
        <span>Pesas libres · Máquinas guiadas · Cardio · Coaching en piso · Mensualidad accesible · Abrimos desde las 6:00&nbsp;am ·&nbsp;</span>
      </div>
    </div>

    <!-- ============ 01 QUIÉNES SOMOS ============ -->
    <section class="sec" id="nosotros">
      <div class="wrap sec-grid">
        <div>
          <p class="sec-kicker reveal">01 / Quiénes somos</p>
          <h2 class="sec-title reveal">Se entrena <span class="accent">en serio</span></h2>
          <div class="about reveal">
            <p>Somos Élite Fitness Gym, el gimnasio de Villas de Oriente en Kanasín. Abrimos desde las 6:00 de la mañana, de lunes a sábado, para que entrenes antes del trabajo, a medio día o al cerrar la jornada — el horario se acomoda a ti, no al revés.</p>
            <p>Nuestros socios lo describen mejor que nosotros: «el gym está bastante completo» y «máquinas completas». Tenemos zona de pesas libres, máquinas guiadas y equipo de cardio para armar una rutina completa sin andar buscando en otro lado. Eso sí, se llena en horas pico — si puedes, entra temprano y tendrás más espacio.</p>
            <p>Y sobre el trato: el personal es amable y la mensualidad tiene un precio que nuestros socios describen como accesible. No prometemos lujos. Prometemos un lugar cerca de casa donde sí se puede entrenar bien.</p>
          </div>
        </div>
        <figure class="foto-card reveal">
          <img src="/elite-fitness-gym/img/foto_1.jpg" alt="Fachada de Élite Fitness Gym en Villas de Oriente, Kanasín" loading="lazy" width="825" height="1100" />
          <figcaption>Nuestra fachada, en la entrada de Villas de Oriente</figcaption>
        </figure>
      </div>
    </section>

    <!-- ============ 02 INSTALACIONES ============ -->
    <section class="sec sec-panel" id="instalaciones">
      <div class="wrap sec-grid">
        <figure class="foto-card reveal">
          <img src="/elite-fitness-gym/img/foto_2.jpg" alt="Área de pesas y bancos dentro de Élite Fitness Gym" loading="lazy" width="508" height="1100" />
          <figcaption>Zona de pesas, dentro del gym</figcaption>
        </figure>
        <div>
          <p class="sec-kicker reveal">02 / Qué encuentras aquí</p>
          <h2 class="sec-title reveal">Todo para tu <span class="accent">rutina completa</span></h2>
          <ul class="oferta reveal">
            <li>
              <svg class="ins-mini" viewBox="0 0 100 100" aria-hidden="true"><use href="#ins-hex"></use></svg>
              <div><h3>Zona de pesas libres</h3><p>Barras, mancuernas y bancos para tren superior e inferior.</p></div>
            </li>
            <li>
              <svg class="ins-mini" viewBox="0 0 100 100" aria-hidden="true"><use href="#ins-hex"></use></svg>
              <div><h3>Máquinas guiadas</h3><p>Equipo completo para complementar tu trabajo de fuerza.</p></div>
            </li>
            <li>
              <svg class="ins-mini" viewBox="0 0 100 100" aria-hidden="true"><use href="#ins-hex"></use></svg>
              <div><h3>Zona de cardio</h3><p>Elípticas para calentar o cerrar el entrenamiento.</p></div>
            </li>
            <li>
              <svg class="ins-mini" viewBox="0 0 100 100" aria-hidden="true"><use href="#ins-hex"></use></svg>
              <div><h3>Personal amable en piso</h3><p>Te orientan si lo necesitas, sin presión.</p></div>
            </li>
            <li>
              <svg class="ins-mini" viewBox="0 0 100 100" aria-hidden="true"><use href="#ins-hex"></use></svg>
              <div><h3>Mensualidad accesible</h3><p>Nuestros socios repiten que el precio vale la pena.</p></div>
            </li>
            <li>
              <svg class="ins-mini" viewBox="0 0 100 100" aria-hidden="true"><use href="#ins-hex"></use></svg>
              <div><h3>Horario extendido</h3><p>Abrimos desde las 6:00&nbsp;am, de lunes a sábado.</p></div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ============ 03 RESEÑAS ============ -->
    <section class="sec" id="resenas">
      <div class="wrap">
        <p class="sec-kicker reveal">03 / Lo que dicen en Google</p>
        <h2 class="sec-title reveal"><span class="accent">4.0</span> de 5, con 24 reseñas</h2>

        <div class="reviews reveal">
          <figure class="rev">
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«El gym está bastante completo, los horarios son muy accesibles el personal amable, se llena mucho en horas pico, la mensualidad está en excelente precio, muy fácil de ubicar super cerca de la entrada villas de oriente»</blockquote>
            <figcaption><strong>Dianey Quinn</strong><span>Hace 3 años · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«Maquinas completas, buen trato…»</blockquote>
            <figcaption><strong>Manuel Canul</strong><span>Hace 8 años · Google</span></figcaption>
          </figure>
        </div>

        <div class="center reveal">
          <a class="btn btn-ghost" href={maps} target="_blank" rel="noopener">Leer más reseñas en Google</a>
        </div>
      </div>
    </section>

    <!-- ============ 04 UBICACIÓN Y HORARIOS ============ -->
    <section class="sec sec-panel" id="ubicacion">
      <div class="wrap">
        <p class="sec-kicker reveal">04 / Dónde estamos</p>
        <h2 class="sec-title reveal">Villas de <span class="accent">Oriente</span></h2>
        <div class="ubica reveal">
          <div class="ubica-info">
            <p class="dir">{direccion}</p>
            <a class="btn btn-solid btn-sm" href={maps} target="_blank" rel="noopener">Abrir en Google Maps</a>

            <h3 class="horario-titulo">
              <svg class="ins-mini ins-mini-sm" viewBox="0 0 100 100" aria-hidden="true"><use href="#ins-hex"></use></svg>
              Horario del gym
            </h3>
            <table class="horarios">
              <tbody>
                <tr data-dia="1"><th scope="row">Lunes</th><td>6:00–16:00</td></tr>
                <tr data-dia="2"><th scope="row">Martes</th><td>6:00–16:00</td></tr>
                <tr data-dia="3"><th scope="row">Miércoles</th><td>6:00–16:00</td></tr>
                <tr data-dia="4"><th scope="row">Jueves</th><td>6:00–16:00</td></tr>
                <tr data-dia="5"><th scope="row">Viernes</th><td>6:00–16:00</td></tr>
                <tr data-dia="6"><th scope="row">Sábado</th><td>6:00–14:00</td></tr>
                <tr data-dia="0"><th scope="row">Domingo</th><td>Cerrado</td></tr>
              </tbody>
            </table>
          </div>
          <div class="mapa">
            <iframe
              src={mapEmbed}
              title="Mapa: Élite Fitness Gym en Villas de Oriente, Kanasín"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA FINAL ============ -->
    <section class="banda">
      <div class="banda-media" aria-hidden="true">
        <img src="/elite-fitness-gym/img/foto_5.jpg" alt="" loading="lazy" />
      </div>
      <div class="banda-scrim" aria-hidden="true"></div>
      <div class="wrap banda-inner">
        <h2 class="banda-title">¿Listo para tu primer entrenamiento?</h2>
        <p class="banda-sub">Escríbenos por WhatsApp y te decimos cómo llegar, o pásate directo — abrimos desde las 6:00&nbsp;am.</p>
        <div class="cta-row">
          <a class="btn btn-solid" href={wa} target="_blank" rel="noopener">WhatsApp directo</a>
          <a class="btn btn-ghost-light" href={telHref}>Llamar · {tel}</a>
        </div>
      </div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="pie">
      <div class="wrap">
        <p class="pie-logo">
          <svg class="ins-mini ins-mini-sm" viewBox="0 0 100 100" aria-hidden="true"><use href="#ins-hex"></use></svg>
          Élite Fitness Gym
        </p>
        <p class="pie-dato">Gimnasio · {direccion}</p>
        <p class="pie-dato"><a href={telHref}>{tel}</a> · <a href={wa} target="_blank" rel="noopener">WhatsApp</a> · <a href={maps} target="_blank" rel="noopener">Cómo llegar</a></p>
        <p class="pie-mini">Lunes a viernes 6:00–16:00 · Sábado 6:00–14:00 · Domingo cerrado</p>
      </div>
    </footer>
  </main>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "HealthClub",
    "name": "Élite Fitness Gym",
    "telephone": "+529991360378",
    "url": "https://demos.ivang.mx/elite-fitness-gym",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle 65-A x calle 6 y 4 255, Villas de Oriente",
      "addressLocality": "Kanasín",
      "addressRegion": "Yucatán",
      "postalCode": "97370",
      "addressCountry": "MX"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.0",
      "reviewCount": "24"
    },
    "openingHours": ["Mo-Fr 06:00-16:00", "Sa 06:00-14:00"]
  }
  </script>

  <style is:global>
    :root {
      --carbon: #16181d;
      --grafito: #22252d;
      --grafito-2: #282c36;
      --violet: #7c5cff;
      --violet-light: #a996ff;
      --violet-deep: #5b3fe0;
      --plata: #cbd5e1;
      --plata-mute: #8b93a3;
      --line: rgba(203, 213, 225, 0.14);
      --display: "Saira", "Arial Narrow", sans-serif;
      --body: "Inter", system-ui, sans-serif;
    }

    body {
      background: var(--carbon);
      color: var(--plata);
      font-family: var(--body);
      font-size: 17px;
      line-height: 1.6;
      overflow-x: clip;
    }

    .efg ::selection { background: var(--violet); color: var(--carbon); }
    .efg a:focus-visible,
    .efg .btn:focus-visible {
      outline: 3px solid var(--violet-light);
      outline-offset: 3px;
      border-radius: 4px;
    }

    .wrap { max-width: 1080px; margin: 0 auto; padding: 0 20px; }
    .accent { color: var(--violet-light); }

    /* ---------- INSIGNIA (firma) ---------- */
    .ins-hex-shape { fill: var(--grafito-2); stroke: var(--violet); stroke-width: 4; }
    .ins-hex-e { font-family: var(--display); font-weight: 800; font-size: 46px; fill: var(--violet-light); }
    .ins-mini { width: 26px; height: 26px; flex: none; }
    .ins-mini-sm { width: 20px; height: 20px; margin-right: 8px; vertical-align: -4px; }

    .badge-hero { display: flex; justify-content: center; margin: 0 0 20px; }
    .badge-hero-svg { width: 148px; height: 148px; filter: drop-shadow(0 14px 28px rgba(0, 0, 0, 0.45)); }
    .badge-word { font-family: var(--display); font-weight: 800; font-size: 30px; fill: var(--plata); letter-spacing: 0.03em; }
    .badge-sub { font-family: var(--display); font-weight: 700; font-size: 12px; fill: var(--violet-light); letter-spacing: 0.16em; }
    .badge-rating { font-family: var(--display); font-weight: 700; font-size: 16px; fill: var(--plata-mute); letter-spacing: 0.06em; }

    /* ---------- HERO ---------- */
    .hero {
      position: relative;
      min-height: calc(100vh - 38px);
      min-height: calc(100svh - 38px);
      display: flex;
      align-items: flex-end;
      padding: 40px 0 44px;
      overflow: hidden;
    }
    .hero-media { position: absolute; inset: 0; z-index: 0; }
    .hero-media img { width: 100%; height: 100%; object-fit: cover; object-position: center 65%; }
    .hero-scrim {
      position: absolute; inset: 0; z-index: 1;
      background:
        radial-gradient(900px 520px at 88% -6%, rgba(124, 92, 255, 0.22), transparent 60%),
        linear-gradient(180deg, rgba(22, 24, 29, 0.55) 0%, rgba(22, 24, 29, 0.88) 58%, rgba(22, 24, 29, 0.98) 100%);
    }
    .hero-inner { position: relative; z-index: 2; width: 100%; }

    .kicker {
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--violet-light);
      margin: 0 0 14px;
      text-align: center;
    }
    .h1 {
      margin: 0;
      font-family: var(--display);
      text-align: center;
      line-height: 0.98;
    }
    .h1-l1 {
      display: block;
      font-size: clamp(40px, 12vw, 90px);
      font-weight: 800;
      color: var(--violet-light);
      letter-spacing: 0.01em;
    }
    .h1-l2 {
      display: block;
      font-size: clamp(30px, 8.5vw, 62px);
      font-weight: 700;
      color: var(--plata);
      letter-spacing: 0.02em;
      margin-top: 4px;
    }
    .tagline {
      font-size: clamp(17px, 4.4vw, 21px);
      font-weight: 400;
      color: var(--plata);
      max-width: 36ch;
      margin: 22px auto 18px;
      text-align: center;
    }

    .chip {
      display: flex;
      width: max-content;
      max-width: 100%;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 8px 16px;
      font-weight: 600;
      font-size: 14.5px;
      color: var(--plata);
      text-decoration: none;
      background: rgba(124, 92, 255, 0.08);
      margin: 0 auto;
    }
    .chip .star { color: var(--violet-light); }
    .chip:hover { border-color: var(--violet); }

    .cta-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; margin: 26px 0 0; }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-family: var(--display);
      font-weight: 800;
      font-size: 18px;
      letter-spacing: 0.03em;
      text-decoration: none;
      padding: 15px 26px;
      border-radius: 10px;
      transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }
    .btn:active { transform: scale(0.97); }
    .btn-solid { background: var(--violet); color: var(--carbon); }
    .btn-solid:hover { background: var(--violet-light); }
    .btn-ghost { border: 2px solid var(--line); color: var(--plata); }
    .btn-ghost:hover { border-color: var(--violet-light); color: var(--violet-light); }
    .btn-ghost-light { border: 2px solid rgba(22, 24, 29, 0.35); color: var(--carbon); }
    .btn-ghost-light:hover { border-color: var(--carbon); }
    .btn-sm { font-size: 15.5px; padding: 12px 20px; }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin: 38px 0 0;
      border-top: 1px solid var(--line);
      padding-top: 20px;
      text-align: center;
    }
    .stats dt {
      font-family: var(--display);
      font-weight: 800;
      font-size: clamp(22px, 5.6vw, 34px);
      color: var(--plata);
    }
    .stats dt span { color: var(--violet-light); }
    .stats dd { margin: 4px 0 0; font-size: 12.5px; color: var(--plata-mute); line-height: 1.35; }

    /* ---------- TIRA DE SERVICIOS ---------- */
    .strip-wrap {
      overflow: hidden;
      background: var(--grafito);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      padding: 13px 0;
    }
    .strip-track { display: inline-flex; white-space: nowrap; animation: strip 30s linear infinite; }
    .strip-track span {
      font-family: var(--display);
      font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.05em;
      color: var(--violet-light);
      padding-right: 0;
    }
    @keyframes strip { to { transform: translateX(-50%); } }

    /* ---------- SECCIONES ---------- */
    .sec { padding: 72px 0; }
    .sec-panel { background: var(--grafito); }
    .sec-kicker {
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--violet-light);
      margin: 0 0 10px;
    }
    .sec-title {
      font-family: var(--display);
      font-weight: 800;
      font-size: clamp(32px, 8vw, 52px);
      line-height: 1.04;
      margin: 0 0 26px;
      color: var(--plata);
    }

    .sec-grid { display: grid; grid-template-columns: 1fr; gap: 32px; align-items: center; }

    .about p { max-width: 60ch; margin: 0 0 16px; color: var(--plata); }

    .foto-card { margin: 0; border-radius: 14px; overflow: hidden; border: 1px solid var(--line); background: var(--grafito-2); }
    .foto-card img { width: 100%; height: 320px; object-fit: cover; }
    .foto-card figcaption { padding: 12px 16px; font-size: 13px; color: var(--plata-mute); }

    /* ---------- OFERTA ---------- */
    .oferta { list-style: none; margin: 0; padding: 0; display: grid; gap: 0; }
    .oferta li { display: flex; gap: 16px; align-items: flex-start; padding: 16px 0; border-top: 1px solid var(--line); }
    .oferta li:last-child { border-bottom: 1px solid var(--line); }
    .oferta h3 { font-family: var(--display); font-weight: 700; font-size: 17px; margin: 2px 0 4px; color: var(--plata); }
    .oferta p { margin: 0; color: var(--plata-mute); font-size: 15px; }

    /* ---------- RESEÑAS ---------- */
    .reviews { display: grid; grid-template-columns: 1fr; gap: 16px; margin: 0 0 30px; }
    .rev {
      margin: 0;
      background: var(--grafito-2);
      border: 1px solid var(--line);
      border-left: 3px solid var(--violet);
      border-radius: 10px;
      padding: 22px 22px 18px;
    }
    .rev-stars { color: var(--violet-light); font-size: 16px; letter-spacing: 0.18em; margin: 0 0 10px; }
    .rev blockquote { margin: 0 0 16px; font-size: 16px; line-height: 1.55; font-weight: 400; color: var(--plata); }
    .rev figcaption { display: flex; flex-direction: column; gap: 2px; }
    .rev figcaption strong { font-family: var(--display); font-weight: 700; font-size: 15.5px; color: var(--plata); }
    .rev figcaption span { font-size: 12.5px; color: var(--plata-mute); }
    .center { text-align: center; }

    /* ---------- UBICACIÓN ---------- */
    .ubica { display: grid; grid-template-columns: 1fr; gap: 30px; }
    .dir { font-size: 17px; font-weight: 500; margin: 0 0 16px; color: var(--plata); }
    .horario-titulo {
      display: flex; align-items: center;
      font-family: var(--display);
      font-weight: 700;
      font-size: 19px;
      margin: 28px 0 12px;
      color: var(--plata);
    }
    .horarios { width: 100%; max-width: 420px; border-collapse: collapse; font-size: 15px; }
    .horarios th, .horarios td { padding: 9px 10px; border-bottom: 1px solid var(--line); text-align: left; }
    .horarios th { font-weight: 500; color: var(--plata); }
    .horarios td { color: var(--plata-mute); text-align: right; font-variant-numeric: tabular-nums; }
    .horarios tr.hoy th, .horarios tr.hoy td { color: var(--carbon); background: var(--violet); font-weight: 700; }
    .horarios tr.hoy th::after {
      content: "hoy";
      font-family: var(--display);
      font-weight: 800;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: var(--carbon);
      color: var(--violet-light);
      border-radius: 4px;
      padding: 2px 7px;
      margin-left: 10px;
      vertical-align: 1px;
    }
    .mapa iframe {
      width: 100%;
      height: 300px;
      border: 0;
      border-radius: 12px;
      display: block;
      filter: invert(0.92) hue-rotate(180deg) saturate(0.7) contrast(0.9);
    }

    /* ---------- CTA FINAL ---------- */
    .banda { position: relative; padding: 74px 0; text-align: center; overflow: hidden; }
    .banda-media { position: absolute; inset: 0; z-index: 0; }
    .banda-media img { width: 100%; height: 100%; object-fit: cover; }
    .banda-scrim {
      position: absolute; inset: 0; z-index: 1;
      background: linear-gradient(180deg, rgba(124, 92, 255, 0.85), rgba(22, 24, 29, 0.94));
    }
    .banda-inner { position: relative; z-index: 2; }
    .banda-title {
      font-family: var(--display);
      font-weight: 800;
      font-size: clamp(28px, 7vw, 46px);
      line-height: 1.05;
      margin: 0 0 12px;
      color: #fff;
    }
    .banda-sub { margin: 0 auto 24px; max-width: 42ch; font-weight: 500; color: rgba(255, 255, 255, 0.92); }
    .banda .cta-row { justify-content: center; }

    /* ---------- FOOTER ---------- */
    .pie { padding: 40px 0 96px; border-top: 1px solid var(--line); text-align: center; }
    .pie-logo {
      display: flex; align-items: center; justify-content: center;
      font-family: var(--display);
      font-weight: 800;
      font-size: 22px;
      color: var(--plata);
      margin: 0 0 12px;
    }
    .pie-dato { margin: 4px 0; color: var(--plata-mute); font-size: 14px; }
    .pie-dato a { color: var(--plata); text-decoration: none; border-bottom: 1px solid var(--violet); }
    .pie-dato a:hover { color: var(--violet-light); }
    .pie-mini { margin: 14px 0 0; color: var(--plata-mute); font-size: 12px; opacity: 0.8; }

    /* ---------- REVEAL (solo con JS) ---------- */
    html.js .reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    html.js .reveal.in { opacity: 1; transform: none; }

    /* ---------- DESKTOP ---------- */
    @media (min-width: 760px) {
      .sec { padding: 100px 0; }
      .sec-grid { grid-template-columns: 1.1fr 0.9fr; gap: 56px; }
      .foto-card img { height: 420px; }
      .reviews { grid-template-columns: repeat(2, 1fr); align-items: start; }
      .ubica { grid-template-columns: 1fr 1.2fr; align-items: start; }
      .mapa iframe { height: 420px; }

      .badge-hero { position: absolute; top: 24px; right: 0; margin: 0; z-index: 2; }
      .badge-hero-svg { width: 176px; height: 176px; }
      .kicker, .tagline, .h1 { text-align: left; }
      .chip { margin: 0; }
      .cta-row { justify-content: flex-start; }
      .stats { max-width: 460px; text-align: left; }
      .stats > div { text-align: left; }
    }

    @media (prefers-reduced-motion: reduce) {
      .strip-track { animation: none; }
    }
  </style>

  <script is:inline>
    (function () {
      var d = document;
      d.documentElement.classList.add('js');

      var hoy = new Date().getDay();
      var fila = d.querySelector('.horarios tr[data-dia="' + hoy + '"]');
      if (fila) fila.classList.add('hoy');

      var els = d.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach(function (el) { io.observe(el); });
      } else {
        els.forEach(function (el) { el.classList.add('in'); });
      }
    })();
  </script>
</BaseLayout>
