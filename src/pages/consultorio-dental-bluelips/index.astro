---
import BaseLayout from '../../layouts/BaseLayout.astro';

const whatsapp = "https://wa.me/529993158725";
const telefono = "999 315 8725";
const mapsUrl = "https://maps.google.com/?cid=4472549811674464070&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA";
---
<BaseLayout
  title="Consultorio Dental Bluelips · Odontología en Kanasín | ⭐ 5.0"
  description="Consultorio dental Bluelips, en Reparto Granjas, Kanasín. ⭐ 5.0 con 49 reseñas en Google. Blanqueamiento, endodoncia y restauraciones con el Dr. Alexis y la Dra. Karina. Agenda por WhatsApp."
  slug="consultorio-dental-bluelips"
  ogImage="/consultorio-dental-bluelips/img/foto_5.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700;800&family=Albert+Sans:wght@400;500;600&display=swap"
  favicon="✨"
  themeColor="#0f5257"
  whatsapp={whatsapp}
  telefono={telefono}
  mapsUrl={mapsUrl}
>
  <!-- ============ HERO ============ -->
  <header class="hero">
    <div class="hero-decor" aria-hidden="true">
      <span class="deco deco-1"></span>
      <span class="deco deco-2"></span>
      <span class="deco deco-3"></span>
    </div>
    <div class="wrap hero-grid">
      <div class="hero-text" data-reveal>
        <p class="eyebrow"><span class="spark" aria-hidden="true"></span> Consultorio dental Bluelips · Reparto Granjas, Kanasín</p>
        <h1 class="hero-title">Sonrisas que <em>brillan</em> de verdad</h1>
        <p class="hero-sub">Con el Dr. Alexis y la Dra. Karina — la clínica dental que tus vecinos en Kanasín ya recomiendan por su trato, su limpieza y sus resultados.</p>
        <a class="rating-chip" href={mapsUrl}>
          <span class="stars" aria-hidden="true">★★★★★</span>
          <strong>5.0</strong> · 49 reseñas en Google
        </a>
        <div class="hero-ctas">
          <a class="btn btn-primary" href={whatsapp}>
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm0 18.2c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.6.8-.8 1-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.4-3c-.3-.4 0-.5.1-.7l.4-.5c.1-.2.1-.3 0-.5l-.8-1.9c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.3-.9.9-.9 2.2s.9 2.6 1.1 2.8c.1.2 1.9 2.9 4.6 4 .6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.1-.3-.2-.7-.3Z"/></svg>
            Agenda por WhatsApp
          </a>
          <a class="btn btn-ghost" href={mapsUrl}>Cómo llegar</a>
        </div>
      </div>
      <figure class="hero-photo" data-reveal>
        <img
          src="/consultorio-dental-bluelips/img/foto_5.jpg"
          alt="Sala de espera del consultorio dental Bluelips en Kanasín"
          width="825" height="1100"
          fetchpriority="high"
        />
        <span class="spark spark-lg" aria-hidden="true"></span>
      </figure>
    </div>
  </header>

  <main>
    <!-- ============ QUIÉNES SOMOS ============ -->
    <section class="section" id="nosotros">
      <div class="wrap">
        <div class="sec-head" data-reveal>
          <p class="eyebrow"><span class="spark" aria-hidden="true"></span> Quiénes somos</p>
          <h2>Tu sonrisa, en manos que la conocen bien</h2>
        </div>
        <div class="nosotros-grid" data-reveal>
          <div class="nosotros-text">
            <p>En Consultorio dental Bluelips, en Reparto Granjas, Kanasín, cuidamos tu sonrisa de cerca — literal y figuradamente. El Dr. Alexis y la Dra. Karina atienden cada cita con calma, te explican el tratamiento paso a paso y no te sueltan hasta que entiendes exactamente qué vamos a hacer y por qué.</p>
            <p>Nuestros pacientes describen el consultorio como limpio, ameno y acogedor — y es justo la sensación que buscamos desde que cruzas la puerta. Cuidamos cada detalle del espacio tanto como cada pieza dental.</p>
            <p>Ya sea una limpieza de rutina, una restauración o el blanqueamiento que te deje la sonrisa que quieres mostrar, en Bluelips lo hacemos con la misma atención al detalle.</p>
          </div>
          <div class="doctor-badges">
            <span class="doc-badge"><span class="spark" aria-hidden="true"></span> Dr. Alexis</span>
            <span class="doc-badge"><span class="spark" aria-hidden="true"></span> Dra. Karina</span>
          </div>
        </div>
      </div>
    </section>

    <div class="shine-bar" aria-hidden="true"></div>

    <!-- ============ TRANSFORMACIONES REALES ============ -->
    <section class="section section-mist" id="transformaciones">
      <div class="wrap">
        <div class="sec-head" data-reveal>
          <p class="eyebrow"><span class="spark" aria-hidden="true"></span> Transformaciones reales</p>
          <h2>Casos que hablan más fuerte que cualquier promesa</h2>
          <p class="sec-lead">Registros clínicos de tratamientos hechos en Bluelips — sin filtros, sin actuación.</p>
        </div>
        <div class="cases-grid" data-reveal>
          <figure class="case-card">
            <img src="/consultorio-dental-bluelips/img/foto_2.jpg" alt="Fotografía clínica de dientes antes y después de un blanqueamiento dental en Bluelips" loading="lazy" width="1100" height="1100" />
            <figcaption>Blanqueamiento dental — antes y después</figcaption>
          </figure>
          <figure class="case-card">
            <img src="/consultorio-dental-bluelips/img/foto_3.jpg" alt="Fotografía clínica de molares antes y después de una restauración dental en Bluelips" loading="lazy" width="1100" height="1100" />
            <figcaption>Restauración dental — antes y después</figcaption>
          </figure>
          <figure class="case-card case-wide">
            <img src="/consultorio-dental-bluelips/img/foto_4.jpg" alt="Modelo digital de una arcada dental trabajada en el consultorio" loading="lazy" width="1100" height="665" />
            <figcaption>Registro digital de un tratamiento en proceso</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ============ TRATAMIENTOS ============ -->
    <section class="section" id="tratamientos">
      <div class="wrap">
        <div class="sec-head" data-reveal>
          <p class="eyebrow"><span class="spark" aria-hidden="true"></span> Tratamientos</p>
          <h2>Todo para que tu sonrisa brille de nuevo</h2>
        </div>
        <ul class="svc-grid" data-reveal>
          <li class="svc svc-t"><span class="spark" aria-hidden="true"></span><h3>Blanqueamiento dental</h3><p>Recupera el brillo natural de tu sonrisa.</p></li>
          <li class="svc svc-c"><span class="spark" aria-hidden="true"></span><h3>Endodoncia</h3><p>Tratamos la pieza dañada y calmamos el dolor.</p></li>
          <li class="svc svc-t"><span class="spark" aria-hidden="true"></span><h3>Restauraciones y resinas</h3><p>Reconstruimos tus dientes con acabado natural.</p></li>
          <li class="svc svc-c"><span class="spark" aria-hidden="true"></span><h3>Odontología general</h3><p>Limpieza, revisión y prevención en cada visita.</p></li>
        </ul>
        <ul class="chips" data-reveal>
          <li>💳 Aceptamos tarjetas</li>
          <li>♿ Acceso para silla de ruedas</li>
          <li>💬 Citas por WhatsApp</li>
        </ul>
      </div>
    </section>

    <div class="shine-bar" aria-hidden="true"></div>

    <!-- ============ PRUEBA SOCIAL ============ -->
    <section class="section section-blush" id="resenas">
      <div class="wrap">
        <div class="sec-head center" data-reveal>
          <p class="eyebrow"><span class="spark" aria-hidden="true"></span> Lo que dicen nuestros pacientes</p>
          <p class="big-rating"><strong>5.0</strong><span class="stars" aria-hidden="true">★★★★★</span></p>
          <p class="rating-note">49 reseñas en Google</p>
        </div>
        <div class="reviews" data-reveal>
          <blockquote class="review">
            <p>"Excelente atención, el Dr Alexis y la Dra Karina sin dudas los mejores odontólogos!! Ya no vamos a ningún otro lugar para cuestiones dentales, cuentan con profesionalismo, maravillosa atención y como un plus la clínica está súper bonita!!!"</p>
            <footer><cite>Berenice Valadez</cite> · Hace 4 meses <span class="stars sm" aria-hidden="true">★★★★★</span></footer>
          </blockquote>
          <blockquote class="review">
            <p>"El mejor consultorio dental del todo el sureste Yucateco! Quedé feliz con mi blanqueamiento dental 🫰🏽"</p>
            <footer><cite>Alan Nahum Rivera Vargas</cite> · Hace 4 meses <span class="stars sm" aria-hidden="true">★★★★★</span></footer>
          </blockquote>
          <blockquote class="review">
            <p>"Excelente atención, los Drs. muy capacitados, te explican todo. Las instalaciones siempre muy limpias. Muy recomendado."</p>
            <footer><cite>Baas Gómez Amayrani Estefania</cite> · Hace 4 meses <span class="stars sm" aria-hidden="true">★★★★★</span></footer>
          </blockquote>
        </div>
        <div class="center" data-reveal>
          <a class="btn btn-primary" href={mapsUrl}>Leer más reseñas en Google</a>
        </div>
      </div>
    </section>

    <!-- ============ UBICACIÓN Y HORARIOS ============ -->
    <section class="section" id="ubicacion">
      <div class="wrap">
        <div class="sec-head" data-reveal>
          <p class="eyebrow"><span class="spark" aria-hidden="true"></span> Ubicación y horarios</p>
          <h2>Estamos en Reparto Granjas, Kanasín</h2>
          <p class="addr">C. 57 524, Granjas, Reparto Granjas, 97370 Kanasín, Yuc., México</p>
        </div>
        <div class="loc-grid" data-reveal>
          <div class="map-box">
            <iframe
              title="Mapa: Consultorio dental Bluelips, Reparto Granjas, Kanasín"
              src="https://www.google.com/maps?q=Consultorio%20dental%20Bluelips%2C%20C.%2057%20524%2C%20Granjas%2C%20Reparto%20Granjas%2C%2097370%20Kanas%C3%ADn%2C%20Yuc.%2C%20M%C3%A9xico&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>
          </div>
          <div class="hours-box">
            <h3>Horarios</h3>
            <table class="hours">
              <tbody>
                <tr data-day="1"><th scope="row">Lunes</th><td>9:00–13:00 y 15:00–19:00</td></tr>
                <tr data-day="2"><th scope="row">Martes</th><td>9:00–13:00 y 15:00–19:00</td></tr>
                <tr data-day="3"><th scope="row">Miércoles</th><td>9:00–13:00 y 15:00–19:00</td></tr>
                <tr data-day="4"><th scope="row">Jueves</th><td>9:00–13:00 y 15:00–19:00</td></tr>
                <tr data-day="5"><th scope="row">Viernes</th><td>9:00–13:00 y 15:00–19:00</td></tr>
                <tr data-day="6"><th scope="row">Sábado</th><td>9:00–13:00</td></tr>
                <tr data-day="0" class="closed"><th scope="row">Domingo</th><td>Cerrado</td></tr>
              </tbody>
            </table>
            <a class="btn btn-cyan" href={mapsUrl}>Cómo llegar</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- ============ FOOTER ============ -->
  <footer class="footer">
    <div class="wrap">
      <p class="f-brand"><span class="spark" aria-hidden="true"></span> Bluelips</p>
      <p class="f-tag">Consultorio Dental · Reparto Granjas, Kanasín</p>
      <p class="f-line">C. 57 524, Granjas, Reparto Granjas, 97370 Kanasín, Yuc., México</p>
      <p class="f-line">
        <a href="tel:+529993158725">999 315 8725</a> ·
        <a href={whatsapp}>WhatsApp</a> ·
        <a href="https://www.facebook.com/cbluelips">Facebook @cbluelips</a>
      </p>
      <p class="f-note">⭐ 5.0 · 49 reseñas en Google</p>
    </div>
  </footer>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Dentist",
    "name": "Consultorio dental Bluelips",
    "url": "https://demos.ivang.mx/consultorio-dental-bluelips",
    "telephone": "+52 999 315 8725",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "C. 57 524, Granjas, Reparto Granjas",
      "addressLocality": "Kanasín",
      "addressRegion": "Yucatán",
      "postalCode": "97370",
      "addressCountry": "MX"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "49"
    },
    "openingHours": ["Mo-Fr 09:00-13:00", "Mo-Fr 15:00-19:00", "Sa 09:00-13:00"]
  }
  </script>

  <style is:global>
    :root {
      --paper: #fbfefe;
      --mist: #e6f8f5;
      --blush: #fff1ee;
      --turquoise: #2bb3a3;
      --turquoise-deep: #14766a;
      --coral: #ff8a7a;
      --coral-deep: #d9503c;
      --ink: #0f5257;
      --white: #ffffff;
      --font-display: 'Outfit', system-ui, sans-serif;
      --font-body: 'Albert Sans', system-ui, sans-serif;
      --cut: 16px;
      --cut-lg: 26px;
    }

    body {
      font-family: var(--font-body);
      background: var(--paper);
      color: var(--ink);
      line-height: 1.6;
      overflow-x: hidden;
    }

    h1, h2, h3 { font-family: var(--font-display); line-height: 1.1; margin: 0 0 0.5em; color: var(--ink); }
    p { margin: 0 0 1em; }
    a { color: var(--turquoise-deep); }
    a:focus-visible, .btn:focus-visible, .rating-chip:focus-visible {
      outline: 3px solid var(--turquoise-deep);
      outline-offset: 3px;
    }

    .wrap { max-width: 1080px; margin: 0 auto; padding: 0 20px; }
    .center { text-align: center; }

    /* ---- Elemento firma: el destello ---- */
    .spark {
      display: inline-block;
      width: 1em;
      height: 1em;
      vertical-align: -0.15em;
      background: linear-gradient(135deg, var(--turquoise) 0%, var(--coral) 100%);
      clip-path: polygon(50% 0%, 61% 39%, 100% 50%, 61% 61%, 50% 100%, 39% 61%, 0% 50%, 39% 39%);
    }
    .spark-lg {
      position: absolute;
      width: 64px;
      height: 64px;
      top: -18px;
      right: -18px;
      box-shadow: 0 8px 24px rgba(15, 82, 87, 0.28);
    }

    /* ---- Franja de brillo (divisor) ---- */
    .shine-bar {
      height: 4px;
      width: 100%;
      background: linear-gradient(90deg, var(--turquoise) 0%, var(--coral) 50%, var(--turquoise) 100%);
      background-size: 220% 100%;
      animation: shineMove 7s linear infinite;
    }
    @keyframes shineMove {
      from { background-position: 0% 0; }
      to { background-position: 220% 0; }
    }

    /* ---- Botones (corte geométrico, nunca redondeado) ---- */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.02rem;
      text-decoration: none;
      padding: 14px 26px;
      clip-path: polygon(0 0, calc(100% - var(--cut)) 0, 100% var(--cut), 100% 100%, var(--cut) 100%, 0 calc(100% - var(--cut)));
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .btn:hover { transform: translateY(-2px); }
    .btn:active { transform: translateY(0); }
    .btn-primary {
      background: var(--turquoise-deep);
      color: var(--white);
      box-shadow: 0 8px 20px rgba(20, 118, 106, 0.32);
    }
    .btn-primary:hover { box-shadow: 0 12px 26px rgba(20, 118, 106, 0.38); }
    .btn-ghost {
      color: var(--ink);
      border: 2px solid var(--ink);
      background: transparent;
    }
    .btn-ghost:hover { background: rgba(15, 82, 87, 0.06); }
    .btn-cyan {
      background: var(--turquoise);
      color: var(--ink);
      box-shadow: 0 6px 16px rgba(43, 179, 163, 0.35);
    }

    /* ---- Hero ---- */
    .hero {
      position: relative;
      background: var(--paper);
      overflow: hidden;
      padding-top: 56px;
    }
    .hero-decor { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
    .deco {
      position: absolute;
      display: block;
      border-radius: 4px;
    }
    .deco-1 {
      width: 240px; height: 240px;
      background: linear-gradient(135deg, var(--turquoise), transparent);
      opacity: 0.16;
      top: -80px; left: -80px;
      transform: rotate(45deg);
    }
    .deco-2 {
      width: 160px; height: 160px;
      background: linear-gradient(135deg, var(--coral), transparent);
      opacity: 0.18;
      bottom: 40px; left: 12%;
      transform: rotate(45deg);
    }
    .deco-3 {
      width: 320px; height: 320px;
      background: linear-gradient(135deg, var(--turquoise), transparent);
      opacity: 0.1;
      top: 20%; right: -140px;
      transform: rotate(45deg);
    }
    .hero-grid {
      position: relative;
      display: grid;
      gap: 40px;
      padding: 44px 20px 64px;
      align-items: center;
    }
    .eyebrow {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 700;
      font-size: 0.8rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--turquoise-deep);
      margin-bottom: 14px;
    }
    .hero-title {
      font-size: clamp(2.4rem, 9vw, 4rem);
      font-weight: 800;
      line-height: 1.03;
      max-width: 12ch;
      margin-bottom: 0.4em;
      text-wrap: balance;
    }
    .hero-title em { font-style: normal; color: var(--turquoise-deep); }
    .hero-sub {
      font-size: clamp(1rem, 3.4vw, 1.15rem);
      max-width: 46ch;
      color: #2c5a5a;
    }
    .rating-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--mist);
      color: var(--ink);
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      padding: 8px 16px;
      clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
      margin-bottom: 26px;
    }
    .stars { color: var(--coral-deep); letter-spacing: 2px; }
    .stars.sm { font-size: 0.85em; }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: 14px; }
    .hero-photo {
      position: relative;
      margin: 0;
      max-width: 340px;
      justify-self: center;
    }
    .hero-photo img {
      width: 100%;
      aspect-ratio: 3 / 4;
      object-fit: cover;
      box-shadow: 0 20px 50px rgba(15, 82, 87, 0.22);
      clip-path: polygon(0 0, calc(100% - var(--cut-lg)) 0, 100% var(--cut-lg), 100% 100%, var(--cut-lg) 100%, 0 calc(100% - var(--cut-lg)));
    }

    /* ---- Secciones ---- */
    .section { padding: 60px 0; }
    .section-mist { background: var(--mist); }
    .section-blush { background: var(--blush); }
    .sec-head { margin-bottom: 30px; max-width: 60ch; }
    .sec-head.center { margin-left: auto; margin-right: auto; text-align: center; max-width: 40ch; }
    .sec-head h2 { font-size: clamp(1.7rem, 6vw, 2.4rem); text-wrap: balance; }
    .sec-lead { color: #2c5a5a; }

    /* ---- Quiénes somos ---- */
    .nosotros-grid { display: grid; gap: 28px; }
    .nosotros-text p { max-width: 62ch; }
    .doctor-badges { display: flex; flex-wrap: wrap; gap: 12px; }
    .doc-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--white);
      border: 2px solid var(--turquoise);
      color: var(--ink);
      font-family: var(--font-display);
      font-weight: 700;
      padding: 10px 18px;
      clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    }

    /* ---- Transformaciones ---- */
    .cases-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }
    .case-card { margin: 0; }
    .case-card img {
      width: 100%;
      aspect-ratio: 1 / 1;
      object-fit: cover;
      clip-path: polygon(0 0, calc(100% - var(--cut)) 0, 100% var(--cut), 100% 100%, var(--cut) 100%, 0 calc(100% - var(--cut)));
      box-shadow: 0 10px 26px rgba(15, 82, 87, 0.16);
    }
    .case-card figcaption {
      margin-top: 10px;
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--turquoise-deep);
    }
    .case-wide { grid-column: 1 / -1; }
    .case-wide img { aspect-ratio: 16 / 9; }

    /* ---- Tratamientos ---- */
    .svc-grid {
      list-style: none;
      margin: 0 0 26px;
      padding: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .svc {
      position: relative;
      background: var(--white);
      padding: 22px 22px 20px;
      border-top: 4px solid var(--turquoise);
      box-shadow: 0 4px 14px rgba(15, 82, 87, 0.08);
    }
    .svc-c { border-top-color: var(--coral); }
    .svc .spark { margin-bottom: 10px; width: 1.3em; height: 1.3em; }
    .svc h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; }
    .svc p { margin: 0; font-size: 0.95rem; color: #3c6a6a; }
    .chips {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .chips li {
      background: var(--white);
      border: 2px solid var(--turquoise-deep);
      color: var(--ink);
      font-weight: 600;
      font-size: 0.88rem;
      padding: 8px 16px;
      clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
    }

    /* ---- Reseñas ---- */
    .big-rating { font-family: var(--font-display); margin: 0; line-height: 1; }
    .big-rating strong { font-size: clamp(3.2rem, 12vw, 4.6rem); font-weight: 800; display: block; color: var(--ink); }
    .big-rating .stars { font-size: 1.3rem; }
    .rating-note { color: #3c6a6a; margin-top: 4px; }
    .reviews { display: grid; gap: 16px; margin: 34px 0 30px; }
    .review {
      margin: 0;
      background: var(--white);
      border-left: 4px solid var(--coral);
      padding: 22px 24px;
      box-shadow: 0 4px 14px rgba(15, 82, 87, 0.08);
    }
    .review p { font-size: 1rem; margin-bottom: 14px; color: var(--ink); }
    .review footer { font-size: 0.86rem; color: #4a7676; }
    .review cite { font-style: normal; font-weight: 700; color: var(--turquoise-deep); }

    /* ---- Ubicación ---- */
    .addr { max-width: 52ch; color: #3c6a6a; }
    .loc-grid { display: grid; gap: 24px; }
    .map-box {
      overflow: hidden;
      clip-path: polygon(0 0, calc(100% - var(--cut-lg)) 0, 100% var(--cut-lg), 100% 100%, var(--cut-lg) 100%, 0 calc(100% - var(--cut-lg)));
      box-shadow: 0 10px 28px rgba(15, 82, 87, 0.14);
    }
    .map-box iframe { display: block; width: 100%; height: 300px; border: 0; }
    .hours-box h3 { font-size: 1.25rem; }
    .hours { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    .hours th, .hours td { text-align: left; padding: 9px 10px; font-size: 0.96rem; }
    .hours th { font-weight: 600; }
    .hours tr { border-bottom: 1px solid #d4ece8; }
    .hours tr.closed td { color: #7fa0a0; }
    .hours tr.today {
      background: var(--mist);
      box-shadow: inset 3px 0 0 var(--turquoise-deep);
    }
    .hours tr.today th::after {
      content: " · hoy";
      color: var(--turquoise-deep);
      font-weight: 700;
      font-size: 0.8em;
    }

    /* ---- Footer ---- */
    .footer {
      background: var(--ink);
      color: rgba(255, 255, 255, 0.85);
      padding: 64px 0 100px;
      text-align: center;
    }
    .f-brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 1.8rem;
      color: var(--white);
      margin-bottom: 4px;
    }
    .f-tag {
      font-size: 0.8rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--turquoise);
      margin-bottom: 20px;
    }
    .f-line { font-size: 0.95rem; margin-bottom: 8px; }
    .footer a { color: var(--white); text-decoration-color: var(--turquoise); }
    .f-note { margin-top: 16px; font-size: 0.9rem; color: rgba(255, 255, 255, 0.6); }

    /* ---- Reveal (solo si hay JS) ---- */
    html.js [data-reveal] {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    html.js [data-reveal].in { opacity: 1; transform: none; }

    /* ---- Desktop ---- */
    @media (min-width: 720px) {
      .section { padding: 84px 0; }
      .hero-grid { grid-template-columns: 1.15fr 0.85fr; padding: 64px 20px 84px; }
      .hero-photo { max-width: 100%; justify-self: end; }
      .nosotros-grid { grid-template-columns: 3fr 2fr; align-items: start; }
      .svc-grid { grid-template-columns: repeat(2, 1fr); }
      .cases-grid { grid-template-columns: 1fr 1fr; }
      .reviews { grid-template-columns: repeat(3, 1fr); align-items: start; }
      .loc-grid { grid-template-columns: 3fr 2fr; align-items: start; }
      .map-box iframe { height: 380px; }
    }
    @media (min-width: 1000px) {
      .svc-grid { grid-template-columns: repeat(4, 1fr); }
    }
  </style>

  <script is:inline>
    // Mejora progresiva: sin JS todo el contenido queda visible.
    document.documentElement.classList.add('js');

    // Scroll-reveal sutil
    var revealables = document.querySelectorAll('[data-reveal]');
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('in');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      revealables.forEach(function (el) { io.observe(el); });
    } else {
      revealables.forEach(function (el) { el.classList.add('in'); });
    }

    // Resaltar el día actual en la tabla de horarios
    var today = new Date().getDay();
    var row = document.querySelector('.hours tr[data-day="' + today + '"]');
    if (row) {
      row.classList.add('today');
      row.setAttribute('aria-current', 'date');
    }
  </script>
</BaseLayout>
