---
import BaseLayout from '../../layouts/BaseLayout.astro';

const slug = 'studio-54';
const nombre = 'Studio 54';
const rating = 4.8;
const totalResenas = 156;
const telefono = '999 129 8283';
const whatsapp = 'https://wa.me/529991298283';
const whatsappCita =
  'https://wa.me/529991298283?text=' +
  encodeURIComponent('Hola Studio 54, vi su sitio y me gustaría agendar una cita.');
const mapsUrl =
  'https://maps.google.com/?cid=9706600491725074520&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA';
const direccion = 'C. 41-A 425, Francisco de Montejo II, 97203 Mérida, Yuc.';
const mapSrc =
  'https://www.google.com/maps?q=' +
  encodeURIComponent('C. 41-A 425, Francisco de Montejo II, 97203 Mérida, Yuc., México') +
  '&output=embed';

const servicios = [
  {
    t: 'Asesoría de imagen',
    d: 'Te acompañamos a decidir el look que va contigo: forma de rostro, tono y estilo de vida.',
  },
  {
    t: 'Color y colorimetría',
    d: 'Rayitos, mechas, retoques y cambios de tono trabajados con marca profesional.',
  },
  {
    t: 'Cortes y estilismo',
    d: 'Corte, peinado y cambios de look para hombre y mujer, en un ambiente relajado.',
  },
  {
    t: 'Reconstrucción y nutrición',
    d: 'Tratamientos para devolverle fuerza y brillo al cabello maltratado o teñido.',
  },
  {
    t: 'Boutique profesional',
    d: 'L’Oréal Professionnel, Paul Mitchell, Revlon y Tec Italy para cuidar tu cabello en casa.',
  },
  {
    t: 'Herramientas y accesorios',
    d: 'Planchas, cepillos Tangle Teezer, esmaltes y detalles para completar tu estilo.',
  },
];

const marcas = [
  "L’Oréal Professionnel",
  'Paul Mitchell',
  'Revlon Professional',
  'Tec Italy',
  'Colorimetría',
  'Cambios de look',
  'Reconstrucción capilar',
  'Asesoría de imagen',
];

const resenas = [
  {
    autor: 'Mara C Navarrete',
    cuando: 'Hace 5 meses',
    texto:
      'Maravilloso, con más de 20 años al Cuidado de tu Imagen y Cabello, siempre con el Mejor Asesoramiento para tu Presentación como persona, en Cambios de Look…',
  },
  {
    autor: 'Gabriel',
    cuando: 'Hace un año',
    texto:
      'Me recomendaron este lugar, desde que llegas al momento te invitan algo de tomar y las personas que cortan muy amables, buen ambiente, excelente todo.',
  },
  {
    autor: 'Ileana Castro',
    cuando: 'Hace 9 meses',
    texto: 'Excelente atención sobre todo de Frank 🙂',
  },
  {
    autor: 'Maria Moha',
    cuando: 'Hace 11 meses',
    texto:
      'Muy buen servicio. Gente muy amable y profesional 👌🏻 100% recomendable, trabajos muy bien realizados 😍😍',
  },
];

const galeria = [
  { src: `/${slug}/img/foto_3.jpg`, alt: 'Interior del salón con espejo de marco rojo y candelabro' },
  { src: `/${slug}/img/foto_2.jpg`, alt: 'Clienta en la silla de estilismo con cabello trabajado en ombré' },
  { src: `/${slug}/img/foto_1.jpg`, alt: 'Mostrador de productos profesionales L’Oréal Professionnel' },
  { src: `/${slug}/img/foto_4.jpg`, alt: 'Muro de productos Revlon Professional y Tec Italy' },
  { src: `/${slug}/img/foto_5.jpg`, alt: 'Vitrina con cepillos, esmaltes y accesorios de belleza' },
];

const horarios = [
  { d: 'Lunes', h: '10:00 – 18:00' },
  { d: 'Martes', h: '10:00 – 18:00' },
  { d: 'Miércoles', h: '10:00 – 18:00' },
  { d: 'Jueves', h: '10:00 – 18:00' },
  { d: 'Viernes', h: '10:00 – 18:00' },
  { d: 'Sábado', h: '10:00 – 18:00' },
  { d: 'Domingo', h: 'Cerrado', off: true },
];
---

<BaseLayout
  title="Studio 54 · Estética y cabello en Mérida"
  description="Cuidado de tu imagen y cabello con actitud, en Francisco de Montejo. ⭐ 4.8 · 156 reseñas en Google. Color, cortes y cambios de look."
  slug={slug}
  ogImage={`/${slug}/img/foto_3.jpg`}
  fonts="https://fonts.googleapis.com/css2?family=Syncopate:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap"
  favicon="🪩"
  themeColor="#0C0A12"
  whatsapp={whatsapp}
  telefono={telefono}
  mapsUrl={mapsUrl}
>
  <!-- ===================== HERO ===================== -->
  <header class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <p class="eyebrow">Centro de estética · Mérida, Yucatán</p>

      <div class="mark" aria-hidden="true">
        <span class="star s1"></span>
        <span class="star s2"></span>
        <div class="starburst">
          <span class="fiftyfour">54</span>
        </div>
      </div>
      <h1 class="wordmark">Studio&nbsp;54</h1>
      <p class="tagline">
        Cuidado de tu imagen y cabello, con actitud. Color, cortes y cambios de
        look en un salón donde el buen ambiente se nota.
      </p>

      <p class="rating-pill">
        <span class="stars" aria-hidden="true">★★★★★</span>
        <strong>4.8</strong> · 156 reseñas en Google
      </p>

      <div class="cta-row">
        <a class="btn btn-primary" href={whatsappCita}>
          <span class="dot" aria-hidden="true"></span> Agendar por WhatsApp
        </a>
        <a class="btn btn-ghost" href={mapsUrl} target="_blank" rel="noopener">Cómo llegar</a>
      </div>

      <figure class="hero-photo reveal">
        <img
          src={`/${slug}/img/foto_3.jpg`}
          alt="Interior de Studio 54: espejo de marco rojo bajo un candelabro"
          width="675"
          height="1200"
          fetchpriority="high"
        />
        <figcaption>Nuestro salón en Francisco de Montejo</figcaption>
      </figure>
    </div>
  </header>

  <!-- ===================== MARQUEE ===================== -->
  <section class="marquee" aria-label="Marcas y servicios">
    <div class="marquee-track">
      {[...marcas, ...marcas].map((m) => (
        <span class="marquee-item">{m}<span class="sep" aria-hidden="true">✦</span></span>
      ))}
    </div>
  </section>

  <!-- ===================== QUIÉNES SOMOS ===================== -->
  <section class="section about" id="nosotros">
    <div class="wrap">
      <p class="eyebrow eyebrow-c">Quiénes somos</p>
      <h2 class="h2">Un estudio hecho para verte bien y sentirte mejor</h2>
      <div class="about-grid">
        <div class="about-copy">
          <p>
            En Studio 54 tratamos tu cabello como parte de tu presentación. Nos
            gusta el asesoramiento honesto: escuchar qué buscas, cuidar lo que
            ya tienes y proponerte el cambio de look que de verdad te queda.
          </p>
          <p>
            Trabajamos color y colorimetría, cortes, reconstrucción y nutrición
            capilar con marcas profesionales. Y como dicen quienes nos visitan,
            aquí desde que llegas te invitan algo de tomar: buen ambiente,
            gente amable y trabajos bien hechos.
          </p>
        </div>
        <ul class="about-stats" aria-label="En números">
          <li><b>4.8</b><span>de 5 en Google</span></li>
          <li><b>156</b><span>reseñas reales</span></li>
          <li><b>Lun–Sáb</b><span>10:00 a 18:00</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICIOS ===================== -->
  <section class="section services" id="servicios">
    <div class="wrap">
      <p class="eyebrow eyebrow-c">Lo que hacemos</p>
      <h2 class="h2">Servicios de cabello e imagen</h2>
      <div class="svc-grid">
        {servicios.map((s) => (
          <article class="svc-card reveal">
            <span class="svc-mark" aria-hidden="true"></span>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </article>
        ))}
      </div>
      <p class="svc-note">Sin listas de precios en línea: pregúntanos por WhatsApp según lo que necesites.</p>
    </div>
  </section>

  <!-- ===================== CTA INTERMEDIO ===================== -->
  <section class="section cta-band">
    <div class="wrap cta-band-inner">
      <div class="starburst-mini" aria-hidden="true"></div>
      <h2 class="h2 cta-band-title">¿Lista para tu cambio de look?</h2>
      <p>Mándanos un mensaje y agendamos el día que mejor te acomode.</p>
      <a class="btn btn-primary" href={whatsappCita}>
        <span class="dot" aria-hidden="true"></span> Escríbenos por WhatsApp
      </a>
    </div>
  </section>

  <!-- ===================== GALERÍA ===================== -->
  <section class="section gallery" id="galeria">
    <div class="wrap">
      <p class="eyebrow eyebrow-c">Nuestro estudio</p>
      <h2 class="h2">Una mirada al salón</h2>
      <div class="gal-grid">
        {galeria.map((g, i) => (
          <figure class={`gal-item reveal ${i === 0 ? 'gal-big' : ''}`}>
            <img src={g.src} alt={g.alt} loading="lazy" decoding="async" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== RESEÑAS ===================== -->
  <section class="section reviews" id="resenas">
    <div class="wrap">
      <p class="eyebrow eyebrow-c">Lo que dicen de nosotros</p>
      <div class="rating-hero">
        <span class="rating-num">4.8</span>
        <div class="rating-meta">
          <span class="stars big" aria-hidden="true">★★★★★</span>
          <span>156 reseñas en Google</span>
        </div>
      </div>
      <div class="rev-grid">
        {resenas.map((r) => (
          <figure class="rev-card reveal">
            <span class="quote-mark" aria-hidden="true">”</span>
            <blockquote>{r.texto}</blockquote>
            <figcaption>
              <b>{r.autor}</b>
              <span>{r.cuando}</span>
            </figcaption>
          </figure>
        ))}
      </div>
      <div class="rev-cta">
        <a class="btn btn-ghost" href={mapsUrl} target="_blank" rel="noopener">Leer más reseñas en Google</a>
      </div>
    </div>
  </section>

  <!-- ===================== UBICACIÓN Y HORARIOS ===================== -->
  <section class="section location" id="ubicacion">
    <div class="wrap loc-grid">
      <div class="loc-info">
        <p class="eyebrow eyebrow-c">Dónde estamos</p>
        <h2 class="h2">Francisco de Montejo, Mérida</h2>
        <p class="loc-address">{direccion}</p>

        <table class="hours" aria-label="Horarios de atención">
          <tbody>
            {horarios.map((row) => (
              <tr class={row.off ? 'closed' : ''}>
                <th scope="row">{row.d}</th>
                <td>{row.h}</td>
              </tr>
            ))}
          </tbody>
        </table>

        <ul class="attrs" aria-label="Datos del lugar">
          <li>💳 Aceptamos tarjetas</li>
          <li>🅿️ Sobre la C. 41-A</li>
        </ul>

        <div class="loc-actions">
          <a class="btn btn-primary" href={whatsappCita}><span class="dot" aria-hidden="true"></span> Agendar cita</a>
          <a class="btn btn-ghost" href={`tel:+52${telefono.replace(/\s/g, '')}`}>Llamar</a>
        </div>
      </div>
      <div class="loc-map">
        <iframe
          title="Mapa de Studio 54 en Mérida"
          src={mapSrc}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section class="section faq" id="faq">
    <div class="wrap wrap-narrow">
      <p class="eyebrow eyebrow-c">Preguntas rápidas</p>
      <h2 class="h2">Antes de venir</h2>
      <div class="faq-list">
        <details>
          <summary>¿Aceptan pago con tarjeta?</summary>
          <p>Sí, puedes pagar con tarjeta además de efectivo.</p>
        </details>
        <details>
          <summary>¿Qué días y horarios abren?</summary>
          <p>De lunes a sábado, de 10:00 a 18:00. Los domingos permanecemos cerrados.</p>
        </details>
        <details>
          <summary>¿Cómo agendo una cita?</summary>
          <p>Lo más rápido es por WhatsApp: nos cuentas qué servicio quieres y coordinamos el día.</p>
        </details>
        <details>
          <summary>¿Dónde están ubicados?</summary>
          <p>En {direccion}, en la colonia Francisco de Montejo II, Mérida.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ===================== CTA FINAL ===================== -->
  <section class="section final-cta">
    <div class="wrap final-inner">
      <div class="mark small" aria-hidden="true">
        <div class="starburst">
          <span class="fiftyfour">54</span>
        </div>
      </div>
      <h2 class="h2">Tu próxima cita empieza con un mensaje</h2>
      <p>Estamos en Francisco de Montejo, listos para atenderte de lunes a sábado.</p>
      <a class="btn btn-primary btn-lg" href={whatsappCita}>
        <span class="dot" aria-hidden="true"></span> Escríbenos por WhatsApp
      </a>
    </div>
  </section>

  <footer class="foot">
    <p class="foot-name">Studio 54</p>
    <p>
      <a href={`tel:+52${telefono.replace(/\s/g, '')}`}>{telefono}</a> ·
      {direccion}
    </p>
    <p class="foot-hours">Lunes a sábado · 10:00 – 18:00</p>
  </footer>

  <style is:global>
    :root {
      --onyx: #0C0A12;
      --onyx-2: #17131F;
      --onyx-3: #201A2C;
      --champagne: #E9C877;
      --champagne-soft: #F3E2B3;
      --magenta: #FF2E92;
      --violet: #A64DFF;
      --ivory: #F6F1EA;
      --muted: #C7BDD6;
      --line: rgba(233, 200, 119, 0.18);
    }

    body {
      background: var(--onyx);
      color: var(--ivory);
      font-family: 'Manrope', system-ui, sans-serif;
      font-size: 17px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    .wrap { width: 100%; max-width: 1040px; margin: 0 auto; padding: 0 22px; }
    .wrap-narrow { max-width: 720px; }

    .section { padding: 68px 0; position: relative; }

    .eyebrow {
      font-family: 'Syncopate', sans-serif;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.34em;
      text-transform: uppercase;
      color: var(--champagne);
      margin: 0 0 18px;
    }
    .eyebrow-c { color: var(--champagne); }

    .h2 {
      font-family: 'Syncopate', sans-serif;
      font-weight: 700;
      font-size: clamp(1.35rem, 5.4vw, 2.15rem);
      line-height: 1.18;
      letter-spacing: 0.01em;
      margin: 0 0 26px;
      color: var(--ivory);
    }

    p { margin: 0 0 16px; }
    a { color: inherit; }

    /* ---------- Buttons ---------- */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: 'Manrope', sans-serif;
      font-weight: 700;
      font-size: 0.98rem;
      letter-spacing: 0.01em;
      text-decoration: none;
      padding: 14px 24px;
      border-radius: 999px;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
      white-space: nowrap;
    }
    .btn-primary {
      color: #17110A;
      background: linear-gradient(135deg, var(--champagne-soft), var(--champagne));
      box-shadow: 0 10px 30px -12px rgba(233, 200, 119, 0.6);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 16px 36px -12px rgba(255, 46, 146, 0.55); }
    .btn-ghost {
      color: var(--ivory);
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--line);
    }
    .btn-ghost:hover { transform: translateY(-2px); border-color: var(--champagne); background: rgba(233,200,119,0.08); }
    .btn-lg { padding: 17px 32px; font-size: 1.05rem; }
    .btn .dot {
      width: 9px; height: 9px; border-radius: 50%;
      background: #1DB954; box-shadow: 0 0 0 4px rgba(29,185,84,0.22);
    }
    :focus-visible { outline: 2px solid var(--magenta); outline-offset: 3px; border-radius: 4px; }

    /* ---------- Hero ---------- */
    .hero {
      position: relative;
      min-height: calc(100svh - var(--demo-banner-h, 38px));
      display: flex;
      align-items: center;
      overflow: hidden;
      padding: 40px 0 56px;
      background:
        radial-gradient(120% 80% at 50% -10%, rgba(166,77,255,0.16), transparent 60%),
        radial-gradient(90% 60% at 80% 20%, rgba(255,46,146,0.12), transparent 55%),
        var(--onyx);
    }
    .hero-glow {
      position: absolute; inset: 0;
      background: radial-gradient(60% 40% at 50% 42%, rgba(233,200,119,0.10), transparent 70%);
      pointer-events: none;
    }
    .hero-inner {
      position: relative;
      width: 100%;
      max-width: 720px;
      margin: 0 auto;
      padding: 0 22px;
      text-align: center;
    }

    .mark { position: relative; display: grid; place-items: center; margin: 6px auto 6px; }
    .starburst {
      position: relative;
      width: min(64vw, 260px);
      aspect-ratio: 1;
      display: grid;
      place-items: center;
    }
    .starburst::before {
      content: "";
      position: absolute; inset: -8%;
      border-radius: 50%;
      background: repeating-conic-gradient(from 0deg,
        transparent 0 6deg, rgba(233,200,119,0.20) 6deg 7.4deg);
      -webkit-mask: radial-gradient(circle, #000 26%, transparent 66%);
      mask: radial-gradient(circle, #000 26%, transparent 66%);
      animation: spin 44s linear infinite;
    }
    .starburst::after {
      content: "";
      position: absolute; inset: 16%;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,46,146,0.30), rgba(166,77,255,0.12) 55%, transparent 72%);
      filter: blur(4px);
    }
    .fiftyfour {
      position: relative;
      font-family: 'Syncopate', sans-serif;
      font-weight: 700;
      font-size: clamp(3.6rem, 20vw, 6.4rem);
      letter-spacing: 0.03em;
      color: var(--champagne);
      text-shadow: 0 0 22px rgba(233,200,119,0.4), 0 2px 0 rgba(0,0,0,0.3);
    }
    .star {
      position: absolute;
      background: var(--champagne-soft);
      clip-path: polygon(50% 0, 61% 39%, 100% 50%, 61% 61%, 50% 100%, 39% 61%, 0 50%, 39% 39%);
      filter: drop-shadow(0 0 6px rgba(233,200,119,0.8));
      animation: twinkle 3.2s ease-in-out infinite;
    }
    .star.s1 { width: 20px; height: 20px; top: 8%; right: 20%; }
    .star.s2 { width: 13px; height: 13px; bottom: 16%; left: 18%; animation-delay: 1.1s; }

    .wordmark {
      font-family: 'Syncopate', sans-serif;
      font-weight: 700;
      font-size: clamp(1.6rem, 7vw, 2.6rem);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin: 4px 0 14px;
      color: var(--ivory);
    }
    .tagline {
      color: var(--muted);
      font-size: 1.02rem;
      max-width: 34ch;
      margin: 0 auto 20px;
    }
    .rating-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 0.92rem;
      color: var(--ivory);
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--line);
      padding: 8px 16px;
      border-radius: 999px;
      margin: 0 0 24px;
    }
    .rating-pill strong { color: var(--champagne); }
    .stars { color: var(--champagne); letter-spacing: 2px; }

    .cta-row { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }

    .hero-photo {
      margin: 40px auto 0;
      max-width: 340px;
      position: relative;
    }
    .hero-photo img {
      width: 100%;
      border-radius: 16px;
      border: 1px solid var(--line);
      box-shadow: 0 30px 60px -30px rgba(0,0,0,0.9), 0 0 0 6px rgba(233,200,119,0.05);
    }
    .hero-photo figcaption {
      font-size: 0.78rem;
      color: var(--muted);
      letter-spacing: 0.02em;
      margin-top: 12px;
      text-transform: uppercase;
    }

    /* ---------- Marquee ---------- */
    .marquee {
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      background: linear-gradient(90deg, rgba(255,46,146,0.06), rgba(166,77,255,0.06));
      overflow: hidden;
      padding: 16px 0;
    }
    .marquee-track {
      display: inline-flex;
      white-space: nowrap;
      animation: slide 34s linear infinite;
    }
    .marquee-item {
      font-family: 'Syncopate', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--champagne-soft);
      display: inline-flex;
      align-items: center;
    }
    .marquee-item .sep { color: var(--magenta); margin: 0 22px; font-size: 0.7rem; }

    /* ---------- About ---------- */
    .about-grid { display: grid; gap: 30px; }
    .about-copy p { color: var(--muted); }
    .about-copy p:first-child { color: var(--ivory); font-size: 1.08rem; }
    .about-stats {
      list-style: none;
      margin: 0; padding: 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    .about-stats li {
      background: var(--onyx-2);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 18px 10px;
      text-align: center;
    }
    .about-stats b {
      display: block;
      font-family: 'Syncopate', sans-serif;
      font-size: 1.15rem;
      color: var(--champagne);
      margin-bottom: 6px;
    }
    .about-stats span { font-size: 0.76rem; color: var(--muted); }

    /* ---------- Services ---------- */
    .svc-grid { display: grid; gap: 14px; }
    .svc-card {
      background: var(--onyx-2);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 24px 22px;
      position: relative;
      transition: transform 0.25s ease, border-color 0.25s ease;
    }
    .svc-card:hover { transform: translateY(-3px); border-color: var(--champagne); }
    .svc-mark {
      display: inline-block;
      width: 26px; height: 26px;
      margin-bottom: 14px;
      background:
        conic-gradient(from 0deg, var(--champagne), var(--magenta), var(--violet), var(--champagne));
      -webkit-mask: radial-gradient(circle at 50% 50%, transparent 30%, #000 31%),
        conic-gradient(#000 0 0);
      clip-path: polygon(50% 0, 61% 39%, 100% 50%, 61% 61%, 50% 100%, 39% 61%, 0 50%, 39% 39%);
      border-radius: 4px;
    }
    .svc-card h3 {
      font-family: 'Syncopate', sans-serif;
      font-size: 0.9rem;
      letter-spacing: 0.02em;
      margin: 0 0 10px;
      color: var(--ivory);
      line-height: 1.35;
    }
    .svc-card p { color: var(--muted); font-size: 0.95rem; margin: 0; }
    .svc-note {
      margin-top: 22px;
      font-size: 0.85rem;
      color: var(--muted);
      text-align: center;
    }

    /* ---------- CTA band ---------- */
    .cta-band {
      background:
        radial-gradient(80% 120% at 50% 0%, rgba(255,46,146,0.14), transparent 60%),
        var(--onyx-2);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      text-align: center;
    }
    .cta-band-inner p { color: var(--muted); }
    .cta-band-title { margin-bottom: 12px; }
    .starburst-mini {
      width: 44px; height: 44px;
      margin: 0 auto 18px;
      background: repeating-conic-gradient(from 0deg,
        transparent 0 10deg, var(--champagne) 10deg 13deg);
      -webkit-mask: radial-gradient(circle, #000 18%, transparent 62%);
      mask: radial-gradient(circle, #000 18%, transparent 62%);
      opacity: 0.9;
    }

    /* ---------- Gallery ---------- */
    .gal-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .gal-item {
      margin: 0;
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid var(--line);
      background: var(--onyx-2);
    }
    .gal-item img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 3/4; }
    .gal-big { grid-column: 1 / -1; }
    .gal-big img { aspect-ratio: 16/11; }

    /* ---------- Reviews ---------- */
    .reviews { background: var(--onyx-2); }
    .rating-hero {
      display: flex;
      align-items: center;
      gap: 18px;
      margin-bottom: 30px;
    }
    .rating-num {
      font-family: 'Syncopate', sans-serif;
      font-weight: 700;
      font-size: clamp(3rem, 16vw, 4.6rem);
      line-height: 1;
      color: var(--champagne);
      text-shadow: 0 0 26px rgba(233,200,119,0.3);
    }
    .rating-meta { display: flex; flex-direction: column; gap: 4px; color: var(--muted); font-size: 0.9rem; }
    .stars.big { font-size: 1.2rem; }
    .rev-grid { display: grid; gap: 14px; }
    .rev-card {
      background: var(--onyx);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 26px 22px 22px;
      position: relative;
    }
    .quote-mark {
      position: absolute;
      top: 6px; right: 20px;
      font-family: 'Syncopate', sans-serif;
      font-size: 3rem;
      color: var(--magenta);
      opacity: 0.5;
      line-height: 1;
    }
    .rev-card blockquote {
      margin: 0 0 16px;
      font-size: 1.02rem;
      line-height: 1.6;
      color: var(--ivory);
    }
    .rev-card figcaption { display: flex; flex-direction: column; }
    .rev-card figcaption b { color: var(--champagne); font-size: 0.95rem; }
    .rev-card figcaption span { color: var(--muted); font-size: 0.8rem; }
    .rev-cta { text-align: center; margin-top: 26px; }

    /* ---------- Location ---------- */
    .loc-grid { display: grid; gap: 26px; }
    .loc-address { color: var(--muted); }
    .hours {
      width: 100%;
      border-collapse: collapse;
      margin: 6px 0 20px;
      font-size: 0.95rem;
    }
    .hours th, .hours td { text-align: left; padding: 10px 0; border-bottom: 1px solid var(--line); }
    .hours th { font-weight: 600; color: var(--ivory); }
    .hours td { text-align: right; color: var(--champagne-soft); }
    .hours tr.closed td { color: var(--magenta); }
    .attrs { list-style: none; margin: 0 0 22px; padding: 0; display: flex; flex-wrap: wrap; gap: 10px; }
    .attrs li {
      font-size: 0.85rem;
      color: var(--ivory);
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--line);
      padding: 8px 14px;
      border-radius: 999px;
    }
    .loc-actions { display: flex; flex-wrap: wrap; gap: 12px; }
    .loc-map {
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid var(--line);
      min-height: 300px;
      background: var(--onyx-2);
    }
    .loc-map iframe { width: 100%; height: 100%; min-height: 300px; border: 0; display: block; filter: grayscale(0.2) contrast(1.05); }

    /* ---------- FAQ ---------- */
    .faq-list { display: grid; gap: 10px; }
    .faq details {
      background: var(--onyx-2);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 4px 20px;
    }
    .faq summary {
      cursor: pointer;
      list-style: none;
      padding: 16px 0;
      font-weight: 700;
      color: var(--ivory);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }
    .faq summary::-webkit-details-marker { display: none; }
    .faq summary::after {
      content: "+";
      font-family: 'Syncopate', sans-serif;
      color: var(--champagne);
      font-size: 1.1rem;
      transition: transform 0.2s ease;
    }
    .faq details[open] summary::after { transform: rotate(45deg); }
    .faq details p { color: var(--muted); margin: 0 0 16px; font-size: 0.95rem; }

    /* ---------- Final CTA ---------- */
    .final-cta {
      text-align: center;
      background:
        radial-gradient(70% 90% at 50% 100%, rgba(166,77,255,0.16), transparent 60%),
        var(--onyx);
    }
    .final-inner p { color: var(--muted); max-width: 40ch; margin-left: auto; margin-right: auto; }
    .mark.small { margin-bottom: 6px; }
    .mark.small .starburst { width: min(40vw, 150px); }
    .mark.small .fiftyfour { font-size: clamp(2.4rem, 12vw, 3.6rem); }

    /* ---------- Footer ---------- */
    .foot {
      text-align: center;
      padding: 44px 22px 96px;
      border-top: 1px solid var(--line);
      color: var(--muted);
      font-size: 0.9rem;
    }
    .foot-name {
      font-family: 'Syncopate', sans-serif;
      font-weight: 700;
      letter-spacing: 0.12em;
      color: var(--champagne);
      margin-bottom: 10px;
    }
    .foot a { color: var(--champagne-soft); text-decoration: none; }
    .foot-hours { margin-top: 6px; font-size: 0.82rem; }

    /* ---------- Reveal (progressive) ---------- */
    body.has-js .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.6s ease, transform 0.6s ease; }
    body.has-js .reveal.in { opacity: 1; transform: none; }

    /* ---------- Animations ---------- */
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes slide { to { transform: translateX(-50%); } }
    @keyframes twinkle { 0%, 100% { opacity: 0.4; transform: scale(0.85); } 50% { opacity: 1; transform: scale(1.1); } }

    @media (prefers-reduced-motion: reduce) {
      .starburst::before, .marquee-track, .star { animation: none !important; }
      body.has-js .reveal { opacity: 1; transform: none; }
    }

    /* ---------- Responsive up ---------- */
    @media (min-width: 720px) {
      .about-grid { grid-template-columns: 1.4fr 1fr; align-items: center; }
      .svc-grid { grid-template-columns: repeat(3, 1fr); }
      .gal-grid { grid-template-columns: repeat(3, 1fr); }
      .gal-big { grid-column: span 2; grid-row: span 2; }
      .gal-big img { aspect-ratio: auto; height: 100%; }
      .rev-grid { grid-template-columns: repeat(2, 1fr); }
      .loc-grid { grid-template-columns: 1fr 1fr; align-items: stretch; }
      .hero-photo { max-width: 420px; }
    }
    @media (min-width: 1000px) {
      .svc-grid { grid-template-columns: repeat(3, 1fr); }
    }
  </style>

  <script is:inline>
    (function () {
      document.body.classList.add('has-js');
      var els = document.querySelectorAll('.reveal');
      if (!('IntersectionObserver' in window) || els.length === 0) {
        els.forEach(function (el) { el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      els.forEach(function (el) { io.observe(el); });
    })();
  </script>
</BaseLayout>
