---
import BaseLayout from '../../layouts/BaseLayout.astro';

const WA = 'https://wa.me/529994152877';
const TEL = '999 415 2877';
const TEL_HREF = 'tel:+529994152877';
const MAPS = 'https://maps.google.com/?cid=537337488577741635&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA';
const FB = 'https://www.facebook.com/medivetmerida/';
const MAP_EMBED = 'https://www.google.com/maps?q=MediVet%2C%20C.%2016%20318%2C%20Maya%2C%2097134%20M%C3%A9rida%2C%20Yuc.%2C%20M%C3%A9xico&output=embed';
---
<BaseLayout
  title="MediVet · Veterinaria en Col. Maya, Mérida"
  description="Consultas, cirugía, hospitalización y hospedaje para tu mascota. ⭐ 4.5 con 61 reseñas en Google. Un equipo al que en serio le gusta convivir con los animales. Escríbenos por WhatsApp."
  slug="medivet"
  ogImage="/medivet/img/foto_5.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Signika:wght@500;600;700&family=Karla:wght@400;500;700&display=swap"
  favicon="🩺"
  themeColor="#2f8fd6"
  whatsapp={WA}
  telefono={TEL}
  mapsUrl={MAPS}
>
  <main class="mv">

    <!-- ============ HERO ============ -->
    <header class="hero">
      <img class="hero-img" src="/medivet/img/foto_5.jpg" alt="Bailey y Tara, dos perritas con collar de nombre, en un jardín" />
      <div class="hero-scrim" aria-hidden="true"></div>
      <div class="hero-content wrap">
        <p class="kicker reveal">Veterinaria · Col. Maya, Mérida</p>
        <h1 class="reveal">Medicina con <span class="accent">cariño</span> para tu mejor amigo</h1>
        <p class="tagline reveal">Un equipo al que en serio le gusta convivir con los animales — y se nota, dicen quienes llevan años trayendo a los suyos.</p>

        <a class="chip reveal" href={MAPS} target="_blank" rel="noopener">
          <span class="star" aria-hidden="true">★</span> 4.5 · 61 reseñas en Google
        </a>

        <div class="cta-row reveal">
          <a class="btn btn-solid" href={WA} target="_blank" rel="noopener">
            <svg viewBox="0 0 32 32" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M16 3C9.4 3 4 8.3 4 14.9c0 2.6.8 5 2.3 7L4 29l7.3-2.3c1.9 1 3.9 1.5 4.7 1.5 6.6 0 12-5.3 12-11.9S22.6 3 16 3zm0 21.8c-1.4 0-3.2-.5-4.7-1.4l-.3-.2-4.3 1.4 1.4-4.2-.2-.3c-1.2-1.7-1.9-3.7-1.9-5.7C6 9.4 10.5 5 16 5s10 4.4 10 9.9-4.5 9.9-10 9.9zm5.5-7.4c-.3-.2-1.8-.9-2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.2-.2.2-.3.3-.5.1-.2 0-.4 0-.6-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4-.3.3-1.1 1.1-1.1 2.7s1.2 3.1 1.3 3.3c.2.2 2.3 3.5 5.6 4.9.8.3 1.4.5 1.9.7.8.2 1.5.2 2.1.1.6-.1 1.8-.7 2.1-1.5.3-.7.3-1.3.2-1.5-.1-.1-.3-.2-.6-.4z"/></svg>
            Escríbenos por WhatsApp
          </a>
          <a class="btn btn-ghost" href={MAPS} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12 2a7 7 0 0 0-7 7c0 5.2 7 13 7 13s7-7.8 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
            Cómo llegar
          </a>
        </div>
      </div>
    </header>

    <!-- ============ FIRMA: latido + huella ============ -->
    <div class="firma-wrap reveal" aria-hidden="true">
      <svg class="firma" viewBox="0 0 600 44" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path class="firma-line" pathLength="1" d="M0,26 L58,26 L74,8 L90,42 L106,16 L122,26 L198,26 L214,8 L230,42 L246,16 L262,26 L338,26 L354,8 L370,42 L386,16 L402,26 L478,26 L494,8 L510,42 L526,16 L542,26 L600,26" />
        <g class="firma-paw" transform="translate(83,0)">
          <ellipse cx="7" cy="15" rx="6.4" ry="5.2"/>
          <circle cx="1.6" cy="4.2" r="2.5"/>
          <circle cx="7" cy="1.4" r="2.5"/>
          <circle cx="12.4" cy="4.2" r="2.5"/>
        </g>
        <g class="firma-paw" transform="translate(223,0)">
          <ellipse cx="7" cy="15" rx="6.4" ry="5.2"/>
          <circle cx="1.6" cy="4.2" r="2.5"/>
          <circle cx="7" cy="1.4" r="2.5"/>
          <circle cx="12.4" cy="4.2" r="2.5"/>
        </g>
        <g class="firma-paw" transform="translate(363,0)">
          <ellipse cx="7" cy="15" rx="6.4" ry="5.2"/>
          <circle cx="1.6" cy="4.2" r="2.5"/>
          <circle cx="7" cy="1.4" r="2.5"/>
          <circle cx="12.4" cy="4.2" r="2.5"/>
        </g>
        <g class="firma-paw" transform="translate(503,0)">
          <ellipse cx="7" cy="15" rx="6.4" ry="5.2"/>
          <circle cx="1.6" cy="4.2" r="2.5"/>
          <circle cx="7" cy="1.4" r="2.5"/>
          <circle cx="12.4" cy="4.2" r="2.5"/>
        </g>
      </svg>
    </div>

    <!-- ============ 01 QUIÉNES SOMOS ============ -->
    <section class="sec" id="nosotros">
      <div class="wrap two-col">
        <div class="about">
          <p class="sec-kicker reveal">Quiénes somos</p>
          <h2 class="sec-title reveal">Un equipo que <em>disfruta</em> cuidar animales</h2>
          <div class="about-text reveal">
            <p>Somos MediVet, una veterinaria en la colonia Maya, en Mérida. Aquí no solo revisamos vacunas y recetamos medicamentos: a nuestro equipo en serio le gusta convivir con los animales, y eso es justo lo que más repiten quienes nos visitan.</p>
            <p>Atendemos consultas, cirugías y hospitalización, y también ofrecemos hospedaje para cuando sales de viaje y no quieres dejar a tu mascota con cualquiera: aquí la conocen, juegan con ella y hacen que se sienta en casa mientras tú no estás.</p>
            <p>Hay familias que llevan más de cinco años trayendo a sus animalitos con nosotros. Eso, más que cualquier otra cosa, es lo que más nos enorgullece.</p>
          </div>
        </div>
        <div class="about-photo reveal">
          <img src="/medivet/img/foto_2.jpg" alt="Perro esperando junto al mostrador de recepción de MediVet" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- Interludio fotográfico -->
    <div class="banda-foto reveal">
      <img src="/medivet/img/foto_4.jpg" alt="Rótulo de MediVet, salud para tu mascota, en la fachada de la clínica" loading="lazy" />
    </div>

    <!-- ============ 02 SERVICIOS ============ -->
    <section class="sec sec-panel" id="servicios">
      <div class="wrap two-col two-col-rev">
        <div class="serv-photo reveal">
          <img src="/medivet/img/foto_3.jpg" alt="Sala de procedimientos de MediVet, con mesa de exploración y equipo veterinario" loading="lazy" />
        </div>
        <div>
          <p class="sec-kicker reveal">Qué ofrecemos</p>
          <h2 class="sec-title reveal">Cómo podemos ayudar a tu mascota</h2>
          <ul class="servicios reveal">
            <li><span class="paw" aria-hidden="true">🐾</span> Consulta veterinaria general</li>
            <li><span class="paw" aria-hidden="true">🐾</span> Vacunación y desparasitación</li>
            <li><span class="paw" aria-hidden="true">🐾</span> Cirugía y esterilización</li>
            <li><span class="paw" aria-hidden="true">🐾</span> Hospitalización</li>
            <li><span class="paw" aria-hidden="true">🐾</span> Hospedaje para mascotas</li>
            <li><span class="paw" aria-hidden="true">🐾</span> Farmacia y productos para tu mascota</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ============ 03 RESEÑAS ============ -->
    <section class="sec" id="resenas">
      <div class="wrap">
        <p class="sec-kicker reveal">Lo que dicen en Google</p>
        <h2 class="sec-title reveal"><span class="accent">4.5 de 5</span> en 61 reseñas</h2>
        <div class="reviews reveal">
          <figure class="rev">
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«Llevamos mas de 5 años asistiendo a MediVet y apreciamos mucho al equipo por todo su apoyo y cariño que han tenido con nuestros animalitos»</blockquote>
            <figcaption><strong>Pamela Cervera</strong><span>Hace un año · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«…a Luna le encanta pasar su estancia ahí, me toca salir de la ciudad por algunos días y en ocasiones por semana y Luna es la más feliz de quedarse con su amigo Kenai y perritos que ha ido conociendo, sin duda veo en los videos que me comparten como lo disfruta y es muy querida por todos. Luna y yo recomendamos totalmente 🐾🙌🏼»</blockquote>
            <figcaption><strong>Elizabeth Enriquez Kanahan</strong><span>Hace un año · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <p class="rev-stars" aria-label="5 estrellas">★★★★★</p>
            <blockquote>«Pacientes y amorosos con los animales. Trato digno y precios justos.»</blockquote>
            <figcaption><strong>Eduardo Castañeda</strong><span>Hace 5 meses · Google</span></figcaption>
          </figure>
        </div>
        <div class="center reveal">
          <a class="btn btn-ghost" href={MAPS} target="_blank" rel="noopener">Leer más reseñas en Google</a>
        </div>
      </div>
    </section>

    <!-- ============ 04 UBICACIÓN Y HORARIOS ============ -->
    <section class="sec sec-panel" id="ubicacion">
      <div class="wrap">
        <p class="sec-kicker reveal">Dónde estamos</p>
        <h2 class="sec-title reveal">Colonia Maya, Mérida</h2>
        <div class="ubica reveal">
          <div class="ubica-info">
            <img class="ubica-foto" src="/medivet/img/foto_1.jpg" alt="Fachada de MediVet, veterinaria en la colonia Maya, Mérida" loading="lazy" />
            <p class="dir">C. 16 318, Maya<br />97134 Mérida, Yuc.</p>
            <a class="btn btn-solid btn-sm" href={MAPS} target="_blank" rel="noopener">Abrir en Google Maps</a>
            <h3 class="horario-titulo">Horario de atención</h3>
            <table class="horarios">
              <tbody>
                <tr data-dia="1"><th scope="row">Lunes</th><td>9:00–18:00</td></tr>
                <tr data-dia="2"><th scope="row">Martes</th><td>9:00–18:00</td></tr>
                <tr data-dia="3"><th scope="row">Miércoles</th><td>9:00–18:00</td></tr>
                <tr data-dia="4"><th scope="row">Jueves</th><td>9:00–18:00</td></tr>
                <tr data-dia="5"><th scope="row">Viernes</th><td>9:00–18:00</td></tr>
                <tr data-dia="6"><th scope="row">Sábado</th><td>9:00–14:00</td></tr>
                <tr data-dia="0"><th scope="row">Domingo</th><td>Cerrado</td></tr>
              </tbody>
            </table>
          </div>
          <div class="mapa">
            <iframe
              src={MAP_EMBED}
              title="Mapa: MediVet en la colonia Maya, Mérida"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CTA FINAL ============ -->
    <section class="banda">
      <div class="wrap">
        <h2 class="banda-title">¿Tu mascota necesita una cita?</h2>
        <p class="banda-sub">Escríbenos por WhatsApp y con gusto te ayudamos.</p>
        <div class="cta-row">
          <a class="btn btn-solid" href={WA} target="_blank" rel="noopener">WhatsApp directo</a>
          <a class="btn btn-ghost-dark" href={TEL_HREF}>Llamar · {TEL}</a>
        </div>
      </div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="pie">
      <div class="wrap">
        <p class="pie-logo">MediVet</p>
        <p class="pie-dato">Veterinaria · C. 16 318, Maya, 97134 Mérida, Yuc.</p>
        <p class="pie-dato"><a href={TEL_HREF}>{TEL}</a> · <a href={WA} target="_blank" rel="noopener">WhatsApp</a> · <a href={FB} target="_blank" rel="noopener">Facebook</a></p>
        <p class="pie-mini">Lunes a viernes 9:00–18:00 · Sábado 9:00–14:00 · Domingo cerrado</p>
      </div>
    </footer>
  </main>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "VeterinaryCare",
    "name": "MediVet",
    "telephone": "+529994152877",
    "url": "https://demos.ivang.mx/medivet",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "C. 16 318, Maya",
      "addressLocality": "Mérida",
      "addressRegion": "Yucatán",
      "postalCode": "97134",
      "addressCountry": "MX"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.5",
      "reviewCount": "61"
    },
    "openingHours": ["Mo-Fr 09:00-18:00", "Sa 09:00-14:00"]
  }
  </script>

  <style is:global>
    :root {
      --white: #f8fbff;
      --panel: #eef5fc;
      --blue: #2f8fd6;
      --blue-dark: #1f6fae;
      --orange: #f5943f;
      --orange-dark: #c96a1f;
      --ink: #1f2a37;
      --muted: #5b6b7c;
      --line: rgba(31, 42, 55, 0.12);
      --display: "Signika", system-ui, sans-serif;
      --body: "Karla", system-ui, sans-serif;
    }

    body {
      background: var(--white);
      color: var(--ink);
      font-family: var(--body);
      font-size: 17px;
      line-height: 1.6;
      overflow-x: clip;
    }

    .mv ::selection { background: var(--orange); color: var(--ink); }
    .mv a:focus-visible,
    .mv .btn:focus-visible {
      outline: 3px solid var(--blue-dark);
      outline-offset: 3px;
    }

    .wrap { max-width: 1060px; margin: 0 auto; padding: 0 20px; }
    .accent { color: var(--blue-dark); }

    /* ---------- HERO ---------- */
    .hero {
      position: relative;
      min-height: calc(100vh - 38px);
      min-height: calc(100svh - 38px);
      display: flex;
      align-items: flex-end;
      overflow: hidden;
      background: var(--ink);
    }
    .hero-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 30%;
    }
    .hero-scrim {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(31, 42, 55, 0.15) 0%, rgba(31, 42, 55, 0.35) 45%, rgba(20, 28, 38, 0.92) 100%);
    }
    .hero-content {
      position: relative;
      z-index: 1;
      padding: 48px 20px 44px;
      color: #fff;
    }
    .kicker {
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--orange);
      margin: 0 0 12px;
    }
    .hero h1 {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(34px, 9vw, 60px);
      line-height: 1.06;
      margin: 0 0 16px;
      max-width: 14ch;
    }
    .hero h1 .accent { color: var(--orange); }
    .tagline {
      font-size: clamp(16px, 4vw, 19px);
      font-weight: 400;
      color: #eaf2fb;
      max-width: 40ch;
      margin: 0 0 20px;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid rgba(255, 255, 255, 0.35);
      border-radius: 999px;
      padding: 8px 16px;
      font-weight: 600;
      font-size: 14.5px;
      color: #fff;
      text-decoration: none;
      background: rgba(255, 255, 255, 0.08);
      -webkit-backdrop-filter: blur(6px);
      backdrop-filter: blur(6px);
    }
    .chip .star { color: var(--orange); }
    .chip:hover { border-color: var(--orange); }

    .cta-row { display: flex; flex-wrap: wrap; gap: 12px; margin: 22px 0 0; }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-family: var(--body);
      font-weight: 700;
      font-size: 16px;
      text-decoration: none;
      padding: 14px 22px;
      border-radius: 12px;
      transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
    }
    .btn:active { transform: scale(0.97); }
    .btn-solid { background: var(--orange); color: #241205; }
    .btn-solid:hover { background: #ffab5c; }
    .btn-ghost { border: 2px solid rgba(255, 255, 255, 0.55); color: #fff; }
    .btn-ghost:hover { border-color: var(--orange); color: var(--orange); }
    .btn-ghost-dark { border: 2px solid rgba(31, 42, 55, 0.35); color: var(--ink); }
    .btn-ghost-dark:hover { border-color: var(--ink); }
    .btn-sm { font-size: 14.5px; padding: 11px 18px; margin-top: 4px; }

    /* ---------- FIRMA: latido + huella ---------- */
    .firma-wrap {
      background: var(--white);
      padding: 22px 0;
    }
    .firma {
      display: block;
      width: 100%;
      height: 40px;
    }
    .firma-line {
      fill: none;
      stroke: var(--orange);
      stroke-width: 2.4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 1;
      stroke-dashoffset: 0;
    }
    .firma-paw { fill: var(--blue); }
    html.js .firma-line {
      stroke-dashoffset: 1;
      transition: stroke-dashoffset 1.5s ease;
    }
    html.js .firma-wrap.in .firma-line { stroke-dashoffset: 0; }
    html.js .firma-paw {
      opacity: 0;
      transition: opacity 0.5s ease 0.9s;
    }
    html.js .firma-wrap.in .firma-paw { opacity: 1; }

    /* ---------- SECCIONES ---------- */
    .sec { padding: 60px 0; }
    .sec-panel { background: var(--panel); }
    .sec-kicker {
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--blue-dark);
      margin: 0 0 10px;
    }
    .sec-title {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(28px, 7vw, 42px);
      line-height: 1.08;
      margin: 0 0 22px;
      color: var(--ink);
    }
    .sec-title em { color: var(--orange-dark); font-style: normal; }
    .sec-title .accent { color: var(--blue-dark); }

    .two-col { display: grid; grid-template-columns: 1fr; gap: 30px; align-items: center; }
    .about-text p { max-width: 58ch; margin: 0 0 16px; color: var(--muted); }
    .about-text p:last-child { margin-bottom: 0; }
    .about-photo img,
    .serv-photo img,
    .ubica-foto {
      width: 100%;
      border-radius: 16px;
      display: block;
      box-shadow: 0 16px 32px rgba(31, 42, 55, 0.14);
    }

    .banda-foto { width: 100%; height: 180px; overflow: hidden; }
    .banda-foto img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }

    /* ---------- SERVICIOS ---------- */
    .servicios {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .servicios li {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      background: var(--white);
      border-radius: 12px;
      font-weight: 600;
      font-size: 16px;
      color: var(--ink);
      box-shadow: 0 6px 16px rgba(31, 42, 55, 0.06);
    }
    .servicios .paw { font-size: 18px; flex-shrink: 0; }

    /* ---------- RESEÑAS ---------- */
    .reviews {
      display: grid;
      grid-template-columns: 1fr;
      gap: 18px;
      margin: 0 0 28px;
    }
    .rev {
      margin: 0;
      background: var(--white);
      color: var(--ink);
      border-radius: 16px;
      padding: 22px 22px 20px;
      border: 1px solid var(--line);
      box-shadow: 0 10px 26px rgba(31, 42, 55, 0.07);
    }
    .rev-stars {
      color: var(--orange);
      font-size: 16px;
      letter-spacing: 0.14em;
      margin: 0 0 10px;
    }
    .rev blockquote {
      margin: 0 0 14px;
      font-size: 16px;
      line-height: 1.55;
      font-weight: 500;
    }
    .rev figcaption {
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .rev figcaption strong {
      font-family: var(--display);
      font-weight: 700;
      font-size: 16px;
      color: var(--blue-dark);
    }
    .rev figcaption span { font-size: 13px; color: var(--muted); }
    .center { text-align: center; }

    /* ---------- UBICACIÓN ---------- */
    .ubica { display: grid; grid-template-columns: 1fr; gap: 28px; }
    .ubica-foto { margin: 0 0 20px; }
    .dir { font-size: 17px; font-weight: 600; margin: 0 0 14px; }
    .horario-titulo {
      font-family: var(--display);
      font-weight: 700;
      font-size: 19px;
      margin: 26px 0 10px;
      color: var(--ink);
    }
    .horarios { width: 100%; max-width: 420px; border-collapse: collapse; font-size: 15px; }
    .horarios th, .horarios td { padding: 9px 10px; border-bottom: 1px solid var(--line); text-align: left; }
    .horarios th { font-weight: 600; color: var(--ink); }
    .horarios td { color: var(--muted); text-align: right; font-variant-numeric: tabular-nums; }
    .horarios tr.hoy th, .horarios tr.hoy td { color: #fff; background: var(--blue); font-weight: 700; }
    .horarios tr.hoy th { border-radius: 8px 0 0 8px; }
    .horarios tr.hoy td { border-radius: 0 8px 8px 0; }
    .horarios tr.hoy th::after {
      content: "hoy";
      font-family: var(--display);
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: var(--orange);
      color: #241205;
      border-radius: 4px;
      padding: 2px 7px;
      margin-left: 10px;
      vertical-align: 1px;
    }
    .mapa iframe {
      width: 100%;
      height: 300px;
      border: 0;
      border-radius: 16px;
      display: block;
    }

    /* ---------- CTA FINAL ---------- */
    .banda {
      background: var(--blue);
      color: #fff;
      padding: 56px 0;
      text-align: center;
    }
    .banda-title {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(28px, 7vw, 44px);
      line-height: 1.1;
      margin: 0 0 12px;
    }
    .banda-sub { margin: 0 auto 22px; max-width: 40ch; font-weight: 500; color: #e8f2fc; }
    .banda .cta-row { justify-content: center; }
    .banda .btn-ghost-dark { border-color: rgba(255, 255, 255, 0.6); color: #fff; }
    .banda .btn-ghost-dark:hover { border-color: #fff; }

    /* ---------- FOOTER ---------- */
    .pie {
      padding: 40px 0 92px;
      text-align: center;
      background: var(--ink);
      color: var(--white);
    }
    .pie-logo {
      font-family: var(--display);
      font-weight: 700;
      font-size: 24px;
      color: #fff;
      margin: 0 0 10px;
    }
    .pie-dato { margin: 4px 0; color: #b9c6d4; font-size: 14.5px; }
    .pie-dato a { color: #fff; text-decoration: none; border-bottom: 1px solid var(--orange); }
    .pie-dato a:hover { color: var(--orange); }
    .pie-mini { margin: 14px 0 0; color: #8291a1; font-size: 12.5px; }

    /* ---------- REVEAL (solo con JS) ---------- */
    html.js .reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    html.js .reveal.in { opacity: 1; transform: none; }

    /* ---------- DESKTOP ---------- */
    @media (min-width: 760px) {
      .sec { padding: 96px 0; }
      .two-col { grid-template-columns: 1.1fr 0.9fr; gap: 56px; }
      .two-col-rev { grid-template-columns: 0.9fr 1.1fr; }
      .two-col-rev .serv-photo { order: 1; }
      .servicios { grid-template-columns: 1fr 1fr; }
      .reviews { grid-template-columns: repeat(3, 1fr); align-items: start; }
      .ubica { grid-template-columns: 1fr 1.15fr; align-items: start; }
      .ubica-foto { max-width: 340px; }
      .mapa iframe { height: 420px; }
      .banda-foto { height: 240px; }
    }
  </style>

  <script is:inline>
    (function () {
      var d = document;
      d.documentElement.classList.add('js');

      // Resaltar el día de hoy en la tabla de horarios
      var hoy = new Date().getDay(); // 0 = domingo
      var fila = d.querySelector('.horarios tr[data-dia="' + hoy + '"]');
      if (fila) fila.classList.add('hoy');

      // Scroll-reveal (mejora progresiva)
      var els = d.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach(function (el) { io.observe(el); });
      } else {
        els.forEach(function (el) { el.classList.add('in'); });
      }
    })();
  </script>
</BaseLayout>
