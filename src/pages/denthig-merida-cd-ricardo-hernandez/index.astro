---
import BaseLayout from '../../layouts/BaseLayout.astro';

const SLUG = 'denthig-merida-cd-ricardo-hernandez';
const img = (n: number) => `/${SLUG}/img/foto_${n}.jpg`;

const WHATSAPP = 'https://wa.me/529993905703';
const TELEFONO = '999 390 5703';
const MAPS_URL =
  'https://maps.google.com/?cid=15797951843565516798&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA';
const MAP_QUERY = encodeURIComponent(
  'Denthig Mérida, Calle 48-A 454, Nuevo Yucatán, 97147 Mérida, Yuc., México'
);
---
<BaseLayout
  title="Denthig Mérida · C.D. Ricardo Hernández | Dentista en Nuevo Yucatán, Mérida"
  description="Consultorio dental del Dr. Ricardo Hernández en Nuevo Yucatán, Mérida. ⭐ 5.0 con 39 reseñas en Google. Explicaciones claras, extracciones sin dolor y costos razonables. Agenda por WhatsApp."
  slug={SLUG}
  ogImage={img(3)}
  fonts="https://fonts.googleapis.com/css2?family=Onest:wght@500;600;700&family=Karla:wght@400;500;600&display=swap"
  favicon="🦷"
  themeColor="#5b7a99"
  whatsapp={WHATSAPP}
  telefono={TELEFONO}
  mapsUrl={MAPS_URL}
>
  <!-- ============ HERO ============ -->
  <header class="hero">
    <div class="wrap hero-grid">
      <div class="hero-text" data-reveal>
        <p class="eyebrow">Denthig Mérida · Nuevo Yucatán</p>
        <h1>Sin rodeos. <span class="accent">Sin dolor.</span></h1>
        <p class="hero-sub">
          El Dr. Ricardo Hernández y su esposa atienden en Denthig, en la colonia Nuevo
          Yucatán: te explican cada procedimiento de forma sencilla y clara, desde una
          limpieza hasta una extracción de muela del juicio, con costos razonables y sin
          sorpresas.
        </p>
        <a class="rating-chip" href={MAPS_URL} target="_blank" rel="noopener">
          <span class="stars" aria-hidden="true">★★★★★</span>
          <strong>5.0</strong> · 39 reseñas en Google
        </a>
        <div class="hero-ctas">
          <a class="btn btn-primary" href={WHATSAPP} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="19" height="19" aria-hidden="true"><path fill="currentColor" d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2Zm0 18.2c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.6.8-.8 1-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.4-3c-.3-.4 0-.5.1-.7l.4-.5c.1-.2.1-.3 0-.5l-.8-1.9c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.3-.9.9-.9 2.2s.9 2.6 1.1 2.8c.1.2 1.9 2.9 4.6 4 .6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.1-.3-.2-.7-.3Z"/></svg>
            Agenda por WhatsApp
          </a>
          <a class="btn btn-ghost" href={MAPS_URL} target="_blank" rel="noopener">Cómo llegar</a>
        </div>
      </div>
      <figure class="hero-media" data-reveal>
        <img
          src={img(3)}
          alt="Sala de espera de Denthig: sencilla, luminosa, con sillones azules y plantas"
          fetchpriority="high"
          width="1200"
          height="900"
        />
        <div class="stamp stamp-lg" aria-hidden="true">
          <svg viewBox="0 0 160 160">
            <circle cx="80" cy="80" r="76" fill="none" stroke="currentColor" stroke-width="2"></circle>
            <circle cx="80" cy="80" r="65" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="2 4"></circle>
            <path id="arcTopLg" d="M 22 84 A 58 58 0 0 1 138 84" fill="none"></path>
            <path id="arcBotLg" d="M 30 108 A 50 50 0 0 0 130 108" fill="none"></path>
            <text font-family="Onest, sans-serif" font-size="13" font-weight="700" letter-spacing="2.5" fill="currentColor">
              <textPath href="#arcTopLg" startOffset="50%" text-anchor="middle">SIN DOLOR</textPath>
            </text>
            <text font-family="Onest, sans-serif" font-size="10.5" font-weight="600" letter-spacing="1.8" fill="currentColor">
              <textPath href="#arcBotLg" startOffset="50%" text-anchor="middle">TRATO HONESTO</textPath>
            </text>
            <path d="M56 78 L72 94 L106 56" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </div>
      </figure>
    </div>
  </header>

  <main>
    <!-- ============ QUIÉNES SOMOS ============ -->
    <section class="section" id="nosotros">
      <div class="wrap split" data-reveal>
        <div class="split-text">
          <p class="eyebrow">Quiénes somos</p>
          <h2>El consultorio del Dr. Ricardo Hernández y su esposa</h2>
          <p>
            Denthig es el consultorio dental del Dr. Ricardo Hernández, en la colonia Nuevo
            Yucatán. Sus pacientes coinciden en algo: aquí no hay rodeos. El doctor explica de
            forma sencilla y clara cada procedimiento — qué se va a hacer, por qué y qué
            esperar — antes de empezar.
          </p>
          <p>
            Eso incluye lo que más se teme: las extracciones. Desde una muela del juicio
            sencilla hasta una compleja, en Denthig el objetivo es que salgas sintiéndote
            segura y en buenas manos, sin dolor y con un costo que ya conocías de antemano.
          </p>
          <p>
            El consultorio, dicen quienes ya vinieron, es agradable y sencillo: limpio,
            ordenado, sin lujos innecesarios. Así trabajan el Dr. Ricardo y su esposa —
            honestos, pacientes y enfocados en ayudarte, un caso a la vez.
          </p>
        </div>
        <figure class="split-media">
          <img
            src={img(1)}
            alt="Unidad y equipo dental dentro del consultorio de Denthig"
            loading="lazy"
            width="1200"
            height="900"
          />
        </figure>
      </div>
    </section>

    <!-- ============ SERVICIOS ============ -->
    <section class="section section-wash" id="servicios">
      <div class="wrap">
        <div class="sec-head" data-reveal>
          <p class="eyebrow">Qué hacemos</p>
          <h2>Tratamientos con explicación clara, paso a paso</h2>
        </div>
        <ul class="svc-grid" data-reveal>
          <li class="svc">
            <h3>Extracciones sin dolor</h3>
            <p>Simples y complejas, incluidas las muelas del juicio. Te explicamos cada paso antes de empezar.</p>
          </li>
          <li class="svc">
            <h3>Limpieza dental</h3>
            <p>Revisión y limpieza para mantener tu boca sana.</p>
          </li>
          <li class="svc">
            <h3>Atención a niños</h3>
            <p>Pacientes desde los 5 años, con calma y sin miedo al dentista.</p>
          </li>
          <li class="svc">
            <h3>Restauraciones</h3>
            <p>Recuperamos piezas dañadas o desgastadas.</p>
          </li>
          <li class="svc">
            <h3>Diagnóstico honesto</h3>
            <p>Te decimos qué necesitas de verdad — y qué puede esperar.</p>
          </li>
          <li class="svc">
            <h3>Costos accesibles</h3>
            <p>Precios razonables, claros desde la primera consulta.</p>
          </li>
        </ul>
        <ul class="chips" data-reveal>
          <li>💳 Aceptamos tarjetas</li>
          <li>💬 Citas por WhatsApp</li>
        </ul>

        <div class="split split-rev feature" data-reveal>
          <figure class="split-media split-media-square">
            <img
              src={img(5)}
              alt="Detalle de una restauración dental realizada en Denthig"
              loading="lazy"
              width="1200"
              height="900"
            />
          </figure>
          <div class="split-text">
            <p class="eyebrow">Trabajo cuidado</p>
            <h2>Precisión que se nota</h2>
            <p>
              Cada restauración se revisa con calma antes de colocarla, para que quede bien a
              la primera. Es la misma filosofía detrás de cada tratamiento en Denthig: sin
              prisas, sin rodeos, explicando cada detalle en el camino.
            </p>
            <a class="btn btn-outline" href={WHATSAPP} target="_blank" rel="noopener">Pregunta por tu tratamiento</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ RESEÑAS ============ -->
    <section class="section section-dark" id="resenas">
      <div class="wrap">
        <div class="sec-head sec-head-center" data-reveal>
          <div class="stamp stamp-sm" aria-hidden="true">
            <svg viewBox="0 0 160 160">
              <circle cx="80" cy="80" r="76" fill="none" stroke="currentColor" stroke-width="2"></circle>
              <circle cx="80" cy="80" r="65" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="2 4"></circle>
              <path id="arcTopSm" d="M 22 84 A 58 58 0 0 1 138 84" fill="none"></path>
              <path id="arcBotSm" d="M 30 108 A 50 50 0 0 0 130 108" fill="none"></path>
              <text font-family="Onest, sans-serif" font-size="13" font-weight="700" letter-spacing="2.5" fill="currentColor">
                <textPath href="#arcTopSm" startOffset="50%" text-anchor="middle">SIN DOLOR</textPath>
              </text>
              <text font-family="Onest, sans-serif" font-size="10.5" font-weight="600" letter-spacing="1.8" fill="currentColor">
                <textPath href="#arcBotSm" startOffset="50%" text-anchor="middle">TRATO HONESTO</textPath>
              </text>
              <path d="M56 78 L72 94 L106 56" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
          <p class="eyebrow eyebrow-on-dark">Lo que dicen nuestros pacientes</p>
          <p class="big-rating"><strong>5.0</strong><span class="stars" aria-hidden="true">★★★★★</span></p>
          <p class="rating-note">39 reseñas en Google</p>
        </div>
        <div class="reviews" data-reveal>
          <blockquote class="review">
            <p>“Excelente atención por parte del Dr. Ricardo y su esposa. Me realizaron dos extracciones, de las muelas del juicio una fue sencilla y la otra fue extracción compleja, desde el primer momento me hicieron sentir segura y en buenas manos. En un consultorio limpio y ordenado. Agradezco mucho su amabilidad, paciencia y profesionalismo. Sin duda, hacen un gran equipo. ¡Recomendadísimos!”</p>
            <footer><cite>Ana</cite> · Hace un año <span class="stars sm" aria-hidden="true">★★★★★</span></footer>
          </blockquote>
          <blockquote class="review">
            <p>“Excelente atención con costos razonables. El doctor es muy profesional, honesto y enfocado en ayudarte; se agradecen sus explicaciones detalladas. El consultorio es un lugar muy agradable.”</p>
            <footer><cite>Haydee Sevilla</cite> · Hace un año <span class="stars sm" aria-hidden="true">★★★★★</span></footer>
          </blockquote>
          <blockquote class="review">
            <p>“…Siempre tuve una buena atención y me explico todo mi proceso nunca sentí dolor a comparación de otros lugares, satisfecho con el servicio y atención! Atendió a mi niña de 5 añitos y ella hasta pedía ir al dentista a arreglar sus muelitas ya que nunca sintió dolor!…”</p>
            <footer><cite>Difreyu Valverde</cite> · Hace 2 años <span class="stars sm" aria-hidden="true">★★★★★</span></footer>
          </blockquote>
        </div>
        <div class="center" data-reveal>
          <a class="btn btn-primary" href={MAPS_URL} target="_blank" rel="noopener">Leer más reseñas en Google</a>
        </div>
      </div>
    </section>

    <!-- ============ UBICACIÓN Y HORARIOS ============ -->
    <section class="section" id="ubicacion">
      <div class="wrap">
        <div class="sec-head" data-reveal>
          <p class="eyebrow">Ubicación y horarios</p>
          <h2>Nos encuentras en Nuevo Yucatán</h2>
          <p class="addr">Calle 48-A 454, Nuevo Yucatán, 97147 Mérida, Yuc., México</p>
        </div>
        <div class="loc-grid" data-reveal>
          <div class="map-col">
            <div class="map-box">
              <iframe
                title="Mapa: Denthig Mérida, C.D. Ricardo Hernández, Nuevo Yucatán"
                src={`https://www.google.com/maps?q=${MAP_QUERY}&output=embed`}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              ></iframe>
            </div>
            <figure class="entrance">
              <img
                src={img(4)}
                alt="Entrada y señalización de Denthig sobre Calle 48-A, Nuevo Yucatán"
                loading="lazy"
                width="900"
                height="1200"
              />
              <figcaption>Así vas a reconocer la entrada</figcaption>
            </figure>
          </div>
          <div class="hours-box">
            <h3>Horarios</h3>
            <table class="hours">
              <tbody>
                <tr data-day="1"><th scope="row">Lunes</th><td>8:00–20:00</td></tr>
                <tr data-day="2"><th scope="row">Martes</th><td>8:00–20:00</td></tr>
                <tr data-day="3"><th scope="row">Miércoles</th><td>8:00–20:00</td></tr>
                <tr data-day="4"><th scope="row">Jueves</th><td>8:00–20:00</td></tr>
                <tr data-day="5"><th scope="row">Viernes</th><td>8:00–20:00</td></tr>
                <tr data-day="6" class="closed"><th scope="row">Sábado</th><td>Cerrado</td></tr>
                <tr data-day="0" class="closed"><th scope="row">Domingo</th><td>Cerrado</td></tr>
              </tbody>
            </table>
            <a class="btn btn-outline" href={MAPS_URL} target="_blank" rel="noopener">Cómo llegar</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- ============ FOOTER ============ -->
  <footer class="footer">
    <div class="wrap">
      <p class="f-brand">Denthig</p>
      <p class="f-tag">C.D. Ricardo Hernández · Nuevo Yucatán, Mérida</p>
      <p class="f-line">Calle 48-A 454, Nuevo Yucatán, 97147 Mérida, Yuc., México</p>
      <p class="f-line">
        <a href="tel:+529993905703">999 390 5703</a> ·
        <a href={WHATSAPP} target="_blank" rel="noopener">WhatsApp</a> ·
        <a href="https://www.facebook.com/denthigmerida?mibextid=LQQJ4d" target="_blank" rel="noopener">Facebook</a>
      </p>
      <p class="f-note">⭐ 5.0 · 39 reseñas en Google</p>
    </div>
  </footer>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Dentist",
    "name": "Denthig Mérida, C.D. Ricardo Hernández",
    "url": "https://demos.ivang.mx/denthig-merida-cd-ricardo-hernandez",
    "telephone": "+52 999 390 5703",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle 48-A 454, Nuevo Yucatán",
      "addressLocality": "Mérida",
      "addressRegion": "Yucatán",
      "postalCode": "97147",
      "addressCountry": "MX"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "39"
    },
    "openingHours": ["Mo-Fr 08:00-20:00"]
  }
  </script>

  <style is:global>
    :root {
      --paper: #f5f4f0;
      --wash: #e9eef2;
      --slate: #5b7a99;
      --slate-deep: #33506c;
      --amber: #e0a458;
      --amber-deep: #8a5a26;
      --ink: #262b30;
      --white: #ffffff;
      --line: rgba(38, 43, 48, 0.14);
      --radius: 14px;
      --font-display: 'Onest', system-ui, sans-serif;
      --font-body: 'Karla', system-ui, sans-serif;
    }

    body {
      font-family: var(--font-body);
      background: var(--paper);
      color: var(--ink);
      line-height: 1.6;
      overflow-x: hidden;
    }

    h1, h2, h3 { font-family: var(--font-display); line-height: 1.14; margin: 0 0 0.5em; color: var(--slate-deep); }
    p { margin: 0 0 1em; }
    a { color: var(--slate-deep); }
    a:focus-visible, .btn:focus-visible, .rating-chip:focus-visible {
      outline: 3px solid var(--amber);
      outline-offset: 3px;
      border-radius: 6px;
    }

    .wrap { max-width: 1040px; margin: 0 auto; padding: 0 20px; }
    .center { text-align: center; }

    /* ---- Botones ---- */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1rem;
      text-decoration: none;
      padding: 13px 24px;
      border-radius: 10px;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .btn:hover { transform: translateY(-2px); }
    .btn:active { transform: translateY(0); }
    .btn-primary {
      background: var(--slate-deep);
      color: var(--white);
      box-shadow: 0 6px 16px rgba(51, 80, 108, 0.28);
    }
    .btn-primary:hover { box-shadow: 0 10px 22px rgba(51, 80, 108, 0.34); }
    .btn-ghost {
      color: var(--ink);
      border: 2px solid var(--ink);
      background: transparent;
    }
    .btn-ghost:hover { background: rgba(38, 43, 48, 0.06); }
    .btn-outline {
      color: var(--slate-deep);
      border: 2px solid var(--slate);
      background: transparent;
    }
    .btn-outline:hover { background: rgba(91, 122, 153, 0.1); }

    /* ---- Rating chip ---- */
    .rating-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--ink);
      background: var(--white);
      border: 1px solid var(--line);
      padding: 8px 14px;
      border-radius: 999px;
      margin-bottom: 22px;
      box-shadow: 0 3px 10px rgba(38, 43, 48, 0.06);
    }
    .rating-chip strong { color: var(--slate-deep); }
    .stars { color: var(--amber-deep); letter-spacing: 1px; }
    .stars.sm { font-size: 0.85em; }

    /* ---- Sello / stamp: elemento firma ---- */
    .stamp {
      color: var(--slate-deep);
      width: 108px;
      height: 108px;
      transform: rotate(-9deg);
    }
    .stamp svg { display: block; width: 100%; height: 100%; }
    .stamp-lg {
      position: absolute;
      right: -14px;
      bottom: -14px;
      background: var(--paper);
      border-radius: 50%;
      padding: 6px;
      box-shadow: 0 8px 20px rgba(38, 43, 48, 0.22);
    }
    .stamp-sm {
      width: 84px;
      height: 84px;
      margin: 0 auto 14px;
      color: var(--amber);
    }

    /* ---- Hero ---- */
    .hero { padding: 56px 0 40px; }
    .hero-grid { display: grid; gap: 40px; }
    .hero-text { max-width: 46ch; }
    .eyebrow {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.78rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--slate);
      margin-bottom: 10px;
    }
    .eyebrow-on-dark { color: var(--amber); }
    h1 {
      font-size: clamp(2.3rem, 9vw, 3.4rem);
      font-weight: 700;
      color: var(--ink);
      text-wrap: balance;
    }
    h1 .accent { color: var(--slate-deep); }
    .hero-sub {
      font-size: clamp(1rem, 3.4vw, 1.12rem);
      color: #3f4650;
      max-width: 48ch;
    }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: 12px; }
    .hero-media {
      position: relative;
      margin: 0;
    }
    .hero-media img {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      border-radius: var(--radius);
      box-shadow: 0 18px 42px rgba(38, 43, 48, 0.18);
    }

    /* ---- Secciones ---- */
    .section { padding: 56px 0; }
    .section-wash { background: var(--wash); }
    .sec-head { margin-bottom: 30px; }
    .sec-head-center { text-align: center; }
    .sec-head h2, .split-text h2 {
      font-size: clamp(1.6rem, 6vw, 2.3rem);
      font-weight: 700;
      color: var(--ink);
      text-wrap: balance;
    }

    /* ---- Split ---- */
    .split { display: grid; gap: 26px; align-items: center; }
    .split-media { margin: 0; }
    .split-media img {
      width: 100%;
      border-radius: var(--radius);
      box-shadow: 0 14px 34px rgba(38, 43, 48, 0.14);
      aspect-ratio: 4 / 3;
      object-fit: cover;
    }
    .split-media-square img { aspect-ratio: 1 / 1; }
    .feature { margin-top: 48px; padding-top: 48px; border-top: 1px solid var(--line); }

    /* ---- Servicios ---- */
    .svc-grid {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .svc {
      background: var(--white);
      border-radius: var(--radius);
      padding: 20px 22px;
      border-left: 3px solid var(--slate);
      box-shadow: 0 4px 12px rgba(38, 43, 48, 0.06);
    }
    .svc h3 { font-size: 1.08rem; font-weight: 700; color: var(--ink); margin-bottom: 4px; }
    .svc p { margin: 0; font-size: 0.94rem; color: #4a5158; }
    .chips {
      list-style: none;
      margin: 24px 0 0;
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .chips li {
      background: var(--amber);
      color: var(--ink);
      font-weight: 600;
      font-size: 0.88rem;
      padding: 8px 16px;
      border-radius: 999px;
    }

    /* ---- Reseñas (sección oscura) ---- */
    .section-dark {
      background: var(--slate-deep);
      color: var(--white);
    }
    .section-dark h2 { color: var(--white); }
    .rating-note { color: rgba(255, 255, 255, 0.78); margin-top: 4px; }
    .big-rating { font-family: var(--font-display); margin: 0; line-height: 1; }
    .big-rating strong { font-size: clamp(3.2rem, 12vw, 4.6rem); font-weight: 700; display: block; color: var(--white); }
    .big-rating .stars { font-size: 1.3rem; color: var(--amber); }
    .reviews { display: grid; gap: 16px; margin: 32px 0 30px; }
    .review {
      margin: 0;
      background: rgba(255, 255, 255, 0.07);
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: var(--radius);
      padding: 22px 22px;
    }
    .review p { font-size: 0.98rem; margin-bottom: 14px; }
    .review footer { font-size: 0.86rem; color: rgba(255, 255, 255, 0.75); }
    .review cite { font-style: normal; font-weight: 700; color: var(--white); }
    .section-dark .btn-primary { background: var(--amber); color: var(--ink); box-shadow: none; }
    .section-dark .btn-primary:hover { background: #ecb26c; }

    /* ---- Ubicación ---- */
    .addr { max-width: 52ch; color: #4a5158; }
    .loc-grid { display: grid; gap: 24px; }
    .map-col { display: grid; gap: 14px; }
    .map-box {
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: 0 10px 26px rgba(38, 43, 48, 0.12);
    }
    .map-box iframe { display: block; width: 100%; height: 300px; border: 0; }
    .entrance {
      display: grid;
      grid-template-columns: 96px 1fr;
      align-items: center;
      gap: 14px;
      margin: 0;
    }
    .entrance img {
      width: 96px;
      height: 96px;
      object-fit: cover;
      border-radius: 10px;
      box-shadow: 0 6px 16px rgba(38, 43, 48, 0.14);
    }
    .entrance figcaption { font-size: 0.9rem; color: #4a5158; }
    .hours-box h3 { font-size: 1.25rem; color: var(--ink); }
    .hours { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    .hours th, .hours td { text-align: left; padding: 9px 10px; font-size: 0.96rem; }
    .hours th { font-weight: 600; color: var(--ink); }
    .hours tr { border-bottom: 1px solid var(--line); }
    .hours tr.closed td { color: #808890; }
    .hours tr.today {
      background: var(--wash);
      border-radius: 8px;
      box-shadow: inset 3px 0 0 var(--slate);
    }
    .hours tr.today th::after {
      content: " · hoy";
      color: var(--slate-deep);
      font-weight: 700;
      font-size: 0.8em;
    }

    /* ---- Footer ---- */
    .footer {
      background: var(--ink);
      color: rgba(255, 255, 255, 0.85);
      padding: 56px 0 96px;
      text-align: center;
    }
    .f-brand {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.9rem;
      color: var(--white);
      line-height: 1;
      margin-bottom: 4px;
    }
    .f-tag {
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 20px;
    }
    .f-line { font-size: 0.95rem; margin-bottom: 8px; }
    .footer a { color: var(--white); text-decoration-color: var(--slate); }
    .f-note { margin-top: 16px; font-size: 0.9rem; color: rgba(255, 255, 255, 0.6); }

    /* ---- Reveal (solo si hay JS) ---- */
    html.js [data-reveal] {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    html.js [data-reveal].in {
      opacity: 1;
      transform: none;
    }

    /* ---- Desktop ---- */
    @media (min-width: 720px) {
      .hero { padding: 84px 0 64px; }
      .hero-grid { grid-template-columns: 6fr 5fr; align-items: center; }
      .section { padding: 84px 0; }
      .split { grid-template-columns: 5fr 6fr; gap: 46px; }
      .split-rev .split-media { order: 2; }
      .svc-grid { grid-template-columns: repeat(2, 1fr); }
      .reviews { grid-template-columns: repeat(3, 1fr); align-items: start; }
      .loc-grid { grid-template-columns: 3fr 2fr; align-items: start; }
      .map-box iframe { height: 360px; }
    }
    @media (min-width: 1000px) {
      .svc-grid { grid-template-columns: repeat(3, 1fr); }
    }
  </style>

  <script is:inline>
    // Mejora progresiva: sin JS todo el contenido queda visible.
    document.documentElement.classList.add('js');

    // Scroll-reveal sutil
    var revealables = document.querySelectorAll('[data-reveal]');
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('in');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      revealables.forEach(function (el) { io.observe(el); });
    } else {
      revealables.forEach(function (el) { el.classList.add('in'); });
    }

    // Resaltar el día actual en la tabla de horarios
    var today = new Date().getDay();
    var row = document.querySelector('.hours tr[data-day="' + today + '"]');
    if (row) {
      row.classList.add('today');
      row.setAttribute('aria-current', 'date');
    }
  </script>
</BaseLayout>
