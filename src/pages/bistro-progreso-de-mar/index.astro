---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Bistro Progreso de Mar — Cocina italiana con expresión caribeña"
  description="Pasta, pizza al horno y ceviche en el puerto de Progreso, Yucatán. ⭐ 4.5 con 73 reseñas en Google. Abrimos todos los días desde las 2:00 pm. Reserva tu mesa por WhatsApp."
  slug="bistro-progreso-de-mar"
  ogImage="/bistro-progreso-de-mar/img/foto_5.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Yeseva+One&family=Karla:ital,wght@0,400;0,500;0,700;1,400&display=swap"
  favicon="🍝"
  themeColor="#0F2C40"
  whatsapp={"https://wa.me/529691039866"}
  telefono={"969 103 9866"}
  mapsUrl={"https://maps.google.com/?cid=3227341973017102984&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA"}
>
  <main class="bm">

    <!-- ============ HERO COMPACTO ============ -->
    <header class="hero">
      <div class="hero-luces" aria-hidden="true"></div>
      <div class="wrap hero-inner">
        <p class="hero-kicker">Trattoria de puerto · Progreso, Yucatán</p>
        <h1>Bistro Progreso de&nbsp;Mar</h1>
        <p class="hero-lema">Pasta, pizza al horno y ceviche — cocina italiana con sabor de mar, en el puerto.</p>
        <blockquote class="hero-cita">
          <p>«…todo muy rico y con expresión caribeña, parada obligada…»</p>
          <cite>— andro narvus, reseña en Google</cite>
        </blockquote>
        <div class="hero-ctas">
          <a class="btn btn-wa" href="https://wa.me/529691039866">Reservar por WhatsApp</a>
          <a class="btn btn-ghost" href="https://maps.google.com/?cid=3227341973017102984&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Cómo llegar</a>
        </div>
        <a class="hero-rating" href="https://maps.google.com/?cid=3227341973017102984&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">
          <span class="estrellas" aria-hidden="true">★★★★★</span>
          <strong>4.5</strong> · 73 reseñas en Google
        </a>
      </div>
    </header>

    <div class="gingham" aria-hidden="true"></div>

    <!-- ============ MOSAICO ============ -->
    <section class="mosaico" aria-label="Fotos del bistró">
      <div class="wrap">
        <div class="mosaico-grid">
          <figure class="m-item m-grande rv">
            <img src="/bistro-progreso-de-mar/img/foto_4.jpg" alt="Platos de pasta con camarones recién servidos en platos negros" width="825" height="1100" fetchpriority="high" />
            <figcaption>Pasta con camarones, recién salida de la cocina</figcaption>
          </figure>
          <figure class="m-item rv">
            <img src="/bistro-progreso-de-mar/img/foto_5.jpg" alt="Pizza de pepperoni al horno sobre papel con motivos marinos" width="1100" height="825" loading="lazy" />
            <figcaption>Pizza de pepperoni al horno</figcaption>
          </figure>
          <figure class="m-item rv">
            <img src="/bistro-progreso-de-mar/img/foto_2.jpg" alt="Pizza de camarones con aceitunas negras" width="1100" height="825" loading="lazy" />
            <figcaption>Pizza de camarones</figcaption>
          </figure>
          <div class="m-item m-tile rv">
            <p class="tile-hora">Abrimos todos los días</p>
            <p class="tile-dato">desde las 2:00&nbsp;pm</p>
            <p class="tile-nota">Comidas · Cenas · Café</p>
          </div>
          <figure class="m-item rv">
            <img src="/bistro-progreso-de-mar/img/foto_3.jpg" alt="Pizza en su caja lista para llevar, con aderezos aparte" width="1100" height="825" loading="lazy" />
            <figcaption>También para llevar a casa</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ============ SOBRE NOSOTROS ============ -->
    <section class="sobre" id="sobre">
      <div class="wrap sobre-grid">
        <div class="sobre-texto rv">
          <p class="overline">Nuestra casa</p>
          <h2>Italia, con los pies en la arena</h2>
          <p>Somos un bistró pequeño y acogedor en el barrio Ismael García de Progreso. Aquí la cocina italiana se encuentra con el mar: pizzas que salen doradas del horno, pastas generosas y un ceviche que nuestros clientes describen como «buenísimo».</p>
          <p>Quienes nos visitan repiten lo mismo: buen sazón, trato amable y esa «expresión caribeña» que hace distinto a cada plato. La carbonara, los mejillones con linguini y la pizza de camarones son de lo que más nos piden.</p>
          <p>De noche nos encuentras fácil: busca los foquitos encendidos sobre la fachada de piedra. Si vienes en grupo, aceptamos reservaciones — escríbenos por WhatsApp y te guardamos la mesa.</p>
        </div>
        <figure class="sobre-foto rv">
          <img src="/bistro-progreso-de-mar/img/foto_1.jpg" alt="Fachada de piedra blanca del bistró de noche, iluminada con foquitos" width="825" height="1100" loading="lazy" />
          <figcaption>Nuestra casita de piedra en la calle 50, de noche</figcaption>
        </figure>
      </div>
    </section>

    <div class="gingham" aria-hidden="true"></div>

    <!-- ============ LO QUE MÁS PIDEN + SERVICIOS ============ -->
    <section class="carta" id="carta">
      <div class="wrap">
        <p class="overline">Del horno y del mar</p>
        <h2>Lo que más piden</h2>
        <div class="platos">
          <article class="plato rv">
            <span class="plato-emoji" aria-hidden="true">🍝</span>
            <h3>Pasta carbonara</h3>
            <p>Un clásico de la casa que las reseñas mencionan una y otra vez.</p>
          </article>
          <article class="plato rv">
            <span class="plato-emoji" aria-hidden="true">🍋</span>
            <h3>Ceviche</h3>
            <p>El toque de puerto: fresco, cítrico y «buenísimo» según nuestros clientes.</p>
          </article>
          <article class="plato rv">
            <span class="plato-emoji" aria-hidden="true">🦪</span>
            <h3>Mejillones con linguini</h3>
            <p>«Magníficos», en palabras de quien los probó. Mar e Italia en un plato.</p>
          </article>
          <article class="plato rv">
            <span class="plato-emoji" aria-hidden="true">🍕</span>
            <h3>Pizza al horno</h3>
            <p>De pepperoni o de camarones, con orilla dorada y queso burbujeante.</p>
          </article>
        </div>
        <ul class="servicios" aria-label="Servicios del bistró">
          <li>Acepta reservaciones</li>
          <li>Comidas y cenas</li>
          <li>Café</li>
          <li>Opciones vegetarianas</li>
          <li>Acepta tarjetas</li>
          <li>Estacionamiento disponible</li>
          <li>Servicio en el local</li>
          <li>Para llevar en caja</li>
        </ul>
      </div>
    </section>

    <!-- ============ RESEÑAS ============ -->
    <section class="resenas" id="resenas">
      <div class="wrap">
        <p class="overline overline-claro">Palabra de cliente</p>
        <h2>⭐ 4.5 · 73 reseñas en Google</h2>
        <div class="resena-grid">
          <article class="resena rv">
            <div class="resena-gingham" aria-hidden="true"></div>
            <p class="resena-estrellas" aria-label="5 estrellas">★★★★★</p>
            <blockquote>
              <p>«Muy rica pasta y el ceviche buenísimo!!! Pequeño restaurant pero con muy buen sazón y con precios decentes. La pasta carbonara y el ceviche son muy buenos…»</p>
            </blockquote>
            <footer><strong>Alberto Menindez</strong> · hace 3 años</footer>
          </article>
          <article class="resena rv">
            <div class="resena-gingham" aria-hidden="true"></div>
            <p class="resena-estrellas" aria-label="5 estrellas">★★★★★</p>
            <blockquote>
              <p>«Como siempre, su comida estuvo excelente anoche. Los mejillones y los linguini estaban magníficos…»</p>
            </blockquote>
            <footer><strong>Scarlett Ryan</strong> · hace un año</footer>
          </article>
          <article class="resena rv">
            <div class="resena-gingham" aria-hidden="true"></div>
            <p class="resena-estrellas" aria-label="5 estrellas">★★★★★</p>
            <blockquote>
              <p>«El lugar acogedor, amable la persona que nos atendió y la pizza riquísima.»</p>
            </blockquote>
            <footer><strong>Nora Puente</strong> · hace 3 años</footer>
          </article>
        </div>
        <p class="resenas-cta">
          <a class="btn btn-claro" href="https://maps.google.com/?cid=3227341973017102984&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA" target="_blank" rel="noopener">Leer más reseñas en Google</a>
        </p>
      </div>
    </section>

    <div class="gingham" aria-hidden="true"></div>

    <!-- ============ UBICACIÓN Y HORARIOS ============ -->
    <section class="ubicacion" id="ubicacion">
      <div class="wrap">
        <p class="overline">Ven a vernos</p>
        <h2>Ubicación y horarios</h2>
        <p class="direccion">C. 50 entre 25 y 23, Ismael García, 97320 Progreso, Yuc., México</p>
        <div class="ubi-grid">
          <div class="mapa rv">
            <iframe
              src="https://www.google.com/maps?q=C.%2050%20entre%2025%20y%2023%2C%20Ismael%20Garc%C3%ADa%2C%2097320%20Progreso%2C%20Yuc.%2C%20M%C3%A9xico&output=embed"
              width="600" height="340" style="border:0" loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Mapa: Bistro Progreso de Mar, calle 50 entre 25 y 23, Progreso"></iframe>
          </div>
          <div class="horarios rv">
            <table>
              <caption class="sr-only">Horarios de apertura por día</caption>
              <tbody>
                <tr data-dia="lunes"><th scope="row">Lunes</th><td>2:00 pm – 11:00 pm</td></tr>
                <tr data-dia="martes"><th scope="row">Martes</th><td>2:00 pm – 10:30 pm</td></tr>
                <tr data-dia="miércoles"><th scope="row">Miércoles</th><td>2:00 pm – 11:00 pm</td></tr>
                <tr data-dia="jueves"><th scope="row">Jueves</th><td>2:00 pm – 11:00 pm</td></tr>
                <tr data-dia="viernes"><th scope="row">Viernes</th><td>2:00 pm – 11:00 pm</td></tr>
                <tr data-dia="sábado"><th scope="row">Sábado</th><td>2:00 pm – 11:00 pm</td></tr>
                <tr data-dia="domingo"><th scope="row">Domingo</th><td>2:00 pm – 11:00 pm</td></tr>
              </tbody>
            </table>
            <div class="ubi-ctas">
              <a class="btn btn-wa" href="https://wa.me/529691039866">Reservar mesa</a>
              <a class="btn btn-borde" href="tel:+529691039866">Llamar: 969 103 9866</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="pie">
      <div class="wrap">
        <p class="pie-nombre">Bistro Progreso de Mar</p>
        <p class="pie-dato">C. 50 entre 25 y 23, Ismael García, 97320 Progreso, Yucatán</p>
        <p class="pie-dato"><a href="tel:+529691039866">969 103 9866</a> · <a href="https://wa.me/529691039866">WhatsApp</a></p>
        <p class="pie-dato pie-suave">Abierto todos los días desde las 2:00 pm</p>
      </div>
    </footer>

  </main>

  <style is:global>
    :root {
      --navy: #0F2C40;
      --navy-2: #123853;
      --medit: #2E6E9E;
      --crema: #FBF4E8;
      --crema-2: #F4E8D4;
      --coral: #E4593B;
      --ambar: #F2B75C;
      --tinta: #22303C;
      --wa: #1DA851;
    }
    body { background: var(--crema); }
    .bm {
      font-family: 'Karla', system-ui, sans-serif;
      color: var(--tinta);
      font-size: 1.0625rem;
      line-height: 1.6;
      overflow-x: clip;
    }
    .bm h1, .bm h2, .bm h3, .pie-nombre {
      font-family: 'Yeseva One', serif;
      font-weight: 400;
      line-height: 1.12;
      margin: 0;
    }
    .wrap { max-width: 1040px; margin: 0 auto; padding: 0 1.15rem; }
    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
    }

    /* ---- Botones ---- */
    .btn {
      display: inline-block;
      padding: .85rem 1.4rem;
      border-radius: 999px;
      font-weight: 700;
      font-size: 1rem;
      text-decoration: none;
      text-align: center;
      transition: transform .18s ease, box-shadow .18s ease;
    }
    .btn:hover { transform: translateY(-2px); }
    .btn:focus-visible { outline: 3px solid var(--ambar); outline-offset: 3px; }
    .btn-wa { background: var(--wa); color: #fff; box-shadow: 0 6px 18px rgba(29,168,81,.35); }
    .btn-ghost { background: rgba(251,244,232,.12); color: var(--crema); border: 1.5px solid rgba(251,244,232,.55); }
    .btn-claro { background: var(--crema); color: var(--navy); }
    .btn-borde { background: transparent; color: var(--navy); border: 1.5px solid var(--medit); }

    /* ---- Cinta de cuadros: papel marinero (elemento firma) ---- */
    .gingham {
      height: 18px;
      background:
        repeating-linear-gradient(90deg, rgba(46,110,158,.5) 0 9px, transparent 9px 18px),
        repeating-linear-gradient(0deg, rgba(46,110,158,.5) 0 9px, transparent 9px 18px),
        #fff;
    }

    /* ---- Hero ---- */
    .hero {
      background:
        radial-gradient(120% 90% at 50% 0%, var(--navy-2) 0%, var(--navy) 62%),
        var(--navy);
      color: var(--crema);
      text-align: center;
      padding: 1.6rem 0 2.4rem;
      position: relative;
    }
    .hero-luces {
      height: 22px;
      margin-bottom: 1.2rem;
      background-image: radial-gradient(circle 5px at 50% 60%, var(--ambar) 0 4px, rgba(242,183,92,.28) 5px, transparent 8px);
      background-size: 38px 22px;
      background-repeat: repeat-x;
      filter: drop-shadow(0 0 6px rgba(242,183,92,.65));
    }
    .hero-kicker {
      font-size: .8rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--ambar);
      margin: 0 0 .6rem;
      font-weight: 700;
    }
    .hero h1 { font-size: clamp(2.1rem, 8vw, 3.4rem); color: #fff; }
    .hero-lema {
      max-width: 34rem;
      margin: .9rem auto 0;
      font-size: 1.1rem;
      color: rgba(251,244,232,.88);
    }
    .hero-cita { margin: 1.1rem auto 0; max-width: 30rem; }
    .hero-cita p {
      font-style: italic;
      color: var(--ambar);
      font-size: 1.02rem;
      margin: 0;
    }
    .hero-cita cite { font-style: normal; font-size: .82rem; color: rgba(251,244,232,.6); }
    .hero-ctas {
      display: flex;
      flex-wrap: wrap;
      gap: .7rem;
      justify-content: center;
      margin-top: 1.4rem;
    }
    .hero-rating {
      display: inline-block;
      margin-top: 1.1rem;
      color: rgba(251,244,232,.85);
      text-decoration: none;
      font-size: .95rem;
      border-bottom: 1px dashed rgba(251,244,232,.4);
      padding-bottom: 2px;
    }
    .hero-rating:hover { color: #fff; }
    .hero-rating:focus-visible { outline: 3px solid var(--ambar); outline-offset: 3px; }
    .estrellas { color: var(--ambar); letter-spacing: .1em; }

    /* ---- Mosaico ---- */
    .mosaico { padding: 1.15rem 0 .4rem; }
    .mosaico-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: .6rem;
    }
    .m-item {
      margin: 0;
      border-radius: 14px;
      overflow: hidden;
      position: relative;
      background: var(--crema-2);
    }
    .m-item img { width: 100%; height: 100%; object-fit: cover; }
    .m-grande { grid-column: span 2; aspect-ratio: 4 / 3; }
    .m-item:not(.m-grande):not(.m-tile) { aspect-ratio: 1 / 1; }
    .m-item figcaption {
      position: absolute;
      left: 0; right: 0; bottom: 0;
      padding: 1.5rem .8rem .55rem;
      font-size: .82rem;
      font-weight: 700;
      color: #fff;
      background: linear-gradient(transparent, rgba(15,44,64,.82));
    }
    .m-tile {
      background: var(--medit);
      color: #fff;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 1rem .8rem;
      gap: .1rem;
    }
    .m-tile p { margin: 0; }
    .tile-hora { font-size: .82rem; text-transform: uppercase; letter-spacing: .12em; opacity: .85; }
    .tile-dato { font-family: 'Yeseva One', serif; font-size: 1.5rem; color: #fff; }
    .tile-nota { font-size: .85rem; color: var(--ambar); font-weight: 700; }

    /* ---- Secciones genéricas ---- */
    .overline {
      font-size: .78rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      font-weight: 700;
      color: var(--coral);
      margin: 0 0 .5rem;
    }
    .overline-claro { color: var(--ambar); }
    .bm h2 { font-size: clamp(1.6rem, 5.5vw, 2.3rem); color: var(--navy); margin-bottom: 1rem; }

    /* ---- Sobre nosotros ---- */
    .sobre { padding: 2.8rem 0 3rem; }
    .sobre-grid { display: grid; gap: 1.6rem; align-items: start; }
    .sobre-texto p:not(.overline) { margin: 0 0 1rem; }
    .sobre-foto {
      margin: 0;
      border-radius: 14px;
      overflow: hidden;
      position: relative;
      box-shadow: 0 14px 34px rgba(15,44,64,.18);
    }
    .sobre-foto figcaption {
      position: absolute;
      left: 0; right: 0; bottom: 0;
      padding: 1.6rem .9rem .6rem;
      font-size: .84rem;
      font-weight: 700;
      color: #fff;
      background: linear-gradient(transparent, rgba(15,44,64,.85));
    }

    /* ---- Carta ---- */
    .carta { padding: 2.8rem 0 3rem; background: var(--crema-2); }
    .platos {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: .7rem;
      margin-top: 1.2rem;
    }
    .plato {
      background: #fff;
      border-radius: 14px;
      padding: 1.1rem 1rem;
      border-top: 4px solid var(--coral);
      box-shadow: 0 4px 14px rgba(15,44,64,.07);
    }
    .plato-emoji { font-size: 1.6rem; display: block; margin-bottom: .4rem; }
    .plato h3 { font-size: 1.12rem; color: var(--navy); margin-bottom: .35rem; }
    .plato p { margin: 0; font-size: .92rem; line-height: 1.5; }
    .servicios {
      list-style: none;
      padding: 0;
      margin: 1.6rem 0 0;
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
    }
    .servicios li {
      background: #fff;
      border: 1.5px solid var(--medit);
      color: var(--navy);
      font-weight: 700;
      font-size: .86rem;
      padding: .42rem .85rem;
      border-radius: 999px;
    }

    /* ---- Reseñas ---- */
    .resenas {
      background:
        radial-gradient(110% 80% at 50% 100%, var(--navy-2) 0%, var(--navy) 65%),
        var(--navy);
      color: var(--crema);
      padding: 2.8rem 0 3rem;
    }
    .resenas h2 { color: #fff; }
    .resena-grid { display: grid; gap: .9rem; margin-top: 1.3rem; }
    .resena {
      background: var(--crema);
      color: var(--tinta);
      border-radius: 14px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .resena-gingham {
      height: 10px;
      background:
        repeating-linear-gradient(90deg, rgba(46,110,158,.5) 0 7px, transparent 7px 14px),
        repeating-linear-gradient(0deg, rgba(46,110,158,.5) 0 7px, transparent 7px 14px),
        #fff;
    }
    .resena-estrellas { color: var(--coral); letter-spacing: .12em; margin: .9rem 1.1rem 0; font-size: .95rem; }
    .resena blockquote { margin: .4rem 1.1rem .2rem; }
    .resena blockquote p { margin: 0; font-size: .98rem; line-height: 1.55; }
    .resena footer { margin: .6rem 1.1rem 1rem; font-size: .88rem; color: var(--medit); }
    .resenas-cta { text-align: center; margin: 1.6rem 0 0; }

    /* ---- Ubicación ---- */
    .ubicacion { padding: 2.8rem 0 3rem; }
    .direccion { font-weight: 700; color: var(--navy); margin: 0 0 1.2rem; }
    .ubi-grid { display: grid; gap: 1.2rem; }
    .mapa { border-radius: 14px; overflow: hidden; box-shadow: 0 10px 26px rgba(15,44,64,.14); }
    .mapa iframe { width: 100%; height: 340px; display: block; }
    .horarios table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 4px 14px rgba(15,44,64,.07);
    }
    .horarios th, .horarios td {
      padding: .6rem .95rem;
      text-align: left;
      font-size: .95rem;
      border-bottom: 1px solid var(--crema-2);
    }
    .horarios th { font-weight: 700; color: var(--navy); }
    .horarios td { text-align: right; }
    .horarios tr:last-child th, .horarios tr:last-child td { border-bottom: none; }
    .horarios tr.hoy th, .horarios tr.hoy td {
      background: var(--navy);
      color: var(--ambar);
    }
    .horarios tr.hoy th::after { content: " · hoy"; font-size: .78rem; color: var(--crema); }
    .ubi-ctas { display: flex; flex-wrap: wrap; gap: .7rem; margin-top: 1.1rem; }
    .ubi-ctas .btn { flex: 1 1 auto; }

    /* ---- Footer ---- */
    .pie {
      background: var(--navy);
      color: rgba(251,244,232,.85);
      text-align: center;
      padding: 2.2rem 0 5.4rem; /* espacio extra para el botón flotante */
    }
    .pie-nombre { color: #fff; font-size: 1.35rem; margin-bottom: .5rem; }
    .pie-dato { margin: .25rem 0; font-size: .95rem; }
    .pie-dato a { color: var(--ambar); text-decoration: none; font-weight: 700; }
    .pie-dato a:hover { text-decoration: underline; }
    .pie-dato a:focus-visible { outline: 3px solid var(--ambar); outline-offset: 3px; }
    .pie-suave { opacity: .65; font-size: .88rem; }

    /* ---- Reveal (solo si hay JS) ---- */
    .rv-off { opacity: 0; transform: translateY(14px); }
    .rv-on { opacity: 1; transform: none; transition: opacity .55s ease, transform .55s ease; }

    /* ---- Tablet / escritorio ---- */
    @media (min-width: 720px) {
      .mosaico-grid { grid-template-columns: repeat(4, 1fr); }
      .m-grande { grid-column: span 2; grid-row: span 2; aspect-ratio: auto; }
      .sobre-grid { grid-template-columns: 1.15fr .85fr; gap: 2.4rem; }
      .platos { grid-template-columns: repeat(4, 1fr); }
      .resena-grid { grid-template-columns: repeat(3, 1fr); }
      .ubi-grid { grid-template-columns: 1.15fr .85fr; align-items: start; }
      .hero { padding-bottom: 2.8rem; }
    }
  </style>

  <script is:inline>
    (function () {
      // Resaltar el día actual en la tabla de horarios
      var dias = ['domingo', 'lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado'];
      var hoy = dias[new Date().getDay()];
      var filas = document.querySelectorAll('[data-dia]');
      for (var i = 0; i < filas.length; i++) {
        if (filas[i].getAttribute('data-dia') === hoy) filas[i].classList.add('hoy');
      }

      // Scroll-reveal como mejora progresiva (sin JS todo queda visible)
      var els = document.querySelectorAll('.rv');
      if ('IntersectionObserver' in window && els.length) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (en.isIntersecting) {
              en.target.classList.add('rv-on');
              io.unobserve(en.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -5% 0px' });
        for (var j = 0; j < els.length; j++) {
          els[j].classList.add('rv-off');
          io.observe(els[j]);
        }
      }
    })();
  </script>
</BaseLayout>
