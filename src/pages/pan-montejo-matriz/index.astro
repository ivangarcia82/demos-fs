<script is:inline>
  (function () {
    var d = document;
    d.documentElement.classList.add('has-js');
    var rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // scroll reveal
    var revs = d.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window && revs.length) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
      revs.forEach(function (el) { io.observe(el); });
    } else {
      revs.forEach(function (el) { el.classList.add('in'); });
    }

    // count-up del número monumental
    var num = d.getElementById('bigNum');
    if (num) {
      var target = 2015;
      if (rm || !('IntersectionObserver' in window)) {
        num.textContent = target.toLocaleString('es-MX');
      } else {
        var started = false;
        var cio = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting && !started) {
              started = true;
              var t0 = null, dur = 1500;
              function step(ts) {
                if (!t0) t0 = ts;
                var p = Math.min((ts - t0) / dur, 1);
                var ease = 1 - Math.pow(1 - p, 3);
                num.textContent = Math.round(ease * target).toLocaleString('es-MX');
                if (p < 1) requestAnimationFrame(step);
              }
              requestAnimationFrame(step);
              cio.unobserve(e.target);
            }
          });
        }, { threshold: 0.5 });
        cio.observe(num);
      }
    }

    // resaltar el día de hoy en horarios
    var map = { 0: 'dom', 1: 'lun', 2: 'mar', 3: 'mie', 4: 'jue', 5: 'vie', 6: 'sab' };
    var row = d.querySelector('.hrow[data-d="' + map[new Date().getDay()] + '"]');
    if (row) row.classList.add('is-today');
  })();
</script>
