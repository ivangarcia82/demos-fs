      margin-top: 1.2rem; font-family: 'Jost', sans-serif; font-size: .78rem;
      letter-spacing: .2em; text-transform: uppercase; color: var(--rose-deep);
    }

    /* ---------- SERVICIOS ---------- */
    .serv { display: grid; grid-template-columns: 1fr; gap: clamp(18px, 3vw, 26px); }
    .serv__card {
      background: var(--porcelain);
      border: 1px solid var(--line);
      border-radius: 6px; overflow: hidden;
      display: flex; flex-direction: column;
      transition: transform .2s ease, box-shadow .2s ease;
