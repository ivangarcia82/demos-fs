---
import BaseLayout from '../../layouts/BaseLayout.astro';

const NOMBRE = 'Gemakeup and Beauty';
const TEL = '983 110 2937';
const WA = 'https://wa.me/529831102937';
const WA_CITA = WA + '?text=' + encodeURIComponent('Hola Gema, vi la página de Gemakeup and Beauty y me gustaría agendar una cita ✨');
const MAPS = 'https://maps.google.com/?cid=16809829589028375627';
const DIR = 'C. 42 394, Francisco de Montejo, 97203 Mérida, Yuc., México';
const MAP_EMBED = `https://www.google.com/maps?q=${encodeURIComponent(DIR)}&output=embed`;

const servicios = [
  {
    t: 'Maquillaje de novia y eventos',
    d: 'Un glam natural, luminoso y a tu medida para tu boda, sesión o gran noche. Trabajamos el look contigo desde el primer mensaje.',
    foto: '/gemakeup-and-beauty/img/foto_1.jpg',
    alt: 'Maquillaje glam natural realizado por Gema García',
  },
  {
    t: 'Maquillaje artístico y de fantasía',
    d: 'Catrinas, personajes y caracterización con detalle de artista: color, pedrería y estructura para looks que impactan.',
    foto: '/gemakeup-and-beauty/img/foto_2.jpg',
    alt: 'Maquillaje artístico de catrina con tocado de flores',
  },
  {
    t: 'Uñas en Soft gel y nail art',
    d: 'Diseños a mano, desde el nude más elegante hasta el arte más colorido. Acabado prolijo y duradero.',
    foto: '/gemakeup-and-beauty/img/foto_3.jpg',
    alt: 'Uñas en tono nude con arte floral, técnica Soft gel',
  },
  {
    t: 'Cursos de uñas con Gema',
    d: 'Aprende la técnica Soft gel desde las bases, con la paciencia y el profesionalismo que sus alumnas recomiendan.',
    foto: '/gemakeup-and-beauty/img/foto_5.jpg',
    alt: 'Uñas rojas con detalle en hoja de oro',
  },
];

const galeria = [
  { src: '/gemakeup-and-beauty/img/foto_2.jpg', alt: 'Maquillaje artístico de catrina con tocado de flores', cap: 'Arte · Catrina', feat: true },
  { src: '/gemakeup-and-beauty/img/foto_1.jpg', alt: 'Maquillaje glam natural realizado por Gema García', cap: 'Glam natural' },
  { src: '/gemakeup-and-beauty/img/foto_3.jpg', alt: 'Uñas nude con arte floral en Soft gel', cap: 'Nail art nude' },
  { src: '/gemakeup-and-beauty/img/foto_4.jpg', alt: 'Maquillaje de fantasía con plumas en tonos azules', cap: 'Fantasía' },
  { src: '/gemakeup-and-beauty/img/foto_5.jpg', alt: 'Uñas rojas con detalle en hoja de oro', cap: 'Uñas de temporada' },
];

const resenas = [
  {
    autor: 'Marisol Romero', cuando: 'Hace 4 meses',
    t: 'La atención de Gema es increíble, desde el principio me hizo sentir muy cómoda con sus mensajes y atenciones muy personalizadas. Durante el evento de mi boda, fue extremadamente linda con mi mamá y conmigo!…',
  },
  {
    autor: 'Gladys Solis', cuando: 'Hace 2 meses',
    t: 'Excelente servicio y atención por parte de Gema, mi maquillaje me encantó en cuanto a estilo y durabilidad, increíble como se mantuvo mi maquillaje intacto y fresco a pesar del calor…',
  },
  {
    autor: 'Lilia Moreno', cuando: 'Hace 4 meses',
    t: '…amo sus productos tengo piel delicada y me caen de maravilla, me gusta mucho que su maquillaje a pesar del clima dura como si me lo acabaran de hacer y su trato es excelente. Recomendada al 100%',
  },
  {
    autor: 'Fabiola Ramayo', cuando: 'Hace 3 meses',
    t: 'El curso de uñas en Soft gel me gusto mucho porque te enseña las bases principales que son muy importantes para el curso…',
  },
  {
    autor: 'Hanna Romero Solano', cuando: 'Hace 4 meses',
    t: 'El curso de uñas fue completo y muy bueno, sin duda regresaría y tomaría muchos cursos más!!',
  },
];

const horarios = [
  ['Lunes', '10:00 – 20:00'],
  ['Martes', '10:00 – 20:00'],
  ['Miércoles', '10:00 – 20:00'],
  ['Jueves', '10:00 – 20:00'],
  ['Viernes', '10:00 – 20:00'],
  ['Sábado', '10:00 – 20:00'],
  ['Domingo', 'Cerrado'],
];
---
<BaseLayout
  title="Gemakeup and Beauty · Maquillaje en Mérida"
  description="Maquillaje profesional para novias y eventos, arte en uñas y cursos con Gema García. ⭐ 5.0 · 97 reseñas en Mérida, Yuc."
  slug="gemakeup-and-beauty"
  ogImage="/gemakeup-and-beauty/img/foto_1.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400..700;1,6..96,400..600&family=Jost:wght@300;400;500;600&display=swap"
  favicon="💄"
  themeColor="#221A18"
  whatsapp={WA}
  telefono={TEL}
  mapsUrl={MAPS}
>
  <!-- ============ HERO / PORTADA EDITORIAL ============ -->
  <header class="hero">
    <img class="hero__bg" src="/gemakeup-and-beauty/img/foto_1.jpg" alt="Maquillaje glam natural realizado por Gema García" />
    <div class="hero__scrim"></div>
    <div class="hero__inner">
      <p class="eyebrow eyebrow--light">Maquillaje profesional · Mérida, Yucatán</p>
      <div class="hero__foot">
        <h1 class="masthead">Gemakeup<br /><span class="masthead__amp">&amp;</span> <em>Beauty</em></h1>
        <svg class="brush hero__brush" viewBox="0 0 220 34" aria-hidden="true">
          <defs>
            <linearGradient id="rg1" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="#E7BBA0" /><stop offset=".55" stop-color="#C98F73" /><stop offset="1" stop-color="#A76F58" />
            </linearGradient>
          </defs>
          <path d="M4 18 C46 4 92 28 132 15 C166 4 196 12 216 20 C192 27 164 17 128 23 C86 31 44 28 4 18 Z" fill="url(#rg1)" />
        </svg>
        <p class="hero__sub">Gema García — Make Up Artist</p>
        <p class="hero__rating"><span class="stars" aria-hidden="true">★★★★★</span> <strong>5.0</strong> · 97 reseñas en Google</p>
        <div class="hero__cta">
          <a class="btn btn--gold" href={WA_CITA} target="_blank" rel="noopener">
            <svg class="ico" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 3C9.4 3 4 8.3 4 14.9c0 2.6.8 5 2.3 7L4 29l7.3-2.3c1.9 1 3.9 1.5 4.7 1.5 6.6 0 12-5.3 12-11.9S22.6 3 16 3zm0 21.8c-1.4 0-3.2-.5-4.7-1.4l-.3-.2-4.3 1.4 1.4-4.2-.2-.3c-1.2-1.7-1.9-3.7-1.9-5.7C6 9.4 10.5 5 16 5s10 4.4 10 9.9-4.5 9.9-10 9.9zm5.5-7.4c-.3-.2-1.8-.9-2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.2-.2.2-.3.3-.5.1-.2 0-.4 0-.6-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4-.3.3-1.1 1.1-1.1 2.7s1.2 3.1 1.3 3.3c.2.2 2.3 3.5 5.6 4.9.8.3 1.4.5 1.9.7.8.2 1.5.2 2.1.1.6-.1 1.8-.7 2.1-1.5.3-.7.3-1.3.2-1.5-.1-.1-.3-.2-.6-.4z"/></svg>
            Agenda por WhatsApp
          </a>
          <a class="btn btn--ghost-light" href={MAPS} target="_blank" rel="noopener">Cómo llegar</a>
        </div>
      </div>
    </div>
  </header>

  <!-- ============ QUIÉNES SOMOS ============ -->
  <section class="sec sec--porcelain about">
    <div class="wrap about__grid">
      <div class="about__text reveal">
        <p class="eyebrow eyebrow--dark">El estudio de Gema</p>
        <h2 class="s-title">Belleza que se siente <em>tuya</em></h2>
        <span class="acc" aria-hidden="true"></span>
        <p>En Gemakeup and Beauty el maquillaje es un arte personal. Cada rostro llega con su historia y su ocasión —una boda, un evento, una sesión— y nuestro trabajo es realzar lo que ya te hace única, no cambiarte.</p>
        <p>Gema acompaña a cada clienta desde el primer mensaje: escucha, propone y cuida los detalles hasta que el resultado se siente natural, luminoso y duradero. Sus clientas lo dicen mejor que nosotros: un maquillaje que aguanta el calor de Mérida y productos amables incluso con la piel más delicada. Y para quienes quieren aprender, sus cursos de uñas enseñan la técnica desde las bases.</p>
      </div>
      <figure class="about__quote reveal">
        <svg class="brush quote__brush" viewBox="0 0 220 34" aria-hidden="true">
          <defs>
            <linearGradient id="rg2" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="#E7BBA0" /><stop offset=".55" stop-color="#C98F73" /><stop offset="1" stop-color="#A76F58" />
            </linearGradient>
          </defs>
          <path d="M4 18 C46 4 92 28 132 15 C166 4 196 12 216 20 C192 27 164 17 128 23 C86 31 44 28 4 18 Z" fill="url(#rg2)" />
        </svg>
        <blockquote>…es realmente una artista…</blockquote>
        <figcaption>Lilia Moreno · clienta en Google</figcaption>
      </figure>
    </div>
  </section>

  <!-- ============ SERVICIOS ============ -->
  <section class="sec sec--blush" id="servicios">
    <div class="wrap">
      <div class="sec__head reveal">
        <p class="eyebrow eyebrow--dark">Lo que hacemos</p>
        <h2 class="s-title">Servicios de estudio</h2>
        <span class="acc" aria-hidden="true"></span>
      </div>
      <div class="serv">
        {servicios.map((s) => (
          <article class="serv__card reveal">
            <div class="serv__media"><img src={s.foto} alt={s.alt} loading="lazy" /></div>
            <div class="serv__body">
              <h3>{s.t}</h3>
              <p>{s.d}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ EL SELLO DE GEMA (DIFERENCIADORES) ============ -->
  <section class="sec sec--dark sello">
    <div class="wrap">
      <div class="sec__head reveal">
        <p class="eyebrow eyebrow--light">Por qué la eligen</p>
        <h2 class="s-title s-title--light">El sello de Gema</h2>
        <span class="acc" aria-hidden="true"></span>
      </div>
      <div class="sello__grid">
        <div class="sello__item reveal">
          <span class="mole" aria-hidden="true"></span>
          <h3>Atención personalizada</h3>
          <p>Te acompaña desde el primer mensaje. Sus clientas destacan lo cómodas que se sienten de principio a fin.</p>
        </div>
        <div class="sello__item reveal">
          <span class="mole" aria-hidden="true"></span>
          <h3>Dura todo el evento</h3>
          <p>Maquillaje que se mantiene intacto y fresco a pesar del calor y el clima de Yucatán.</p>
        </div>
        <div class="sello__item reveal">
          <span class="mole" aria-hidden="true"></span>
          <h3>Amable con tu piel</h3>
          <p>Productos que caen de maravilla incluso en pieles delicadas, según quienes ya la probaron.</p>
        </div>
        <div class="sello__item reveal">
          <span class="mole" aria-hidden="true"></span>
          <h3>Cursos que sí enseñan</h3>
          <p>En sus cursos de uñas aprendes las bases con paciencia, dedicación y profesionalismo.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ GALERÍA ============ -->
  <section class="sec sec--porcelain" id="galeria">
    <div class="wrap">
      <div class="sec__head reveal">
        <p class="eyebrow eyebrow--dark">Portafolio</p>
        <h2 class="s-title">Su trabajo, de cerca</h2>
        <span class="acc" aria-hidden="true"></span>
      </div>
      <div class="gal">
        {galeria.map((g) => (
          <figure class={g.feat ? 'gal__item gal__item--feat reveal' : 'gal__item reveal'}>
            <img src={g.src} alt={g.alt} loading="lazy" />
            <figcaption>{g.cap}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA INTERMEDIO ============ -->
  <section class="cta-band">
    <div class="wrap cta-band__in reveal">
      <p class="cta-band__k">¿Tienes un evento próximo?</p>
      <h2 class="cta-band__t">Aparta tu fecha con <em>Gema</em></h2>
      <a class="btn btn--gold" href={WA_CITA} target="_blank" rel="noopener">
        <svg class="ico" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 3C9.4 3 4 8.3 4 14.9c0 2.6.8 5 2.3 7L4 29l7.3-2.3c1.9 1 3.9 1.5 4.7 1.5 6.6 0 12-5.3 12-11.9S22.6 3 16 3zm0 21.8c-1.4 0-3.2-.5-4.7-1.4l-.3-.2-4.3 1.4 1.4-4.2-.2-.3c-1.2-1.7-1.9-3.7-1.9-5.7C6 9.4 10.5 5 16 5s10 4.4 10 9.9-4.5 9.9-10 9.9zm5.5-7.4c-.3-.2-1.8-.9-2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.2-.2.2-.3.3-.5.1-.2 0-.4 0-.6-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4-.3.3-1.1 1.1-1.1 2.7s1.2 3.1 1.3 3.3c.2.2 2.3 3.5 5.6 4.9.8.3 1.4.5 1.9.7.8.2 1.5.2 2.1.1.6-.1 1.8-.7 2.1-1.5.3-.7.3-1.3.2-1.5-.1-.1-.3-.2-.6-.4z"/></svg>
        Escribir por WhatsApp
      </a>
    </div>
  </section>

  <!-- ============ RESEÑAS ============ -->
  <section class="sec sec--blush" id="resenas">
    <div class="wrap">
      <div class="sec__head reveal">
        <p class="eyebrow eyebrow--dark">Lo que dicen sus clientas</p>
        <h2 class="s-title">⭐ 5.0 · 97 reseñas</h2>
        <span class="acc" aria-hidden="true"></span>
      </div>
      <div class="revs">
        {resenas.map((r) => (
          <figure class="rev reveal">
            <div class="rev__stars" aria-hidden="true">★★★★★</div>
            <blockquote>{r.t}</blockquote>
            <figcaption><span class="rev__name">{r.autor}</span><span class="rev__when">{r.cuando}</span></figcaption>
          </figure>
        ))}
      </div>
      <div class="revs__more reveal">
        <a class="btn btn--ghost-dark" href={MAPS} target="_blank" rel="noopener">Leer más reseñas en Google</a>
      </div>
    </div>
  </section>

  <!-- ============ UBICACIÓN + HORARIOS ============ -->
  <section class="sec sec--porcelain" id="ubicacion">
    <div class="wrap">
      <div class="sec__head reveal">
        <p class="eyebrow eyebrow--dark">Visítanos</p>
        <h2 class="s-title">Dónde encontrarnos</h2>
        <span class="acc" aria-hidden="true"></span>
      </div>
      <div class="loc">
        <div class="loc__info reveal">
          <h3>Dirección</h3>
          <p class="loc__addr">C. 42 394, Francisco de Montejo,<br />97203 Mérida, Yuc.</p>
          <a class="btn btn--dark btn--sm" href={MAPS} target="_blank" rel="noopener">Abrir en Google Maps</a>

          <h3 class="loc__h3b">Horarios</h3>
          <table class="hours">
            <tbody>
              {horarios.map(([dia, hora]) => (
                <tr class={hora === 'Cerrado' ? 'is-closed' : ''}>
                  <th scope="row">{dia}</th>
                  <td>{hora}</td>
                </tr>
              ))}
            </tbody>
          </table>

          <p class="loc__chip"><span aria-hidden="true">✓</span> Aceptamos pago con tarjeta</p>
        </div>
        <div class="loc__map reveal">
          <iframe
            title="Mapa de Gemakeup and Beauty en Francisco de Montejo, Mérida"
            src={MAP_EMBED}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA FINAL ============ -->
  <section class="sec sec--dark final">
    <div class="wrap final__in reveal">
      <p class="eyebrow eyebrow--light">Tu cita te espera</p>
      <h2 class="final__t">Deja tu <em>look</em> en manos de una artista</h2>
      <svg class="brush final__brush" viewBox="0 0 220 34" aria-hidden="true">
        <defs>
          <linearGradient id="rg3" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0" stop-color="#E7BBA0" /><stop offset=".55" stop-color="#C98F73" /><stop offset="1" stop-color="#A76F58" />
          </linearGradient>
        </defs>
        <path d="M4 18 C46 4 92 28 132 15 C166 4 196 12 216 20 C192 27 164 17 128 23 C86 31 44 28 4 18 Z" fill="url(#rg3)" />
      </svg>
      <div class="final__cta">
        <a class="btn btn--gold" href={WA_CITA} target="_blank" rel="noopener">
          <svg class="ico" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 3C9.4 3 4 8.3 4 14.9c0 2.6.8 5 2.3 7L4 29l7.3-2.3c1.9 1 3.9 1.5 4.7 1.5 6.6 0 12-5.3 12-11.9S22.6 3 16 3zm0 21.8c-1.4 0-3.2-.5-4.7-1.4l-.3-.2-4.3 1.4 1.4-4.2-.2-.3c-1.2-1.7-1.9-3.7-1.9-5.7C6 9.4 10.5 5 16 5s10 4.4 10 9.9-4.5 9.9-10 9.9zm5.5-7.4c-.3-.2-1.8-.9-2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.2-.2.2-.3.3-.5.1-.2 0-.4 0-.6-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4-.3.3-1.1 1.1-1.1 2.7s1.2 3.1 1.3 3.3c.2.2 2.3 3.5 5.6 4.9.8.3 1.4.5 1.9.7.8.2 1.5.2 2.1.1.6-.1 1.8-.7 2.1-1.5.3-.7.3-1.3.2-1.5-.1-.1-.3-.2-.6-.4z"/></svg>
          Agenda por WhatsApp
        </a>
        <a class="btn btn--ghost-light" href={`tel:+529831102937`}>Llamar {TEL}</a>
      </div>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->
  <footer class="foot">
    <div class="wrap foot__in">
      <p class="foot__brand">Gemakeup <em>&amp;</em> Beauty</p>
      <p class="foot__meta">Gema García · Make Up Artist — Francisco de Montejo, Mérida, Yuc.</p>
      <p class="foot__meta"><a href={`tel:+529831102937`}>{TEL}</a> · Lun a Sáb, 10:00 – 20:00</p>
      <p class="foot__note">⭐ 5.0 · 97 reseñas en Google</p>
    </div>
  </footer>

  <style is:global>
    :root {
      --porcelain: #F7ECE4;
      --porcelain-2: #F2E2D6;
      --blush: #EAD2C4;
      --rose: #B26C63;
      --rose-deep: #8E5149;
      --gold: #C08A73;
      --gold-lt: #E4BA9E;
      --charcoal: #221A18;
      --charcoal-2: #2C2320;
      --ink: #453A34;
      --line: rgba(34, 26, 24, .14);
      --gold-grad: linear-gradient(120deg, #E7BBA0, #C98F73 55%, #A76F58);
    }

    body {
      background: var(--porcelain);
      color: var(--ink);
      font-family: 'Jost', system-ui, sans-serif;
      font-weight: 400;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    ::selection { background: var(--rose); color: #fff; }

    .wrap { width: 100%; max-width: 1080px; margin-inline: auto; padding-inline: clamp(20px, 5.5vw, 44px); }

    /* ---------- Tipografía compartida ---------- */
    .eyebrow {
      font-family: 'Jost', sans-serif;
      font-weight: 500;
      font-size: .72rem;
      letter-spacing: .3em;
      text-transform: uppercase;
      margin: 0 0 1rem;
    }
    .eyebrow--light { color: var(--gold-lt); }
    .eyebrow--dark { color: var(--rose-deep); }

    .s-title {
      font-family: 'Bodoni Moda', 'Times New Roman', serif;
      font-weight: 500;
      font-size: clamp(2.1rem, 7vw, 3.4rem);
      line-height: 1.02;
      letter-spacing: -.01em;
      color: var(--charcoal);
      margin: 0;
    }
    .s-title--light { color: var(--porcelain); }
    .s-title em, .about__text em, .final__t em, .cta-band__t em, .masthead em {
      font-style: italic;
    }

    /* Trazo de labial — elemento firma (acento bajo títulos) */
    .acc {
      display: block;
      width: 66px;
      height: 7px;
      margin: 1.1rem 0 0;
      border-radius: 8px;
      background: var(--gold-grad);
      transform: skewX(-22deg);
    }
    .brush { display: block; height: auto; }

    .sec { padding-block: clamp(64px, 12vw, 118px); }
    .sec--porcelain { background: var(--porcelain); }
    .sec--blush { background: var(--blush); }
    .sec--dark { background: var(--charcoal); color: var(--porcelain); }
    .sec__head { margin-bottom: clamp(34px, 6vw, 56px); max-width: 40ch; }

    /* ---------- Botones ---------- */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: .55em;
      font-family: 'Jost', sans-serif; font-weight: 500; font-size: .96rem;
      letter-spacing: .01em;
      padding: .95em 1.7em; border-radius: 999px;
      text-decoration: none; border: 1.5px solid transparent; cursor: pointer;
      transition: transform .18s ease, box-shadow .18s ease, background-color .18s ease, color .18s ease;
    }
    .btn--sm { padding: .72em 1.3em; font-size: .88rem; }
    .btn .ico { width: 1.25em; height: 1.25em; flex: none; }
    .btn--gold { background-image: var(--gold-grad); color: #2A1C15; box-shadow: 0 8px 22px rgba(120, 70, 45, .28); }
    .btn--dark { background: var(--charcoal); color: var(--porcelain); }
    .btn--ghost-light { border-color: rgba(247, 236, 228, .55); color: var(--porcelain); }
    .btn--ghost-dark { border-color: var(--charcoal); color: var(--charcoal); }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 12px 26px rgba(80, 45, 30, .3); }
    .btn--ghost-light:hover { background: rgba(247, 236, 228, .12); }
    .btn--ghost-dark:hover { background: rgba(34, 26, 24, .07); }
    .btn:focus-visible { outline: 3px solid var(--gold); outline-offset: 3px; }

    /* ---------- HERO ---------- */
    .hero {
      position: relative;
      min-height: calc(100svh - var(--demo-banner-h, 38px));
      display: flex;
      overflow: hidden;
      background: var(--charcoal);
    }
    .hero__bg {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; object-position: 50% 18%;
    }
    .hero__scrim {
      position: absolute; inset: 0;
      background:
        linear-gradient(to bottom, rgba(20, 14, 12, .12) 0%, rgba(20, 14, 12, .05) 38%, rgba(24, 17, 15, .82) 82%, rgba(24, 17, 15, .95) 100%),
        linear-gradient(to right, rgba(24, 17, 15, .38), rgba(24, 17, 15, 0) 60%);
    }
    .hero__inner {
      position: relative; z-index: 2;
      width: 100%; max-width: 1080px; margin-inline: auto;
      padding: calc(1.4rem + var(--demo-banner-h, 38px)) clamp(20px, 5.5vw, 44px) clamp(30px, 6vw, 54px);
      display: flex; flex-direction: column; justify-content: space-between; gap: 2rem;
    }
    .hero__foot { max-width: 620px; }
    .masthead {
      font-family: 'Bodoni Moda', serif; font-weight: 500;
      color: var(--porcelain);
      font-size: clamp(3.1rem, 15vw, 6.4rem);
      line-height: .9; letter-spacing: -.02em; margin: 0;
      text-shadow: 0 2px 30px rgba(0, 0, 0, .35);
