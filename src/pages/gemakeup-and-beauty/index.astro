    .about__quote blockquote {
      margin: 0; font-family: 'Bodoni Moda', serif; font-style: italic; font-weight: 500;
      font-size: clamp(1.9rem, 6vw, 2.9rem); line-height: 1.15; color: var(--charcoal);
