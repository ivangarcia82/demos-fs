    .hero__rating .stars { color: var(--gold-lt); letter-spacing: .12em; }
    .hero__rating strong { font-weight: 600; }
    .hero__cta { display: flex; flex-wrap: wrap; gap: .8rem; }

    /* ---------- ABOUT ---------- */
    .about__grid { display: grid; grid-template-columns: 1fr; gap: clamp(34px, 6vw, 60px); align-items: center; }
    .about__text p { margin: 1.1rem 0 0; font-weight: 300; font-size: 1.06rem; color: var(--ink); }
    .about__text p:first-of-type { margin-top: 1.4rem; }
    .about__quote {
      margin: 0; padding: clamp(28px, 5vw, 44px);
      background: var(--porcelain-2);
      border: 1px solid var(--line);
