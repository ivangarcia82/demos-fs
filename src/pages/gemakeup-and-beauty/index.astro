    .masthead__amp { color: var(--gold-lt); font-style: italic; }
    .masthead em { color: var(--porcelain); }
    .hero__brush { width: clamp(150px, 42vw, 220px); margin: .7rem 0 0; filter: drop-shadow(0 3px 8px rgba(0, 0, 0, .3)); }
    .hero__sub {
      font-family: 'Jost', sans-serif; font-weight: 300;
      color: var(--porcelain); opacity: .92;
      font-size: clamp(1rem, 3.4vw, 1.2rem); letter-spacing: .16em; text-transform: uppercase;
      margin: 1.1rem 0 0;
