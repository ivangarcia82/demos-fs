    .serv__card:hover { transform: translateY(-4px); box-shadow: 0 16px 34px rgba(90, 55, 38, .16); }
    .serv__media { aspect-ratio: 4 / 3; overflow: hidden; }
    .serv__media img { width: 100%; height: 100%; object-fit: cover; }
    .serv__body { padding: 1.4rem 1.5rem 1.7rem; }
    .serv__body h3 { font-family: 'Bodoni Moda', serif; font-weight: 600; font-size: 1.4rem; line-height: 1.15; color: var(--charcoal); margin: 0 0 .5rem; }
    .serv__body p { margin: 0; font-weight: 300; font-size: .98rem; }

    /* ---------- SELLO / DIFERENCIADORES ---------- */
    .sello__grid { display: grid; grid-template-columns: 1fr; gap: clamp(20px, 3vw, 30px); }
    .sello__item {
      padding: 1.6rem 0 0; border-top: 1px solid rgba(247, 236, 228, .18);
    }
    .mole {
      display: inline-block; width: 10px; height: 10px; border-radius: 50%;
      background: var(--gold-grad); margin-bottom: 1rem;
      box-shadow: 0 0 0 4px rgba(228, 186, 158, .14);
    }
    .sello__item h3 { font-family: 'Bodoni Moda', serif; font-weight: 500; font-size: 1.5rem; color: var(--porcelain); margin: 0 0 .5rem; }
    .sello__item p { margin: 0; font-weight: 300; color: rgba(247, 236, 228, .82); }

    /* ---------- GALERÍA ---------- */
    .gal { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .gal__item { position: relative; margin: 0; overflow: hidden; border-radius: 5px; aspect-ratio: 3 / 4; }
    .gal__item--feat { grid-column: span 2; aspect-ratio: 4 / 3; }
    .gal__item img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
    .gal__item:hover img { transform: scale(1.04); }
    .gal__item figcaption {
      position: absolute; left: 0; right: 0; bottom: 0;
      padding: 1.4rem .9rem .7rem;
      font-family: 'Jost', sans-serif; font-size: .72rem; letter-spacing: .18em; text-transform: uppercase;
      color: #fff;
      background: linear-gradient(to top, rgba(24, 16, 14, .78), rgba(24, 16, 14, 0));
    }

    /* ---------- CTA INTERMEDIO ---------- */
    .cta-band { background: var(--porcelain-2); padding-block: clamp(52px, 9vw, 84px); }
    .cta-band__in { text-align: center; display: flex; flex-direction: column; align-items: center; }
    .cta-band__k { margin: 0 0 .5rem; font-family: 'Jost', sans-serif; font-size: .74rem; letter-spacing: .28em; text-transform: uppercase; color: var(--rose-deep); }
    .cta-band__t { font-family: 'Bodoni Moda', serif; font-weight: 500; font-size: clamp(1.9rem, 6.5vw, 3rem); color: var(--charcoal); margin: 0 0 1.6rem; }

    /* ---------- RESEÑAS ---------- */
    .revs { display: grid; grid-template-columns: 1fr; gap: clamp(16px, 3vw, 24px); }
    .rev {
      margin: 0; background: var(--porcelain); border-radius: 6px;
      padding: clamp(24px, 4vw, 34px); border: 1px solid var(--line);
      display: flex; flex-direction: column;
    }
    .rev__stars { color: var(--gold); letter-spacing: .14em; font-size: 1rem; margin-bottom: .9rem; }
    .rev blockquote { margin: 0; font-family: 'Bodoni Moda', serif; font-style: italic; font-size: 1.16rem; line-height: 1.5; color: var(--charcoal); }
    .rev figcaption { margin-top: 1.3rem; display: flex; flex-direction: column; gap: .1rem; }
    .rev__name { font-family: 'Jost', sans-serif; font-weight: 600; color: var(--charcoal); letter-spacing: .02em; }
    .rev__when { font-size: .82rem; color: var(--rose-deep); letter-spacing: .04em; }
    .revs__more { margin-top: clamp(28px, 5vw, 44px); text-align: center; }

    /* ---------- UBICACIÓN ---------- */
    .loc { display: grid; grid-template-columns: 1fr; gap: clamp(26px, 5vw, 46px); align-items: start; }
    .loc__info h3 { font-family: 'Bodoni Moda', serif; font-weight: 600; font-size: 1.3rem; color: var(--charcoal); margin: 0 0 .5rem; }
    .loc__h3b { margin-top: 2.2rem !important; }
    .loc__addr { margin: 0 0 1.3rem; font-weight: 300; font-size: 1.05rem; }
    .hours { width: 100%; border-collapse: collapse; font-size: .98rem; }
    .hours th, .hours td { text-align: left; padding: .62rem 0; border-bottom: 1px solid var(--line); font-weight: 400; }
    .hours th { font-weight: 500; color: var(--charcoal); }
    .hours td { text-align: right; color: var(--ink); }
    .hours .is-closed td { color: var(--rose-deep); }
    .loc__chip {
      margin-top: 1.6rem; display: inline-flex; align-items: center; gap: .5em;
      background: var(--porcelain-2); border: 1px solid var(--line); border-radius: 999px;
      padding: .55em 1.1em; font-size: .9rem; font-weight: 500; color: var(--charcoal);
    }
    .loc__chip span { color: var(--rose); font-weight: 700; }
    .loc__map { border-radius: 6px; overflow: hidden; border: 1px solid var(--line); min-height: 300px; }
    .loc__map iframe { width: 100%; height: 100%; min-height: 340px; border: 0; display: block; filter: grayscale(.2) contrast(1.02); }

    /* ---------- CTA FINAL ---------- */
    .final__in { text-align: center; display: flex; flex-direction: column; align-items: center; }
    .final__t { font-family: 'Bodoni Moda', serif; font-weight: 500; font-size: clamp(2rem, 7vw, 3.3rem); line-height: 1.06; color: var(--porcelain); margin: 0; }
    .final__brush { width: clamp(140px, 38vw, 200px); margin: 1.4rem 0 1.9rem; }
    .final__cta { display: flex; flex-wrap: wrap; gap: .8rem; justify-content: center; }

    /* ---------- FOOTER ---------- */
    .foot { background: var(--charcoal-2); color: var(--porcelain); padding: clamp(46px, 8vw, 66px) 0 96px; text-align: center; }
    .foot__brand { font-family: 'Bodoni Moda', serif; font-size: 1.9rem; font-weight: 500; margin: 0 0 .8rem; }
    .foot__brand em { color: var(--gold-lt); font-style: italic; }
    .foot__meta { margin: .25rem 0; font-weight: 300; font-size: .95rem; color: rgba(247, 236, 228, .82); }
    .foot__meta a { color: var(--gold-lt); text-decoration: none; border-bottom: 1px solid rgba(228, 186, 158, .4); }
    .foot__meta a:hover { color: var(--porcelain); }
    .foot__note { margin: 1.2rem 0 0; font-size: .82rem; letter-spacing: .12em; text-transform: uppercase; color: var(--gold-lt); }
    .foot a:focus-visible, .hours a:focus-visible { outline: 2px solid var(--gold-lt); outline-offset: 3px; }

    /* ---------- Scroll reveal (mejora progresiva) ---------- */
    .js-reveal .reveal { opacity: 0; transform: translateY(22px); transition: opacity .7s ease, transform .7s ease; }
    .js-reveal .reveal.in { opacity: 1; transform: none; }

    @media (prefers-reduced-motion: reduce) {
      .js-reveal .reveal { opacity: 1; transform: none; transition: none; }
    }

    /* ---------- Desktop ---------- */
    @media (min-width: 720px) {
      .serv { grid-template-columns: repeat(2, 1fr); }
      .sello__grid { grid-template-columns: repeat(2, 1fr); gap: 2.4rem 3rem; }
      .revs { grid-template-columns: repeat(2, 1fr); }
      .gal { grid-template-columns: repeat(3, 1fr); }
      .gal__item--feat { grid-column: span 2; grid-row: span 2; aspect-ratio: auto; }
    }
    @media (min-width: 880px) {
      .about__grid { grid-template-columns: 1.15fr .85fr; }
      .loc { grid-template-columns: 1fr 1.1fr; }
      .sello__grid { grid-template-columns: repeat(4, 1fr); gap: 2.6rem 2rem; }
    }
  </style>

  <script is:inline>
    (function () {
      var root = document.documentElement;
      root.classList.add('js-reveal');
      var els = document.querySelectorAll('.reveal');
      if (!('IntersectionObserver' in window)) {
        els.forEach(function (el) { el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
      els.forEach(function (el) { io.observe(el); });
    })();
  </script>
</BaseLayout>
