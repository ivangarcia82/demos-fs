  <script is:inline>
    (function () {
      // Chip "abierto ahora" — horario real: todos los días 11:00–23:00
      var chip = document.getElementById('chip-open');
      if (chip) {
        var h = new Date().getHours();
        var abierto = h >= 11 && h < 23;
        chip.classList.add(abierto ? 'abierto' : 'cerrado');
        chip.innerHTML = '<span class="dot" aria-hidden="true"></span> ' +
          (abierto ? 'Abierto ahora · cerramos a las 11:00 pm' : 'Cerrado ahora · abrimos a las 11:00 am');
      }

      // Resaltar el día de hoy en la tabla de horarios (0 = lunes ... 6 = domingo)
      var hoy = (new Date().getDay() + 6) % 7;
      var fila = document.querySelector('.horarios tr[data-dia="' + hoy + '"]');
      if (fila) fila.classList.add('hoy');

      // Scroll reveal como mejora progresiva
      var nodos = document.querySelectorAll('[data-reveal]');
      if ('IntersectionObserver' in window && nodos.length) {
        var io = new IntersectionObserver(function (entradas) {
          entradas.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('reveal-in');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12 });
        nodos.forEach(function (n) {
          n.classList.add('reveal-init');
          io.observe(n);
        });
      }
    })();
  </script>
