    /* ---- Scroll reveal (solo se activa con JS) ---- */
    .reveal-init {
      opacity: 0;
      transform: translateY(14px);
      transition: opacity 0.55s ease, transform 0.55s ease;
    }
    .reveal-in {
      opacity: 1;
      transform: none;
    }
