    .cap-final__sub { color: var(--ivory-dim); max-width: 40ch; margin: 0 auto; }

    /* ---------- FOOTER ---------- */
    .cap-foot {
      background: #081524;
      padding: 44px 0 96px;
      border-top: 1px solid rgba(201,162,78,0.12);
