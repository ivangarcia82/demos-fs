    a:focus-visible, .cap-textlink:focus-visible {
      outline: 3px solid var(--gold-bright);
      outline-offset: 3px;
      border-radius: 4px;
    }

    /* ---------- RESPONSIVE ---------- */
    @media (min-width: 620px) {
      .cap-mom-grid { grid-template-columns: repeat(2, 1fr); }
      .cap-res-grid { grid-template-columns: repeat(2, 1fr); }
      .cap-mosaic {
        grid-template-columns: repeat(2, 1fr);
        grid-auto-rows: 220px;
      }
      .cap-shot img { aspect-ratio: auto; }
      .cap-shot--0 { grid-column: span 2; grid-row: span 2; }
      .cap-cta-band__inner { flex-direction: row; justify-content: space-between; text-align: left; }
    }
    @media (min-width: 900px) {
      .cap-ubi__grid { grid-template-columns: 1fr 1.1fr; align-items: stretch; }
      .cap-mosaic { grid-template-columns: repeat(3, 1fr); }
      .cap-shot--0 { grid-column: span 2; grid-row: span 2; }
    }

    @media (prefers-reduced-motion: reduce) {
      .cap-tw { animation: none; opacity: 0.85; }
      .cap-shot:hover img { transform: none; }
      .cap-btn--gold:hover { transform: none; }
    }
  </style>

  <script is:inline>
    document.documentElement.classList.add('js');
    (function () {
      var els = document.querySelectorAll('.cap-reveal');
      if (!('IntersectionObserver' in window) || !els.length) {
        els.forEach(function (el) { el.classList.add('is-visible'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      els.forEach(function (el) { io.observe(el); });
    })();
  </script>
