---
import BaseLayout from '../../layouts/BaseLayout.astro';

const slug = 'romelia';
const wa = 'https://wa.me/529993421771';
const waReserva = wa + '?text=' + encodeURIComponent('¡Hola Romelia! Vi su página y me gustaría reservar una mesa para desayunar.');
const telefono = '999 342 1771';
const mapsUrl = 'https://maps.google.com/?cid=5337804479431562835&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA';
const direccion = 'C. 23, San Ramón Nte I, 97117 Mérida, Yuc., México';
const mapEmbed = 'https://www.google.com/maps?q=' + encodeURIComponent(direccion) + '&output=embed';
const img = (n) => `/${slug}/img/foto_${n}.jpg`;

const horarios = [
  ['Lunes', '8:00 – 16:30'],
  ['Martes', '8:00 – 16:30'],
  ['Miércoles', '8:00 – 16:30'],
  ['Jueves', '8:00 – 16:30'],
  ['Viernes', '8:00 – 16:30'],
  ['Sábado', '8:00 – 16:30'],
  ['Domingo', '8:00 – 16:30'],
];

const atributos = [
  'Servicio en el local', 'Para llevar', 'Recolección en la puerta',
  'Acepta reservaciones', 'Acepta tarjetas', 'Estacionamiento',
  'Acceso para silla de ruedas', 'Desayunos', 'Comidas', 'Café',
];
---
<BaseLayout
  title="Romelia — Desayunos, brunch y pan de masa madre en Mérida"
  description="Pan de masa madre, chilaquiles, pan francés y buen café en San Ramón, Mérida. ⭐ 4.6 · 1,444 reseñas en Google. Reserva tu mesa por WhatsApp."
  slug={slug}
  ogImage={img(2)}
  fonts="https://fonts.googleapis.com/css2?family=Prata&family=Mulish:wght@300;400;500;600;700;800&display=swap"
  favicon="🌿"
  themeColor="#3e4a34"
  whatsapp={wa}
  telefono={telefono}
  mapsUrl={mapsUrl}
>
  <!-- ===== SVG defs: laurel signature + sprig ===== -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
    <symbol id="laurel" viewBox="0 0 160 220">
      <g fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M122 210 C 60 196 34 152 40 98 C 45 52 74 24 120 12" />
      </g>
      <g fill="currentColor">
        <ellipse cx="104" cy="196" rx="13" ry="5" transform="rotate(24 104 196)" />
        <ellipse cx="80" cy="182" rx="14" ry="5.2" transform="rotate(12 80 182)" />
        <ellipse cx="60" cy="162" rx="15" ry="5.4" transform="rotate(-2 60 162)" />
        <ellipse cx="47" cy="136" rx="15" ry="5.4" transform="rotate(-16 47 136)" />
        <ellipse cx="42" cy="108" rx="15" ry="5.4" transform="rotate(-30 42 108)" />
        <ellipse cx="45" cy="80" rx="14" ry="5.2" transform="rotate(-44 45 80)" />
        <ellipse cx="56" cy="54" rx="13" ry="5" transform="rotate(-58 56 54)" />
        <ellipse cx="74" cy="32" rx="12" ry="4.6" transform="rotate(-70 74 32)" />
        <ellipse cx="98" cy="18" rx="10" ry="4" transform="rotate(-80 98 18)" />
      </g>
    </symbol>
    <symbol id="sprig" viewBox="0 0 48 24">
      <g fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M5 12 H 41" />
      </g>
      <g fill="currentColor">
        <ellipse cx="14" cy="8" rx="5" ry="2.2" transform="rotate(-26 14 8)" />
        <ellipse cx="14" cy="16" rx="5" ry="2.2" transform="rotate(26 14 16)" />
        <ellipse cx="24" cy="7" rx="5" ry="2.2" transform="rotate(-26 24 7)" />
        <ellipse cx="24" cy="17" rx="5" ry="2.2" transform="rotate(26 24 17)" />
        <ellipse cx="41" cy="12" rx="4.4" ry="3.4" />
      </g>
    </symbol>
  </svg>

  <!-- ===== HERO ===== -->
  <header class="hero">
    <img class="hero__bg" src={img(1)} alt="Terraza de Romelia: puertas de madera verde salvia, toldo de lino y mesas de madera entre plantas" fetchpriority="high" width="900" height="1200" />
    <div class="hero__scrim"></div>
    <div class="hero__inner">
      <p class="eyebrow eyebrow--light">
        <svg class="sprig" width="34" height="17" aria-hidden="true"><use href="#sprig" /></svg>
        Desayunos &amp; comidas · Mérida
      </p>
      <h1 class="hero__title">Romelia</h1>
      <p class="hero__tag">Pan de masa madre, brunch y buen café, a un paso del City Center.</p>
      <p class="rating rating--hero">
        <span class="stars stars--dark" style="--pct:92%" aria-hidden="true">★★★★★</span>
        <span><strong>4.6</strong> · 1,444 reseñas en Google</span>
      </p>
      <div class="cta-row">
        <a class="btn btn--light" href={waReserva} target="_blank" rel="noopener">
          <svg viewBox="0 0 32 32" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M16 3C9.4 3 4 8.3 4 14.9c0 2.6.8 5 2.3 7L4 29l7.3-2.3c1.9 1 3.9 1.5 4.7 1.5 6.6 0 12-5.3 12-11.9S22.6 3 16 3zm0 21.8c-1.4 0-3.2-.5-4.7-1.4l-.3-.2-4.3 1.4 1.4-4.2-.2-.3c-1.2-1.7-1.9-3.7-1.9-5.7C6 9.4 10.5 5 16 5s10 4.4 10 9.9-4.5 9.9-10 9.9zm5.5-7.4c-.3-.2-1.8-.9-2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.2-.2.2-.3.3-.5.1-.2 0-.4 0-.6-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4-.3.3-1.1 1.1-1.1 2.7s1.2 3.1 1.3 3.3c.2.2 2.3 3.5 5.6 4.9.8.3 1.4.5 1.9.7.8.2 1.5.2 2.1.1.6-.1 1.8-.7 2.1-1.5.3-.7.3-1.3.2-1.5-.1-.1-.3-.2-.6-.4z"/></svg>
          Reservar por WhatsApp
        </a>
        <a class="btn btn--ghost btn--ghost-light" href={mapsUrl} target="_blank" rel="noopener">Cómo llegar</a>
      </div>
      <ul class="hero__meta">
        <li>Todos los días · 8:00–16:30</li>
        <li>Estacionamiento</li>
        <li>Acepta tarjetas</li>
      </ul>
    </div>
  </header>

  <!-- ===== INTRO / QUIÉNES SOMOS ===== -->
  <section class="sec sec--paper">
    <div class="wrap intro reveal">
      <p class="eyebrow">
        <svg class="sprig" width="34" height="17" aria-hidden="true"><use href="#sprig" /></svg>
        La casa
      </p>
      <h2 class="h2">Una mesa para quedarse un rato más</h2>
      <div class="intro__cols">
        <div class="intro__lead">
          <p>Romelia es una casa de desayunos y comidas en San Ramón Norte, donde el día empieza con el horno encendido y el café recién hecho. Horneamos nuestro propio pan de masa madre —conchas, panes rellenos de guayaba, croissants— y montamos platos que se ven tan bien como saben.</p>
          <p>Nos gusta cocinar con ingredientes frescos y servir sin prisa: dejamos la botella de agua en la mesa, estamos pendientes de que no te falte nada y te contamos qué salió rico ese día. Ven temprano si quieres ver la variedad de panes recién salidos.</p>
        </div>
        <figure class="intro__quote">
          <blockquote>«El café es muy bueno, con buena intensidad de sabor.»</blockquote>
          <figcaption>— Kevin B. · reseña en Google</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ===== SIGNATURE: EMBLEMA 1,444 ===== -->
  <section class="sec sec--emblem on-dark">
    <div class="wrap emblem reveal">
      <p class="eyebrow eyebrow--light">Lo que dice la gente</p>
      <div class="emblem__crest">
        <svg class="laurel laurel--l" viewBox="0 0 160 220" width="90" height="124" aria-hidden="true"><use href="#laurel" /></svg>
        <div class="emblem__center">
          <span class="emblem__figure">1,444</span>
          <span class="emblem__label">reseñas de comensales en Google</span>
        </div>
        <svg class="laurel laurel--r" viewBox="0 0 160 220" width="90" height="124" aria-hidden="true"><use href="#laurel" /></svg>
      </div>
      <p class="emblem__foot">
        <span class="stars stars--dark" style="--pct:92%" aria-hidden="true">★★★★★</span>
        <strong>4.6</strong> de promedio · desayunos, brunch y café en Mérida
      </p>
    </div>
  </section>

  <!-- ===== EN LA MESA / LO MÁS PEDIDO ===== -->
  <section class="sec sec--carta">
    <div class="wrap">
      <div class="carta__head reveal">
        <p class="eyebrow">
          <svg class="sprig" width="34" height="17" aria-hidden="true"><use href="#sprig" /></svg>
          En la mesa
        </p>
        <h2 class="h2">Lo que más piden nuestros comensales</h2>
        <p class="lede">Del horno de masa madre a los chilaquiles de la mañana. Esto es lo que la gente vuelve a pedir.</p>
      </div>

      <div class="carta__grid">
        <article class="card card--menu reveal">
          <h3 class="card__title">Del horno</h3>
          <ul class="menu">
            <li>Conchas y pan relleno de guayaba</li>
            <li>Croissant de crema de pistache</li>
            <li>Pan de crembulé</li>
            <li>Focaccia de carnes frías</li>
          </ul>
          <p class="card__note">Pan de masa madre horneado en casa.</p>
        </article>

        <figure class="card card--photo reveal">
          <img src={img(2)} alt="Pan francés con fresas, plátano, moras y crema, espolvoreado con azúcar glass" loading="lazy" width="900" height="1200" />
          <figcaption>Pan francés con fruta de temporada</figcaption>
        </figure>

        <article class="card card--menu reveal">
          <h3 class="card__title">Para desayunar</h3>
          <ul class="menu">
            <li>Chilaquiles rojos</li>
            <li>Huevos en salsa con aguacate</li>
            <li>Pan de masa madre con huevo y arúgula</li>
            <li>Molletes</li>
            <li>Huevos revueltos cremosos con pan brioche</li>
          </ul>
        </article>

        <article class="card card--menu reveal">
          <h3 class="card__title">Almuerzo &amp; brunch</h3>
          <ul class="menu">
            <li>Bagel angus</li>
            <li>Burrito de la casa</li>
            <li>Hamburguesa con crema de cacahuate</li>
            <li>Risotto al fungi o con tocino</li>
          </ul>
        </article>

        <figure class="card card--photo reveal">
          <img src={img(4)} alt="Chilaquiles rojos con queso, aguacate, rábano y cilantro, con jugo natural" loading="lazy" width="1600" height="1200" />
          <figcaption>Chilaquiles rojos con jugo natural</figcaption>
        </figure>

        <article class="card card--menu card--drinks reveal">
          <h3 class="card__title">Para beber</h3>
          <ul class="menu">
            <li>Café</li>
            <li>Jugo de naranja</li>
            <li>Té con cítricos y menta</li>
          </ul>
          <p class="card__note">Sin precios en esta demo: pregúntalos en el local.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===== GALERÍA ===== -->
  <section class="sec sec--paper">
    <div class="wrap">
      <div class="carta__head reveal">
        <p class="eyebrow">
          <svg class="sprig" width="34" height="17" aria-hidden="true"><use href="#sprig" /></svg>
          El lugar
        </p>
        <h2 class="h2">Un rincón para desayunar bonito</h2>
      </div>
      <div class="gallery reveal">
        <figure class="gallery__item gallery__item--tall">
          <img src={img(3)} alt="Pan de masa madre con huevo, arúgula y ensalada fresca sobre plato negro" loading="lazy" width="900" height="1200" />
        </figure>
        <figure class="gallery__item">
          <img src={img(5)} alt="Huevos en salsa roja con aguacate, rábano sandía y cilantro, junto a una taza de café" loading="lazy" width="1600" height="1200" />
        </figure>
        <figure class="gallery__item">
          <img src={img(4)} alt="Chilaquiles rojos coloridos con queso, aguacate y rábano" loading="lazy" width="1600" height="1200" />
        </figure>
        <figure class="gallery__item gallery__item--wide">
          <img src={img(1)} alt="Fachada verde salvia de Romelia con toldo de lino, mesas de madera y plantas" loading="lazy" width="900" height="1200" />
        </figure>
      </div>
    </div>
  </section>

  <!-- ===== RESEÑAS ===== -->
  <section class="sec sec--reviews on-dark">
    <div class="wrap">
      <div class="carta__head reveal">
        <p class="eyebrow eyebrow--light">Reseñas reales</p>
        <h2 class="h2 h2--light">Lo escribieron ellos, no nosotros</h2>
      </div>
      <div class="reviews reveal">
        <figure class="review">
          <div class="review__stars" aria-hidden="true">★★★★★</div>
          <blockquote>«…Romelia es un lugar agradable con excelentes opciones de platos para ambos, además de brindar una muy buena atención, son rápidos y siempre estan pendientes de los comensales.»</blockquote>
          <figcaption><span class="review__name">Jorge Parra</span><span class="review__when">Hace 7 meses</span></figcaption>
        </figure>
        <figure class="review">
          <div class="review__stars" aria-hidden="true">★★★★</div>
          <blockquote>«Excelente! Desde el servicio que fueron muy atentos, nos explicaron los platillos y sugerencias; los panes muy ricos, el croissant relleno de crema de pistache y el pan de crembulé; la comida deliciosa, los molletes, el burrito y el focaccia de carnes frías…»</blockquote>
          <figcaption><span class="review__name">A. Casanova</span><span class="review__when">Hace 6 meses</span></figcaption>
        </figure>
        <figure class="review">
          <div class="review__stars" aria-hidden="true">★★★★★</div>
          <blockquote>«Los platillos están hechos con ingredientes saludables y frescos. Los panes son preparados con masa madre. La concha y el que está relleno de guayaba, saben exquisito.»</blockquote>
          <figcaption><span class="review__name">Lucy Cervera</span><span class="review__when">Hace 4 meses</span></figcaption>
        </figure>
        <figure class="review">
          <div class="review__stars" aria-hidden="true">★★★★</div>
          <blockquote>«…todos reaccionaron de manera rápida eficiente y sin alborotar a sus comensales y aún así la atención no se desvió de nosotras, muy buen equipo.»</blockquote>
          <figcaption><span class="review__name">Berenice Ojeda</span><span class="review__when">Hace 2 meses</span></figcaption>
        </figure>
      </div>
      <div class="reviews__cta reveal">
        <a class="btn btn--ghost btn--ghost-light" href={mapsUrl} target="_blank" rel="noopener">Leer más reseñas en Google</a>
      </div>
    </div>
  </section>

  <!-- ===== POR QUÉ ROMELIA + ATRIBUTOS ===== -->
  <section class="sec sec--paper">
    <div class="wrap">
      <div class="carta__head reveal">
        <p class="eyebrow">
          <svg class="sprig" width="34" height="17" aria-hidden="true"><use href="#sprig" /></svg>
          Por qué Romelia
        </p>
        <h2 class="h2">Detalles que se notan</h2>
      </div>
      <div class="why reveal">
        <div class="why__item">
          <svg class="why__mark" viewBox="0 0 48 24" width="40" height="20" aria-hidden="true"><use href="#sprig" /></svg>
          <h3>Pan de masa madre propio</h3>
          <p>Horneamos aquí mismo. La variedad de panes cambia con el día; por eso conviene llegar temprano.</p>
        </div>
        <div class="why__item">
          <svg class="why__mark" viewBox="0 0 48 24" width="40" height="20" aria-hidden="true"><use href="#sprig" /></svg>
          <h3>Servicio atento y rápido</h3>
          <p>Nuestros comensales lo repiten: estamos pendientes, rellenamos el agua y explicamos el menú sin presionar.</p>
        </div>
        <div class="why__item">
          <svg class="why__mark" viewBox="0 0 48 24" width="40" height="20" aria-hidden="true"><use href="#sprig" /></svg>
          <h3>Cómodo para todos</h3>
          <p>Aceptamos reservaciones y tarjetas, hay estacionamiento y acceso para silla de ruedas.</p>
        </div>
      </div>
      <ul class="pills reveal" aria-label="Servicios disponibles">
        {atributos.map((a) => (<li class="pill">{a}</li>))}
      </ul>
    </div>
  </section>

  <!-- ===== UBICACIÓN + HORARIOS ===== -->
  <section class="sec sec--place">
    <div class="wrap">
      <div class="carta__head reveal">
        <p class="eyebrow">
          <svg class="sprig" width="34" height="17" aria-hidden="true"><use href="#sprig" /></svg>
          Dónde y cuándo
        </p>
        <h2 class="h2">Te esperamos en San Ramón Norte</h2>
      </div>
      <div class="place">
        <div class="place__info reveal">
          <div class="place__block">
            <h3>Dirección</h3>
            <p>{direccion}</p>
            <a class="link" href={mapsUrl} target="_blank" rel="noopener">Abrir en Google Maps →</a>
          </div>
          <div class="place__block">
            <h3>Horarios</h3>
            <table class="hours">
              <tbody>
                {horarios.map(([d, h]) => (
                  <tr><th scope="row">{d}</th><td>{h}</td></tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="place__block">
            <h3>Teléfono</h3>
            <p><a class="link" href={`tel:+52${telefono.replace(/\s/g,'')}`}>{telefono}</a></p>
          </div>
        </div>
        <div class="place__map reveal">
          <iframe
            title="Ubicación de Romelia en Google Maps"
            src={mapEmbed}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA FINAL ===== -->
  <section class="sec sec--cta on-dark">
    <div class="wrap cta reveal">
      <svg class="cta__sprig" viewBox="0 0 48 24" width="52" height="26" aria-hidden="true"><use href="#sprig" /></svg>
      <h2 class="cta__title">¿Se te antojó el desayuno?</h2>
      <p class="cta__text">Aparta tu mesa por WhatsApp y llega directo a lo bueno: pan recién horneado y buen café.</p>
      <div class="cta-row cta-row--center">
        <a class="btn btn--light" href={waReserva} target="_blank" rel="noopener">
          <svg viewBox="0 0 32 32" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M16 3C9.4 3 4 8.3 4 14.9c0 2.6.8 5 2.3 7L4 29l7.3-2.3c1.9 1 3.9 1.5 4.7 1.5 6.6 0 12-5.3 12-11.9S22.6 3 16 3zm0 21.8c-1.4 0-3.2-.5-4.7-1.4l-.3-.2-4.3 1.4 1.4-4.2-.2-.3c-1.2-1.7-1.9-3.7-1.9-5.7C6 9.4 10.5 5 16 5s10 4.4 10 9.9-4.5 9.9-10 9.9zm5.5-7.4c-.3-.2-1.8-.9-2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.4.2-.7.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.2-.2.2-.3.3-.5.1-.2 0-.4 0-.6-.1-.2-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4-.3.3-1.1 1.1-1.1 2.7s1.2 3.1 1.3 3.3c.2.2 2.3 3.5 5.6 4.9.8.3 1.4.5 1.9.7.8.2 1.5.2 2.1.1.6-.1 1.8-.7 2.1-1.5.3-.7.3-1.3.2-1.5-.1-.1-.3-.2-.6-.4z"/></svg>
          Reservar por WhatsApp
        </a>
        <a class="btn btn--ghost btn--ghost-light" href={`tel:+52${telefono.replace(/\s/g,'')}`}>Llamar {telefono}</a>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="wrap footer__inner">
      <p class="footer__brand">Romelia</p>
      <p class="footer__line">{direccion}</p>
      <p class="footer__line">Todos los días · 8:00 a 16:30 · <a class="link link--light" href={`tel:+52${telefono.replace(/\s/g,'')}`}>{telefono}</a></p>
      <svg class="footer__sprig" viewBox="0 0 48 24" width="46" height="23" aria-hidden="true"><use href="#sprig" /></svg>
    </div>
  </footer>

  <style is:global>
    :root {
      --sage-950: #2b3323;
      --sage-900: #333c29;
      --sage-800: #3e4a34;
      --sage-700: #4c5741;
      --sage-500: #6b7550;
      --marfil:   #f4eede;
      --marfil-2: #ece2cc;
      --blush:    #dca491;
      --blush-soft: #e7c1b2;
      --brass:    #b08a50;
      --brass-soft: #cba875;
      --ink:      #24211a;
      --muted:    rgba(36, 33, 26, .66);
      --line:     rgba(36, 33, 26, .14);
    }

    body {
      background: var(--marfil);
      color: var(--ink);
      font-family: 'Mulish', system-ui, sans-serif;
      font-weight: 400;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .wrap { width: min(100% - 2.2rem, 1080px); margin-inline: auto; }

    ::selection { background: var(--blush); color: var(--sage-950); }

    a { color: inherit; }
    :focus-visible { outline: 2px solid var(--brass); outline-offset: 3px; border-radius: 2px; }
    .on-dark :focus-visible { outline-color: var(--blush-soft); }

    /* ---- Type ---- */
    .h2 {
      font-family: 'Prata', Georgia, serif;
      font-weight: 400;
      font-size: clamp(1.7rem, 5.2vw, 2.6rem);
      line-height: 1.12;
      letter-spacing: .005em;
      color: var(--sage-900);
      margin: 0;
    }
    .h2--light { color: var(--marfil); }
    .lede { color: var(--muted); font-size: 1.05rem; max-width: 46ch; margin: .9rem 0 0; }

    .eyebrow {
      display: inline-flex; align-items: center; gap: .55rem;
      font-size: .74rem; font-weight: 700; letter-spacing: .22em; text-transform: uppercase;
      color: var(--brass); margin: 0 0 1rem;
    }
    .eyebrow--light { color: var(--blush-soft); }
    .sprig { color: var(--brass); flex: none; }
    .eyebrow--light .sprig { color: var(--blush-soft); }

    /* ---- Stars ---- */
    .stars {
      display: inline-block;
      font-size: 1em; letter-spacing: .12em;
      background: linear-gradient(90deg, var(--brass) var(--pct, 100%), rgba(36,33,26,.2) var(--pct, 100%));
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }
    .stars--dark { background: linear-gradient(90deg, var(--brass-soft) var(--pct, 100%), rgba(244,238,222,.32) var(--pct, 100%)); -webkit-background-clip: text; background-clip: text; }

    /* ---- Buttons ---- */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: .55rem;
      font-family: 'Mulish', sans-serif; font-weight: 700; font-size: 1rem;
      padding: .85rem 1.4rem; border-radius: 999px; text-decoration: none;
      border: 1.6px solid transparent; cursor: pointer;
      transition: transform .18s ease, background-color .18s ease, color .18s ease, box-shadow .18s ease;
    }
    .btn svg { flex: none; }
    .btn--wa { background: var(--sage-800); color: var(--marfil); }
    .btn--wa:hover { background: var(--sage-900); transform: translateY(-2px); }
    .btn--light { background: var(--marfil); color: var(--sage-900); box-shadow: 0 10px 26px rgba(21, 26, 16, .28); }
    .btn--light:hover { background: #fff; transform: translateY(-2px); }
    .btn--ghost { background: transparent; border-color: var(--sage-500); color: var(--sage-900); }
    .btn--ghost:hover { background: var(--sage-900); border-color: var(--sage-900); color: var(--marfil); transform: translateY(-2px); }
    .btn--ghost-light { border-color: rgba(244,238,222,.6); color: var(--marfil); }
    .btn--ghost-light:hover { background: var(--marfil); border-color: var(--marfil); color: var(--sage-900); }

    .cta-row { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: 1.6rem; }
    .cta-row--center { justify-content: center; }

    /* ---- HERO ---- */
    .hero {
      position: relative; isolation: isolate; overflow: hidden;
      min-height: calc(100svh - var(--demo-banner-h, 38px));
      display: flex; align-items: flex-end;
      padding: clamp(2rem, 6vw, 4rem) 0;
    }
    .hero__bg {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; object-position: 50% 42%; z-index: -2;
    }
    .hero__scrim {
      position: absolute; inset: 0; z-index: -1;
      background:
        linear-gradient(180deg, rgba(43,51,35,.28) 0%, rgba(43,51,35,.10) 34%, rgba(43,51,35,.72) 78%, rgba(43,51,35,.94) 100%),
        linear-gradient(90deg, rgba(43,51,35,.5) 0%, rgba(43,51,35,0) 60%);
    }
    .hero__inner { width: min(100% - 2.2rem, 1080px); margin-inline: auto; color: var(--marfil); }
    .hero__title {
      font-family: 'Prata', Georgia, serif; font-weight: 400;
      font-size: clamp(3.4rem, 17vw, 7rem); line-height: .92;
      margin: .2rem 0 .1rem; letter-spacing: .01em;
      text-shadow: 0 2px 30px rgba(20,24,14,.35);
    }
    .hero__tag {
      font-size: clamp(1.05rem, 3.4vw, 1.4rem); max-width: 22ch;
      color: var(--marfil); margin: 0 0 1.1rem; line-height: 1.35;
    }
    .rating { display: flex; align-items: center; gap: .55rem; flex-wrap: wrap; font-size: .98rem; margin: 0; }
    .rating--hero { color: var(--marfil); }
    .rating strong { font-weight: 800; }
    .rating--hero .stars { font-size: 1.15rem; }
    .hero__meta {
      list-style: none; display: flex; flex-wrap: wrap; gap: .5rem .9rem;
      padding: 0; margin: 1.5rem 0 0; font-size: .82rem; letter-spacing: .04em;
      color: rgba(244,238,222,.9);
    }
    .hero__meta li { display: inline-flex; align-items: center; }
    .hero__meta li + li::before { content: '·'; margin-right: .9rem; opacity: .6; }

    /* ---- Section rhythm ---- */
    .sec { padding: clamp(3.4rem, 8vw, 6rem) 0; }
    .sec--paper { background: var(--marfil); }
    .sec--carta { background: var(--marfil-2); }
    .sec--place { background: var(--marfil-2); }
    .on-dark { color: var(--marfil); }

    .carta__head { margin-bottom: clamp(1.8rem, 4vw, 2.6rem); max-width: 60ch; }

    /* ---- Intro ---- */
    .intro__cols { display: grid; gap: 1.8rem; margin-top: 1.4rem; }
    .intro__lead p { margin: 0 0 1rem; font-size: 1.06rem; }
    .intro__lead p:last-child { margin-bottom: 0; }
    .intro__quote {
      margin: 0; padding: 1.4rem 1.5rem; border-left: 3px solid var(--brass);
      background: var(--marfil-2); border-radius: 0 12px 12px 0;
    }
    .intro__quote blockquote { margin: 0; font-family: 'Prata', serif; font-size: 1.2rem; line-height: 1.4; color: var(--sage-900); }
    .intro__quote figcaption { margin-top: .7rem; font-size: .85rem; color: var(--muted); letter-spacing: .02em; }

    /* ---- Emblema signature ---- */
    .sec--emblem { background: var(--sage-900); text-align: center; overflow: hidden; }
    .emblem__crest { display: flex; align-items: center; justify-content: center; gap: clamp(.4rem, 2vw, 1.6rem); margin: 1.2rem 0 1.4rem; }
    .laurel { color: var(--brass-soft); flex: none; }
    .laurel--r { transform: scaleX(-1); }
    .emblem__center { display: flex; flex-direction: column; align-items: center; min-width: 0; }
    .emblem__figure {
      font-family: 'Prata', Georgia, serif; font-weight: 400;
      font-size: clamp(3.6rem, 18vw, 7.5rem); line-height: .9;
      color: var(--marfil); letter-spacing: .01em;
    }
    .emblem__label { font-size: clamp(.72rem, 2.6vw, .9rem); letter-spacing: .16em; text-transform: uppercase; color: var(--blush-soft); margin-top: .4rem; max-width: 18ch; }
    .emblem__foot { margin: 0; font-size: 1rem; color: rgba(244,238,222,.9); display: inline-flex; flex-wrap: wrap; justify-content: center; gap: .5rem; align-items: center; }
    .emblem__foot .stars { font-size: 1.1rem; }
    .emblem__foot strong { color: var(--marfil); font-weight: 800; }

    /* ---- Carta grid ---- */
    .carta__grid { display: grid; gap: 1rem; grid-template-columns: 1fr; }
    .card { border-radius: 16px; overflow: hidden; }
    .card--menu {
      background: var(--marfil); border: 1px solid var(--line);
      padding: 1.5rem 1.5rem 1.6rem; box-shadow: 0 1px 0 rgba(255,255,255,.6) inset;
    }
    .card__title { font-family: 'Prata', serif; font-weight: 400; font-size: 1.35rem; color: var(--sage-800); margin: 0 0 1rem; padding-bottom: .7rem; border-bottom: 1px solid var(--line); }
    .menu { list-style: none; padding: 0; margin: 0; }
    .menu li { position: relative; padding: .4rem 0 .4rem 1.35rem; font-size: 1rem; border-bottom: 1px dashed var(--line); }
    .menu li:last-child { border-bottom: 0; }
    .menu li::before { content: ''; position: absolute; left: 0; top: .95em; width: .5rem; height: .5rem; border-radius: 50%; background: var(--blush); }
    .card__note { margin: 1rem 0 0; font-size: .82rem; color: var(--muted); font-style: italic; }
    .card--photo { position: relative; min-height: 220px; }
    .card--photo img { width: 100%; height: 100%; object-fit: cover; }
    .card--photo figcaption {
      position: absolute; left: 0; right: 0; bottom: 0; padding: 1.4rem 1.1rem .9rem;
      color: var(--marfil); font-weight: 600; font-size: .95rem;
      background: linear-gradient(180deg, rgba(43,51,35,0), rgba(43,51,35,.85));
    }

    /* ---- Gallery ---- */
    .gallery { display: grid; grid-template-columns: repeat(2, 1fr); gap: .7rem; }
    .gallery__item { margin: 0; border-radius: 14px; overflow: hidden; background: var(--marfil-2); }
    .gallery__item img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4 / 3; transition: transform .5s ease; }
    .gallery__item--tall { grid-row: span 2; }
    .gallery__item--tall img { aspect-ratio: 3 / 4; height: 100%; }
    .gallery__item--wide img { aspect-ratio: 4 / 3; }
    .gallery__item:hover img { transform: scale(1.04); }

    /* ---- Reviews ---- */
    .sec--reviews { background: var(--sage-800); }
    .reviews { display: grid; gap: 1rem; grid-template-columns: 1fr; }
    .review {
      margin: 0; padding: 1.5rem 1.4rem; border-radius: 16px;
      background: rgba(244,238,222,.06); border: 1px solid rgba(244,238,222,.14);
    }
    .review__stars { color: var(--brass-soft); letter-spacing: .12em; font-size: 1rem; margin-bottom: .7rem; }
    .review blockquote { margin: 0; font-size: 1.02rem; line-height: 1.55; color: var(--marfil); }
    .review figcaption { margin-top: 1rem; display: flex; flex-direction: column; }
    .review__name { font-weight: 700; color: var(--blush-soft); }
    .review__when { font-size: .82rem; color: rgba(244,238,222,.62); }
    .reviews__cta { margin-top: 1.8rem; text-align: center; }

    /* ---- Why + pills ---- */
    .why { display: grid; gap: 1.1rem; grid-template-columns: 1fr; }
    .why__item { padding: 1.4rem 1.4rem 1.5rem; background: var(--marfil-2); border-radius: 16px; border: 1px solid var(--line); }
    .why__mark { color: var(--brass); margin-bottom: .7rem; }
    .why__item h3 { font-family: 'Prata', serif; font-weight: 400; font-size: 1.2rem; color: var(--sage-800); margin: 0 0 .5rem; }
    .why__item p { margin: 0; font-size: .98rem; color: var(--ink); }
    .pills { list-style: none; display: flex; flex-wrap: wrap; gap: .55rem; padding: 0; margin: 1.8rem 0 0; }
    .pill {
      display: inline-flex; align-items: center; gap: .5rem;
      padding: .5rem .95rem; border-radius: 999px; font-size: .86rem; font-weight: 600;
      background: var(--marfil); border: 1px solid var(--line); color: var(--sage-900);
    }
    .pill::before { content: ''; width: .5rem; height: .5rem; border-radius: 50%; background: var(--brass); flex: none; }

    /* ---- Place ---- */
    .place { display: grid; gap: 1.6rem; }
    .place__block { padding-bottom: 1.3rem; margin-bottom: 1.3rem; border-bottom: 1px solid var(--line); }
    .place__block:last-child { border-bottom: 0; margin-bottom: 0; padding-bottom: 0; }
    .place__block h3 { font-size: .78rem; letter-spacing: .18em; text-transform: uppercase; color: var(--brass); margin: 0 0 .6rem; }
    .place__block p { margin: 0; font-size: 1.05rem; }
    .link { color: var(--sage-800); font-weight: 700; text-decoration: none; border-bottom: 1.5px solid var(--brass); padding-bottom: 1px; }
    .link:hover { color: var(--sage-900); border-color: var(--sage-900); }
    .link--light { color: var(--blush-soft); border-color: var(--brass-soft); }
    .hours { width: 100%; border-collapse: collapse; max-width: 340px; }
    .hours th { text-align: left; font-weight: 600; padding: .38rem 0; color: var(--ink); font-size: .98rem; }
    .hours td { text-align: right; padding: .38rem 0; color: var(--muted); font-variant-numeric: tabular-nums; }
    .hours tr + tr th, .hours tr + tr td { border-top: 1px dashed var(--line); }
    .place__map { border-radius: 16px; overflow: hidden; border: 1px solid var(--line); box-shadow: 0 14px 40px rgba(43,51,35,.12); }
    .place__map iframe { display: block; width: 100%; height: 340px; border: 0; }

    /* ---- CTA final ---- */
    .sec--cta { background: var(--sage-900); text-align: center; }
    .cta { max-width: 44ch; margin-inline: auto; }
    .cta__sprig { color: var(--brass-soft); margin-bottom: .6rem; }
    .cta__title { font-family: 'Prata', serif; font-weight: 400; font-size: clamp(1.8rem, 6vw, 2.7rem); line-height: 1.1; margin: 0 0 .8rem; color: var(--marfil); }
    .cta__text { margin: 0; color: rgba(244,238,222,.86); font-size: 1.05rem; }

    /* ---- Footer ---- */
    .footer { background: var(--sage-950); color: var(--marfil); padding: 3rem 0 6rem; text-align: center; }
    .footer__inner { display: flex; flex-direction: column; align-items: center; gap: .5rem; }
    .footer__brand { font-family: 'Prata', serif; font-size: 1.7rem; margin: 0 0 .3rem; }
    .footer__line { margin: 0; font-size: .9rem; color: rgba(244,238,222,.74); }
    .footer__sprig { color: var(--brass-soft); margin-top: 1rem; }

    /* ---- Reveal (progressive enhancement) ---- */
    html.js .reveal { opacity: 0; transform: translateY(18px); transition: opacity .7s ease, transform .7s ease; }
    html.js .reveal.in { opacity: 1; transform: none; }

    /* ---- Responsive ---- */
    @media (min-width: 620px) {
      .intro__cols { grid-template-columns: 1.6fr 1fr; align-items: start; }
      .carta__grid { grid-template-columns: repeat(2, 1fr); }
      .why { grid-template-columns: repeat(3, 1fr); }
      .reviews { grid-template-columns: repeat(2, 1fr); }
      .gallery { grid-template-columns: repeat(3, 1fr); grid-auto-rows: 1fr; }
      .gallery__item--wide { grid-column: span 2; }
    }
    @media (min-width: 900px) {
      .carta__grid { grid-template-columns: repeat(3, 1fr); }
      .place { grid-template-columns: 1fr 1.15fr; align-items: start; }
      .place__map iframe { height: 420px; }
      .hero { align-items: center; }
      .hero__inner { max-width: 1080px; }
      .hero__tag { max-width: 26ch; }
    }
  </style>

  <script is:inline>
    (function () {
      var root = document.documentElement;
      root.classList.add('js');
      var els = Array.prototype.slice.call(document.querySelectorAll('.reveal'));
      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach(function (el) { el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
        });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
      els.forEach(function (el) { io.observe(el); });
    })();
  </script>
</BaseLayout>
