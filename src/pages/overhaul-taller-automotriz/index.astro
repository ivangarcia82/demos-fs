---
import BaseLayout from '../../layouts/BaseLayout.astro';

const wa = 'https://wa.me/529992852809';
const tel = '999 285 2809';
const maps = 'https://maps.google.com/?cid=12419342141841176166&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAIYBCAA';
const mapEmbed = 'https://www.google.com/maps?q=Overhaul%20Taller%20Automotriz%2C%20C.%2010%20351%2C%20D%C3%ADaz%20Ordaz%2C%2097130%20M%C3%A9rida%2C%20Yuc.%2C%20M%C3%A9xico&output=embed';

// Servicios reales, tomados de la rotulación del propio taller (fotos de la
// fachada) y confirmados por las reseñas. Sin inventar.
const servicios = [
  ['Mecánica automotriz general', 'Diagnóstico a detalle y reparación explicada antes de tocar el coche.'],
  ['Clutch, frenos y suspensión', 'Que frene firme, agarre parejo y responda como debe.'],
  ['Transmisión', 'Automática y estándar, revisadas por gente que conoce el sistema.'],
  ['Afinación e inyección', 'Afinaciones con sistema de inyección de combustible a punto.'],
  ['Dirección hidráulica', 'Revisada y calibrada para que el volante vuelva a sentirse firme.'],
  ['Hojalatería y pintura', 'De un golpe menor a reconstruir carrocería, con acabado de taller.'],
  ['Tapicería', 'Interiores y asientos devueltos a su estado.'],
  ['Sistema eléctrico', 'Fallas de arranque, luces y carga rastreadas hasta el origen.'],
  ['Rescate 24 hrs', 'Grúa y auxilio vial cuando el coche se queda a medio camino.'],
];
---
<BaseLayout
  title="Overhaul Taller Automotriz · Mecánica en Mérida"
  description="⭐ 4.8 · 226 reseñas en Google. Mecánica, hojalatería y pintura en Díaz Ordaz, Mérida. Diagnóstico explicado y entrega en el tiempo acordado. Escríbenos por WhatsApp."
  slug="overhaul-taller-automotriz"
  ogImage="/overhaul-taller-automotriz/img/foto_2.jpg"
  fonts="https://fonts.googleapis.com/css2?family=Saira+Condensed:wght@500;600;700;800&family=Barlow:wght@400;500;600&display=swap"
  favicon="🔧"
  themeColor="#15171a"
  whatsapp={wa}
  telefono={tel}
  mapsUrl={maps}
>
  <main class="oh">

    <!-- ============================ HERO ============================ -->
    <header class="hero">
      <div class="hero-grid wrap">
        <div class="hero-lead">
          <p class="eyebrow reveal">Mecánica · Hojalatería · Pintura — Díaz Ordaz, Mérida</p>
          <h1 class="wordmark reveal">
            <span class="wm-main">Overhaul</span>
            <span class="wm-sub">Taller Automotriz</span>
          </h1>
          <p class="lede reveal">
            Un <em>overhaul</em> es reconstruir un motor a fondo, pieza por pieza.
            Así revisamos cada vehículo: <strong>a detalle, explicado y entregado
            en el tiempo acordado.</strong>
          </p>
          <div class="cta-row reveal">
            <a class="btn btn-solid" href={wa} target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2zm0 18.2c-1.5 0-3-.4-4.3-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.6.8-.8 1-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.4-3c-.3-.4 0-.5.2-.7l.4-.5c.1-.2.2-.3.3-.5v-.5c0-.1-.5-1.3-.7-1.8-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.3.3-.9.9-.9 2.2s.9 2.5 1 2.7c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2l-.4-.3z"/></svg>
              Escríbenos por WhatsApp
            </a>
            <a class="btn btn-line" href={maps} target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12 2a7 7 0 0 0-7 7c0 5.2 7 13 7 13s7-7.8 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
              Cómo llegar
            </a>
          </div>
        </div>

        <!-- Elemento firma: instrumento / medidor de taller -->
        <aside class="instrument reveal" aria-label="Calificación 4.8 de 5 en Google">
          <div class="instr-bezel">
            <svg class="gauge" viewBox="0 0 300 190" role="img" aria-label="Medidor apuntando a 4.8 de 5">
              <path d="M 24 160 A 126 126 0 0 1 276 160" class="g-track" pathLength="100" />
              <path d="M 24 160 A 126 126 0 0 1 276 160" class="g-value" pathLength="100" />
              <g class="g-ticks" stroke-linecap="round">
                <line x1="24" y1="160" x2="42" y2="160" transform="rotate(0 150 160)"/>
                <line x1="24" y1="160" x2="40" y2="160" transform="rotate(36 150 160)"/>
                <line x1="24" y1="160" x2="40" y2="160" transform="rotate(72 150 160)"/>
                <line x1="24" y1="160" x2="40" y2="160" transform="rotate(108 150 160)"/>
                <line x1="24" y1="160" x2="40" y2="160" transform="rotate(144 150 160)"/>
                <line x1="24" y1="160" x2="42" y2="160" transform="rotate(180 150 160)"/>
              </g>
              <g class="g-needle">
                <line x1="150" y1="160" x2="150" y2="46" />
                <circle cx="150" cy="160" r="11" class="g-hub"/>
                <circle cx="150" cy="160" r="4" class="g-hub-in"/>
              </g>
            </svg>
            <div class="instr-read">
              <span class="instr-val">4.8<span class="instr-max">/5</span></span>
              <span class="instr-stars" aria-hidden="true">★★★★★</span>
              <span class="instr-label">226 reseñas verificadas en Google</span>
            </div>
          </div>
        </aside>
      </div>
      <div class="hazard" aria-hidden="true"></div>
    </header>

    <!-- ==================== DEFINICIÓN / TESIS ==================== -->
    <section class="section s-graphite def">
      <div class="wrap">
        <p class="def-term">o·ver·haul <span class="def-pos">sustantivo</span></p>
        <p class="def-body">
          Reconstrucción completa de un mecanismo, revisado y ajustado pieza por
          pieza hasta dejarlo como nuevo. <span class="def-accent">No damos vueltas:
          diagnosticamos, te lo explicamos claro y lo reparamos bien la primera vez.</span>
        </p>
        <div class="tickrule" aria-hidden="true"></div>
      </div>
    </section>

    <!-- ==================== QUIÉNES SOMOS ==================== -->
    <section class="section s-light" id="taller">
      <div class="wrap">
        <p class="eyebrow eyebrow-dark reveal">El taller</p>
        <h2 class="h-sec h-sec--dark reveal">Ingeniería, no improvisación</h2>
        <div class="prose reveal">
          <p>
            Somos <strong>Overhaul Taller Automotriz</strong>, sobre la calle 10 de
            la colonia Díaz Ordaz, en Mérida. Hacemos mecánica automotriz en general,
            hojalatería, pintura, tapicería y sistema eléctrico — el servicio completo,
            bajo un mismo techo.
          </p>
          <p>
            El taller trabaja bajo la dirección del <strong>Ing. Gerardo Villasís</strong>,
            y eso se nota en cómo recibimos cada coche: lo revisamos a detalle, te
            explicamos con claridad qué tiene y lo entregamos en el tiempo acordado,
            a un precio justo.
          </p>
          <p>
            Muchos clientes llegan después de pasar por otros talleres que no
            resolvieron. Aquí lo resolvemos — y te devolvemos el auto funcionando
            como debe, lavado y listo para rodar.
          </p>
        </div>
      </div>
    </section>

    <!-- ==================== SERVICIOS ==================== -->
    <section class="section s-dark" id="servicios">
      <div class="wrap">
        <p class="eyebrow reveal">Qué hacemos</p>
        <h2 class="h-sec reveal">Servicio completo, un mismo taller</h2>
        <ul class="specs reveal">
          {servicios.map(([t, d]) => (
            <li class="spec">
              <span class="spec-mark" aria-hidden="true">+</span>
              <div>
                <h3>{t}</h3>
                <p>{d}</p>
              </div>
            </li>
          ))}
        </ul>
        <p class="card-note reveal">
          <span class="chip-card">Visa · MasterCard</span> Aceptamos pago con tarjeta.
        </p>
      </div>
    </section>

    <!-- ==================== DIFERENCIADORES ==================== -->
    <section class="section s-light" id="porque">
      <div class="wrap">
        <p class="eyebrow eyebrow-dark reveal">Por qué te conviene</p>
        <h2 class="h-sec h-sec--dark reveal">Lo que repiten nuestros clientes</h2>
        <div class="reasons reveal">
          <article class="reason">
            <span class="reason-idx">Claridad</span>
            <h3>Diagnóstico explicado</h3>
            <p>Te decimos con claridad qué tiene tu coche <em>antes</em> de tocarlo. Sin sorpresas al final.</p>
          </article>
          <article class="reason">
            <span class="reason-idx">Tiempo</span>
            <h3>Entrega a tiempo</h3>
            <p>La reparación queda en el tiempo acordado. Sabes cuándo recoges tu auto.</p>
          </article>
          <article class="reason">
            <span class="reason-idx">Experiencia</span>
            <h3>Resolvemos lo difícil</h3>
            <p>Lo que otros talleres no pudieron, aquí lo sacamos adelante y bien.</p>
          </article>
          <article class="reason">
            <span class="reason-idx">Precio</span>
            <h3>Precio justo</h3>
            <p>Trabajo de calidad a un costo honesto. Y aceptamos tarjeta.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ==================== PRUEBA SOCIAL ==================== -->
    <section class="section s-graphite" id="resenas">
      <div class="wrap">
        <div class="score reveal">
          <div class="score-big">
            <span class="score-num">4.8</span>
            <span class="score-of">/ 5</span>
          </div>
          <div class="score-meta">
            <span class="score-stars" aria-hidden="true">★★★★★</span>
            <span>226 reseñas en Google</span>
          </div>
        </div>
        <div class="reviews reveal">
          <figure class="rev">
            <p class="rev-stars" aria-label="5 de 5 estrellas">★★★★★</p>
            <blockquote>Excelente atención y servicio, entrega en tiempo, tranquilidad de saber que tu vehículo está buenas manos !!</blockquote>
            <figcaption><strong>Lili Peraza</strong><span>Hace 1 mes · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <p class="rev-stars" aria-label="5 de 5 estrellas">★★★★★</p>
            <blockquote>…Revisaron mi vehículo a detalle, me explicaron claramente el problema y realizaron la reparación en el tiempo acordado. El auto quedó funcionando perfectamente y a un precio justo.</blockquote>
            <figcaption><strong>Irene Peraza Briceño</strong><span>Hace 1 mes · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <p class="rev-stars" aria-label="5 de 5 estrellas">★★★★★</p>
            <blockquote>…pudieron resolver otros problemas que traía de otros malos talleres y ellos lo resolvieron muy bien.</blockquote>
            <figcaption><strong>Jose Kau</strong><span>Hace un año · Google</span></figcaption>
          </figure>
          <figure class="rev">
            <p class="rev-stars" aria-label="5 de 5 estrellas">★★★★★</p>
            <blockquote>Buen taller, buen servicio, buenos precios, excelente atención del dueño. Trabajos de muy buena calidad…</blockquote>
            <figcaption><strong>Brayan Dzul</strong><span>Hace 6 meses · Google</span></figcaption>
          </figure>
        </div>
        <div class="center reveal">
          <a class="btn btn-line" href={maps} target="_blank" rel="noopener">Leer más reseñas en Google</a>
        </div>
      </div>
    </section>

    <!-- ==================== GALERÍA ==================== -->
    <section class="section s-dark" id="galeria">
      <div class="wrap">
        <p class="eyebrow reveal">En el taller</p>
        <h2 class="h-sec reveal">Trabajo real</h2>
        <div class="gallery reveal">
          <figure class="g-item g-wide">
            <img src="/overhaul-taller-automotriz/img/foto_2.jpg" alt="Fachada del taller Overhaul sobre la calle 10 en Díaz Ordaz, Mérida" loading="lazy" width="1600" height="900" />
            <figcaption>Fachada · Calle 10, Díaz Ordaz</figcaption>
          </figure>
          <figure class="g-item">
            <img src="/overhaul-taller-automotriz/img/foto_5.jpg" alt="Auto de cliente listo y detallado dentro del taller Overhaul" loading="lazy" width="1600" height="1200" />
            <figcaption>Listo para entrega</figcaption>
          </figure>
          <figure class="g-item">
            <img src="/overhaul-taller-automotriz/img/foto_4.jpg" alt="Sedán negro a la salida del taller Overhaul tras su servicio" loading="lazy" width="1600" height="1200" />
            <figcaption>A la salida</figcaption>
          </figure>
          <figure class="g-item">
            <img src="/overhaul-taller-automotriz/img/foto_3.jpg" alt="Servicio de grúa y rescate frente al taller Overhaul" loading="lazy" width="1600" height="1200" />
            <figcaption>Rescate y grúa</figcaption>
          </figure>
          <figure class="g-item">
            <img src="/overhaul-taller-automotriz/img/foto_1.jpg" alt="Colección de autos a escala en la sala de espera del taller Overhaul" loading="lazy" width="1600" height="900" />
            <figcaption>Nuestra sala de espera</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ==================== UBICACIÓN + HORARIOS ==================== -->
    <section class="section s-light" id="ubicacion">
      <div class="wrap">
        <p class="eyebrow eyebrow-dark reveal">Dónde estamos</p>
        <h2 class="h-sec h-sec--dark reveal">Calle 10, Díaz Ordaz</h2>
        <div class="locate reveal">
          <div class="locate-info">
            <p class="addr">C. 10 351, Díaz Ordaz<br />97130 Mérida, Yucatán</p>
            <a class="btn btn-solid btn-sm" href={maps} target="_blank" rel="noopener">Abrir en Google Maps</a>
            <h3 class="hours-title">Horario</h3>
            <table class="hours">
              <tbody>
                <tr data-dia="1"><th scope="row">Lunes</th><td>8:00 – 19:00</td></tr>
                <tr data-dia="2"><th scope="row">Martes</th><td>8:00 – 19:00</td></tr>
                <tr data-dia="3"><th scope="row">Miércoles</th><td>8:00 – 19:00</td></tr>
                <tr data-dia="4"><th scope="row">Jueves</th><td>8:00 – 19:00</td></tr>
                <tr data-dia="5"><th scope="row">Viernes</th><td>8:00 – 19:00</td></tr>
                <tr data-dia="6"><th scope="row">Sábado</th><td>8:00 – 16:00</td></tr>
                <tr data-dia="0"><th scope="row">Domingo</th><td class="closed">Cerrado</td></tr>
              </tbody>
            </table>
          </div>
          <div class="map">
            <iframe
              src={mapEmbed}
              title="Mapa: Overhaul Taller Automotriz en Díaz Ordaz, Mérida"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== CTA FINAL ==================== -->
    <section class="section closer">
      <div class="hazard hazard-top" aria-hidden="true"></div>
      <div class="wrap closer-in">
        <h2 class="closer-title">¿Tu coche ya te está avisando?</h2>
        <p class="closer-sub">Tráelo antes de que te deje a pie. Diagnóstico claro, precio justo y entrega en el tiempo acordado.</p>
        <div class="cta-row cta-center">
          <a class="btn btn-dark" href={wa} target="_blank" rel="noopener">WhatsApp directo</a>
          <a class="btn btn-dark-line" href="tel:+529992852809">Llamar · 999 285 2809</a>
        </div>
      </div>
    </section>

    <!-- ==================== FOOTER ==================== -->
    <footer class="foot">
      <div class="wrap">
        <p class="foot-name">Overhaul <span>Taller Automotriz</span></p>
        <p class="foot-line">Mecánica · Hojalatería · Pintura · Rescate 24 hrs</p>
        <p class="foot-line">C. 10 351, Díaz Ordaz · 97130 Mérida, Yucatán</p>
        <p class="foot-line"><a href="tel:+529992852809">999 285 2809</a> · <a href={wa} target="_blank" rel="noopener">WhatsApp</a></p>
        <p class="foot-mini">Lun–Vie 8:00–19:00 · Sáb 8:00–16:00 · Dom cerrado</p>
      </div>
    </footer>
  </main>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AutoRepair",
    "name": "Overhaul Taller Automotriz",
    "telephone": "+529992852809",
    "url": "https://demos.ivang.mx/overhaul-taller-automotriz",
    "image": "https://demos.ivang.mx/overhaul-taller-automotriz/img/foto_2.jpg",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "C. 10 351, Díaz Ordaz",
      "addressLocality": "Mérida",
      "addressRegion": "Yucatán",
      "postalCode": "97130",
      "addressCountry": "MX"
    },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "reviewCount": "226" },
    "openingHours": ["Mo-Fr 08:00-19:00", "Sa 08:00-16:00"]
  })} />

  <style is:global>
    :root {
      --graphite: #15171a;
      --graphite-2: #1c1f23;
      --steel-900: #23272c;
      --steel-800: #2b3036;
      --steel-700: #363c43;
      --steel-600: #4a515a;
      --steel-400: #8d949c;
      --steel-300: #b9bfc5;
      --steel-200: #d3d7db;
      --concrete: #eae7e1;
      --concrete-2: #ded9d1;
      --ink: #191c1f;
      --ink-soft: #454b51;
      --safety: #f26a1e;
      --safety-2: #ff7e33;
      --safety-deep: #c9531a;
      --line-d: rgba(184, 191, 197, 0.14);
      --line-l: rgba(25, 28, 31, 0.14);
      --display: "Saira Condensed", "Arial Narrow", sans-serif;
      --body: "Barlow", system-ui, sans-serif;
    }

    body {
      background: var(--graphite);
      color: var(--steel-300);
      font-family: var(--body);
      font-size: 17px;
      line-height: 1.62;
      overflow-x: clip;
    }
    .oh ::selection { background: var(--safety); color: #fff; }
    .oh a { color: inherit; }
    .oh a:focus-visible,
    .oh .btn:focus-visible,
    .oh iframe:focus-visible {
      outline: 3px solid var(--safety-2);
      outline-offset: 3px;
    }
    .wrap { max-width: 1080px; margin: 0 auto; padding: 0 20px; }

    /* ---------- tipografía compartida ---------- */
    .eyebrow {
      font-family: var(--display);
      font-weight: 600;
      font-size: 13px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--safety-2);
      margin: 0 0 14px;
    }
    .eyebrow-dark { color: var(--safety-deep); }
    .h-sec {
      font-family: var(--display);
      font-weight: 800;
      font-size: clamp(34px, 8.4vw, 62px);
      line-height: 0.94;
      letter-spacing: 0.005em;
      text-transform: uppercase;
      margin: 0 0 30px;
      color: var(--steel-200);
      max-width: 16ch;
    }
    .h-sec--dark { color: var(--ink); }

    /* ---------- botones ---------- */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-family: var(--display);
      font-weight: 700;
      font-size: 18px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 15px 26px;
      border-radius: 3px;
      transition: transform .14s ease, background-color .16s ease, border-color .16s ease, color .16s ease;
    }
    .btn:active { transform: translateY(1px); }
    .btn-solid { background: var(--safety); color: #fff; box-shadow: inset 0 0 0 1px rgba(255,255,255,.06); }
    .btn-solid:hover { background: var(--safety-2); }
    .btn-line { border: 2px solid var(--steel-600); color: var(--steel-200); }
    .btn-line:hover { border-color: var(--safety-2); color: var(--safety-2); }
    .btn-sm { font-size: 15px; padding: 12px 20px; }
    .btn-dark { background: var(--graphite); color: var(--steel-200); }
    .btn-dark:hover { background: #0c0e10; }
    .btn-dark-line { border: 2px solid rgba(255,255,255,.5); color: #fff; }
    .btn-dark-line:hover { border-color: #fff; }
    .cta-row { display: flex; flex-wrap: wrap; gap: 12px; }
    .cta-center { justify-content: center; }

    /* ---------- secciones base ---------- */
    .section { padding: 74px 0; position: relative; }
    .s-graphite { background: var(--graphite); }
    .s-dark { background: var(--graphite-2); border-top: 1px solid var(--line-d); border-bottom: 1px solid var(--line-d); }
    .s-light { background: var(--concrete); color: var(--ink); }

    /* ============================ HERO ============================ */
    .hero {
      position: relative;
      min-height: calc(100svh - var(--demo-banner-h, 38px));
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      padding: 40px 0 0;
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(21,23,26,.62) 0%, rgba(21,23,26,.80) 42%, rgba(21,23,26,.97) 100%),
        radial-gradient(120% 80% at 78% 8%, rgba(242,106,30,.20), transparent 55%),
        url('/overhaul-taller-automotriz/img/foto_5.jpg') center 30% / cover no-repeat,
        var(--graphite);
    }
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 34px;
      align-items: center;
      padding-top: 24px;
      padding-bottom: 40px;
    }
    .hero-lead { position: relative; z-index: 2; }
    .wordmark { margin: 0 0 22px; display: flex; flex-direction: column; }
    .wm-main {
      font-family: var(--display);
      font-weight: 800;
      font-size: clamp(58px, 17vw, 132px);
      line-height: 0.82;
      letter-spacing: 0.006em;
      text-transform: uppercase;
      color: #fff;
      text-shadow: 0 2px 30px rgba(0,0,0,.4);
    }
    .wm-sub {
      font-family: var(--display);
      font-weight: 600;
      font-size: clamp(19px, 5.4vw, 34px);
      letter-spacing: 0.34em;
      text-transform: uppercase;
      color: var(--safety-2);
      margin-top: 8px;
      padding-left: 3px;
    }
    .lede {
      font-size: clamp(17px, 4.2vw, 21px);
      color: var(--steel-200);
      max-width: 40ch;
      margin: 0 0 26px;
      line-height: 1.5;
    }
    .lede em { font-style: italic; color: #fff; }
    .lede strong { color: #fff; font-weight: 600; }
    .hero .cta-row { position: relative; z-index: 2; }

    /* ---------- instrumento (firma) ---------- */
    .instrument { position: relative; z-index: 2; justify-self: start; width: min(360px, 100%); }
    .instr-bezel {
      background:
        linear-gradient(180deg, rgba(255,255,255,.05), rgba(0,0,0,.32)),
        linear-gradient(145deg, var(--steel-800), var(--steel-900));
      border: 1px solid var(--steel-700);
      border-radius: 14px;
      padding: 22px 22px 20px;
      box-shadow: 0 24px 60px -24px rgba(0,0,0,.8), inset 0 1px 0 rgba(255,255,255,.06);
    }
    .gauge { width: 100%; height: auto; display: block; }
    .g-track { fill: none; stroke: var(--steel-700); stroke-width: 14; stroke-linecap: round; }
    .g-value {
      fill: none; stroke: var(--safety); stroke-width: 14; stroke-linecap: round;
      stroke-dasharray: 100; stroke-dashoffset: 4;
      filter: drop-shadow(0 0 6px rgba(242,106,30,.45));
    }
    html.js .g-value { stroke-dashoffset: 100; animation: g-fill 1.5s .25s cubic-bezier(.16,1,.3,1) forwards; }
    @keyframes g-fill { to { stroke-dashoffset: 4; } }
    .g-ticks line { stroke: var(--steel-600); stroke-width: 3; }
    .g-needle line { stroke: var(--steel-200); stroke-width: 4; stroke-linecap: round; }
    .g-hub { fill: var(--steel-800); stroke: var(--safety); stroke-width: 3; }
    .g-hub-in { fill: var(--safety); }
    .g-needle { transform: rotate(82.8deg); transform-origin: 150px 160px; }
    html.js .g-needle { animation: g-swing 1.5s .25s cubic-bezier(.16,1,.3,1) both; }
    @keyframes g-swing { from { transform: rotate(-86deg); } to { transform: rotate(82.8deg); } }
    .instr-read { text-align: center; margin-top: 6px; }
    .instr-val {
      font-family: var(--display); font-weight: 800; font-size: 56px; line-height: 1;
      color: #fff; display: inline-block;
    }
    .instr-max { font-size: 24px; color: var(--steel-400); font-weight: 600; }
    .instr-stars { display: block; color: var(--safety-2); letter-spacing: .28em; font-size: 16px; margin: 4px 0 6px; }
    .instr-label { display: block; font-size: 13px; color: var(--steel-400); letter-spacing: .02em; }

    /* ---------- hazard stripe ---------- */
    .hazard {
      height: 12px;
      background-image: repeating-linear-gradient(-45deg, var(--safety) 0 16px, var(--graphite) 16px 32px);
      opacity: .92;
    }
    .hazard-top { position: absolute; top: 0; left: 0; right: 0; }

    /* ---------- caliper / tick rule ---------- */
    .tickrule {
      height: 20px;
      margin-top: 34px;
      background-image:
        repeating-linear-gradient(90deg, var(--safety) 0 2px, transparent 2px 64px),
        repeating-linear-gradient(90deg, var(--steel-600) 0 1px, transparent 1px 12px);
      background-size: 64px 18px, 12px 10px;
      background-position: left bottom, left bottom;
      background-repeat: repeat-x, repeat-x;
      opacity: .7;
    }

    /* ---------- definición / tesis ---------- */
    .def { padding: 60px 0 56px; }
    .def-term {
      font-family: var(--display); font-weight: 700; font-size: clamp(26px, 6vw, 40px);
      letter-spacing: .02em; text-transform: lowercase; color: #fff; margin: 0 0 16px;
    }
    .def-pos {
      font-family: var(--body); font-style: italic; font-weight: 400;
      font-size: 15px; letter-spacing: 0; text-transform: none; color: var(--steel-400);
      margin-left: 10px; vertical-align: 3px;
    }
    .def-body { font-size: clamp(18px, 4.4vw, 24px); line-height: 1.5; max-width: 30ch; color: var(--steel-300); margin: 0; }
    .def-accent { color: #fff; font-weight: 500; }
    .def .def-body { max-width: 46ch; }

    /* ---------- prose ---------- */
    .prose p { max-width: 60ch; margin: 0 0 18px; color: var(--ink-soft); font-size: 17.5px; }
    .prose strong { color: var(--ink); font-weight: 600; }

    /* ---------- servicios / spec list ---------- */
    .specs {
      list-style: none; margin: 0; padding: 0;
      display: grid; grid-template-columns: 1fr; gap: 0;
    }
    .spec {
      display: flex; gap: 16px; align-items: baseline;
      padding: 17px 2px; border-top: 1px solid var(--line-d);
    }
    .spec:last-child { border-bottom: 1px solid var(--line-d); }
    .spec-mark {
      font-family: var(--display); font-weight: 700; font-size: 22px;
      color: var(--safety-2); line-height: 1; min-width: 20px;
    }
    .spec h3 {
      font-family: var(--display); font-weight: 700; font-size: 21px;
      letter-spacing: .02em; text-transform: uppercase; margin: 0 0 3px; color: var(--steel-200);
    }
    .spec p { margin: 0; color: var(--steel-400); font-size: 15.5px; }
    .card-note { margin: 30px 0 0; color: var(--steel-400); font-size: 15px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .chip-card {
      font-family: var(--display); font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
      font-size: 13px; color: var(--steel-200);
      border: 1px solid var(--steel-600); border-radius: 4px; padding: 6px 12px;
    }

    /* ---------- diferenciadores ---------- */
    .reasons { display: grid; grid-template-columns: 1fr; gap: 14px; }
    .reason {
      background: #fff; border: 1px solid var(--line-l); border-radius: 8px;
      padding: 22px 22px 20px; position: relative; overflow: hidden;
    }
    .reason::before {
      content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--safety);
    }
    .reason-idx {
      font-family: var(--display); font-weight: 700; font-size: 13px; text-transform: uppercase;
      color: var(--safety-deep); letter-spacing: .16em; display: block; margin-bottom: 8px;
    }
    .reason h3 {
      font-family: var(--display); font-weight: 700; font-size: 22px; text-transform: uppercase;
      letter-spacing: .02em; margin: 0 0 6px; color: var(--ink);
    }
    .reason p { margin: 0; color: var(--ink-soft); font-size: 15.5px; }
    .reason em { font-style: italic; color: var(--safety-deep); font-weight: 600; }

    /* ---------- prueba social ---------- */
    .score { display: flex; align-items: center; gap: 18px; margin: 0 0 34px; flex-wrap: wrap; }
    .score-big { display: flex; align-items: baseline; gap: 6px; }
    .score-num { font-family: var(--display); font-weight: 800; font-size: clamp(58px, 16vw, 92px); line-height: .85; color: #fff; }
    .score-of { font-family: var(--display); font-weight: 600; font-size: 26px; color: var(--steel-400); }
    .score-meta { display: flex; flex-direction: column; }
    .score-stars { color: var(--safety-2); letter-spacing: .24em; font-size: 20px; }
    .score-meta span:last-child { color: var(--steel-400); font-size: 15px; }

    .reviews { display: grid; grid-template-columns: 1fr; gap: 14px; margin: 0 0 30px; }
    .rev {
      margin: 0; background: var(--steel-900); border: 1px solid var(--line-d);
      border-radius: 8px; padding: 20px 22px 18px;
      border-top: 3px solid var(--safety);
    }
    .rev-stars { color: var(--safety-2); font-size: 15px; letter-spacing: .18em; margin: 0 0 10px; }
    .rev blockquote { margin: 0 0 14px; font-size: 16.5px; line-height: 1.5; color: var(--steel-200); }
    .rev figcaption { display: flex; flex-direction: column; gap: 2px; }
    .rev figcaption strong { font-family: var(--display); font-weight: 700; font-size: 17px; letter-spacing: .02em; color: #fff; }
    .rev figcaption span { font-size: 13px; color: var(--steel-400); }
    .center { text-align: center; }

    /* ---------- galería ---------- */
    .gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .g-item { margin: 0; position: relative; border-radius: 8px; overflow: hidden; border: 1px solid var(--line-d); }
    .g-item img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4 / 3; }
    .g-wide { grid-column: 1 / -1; }
    .g-wide img { aspect-ratio: 16 / 9; }
    .g-item figcaption {
      position: absolute; left: 0; right: 0; bottom: 0;
      font-family: var(--display); font-weight: 600; font-size: 13px; letter-spacing: .06em; text-transform: uppercase;
      color: #fff; padding: 20px 14px 10px;
      background: linear-gradient(180deg, transparent, rgba(0,0,0,.72));
    }

    /* ---------- ubicación ---------- */
    .locate { display: grid; grid-template-columns: 1fr; gap: 26px; }
    .addr { font-size: 18px; font-weight: 500; margin: 0 0 16px; color: var(--ink); }
    .hours-title {
      font-family: var(--display); font-weight: 700; font-size: 20px; text-transform: uppercase;
      letter-spacing: .04em; margin: 30px 0 8px; color: var(--ink);
    }
    .hours { width: 100%; max-width: 400px; border-collapse: collapse; font-size: 15.5px; }
    .hours th, .hours td { padding: 9px 4px; border-bottom: 1px solid var(--line-l); text-align: left; }
    .hours th { font-weight: 500; color: var(--ink); }
    .hours td { color: var(--ink-soft); text-align: right; font-variant-numeric: tabular-nums; }
    .hours td.closed { color: var(--safety-deep); font-weight: 600; }
    .hours tr.today th, .hours tr.today td { background: var(--ink); color: #fff; font-weight: 600; }
    .hours tr.today th::after {
      content: "hoy"; font-family: var(--display); font-weight: 700; font-size: 11px;
      letter-spacing: .1em; text-transform: uppercase; background: var(--safety); color: #fff;
      border-radius: 3px; padding: 1px 7px; margin-left: 10px; vertical-align: 1px;
    }
    .hours tr.today td.closed { color: #fff; }
    .map iframe {
      width: 100%; height: 300px; border: 0; border-radius: 8px; display: block;
      border: 1px solid var(--line-l);
    }

    /* ---------- CTA final ---------- */
    .closer { background: var(--safety); color: #fff; text-align: center; padding: 74px 0 66px; }
    .closer-in { position: relative; z-index: 1; }
    .closer-title {
      font-family: var(--display); font-weight: 800; font-size: clamp(32px, 8.2vw, 58px);
      line-height: .96; text-transform: uppercase; margin: 8px 0 12px; color: #fff;
    }
    .closer-sub { margin: 0 auto 26px; max-width: 44ch; color: rgba(255,255,255,.94); font-size: 17px; }

    /* ---------- footer ---------- */
    .foot { padding: 46px 0 100px; text-align: center; background: var(--graphite); border-top: 1px solid var(--line-d); }
    .foot-name { font-family: var(--display); font-weight: 800; font-size: 30px; text-transform: uppercase; letter-spacing: .03em; color: var(--steel-200); margin: 0 0 8px; }
    .foot-name span { color: var(--safety-2); }
    .foot-line { margin: 4px 0; color: var(--steel-400); font-size: 14.5px; }
    .foot-line a { color: var(--steel-200); text-decoration: none; border-bottom: 1px solid var(--safety); }
    .foot-line a:hover { color: var(--safety-2); }
    .foot-mini { margin: 14px 0 0; color: var(--steel-600); font-size: 12.5px; letter-spacing: .02em; }

    /* ---------- reveal (mejora progresiva) ---------- */
    html.js .reveal { opacity: 0; transform: translateY(16px); transition: opacity .6s ease, transform .6s ease; }
    html.js .reveal.in { opacity: 1; transform: none; }

    @media (prefers-reduced-motion: reduce) {
      .g-needle { animation: none; transform: rotate(82.8deg); }
      .g-value { animation: none; stroke-dashoffset: 4; }
    }

    /* ============================ DESKTOP ============================ */
    @media (min-width: 760px) {
      .section { padding: 104px 0; }
      .hero { justify-content: center; }
      .hero-grid { grid-template-columns: 1.25fr 0.85fr; gap: 48px; align-items: center; }
      .instrument { justify-self: end; width: 360px; }
      .specs { grid-template-columns: 1fr 1fr; column-gap: 46px; }
      .spec:nth-child(2) { border-top: 1px solid var(--line-d); }
      .reasons { grid-template-columns: repeat(2, 1fr); gap: 16px; }
      .reviews { grid-template-columns: repeat(2, 1fr); align-items: start; }
      .gallery { grid-template-columns: repeat(4, 1fr); grid-auto-rows: 200px; }
      .g-item img { aspect-ratio: auto; height: 100%; }
      .g-wide { grid-column: span 2; grid-row: span 2; }
      .locate { grid-template-columns: 0.9fr 1.1fr; align-items: start; }
      .map iframe { height: 100%; min-height: 380px; }
      .def-body { font-size: 26px; }
    }
    @media (min-width: 1000px) {
      .reasons { grid-template-columns: repeat(4, 1fr); }
      .reviews { grid-template-columns: repeat(4, 1fr); }
    }
  </style>

  <script is:inline>
    (function () {
      var d = document;
      d.documentElement.classList.add('js');

      // Resaltar el día de hoy
      var hoy = new Date().getDay();
      var fila = d.querySelector('.hours tr[data-dia="' + hoy + '"]');
      if (fila) fila.classList.add('today');

      // Scroll-reveal
      var els = d.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach(function (el) { io.observe(el); });
      } else {
        els.forEach(function (el) { el.classList.add('in'); });
      }
    })();
  </script>
</BaseLayout>
